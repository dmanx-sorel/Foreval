  object EF: TEdit
    Left = 9
    Height = 21
    Top = 400
    Width = 1160
    TabOrder = 0
    Text = ' (sin(x/cos(x/y))^3-cos(x*sin(x/y))^3)*(cos(x/cos(x/y))^3-sin(x*sin(x/y))^3)*exp(x/exp(x/z1))*polynom(ad,x/z1)/(sh(x/z1)+ch(x/exp(x/z1)+th(x/exp(x/z1))))*((sin(a/b)^2+cos(b/a)^2)^(x/y))/((sin(ai/bi)-cos(bi/ai))^(x/z1))+log(sin(ai),x)*log(z1,cos(bi))'
  end
