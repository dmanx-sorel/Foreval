  object MT1: TMemo
    Left = 845
    Height = 249
    Top = 120
    Width = 321
    Lines.Strings = (
      'On default:'
      '                    variables: '
      ' x, y, t, s, r, p, q, u, v   -  real extended;'
      ' z1, z2, z3, z4, z5         -  complex extended;'
      ' n, k, j, m, l                   -   integer;'
      ''
      '                    parameters:'
      ' a, b, c, d, e      - real;'
      ' ai, bi, ci, di, ei - complex;'
      ''
      '                          arrays:'
      ' ad                                   - double    (Length=3)'
      ' vd, vd1, vd2, vd3, xvd - double     (Length=100)'
      ' ve, ve1, ve2, ve3, xve - extended (Length=100)'
      ' vi,   vi1,  vi2,  vi3,   xvi  - integer    (Length=100)'
      ''
      'PS'
      'Added external functions: see text '
      'TestForevalG9.pas'
      ' ''Float Var Type'' mode applies only for'
      ' (x,y,t)&(z1,z2,z3) variables.'
