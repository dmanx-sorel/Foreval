procedure TForevalH.SubstParamCXPS(PS: PString;  var CX: TComplex; var SB: Integer);
label endp,endpp;
var
BDelBr: Boolean;
C,Cr1,Cr2,Ci1,Ci2,Re,Im: TFloat;
N,i,NPos: Cardinal;
NCop,Li,T1,T2,nz,ni,TV,Neg,NCop1,NCop2: Integer;
S1,S2,Sc,Si,St: String;                              //SB=C_None{no},C_Real(real),C_Image(image),C_Complex(complex)
begin
if F_SyntaxErrorCode <> 0 then goto endpp;

Neg:=1;
(*
//for speed up parse {.375B}
SaveSW;  {TryStrToFloat damage SW}
if TryStrToFloat(PS^,Re,G_FMT) then
begin
 SB:=C_Real;
 CX.re:=Re;
 CX.im:=0;
 goto endp;
end;
 *)

//FindExternalBracket(S,S);

//BDelBr:=DeleteExternalBracketPS(PS); {.316}
BDelBr:=DeleteExternalBracketNegPS(PS,Neg); {.317}

C:=0; SB:=C_None; CX.re:=0; CX.im:=0; nz:=1;
Cr1:=0; Cr2:=0; Ci1:=0; Ci2:=0;
//SubstParam(S, C, SB);
SubstParamPS(PS,Re,Im, TV);

if TV = T_Real then
begin
  CX.re:=Re;
  SB:=C_Real;
  goto endp;
end
else
if TV = T_Complex then
begin
  CX.re:=Re;
  CX.im:=Im;
  SB:=C_Complex;
  goto endp;
end;

if F_SubstNumCX = False then
begin
 SB:=C_None;
 goto endp;
end;



St:=PS^;
if (St = S_IM_UNIT) and (F_RecoverImUnit = False) then
begin
   CX.im:=1;
   SB:=C_Image;
   F_ComplexNumber:=True;  {.347}
   goto endp;
end;



C:=0; SB:=C_None;
//FindMainOperationP(PS,NCop,NPos);
FindMainOperationPS(PS,NCop,NPos,NCop1,NCop2); {.315}

{$IFDEF NEWPARSE}
{.383}
 if (NCOP = COP_NEG) and (NCop1 = COP_NEG) and  (NCop2 = _NOT_FOUND)  then NCOP:=_NOT_FOUND; // -2; -a; -i
{$ENDIF}


if NCop = _NOT_FOUND then        //3i,-3i
begin
 Li:=Length(S_IM_UNIT);
 Sc:=Copy(PS^,1,Length(PS^)-Li);
 Si:=Copy(PS^,Length(PS^)-Li+1,Li);


 if (Si = S_IM_UNIT) and (F_RecoverImUnit = False) then
 begin
   if Sc = '-' then Sc:='-1';    //-i
   //FindExternalBracket(Sc,Sc);
   DeleteExternalBracketPS(@Sc); {.219}
   //SubstParam(Sc, C, SB);
   SubstParamPS(@Sc, Re,Im, TV);
   //if SB = C_Real then
   if TV = T_Real then
   begin
     CX.im:=Re;
     SB:=C_Image;
     F_ComplexNumber:=True;   {.347}
   end;
 end;

 goto endp;
end;

//-2-(-8)
//ai+i    5i+1
if  (NCop = COP_ADD) or (NCop = COP_SUB) then      {+,-}
begin
 if NCop = COP_SUB then nz:=-1;

 S1:=Copy(PS^,1,NPos-1);
 S2:=Copy(PS^,NPos+1,Length(PS^)-NPos+1);

 Li:=Length(S_IM_UNIT);
 Sc:=Copy(S1,1,Length(S1)-Li);
 Si:=Copy(S1,Length(S1)-Li+1,Li);
 T1:=0;

 if (Si = S_IM_UNIT) and (F_RecoverImUnit = False) then             //i-7i,  i+i, -i-i, -i-(i)
 begin
   //FindExternalBracket(Sc,Sc);
   DeleteExternalBracketPS(@Sc); {.219}
   if Sc = '-' then Sc:='-1';    //-i
   if Sc = '' then Sc:='1';
   //SubstParam(Sc, C, SB);
   //SubstParamPS(@Sc, Re, Im, TV);
   SubstNumPS(@Sc, Re, Im, TV); {.330} // ai+i, ai+1 del ERROR in param end on i  //учитывать только числа при i !!! . не параметры
   //if SB = C_Real then
   if TV = T_Real then
   begin
     Ci1:=Re;
     T1:=_IM;
     SB:=C_Real;
     F_ComplexNumber:=True; {.347}
   end;
 end
 else
 begin
   //FindExternalBracket(S1,S1);
   DeleteExternalBracketPS(@S1); {.219}
   //SubstParam(S1, C, SB);
   //if SB = C_Real then
   SubstParamPS(@S1, Re, Im, TV);
   if TV = T_Real then
   begin
     Cr1:=Re;
     T1:=_RE;
     SB:=C_Real;
   end;
 end;

 if T1 = 0 then begin SB:=C_None; goto endp; end;


 //i+ai     1+5i
 Li:=Length(S_IM_UNIT);
 Sc:=Copy(S2,1,Length(S2)-Li);
 Si:=Copy(S2,Length(S2)-Li+1,Li);
 T2:=0;

 if (Si = S_IM_UNIT) and (F_RecoverImUnit = False) then
 begin
   //FindExternalBracket(Sc,Sc);
   DeleteExternalBracketPS(@Sc); {.219}
   if Sc = '-' then Sc:='-1';    //-i
   if Sc = '' then Sc:='1';
   //SubstParam(Sc, C, SB);
   //if SB = C_Real then
   //SubstParamPS(@Sc, Re, Im, TV);
   SubstNumPS(@Sc, Re, Im, TV); {.330} // i+ai, 1+ai del ERROR in param end on i    //учитывать только числа при i !!! . не параметры
   if TV = T_Real then
   begin
     Ci2:=Re;
     T2:=_IM;
     SB:=C_Real;
     F_ComplexNumber:=True; {.347}
   end;
 end
 else
 begin
   //FindExternalBracket(S2,S2);
   DeleteExternalBracketPS(@S2); {.219}
   //SubstParam(S2, C, SB);
   //if SB = C_Real then
   SubstParamPS(@S2, Re, Im, TV);
   if TV = T_Real then
   begin
     Cr2:=Re;
     T2:=_RE;
     SB:=C_Real;
   end;
 end;

 if T2 = 0 then begin SB:=C_None; goto endp; end;

 if (T1 = _RE) and (T2 = _RE) then
 begin
  CX.re:=Cr1+nz*Cr2; SB:=C_Real;
 end
 else
  if (T1 = _IM) and (T2 = _IM) then
 begin
  CX.im:=Ci1+nz*Ci2; SB:=C_Image;
 end
 else
 if (T1 = _RE) and (T2 = _IM) then
 begin
  CX.re:=Cr1; CX.im:=nz*Ci2; SB:=C_Complex;
 end
 else
 if (T1 = _IM) and (T2 = _RE) then
 begin
  CX.re:=nz*Cr2; CX.im:=Ci1; SB:=C_Complex;
 end;

end;




endp:

//restore PS^ :

//if BDelBr = True then PS^:='('+PS^+')';  {.316}

{.317}

CX.re:=Neg*CX.re;
CX.im:=Neg*CX.im;

if BDelBr = True then
begin
 if Neg = 1 then PS^:='('+PS^+')' else if Neg = -1  then    PS^:='(-('+PS^+'))';    //.317
end;

  endpp:
end;



