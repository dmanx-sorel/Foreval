procedure TForevalH.GetReplaceData({NF,NS,}NodeF,NodeS: PNode; VType: integer; var RangW,RangR,NMem,MShft: Integer);
var
 NFuncNF,NFuncNS,NFF,NFS: Cardinal;
begin
{
NFuncNF:=Interp[NF].NFunc;
NFuncNS:=Interp[NS].NFunc;
NFF:=Interp[NF].NF;
NFS:=Interp[NS].NF;
 }
NFuncNF:=NodeF^.NFunc;
NFuncNS:=NodeS^.NFunc;
NFF:=NodeF^.NF;
NFS:=NodeS^.NF;

RangW:=rf_NO_REPLACE;
RangR:=rf_NO_REPLACE;
MShft:=0;
NMem:=0;

if (NodeF^.NFunc <= High(TableRF)) and (NodeS^.NFunc <= High(TableRF))  then   //только для внутренних функций (full+composite)
begin



  if VType = T_Real then
  begin
     RangW:=TableRF[NFuncNF,NFuncNS].WRF_R;
     RangR:=TableRF[NFuncNF,NFuncNS].RRF_R;
     MShft:=TableRF[NFuncNF,NFuncNS].SHFT_R;
     NMem:=TableRF[NFuncNF,NFuncNS].NMEM_R;
  end
  else
  if VType = T_Complex then
  begin
     RangW:=TableRF[NFuncNF,NFuncNS].WRF_Z;
     RangR:=TableRF[NFuncNF,NFuncNS].RRF_Z;
     MShft:=TableRF[NFuncNF,NFuncNS].SHFT_Z;
     NMem:=TableRF[NFuncNF,NFuncNS].NMEM_Z;

     //исключение, т.к. комплексная ф-ия cossin замещает действительные cos, sin (несоответствие VType ф-ий)
    (* if (NFuncNF = CM_SINCOS) and ((NFuncNS = CM_COS) or (NFuncNS = CM_SIN)) then    {.331}
     begin
        RangW:=rf_FULL_REPLACE;
        RangR:=rf_FULL_REPLACE;
        if NFuncNS = CM_COS then
        begin
          NMem:=TableRF[CM_SINCOS,CM_COS].NMEM_R;
          MShft:=TableRF[CM_SINCOS,CM_COS].SHFT_R;
        end
        else
         if NFuncNS = CM_SIN then
        begin
          NMem:=TableRF[CM_SINCOS,CM_SIN].NMEM_R;
          MShft:=TableRF[CM_SINCOS,CM_SIN].SHFT_R;
        end;
     end;
     *)


  end;

end
else
if  ((NodeF^.NFunc = NodeS^.NFunc) and (NodeF^.NF = NodeS^.NF))  then      //только полное замещение для добавляемых функций
 begin

  if VType = T_Real then
  begin
     RangW:=rf_FULL_REPLACE;
     RangR:=rf_FULL_REPLACE;
     MShft:=0;
     NMem:=1;
  end
  else
  if VType = T_Complex then
  begin
     RangW:=rf_FULL_REPLACE;
     RangR:=rf_FULL_REPLACE;
     MShft:=0;
     NMem:=2;
  end;
end;

end;






