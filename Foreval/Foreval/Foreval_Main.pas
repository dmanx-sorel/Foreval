i: integer;                                 //MType =  _Double, _Extended, _Integer, _Pointer, _Single
Name1: String;
begin


if CheckName(Name) = false then
 begin
     F_SyntaxErrorCode:=E_WRONG_NAME;
     F_SyntaxErrorString:=Name;
     //IntException;
     goto endp;
  end;

//if F_LeadToLowerCase = True then Name:=LowerCase(Name); {.221}

 for i := 0 to Length(Alg.Obj) - 1 do
   begin
     Name1:=Alg.Obj[i].Name;

     //перезаписать новую с таким же именем на место предыдущей
     if (Name1  = Name) {and (Alg.Obj[i].TypeF = IdType) and (Alg.Obj[i].MType = MType)} then
     begin
       Alg.Obj[i].Addr:=AddrRE;
       Alg.Obj[i].AddrIM:=AddrIM;
