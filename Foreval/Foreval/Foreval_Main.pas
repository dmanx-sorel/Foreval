              EOFN:=True;
              SetLength(LV1,0);
              goto endp;
            end
            else
            if (BZ2 = True) and (LV[0].Expression <> S_IM_UNIT)  then
            begin
              ND1.FD:=0;
              ND1.COP:=_LDSC;
              ND1.NFunc:=0;
              EOFN:=True;
              SetLength(LV1,0);
              goto endp;
            end;

          end;
