   //только для функций:                                                                       {.357}
   if (NFunc2 = CM_DIV) or (NFunc2 = CM_MUL) or (NFunc2 = CM_SUB) or (NFunc2 = CM_ADD) or (NFunc2 = CM_NEG)  then goto 2;

