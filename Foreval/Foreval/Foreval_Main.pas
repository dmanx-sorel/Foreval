        end};


       if BEF = False then ExtFunc:=True;

       //if NArg = 0 then EOFN:=True;



 end
 else  //nf=-1
 //поиск элементов векторов: AI = (1)Vec[IntConst],(2)Vec[IntVar],(3)Vec[IntForm], (0)Vec[Trunc(Expr)]
 begin
  array_:

  FindFuncBrPS(PS,'[',']',Sv,Sa,FH1);
  if FH1 = True then FindVarPS(@Sv,ni) else ni:=-1; {.333}

