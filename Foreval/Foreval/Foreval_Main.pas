function TForevalH.GetLineStackAdr(NodeM: PNode; NArg: Cardinal{NM,NArg: Cardinal}): TAddress;
var
i,NL,N,NF,TV,TM,CallT, NArgF, S, SzArg: Integer;
SAdr: TAddress;
begin
             //"упаковка" в стека в 16-ти байтные ячейки (вместо 32 (TComplexE=ext,ext))

    {N:=Interp[NM].NFunc;
    NF:=Interp[NM].NF;
    NL:=Interp[NM].NL;
    S:=Interp[NM].S;
    }
    S:=NodeM^.S;
    NL:=NodeM^.NL;
    N:=NodeM^.NFunc;
    NF:=NodeM^.NF;

    NArgF:=Alg.ExFunc[N].Func[NF].NArg;

    SzArg:=0;

    //{$OverFlowChecks Off}
    //{$RangeChecks Off}

    //SzArg - размерность предыдущих аргументов
    for I := 0 to NArg - 2 do
      begin
        TV:=Alg.ExFunc[N].Func[NF].TV[i];
        if (TV = T_Real) or (TV = T_Array) then SzArg:=SzArg+16 else
        if (TV = T_Complex) then SzArg:=SzArg+32;
      end;
    //{$OverFlowChecks On}
    //{$RangeChecks On}

    SAdr:=GetStackAdr(S,_RE)+SzArg;    //GetStackAdr(S,_RE) - адрес первой ячейки функции

    GetLineStackAdr:=SAdr;
end;



procedure TForevalH.SaveArgMemAdr(Node: PNode{i: Cardinal});
var
S,N,NM,CallT,NF,dt,sh,Adr,tf,NL: Cardinal;
SAdr: TAddress;
begin                         //NM - номер функции
   {S:=Interp[I].S;            //NL - порядковый номер аргумента в функции
   NM:=Interp[I].NM;
   NL:=Interp[I].NL;
   N:=Interp[NM].NFunc;
   NF:=Interp[NM].NF;
   }
   S:=Node^.S;
   NL:=Node^.NL;
   N:=Node^.Pr^.NFunc;
   NF:=Node^.Pr^.NF;
   dt:=0;

   SAdr:=GetLineStackAdr({NM}Node^.Pr,NL);    //получить адрес сохранения для текущего аргумента(NL)

     case Node^.ExtArg of
      D_Real:         dt:=_Double;
      D_Complex:      dt:=_Double;
      E_Real:         dt:=_Extended;
      E_Complex:      dt:=_Extended;
      S_Real:         dt:=_Single;
      S_Complex:      dt:=_Single;
      D_Array_Real:   dt:=_Pointer;
      E_Array_Real:   dt:=_Pointer;
      I_Array_Real:   dt:=_Pointer;
      S_Array_Real:   dt:=_Pointer;
      I_Real:         dt:=_Integer;
      I_Pointer:      dt:=_Pointer;
     end;

     if (Node^.TypeF = T_Real) and (Node^.COP = _LDINTFORM) then {.309}  //EAX -> MEM
     begin
      MOVREGM(R_EAX,SAdr);
     end
     else    //IntArray[indx]: EAX -> MEM
     if (Node^.TypeF = T_Real) and (Node^.ExtArg =  I_Real) and (Node^.NFunc = CM_LDSVX) and  (Node^.ExtArgPlace =  R_EAX) then {.369}
     begin
       MOVREGM(R_EAX,SAdr);
     end
     else
     if Node^.TypeF = T_Real then
     begin
      FSTPM(SAdr,dt);
     end
     else
     if (Node^.TypeF = T_Complex)  then
     begin
      FSTPM(SAdr,dt);
      FSTPM(SAdr+sh_E,dt);
     end
     else
     if Node^.TypeF = T_Array then
     begin  {arraycpu}
      //FSTPM(SAdr,_Pointer);    {.197}

      //POPF(SAdr);      {.223}

      //PUSHF(GetStackAdr(S,_RE)) ;
      //POPF(SAdr);
        {
        PUSHF(Alg.Obj[GNode^.NObj].Addr);
        POPF(SAdr);
        }

        (*
        MOVMREG(R_EAX,Alg.Obj[GNode^.NObj].Addr);             {.309}
        MOVREGM(R_EAX,SAdr);
        *)
        {.353}   //выгрузка адреса массива из EAX в адрес аргумента ф-ии:
        MOVREGM(R_EAX,SAdr);
     end
     else
     if Node^.TypeF = T_Pointer then
     begin  {arraycpu}
        {.353}   //выгрузка указателя из EAX в адрес аргумента ф-ии:
        MOVREGM(R_EAX,SAdr);
     end;
end;




