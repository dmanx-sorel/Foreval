procedure TForevalH.DeleteFunc(idn,idf: integer);
var
arg: integer;
begin
if idf = _ANY then
begin
  SetLength(Alg.ExFunc[idn].Func,0);
  Alg.ExFunc[idn].Enable:=_NO;
  Alg.ExFunc[idn].Name:=SDeletedFuncName;
end
else
begin
  arg:=Alg.ExFunc[idn].Func[idf].NArg;
  Alg.ExFunc[idn].Func[idf].TV:=nil;
  Alg.ExFunc[idn].Func[idf].TM:=nil;
  Alg.ExFunc[idn].Func[idf].addr:=0;
  Alg.ExFunc[idn].Func[idf].NArg:=0;  {.365}
  Alg.ExFunc[idn].Func[idf].CallT:=0;
  Alg.ExFunc[idn].Func[idf].TypeF:=0;
  Alg.ExFunc[idn].Func[idf].IntF:=0;
  Alg.ExFunc[idn].Func[idf].Enable:=_DELETED;   {.365}

  if arg = 0 then  SetLength(Alg.ExFunc[idn].Func,0); {.207}  //void()=x

end;
end;



procedure TForevalH.SetF(code: Integer; idName,idArg: Integer);
var
i: integer;
begin
if (idName >= 0) and (idName <=  Length(Alg.ExFunc) - 1) then
begin
  if code = 1 then  Alg.ExFunc[idName].Enable:=_YES else
  if code = 2 then  Alg.ExFunc[idName].Enable:=_NO  else
  if code = 3 then
  begin
     if idName = CM_DIV then     Alg.ExFunc[CM_DIV].ReplFunc:=_Yes    else
     if idName = CM_MUL then     Alg.ExFunc[CM_MUL].ReplFunc:=_Yes    else
     if idName = CM_ADD then     Alg.ExFunc[CM_ADD].ReplFunc:=_Yes    else
     if idName = CM_SUB then     Alg.ExFunc[CM_SUB].ReplFunc:=_Yes    else
     if idName = CM_NEG then     Alg.ExFunc[CM_NEG].ReplFunc:=_Yes    else
     if idName = CM_LDSVX then   Alg.ExFunc[CM_LDSVX].ReplFunc:=_Yes    ;
  end
  else
  if code = 4 then
  begin
     if idName = CM_DIV then     Alg.ExFunc[CM_DIV].ReplFunc:=_No    else
     if idName = CM_MUL then     Alg.ExFunc[CM_MUL].ReplFunc:=_No    else
     if idName = CM_ADD then     Alg.ExFunc[CM_ADD].ReplFunc:=_No    else
     if idName = CM_SUB then     Alg.ExFunc[CM_SUB].ReplFunc:=_No    else
     if idName = CM_NEG then     Alg.ExFunc[CM_NEG].ReplFunc:=_No    else
     if idName = CM_LDSVX then   Alg.ExFunc[CM_LDSVX].ReplFunc:=_No    ;
  end
  else
  if code = 5 then   SetNewFuncToOperation('^',idName)   {.195}
  else
  if code = 6 then
  begin                  {.215}
   Alg.ExFunc[idName].ReplFunc:=_YES;
   for i := 0 to Length(Alg.ExFunc[idName].Func) - 1 do   Alg.ExFunc[idName].Func[i].ReplFunc:=_YES;
  end
  else
  if code = 7 then
  begin                  {.215}
   Alg.ExFunc[idName].ReplFunc:=_NO;
   for i := 0 to Length(Alg.ExFunc[idName].Func) - 1 do   Alg.ExFunc[idName].Func[i].ReplFunc:=_NO;
  end
  else
  if code = 8 then      {.215}
  begin
   for i := 0 to Length(Alg.ExFunc[idName].Func) - 1 do   Alg.ExFunc[idName].Func[i].CalcConst:=_YES;
  end
  else
  if code = 9 then      {.215}
  begin
   for i := 0 to Length(Alg.ExFunc[idName].Func) - 1 do   Alg.ExFunc[idName].Func[i].CalcConst:=_NO;
  end
  else
  if code = 10 then      {.217}
  begin
    Alg.ExFunc[idName].ReplFuncCFR:=_NO;
  end
  else
  if code = 11 then      {.217}
  begin
    Alg.ExFunc[idName].ReplFuncCFZ:=_NO;
  end
  else
  if code = 12 then      {.217}
  begin
    Alg.ExFunc[idName].ReplFuncCFR:=_YES;
  end
  else
  if code = 13 then      {.217}
  begin
    Alg.ExFunc[idName].ReplFuncCFZ:=_YES;
  end
  else
  if code = 14 then
  begin
     for i := 0 to Length(Alg.ExFunc)  - 1 do
       begin
          Alg.ExFunc[i].ReplFuncCFR:=_NO;
       end;
  end
  else
  if code = 15 then
  begin
     for i := 0 to Length(Alg.ExFunc)  - 1 do
       begin
          Alg.ExFunc[i].ReplFuncCFZ:=_NO;
       end;
  end
   else
  if code = 16 then
  begin
     for i := 0 to Length(Alg.ExFunc)  - 1 do
       begin
          Alg.ExFunc[i].ReplFuncCFR:=_YES;
       end;
  end
  else
  if code = 17 then
  begin
     for i := 0 to Length(Alg.ExFunc)  - 1 do
       begin
          Alg.ExFunc[i].ReplFuncCFZ:=_YES;
       end;
  end
  else
  if code = 18 then             {.377C}
  begin
       SetLength(Alg.ExFunc[idName].NameEx,1);
  end;


end;
//ForevalZ_Command.F_FastSpec:=True;
end;




