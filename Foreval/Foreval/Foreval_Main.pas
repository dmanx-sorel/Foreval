//следующий исполняемый узел
function TForevalH.GetNextNode(PrntNode: PNode):  PNode;
label endp;
{var
 PrntNode: PNode;
 S: String;  }
begin

 //PrntNode:=PrntNodeIn;

 while PrntNode^.Pr <> nil do
 begin

   while PrntNode^.Nb <> nil  do
   begin
     PrntNode:=PrntNode^.Nb;

     PrntNode:=GetLowLeftNode(PrntNode);
     {while PrntNode^.Ch <> nil do
     begin
       PrntNode:=PrntNode^.Ch;
     end;}

    //COP=NOP:
    //WriteCode;     //нижний левый
     F_TypeOfNode:=N_End;
     goto endp;
   end;
  //COP<>NOP:
   PrntNode:=PrntNode^.Pr;    // родительский от крайнего правого  на уровне
   F_TypeOfNode:=N_Parent;
   goto endp;
   //WriteCode;
 end;

 endp:
  GetNextNode:=PrntNode;
end;






procedure TForevalH.LinkTreeData_Tree;
label endp;
begin
if F_SyntaxErrorCode <> 0 then goto endp;

Tree:=BeginTree; //не обязательно, т.к. чтение дерева - циклически

while Tree^.Ch <> nil do
begin
Tree:=Tree^.Ch;
end;
//COP=NOP:
LinkDataNode(Tree);      //нижний левый

while Tree^.Pr <> nil do
begin

   while Tree^.Nb <> nil  do
   begin
    Tree:=Tree^.Nb;
    while Tree^.Ch <> nil do
    begin
     Tree:=Tree^.Ch;
    end;
    //COP=NOP:
    LinkDataNode(Tree);     //нижний левый
   end;

 //COP<>NOP:
 Tree:=Tree^.Pr;          // родительский от крайнего правого  на уровне
 LinkDataNode(Tree);

end;
//1-ый элемент в WriteCode выпадает


endp:


end;





procedure TForevalH.LinkTreeData_SeqList;
var
Node: PNode;
begin

Node:=FirstNode;

while Node <> nil do
begin
  LinkDataNode(Node);
  Node:=Node^.Next;
end;

{
LFunc:=1;
SetLength(Interp,LInterp);

   Tree:=BeginTree; //не обязательно, т.к. чтение дерева - циклически
   Tree:=GetLowLeftNode(Tree);
   WriteCode;

   while Tree^.Pr <> nil do
   begin
      Tree:=GetNextNode(Tree);
      WriteCode;
      //if F_TypeOfNode = N_Parent then FreeChld(Tree);
   end;

}

end;




procedure TForevalH.LinkTreeData;
begin

if F_SequentList = True then
   LinkTreeData_SeqList
else
   LinkTreeData_Tree;

end;




