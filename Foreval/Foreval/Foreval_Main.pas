begin
//if F_SyntaxErrorCode <> 0 then goto endp;

bFZ:=False;
//if Tree = nil  then goto endp;

repeat
   H:=Tree;
   S:=H^.SDiff;
   FindExternalBracketNegPS(@S);
   if S <> '0' then goto endp;
   Tree:=Tree^.Nb;
until Tree = nil ;
