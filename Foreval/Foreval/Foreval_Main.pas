procedure TForevalH.Compile;
label recompile,2,endp, outc;
var
i,j,N,alg,db,db1: Integer;
AH,AB: TArray4;
R: TFloat;
P: Pointer;
X: TFloat;
CS,LCode: Cardinal;
ANL: TArrayC;
S,S1: String;
AdrCmpl,AdrD,AdrS: Pointer;
AdrTst: TAddress;
Node: PNode;
begin
if F_SyntaxErrorCode <> 0 then goto endp;
if F_InternalError <> 0 then goto endp; {.322}

//каждый раз инициализация т.к. предыдущее выражение может сбросить F_SaveInFPU:
N_Stack:=0;
_MaxStack:=0;
//F_Opt:=False;
F_ExtFunc:=False;
ES_OverFlow:=False;
F_EnableCheckStack:=True;
F_Mode:=M_Compile;   {.197}
F_IntermediateLastNode:=False; {.310}

    {$IFDEF DEBUGS}
       dbMaxLoadCom:=0;
       TestZ.Form1.MT.Lines.Add('***********************************************************');
    {$ENDIF}

recompile:
new(FuncData); FuncData^.Next:=nil; BFuncData:=FuncData;
//LFunc:=Length(Interp);    {.233}
SetLength(ICOMP,0);
N_CurrentDataCell:=0;

for I := 1 to 8 do
begin
 REG[i]:=0;
 REGF[i]:=0;
end;


SetLength(GotoLab,0);

CS:=0;
F_JMP:=1;
TE_ADDR:=0;   TE_ADDR1:=0;
//F_SaveInFPU:=False;
//PUSHAD;
Node:=FirstNode;
//while Node <> BeginTree do
while Node <> nil do //for i:=1 to LFunc-1 do               //(sin(z1/z2)+cos(x)^(z1/z2))
begin
   Node^.CS:=0;

   if Node^.COP <> _NOP then  //COP=_NOP: только для аргументов замещаемой комманды //for(j,0,1,t=(x^2+x)*(x^2+x) ); t
   begin
      {$IFDEF DEBUGS}
         S:=Node^.Expression;
         db1:=Node^.SData1;
         if db1 = _MEM then S1:='SaveRes:MEM'  else if db1 = _FPU then S1:='SaveRes:FPU';
         dbFPUBefore:=N_Stack; dbFPULoad:=0;
      {$ENDIF}

      //S:=Node^.Expression;
      //for(j,0,1,t=(x^2+x)*(x^2+x) ); t

      GNode:=Node;//NFunc:=i;
      Node^.NC:=Length(ICOMP);

      AddCommand(Node{i});
      Node^.NCP:=Length(ICOMP);
      CS:=Length(ICOMP)-CS;
      Node^.CS:=CS+GetLevelsCS(Node{i});
      CS:=Length(ICOMP);

      {$IFDEF DEBUGS}
        dbMaxLoadCom:=dbFPUBefore+dbFPULoad;
        TestZ.Form1.MT.Lines.Add('"'+S+'"   '+S1+'    loadFPUafter:'+IntToStr(N_Stack)+ '    MaxLoadFPU:'+IntToStr(_MaxStack{dbMaxLoadCom}));
      {$ENDIF}

      //if F_SyntaxErrorCode  <> 0 then goto outc;     {.387}
  end;

  Node:=Node^.Next;
end;


//расстановка адресов переходов jmp adr
F_JMP:=2;
Node:=FirstNode;
//for i:=1 to LFunc-1 do
while Node <> nil do
begin
  GNode:=Node; //NFunc:=i;
  if Node^.NFunc = CM_JMP then   JMP_C;
  if Node^.NFunc = CM_GOSUB then GoSub_SetAddr;
  Node:=Node^.Next;
end;

SaveMainRes; {.324}
SaveReg;
RET;
//POPAD;


//if  (F_SaveInFPU = True) and (_MaxStack > 8) and ({F_Opt = False}F_Mode=M_Compile) then
if  (F_SaveInFPU = True) and (ES_OverFlow = True) and (F_Mode = M_Compile) then    {.300}
begin
//может быть только в случае внутренней ошибки в DinamicLoadOptimizator: неверный расчет Load FPU => защита)
  N_Stack:=0;
  _MaxStack:=0;
  ES_OverFlow:=False;
  FreeData;
  //Db_OverFlow:=True;
  F_SaveInFPU:=False;
  Db_DinLoadOverFlow:=True;
  //S:=CurrentExpression;
  goto recompile;
end;

 //outc:
if F_UseVirtAlloc = False then    {.193}
begin
  //выравнивание кода на alg:
  alg:=16;
  SetLength(Func.Code,Length(ICOMP)+alg+1);
  for i:=0 to alg+1  do
  begin
   if Cardinal(@Func.Code[i]) mod alg = 0 then
   begin
    NAdr:=i;
    goto 2;
   end;
  end;
  2:
  for i:=0 to High(ICOMP) do begin
   Func.Code[i+NAdr]:=ICOMP[i];
  end;

  Func.Addr:=TAddress(@Func.Code[NAdr]);     {.193}
  Func.PAddr:=@Func.Code[NAdr];
  Func.CodeSize:=Length(ICOMP);
  Func.AllocMem:=1;
end
else
{
  fzSet(fz_ENABLE, fz_USE_VIRTUAL_ALLOC); 
  allows memory for the  code  is allocated  out  by  the system command  instead: command 'SetLength' in a dynamic array.
{
//F_VirtAlloc = True   {.193}
begin     //only for WinXP SP2+;  memory alloc. only for exe code. Use, only if is any errors with standard memory allocating   (SetLength)
  LCode:=Length(ICOMP);
  AdrD:=VirtualAlloc(Nil, LCode, MEM_COMMIT or MEM_RESERVE, PAGE_EXECUTE_READWRITE);
  AdrS:=@ICOMP[0];
  CopyMemory(AdrD,AdrS,LCode);
  Func.Addr:=TAddress(AdrD);
  Func.PAddr:=AdrD;
  Func.CodeSize:=LCode;
  Func.AllocMem:=2;
end;

CodeSizeComplExpr:= Func.CodeSize; {.365}

outc:
ICOMP:=nil;
Func.Data:=BFuncData;

//PInteger(AdrCmpl)^:=Func.Addr;
{AdrTst:=Func.Addr;
asm
  push eax
  mov eax, AdrTst
  call eax

  pop  eax

end;  }

endp:
end;


