procedure TForevalH.TranslErrMsg({SubExpr: String}Node: PNode);
var
SA,SF,St,SubExpr,St1: String;
PF: Cardinal;
NCHLD: TArrayPN ;
j: Integer;
SN: TArrayS;
begin
 //if F_SyntaxErrorCode = E_NOT_DEFINED_OPERATION_FOR_TYPE  then F_SyntaxErrorString:=F_SyntaxErrorStringA+'('+F_SyntaxErrorString+')';
 //if F_SyntaxErrorCode = E_NOT_DEFINED_FUNCTION_FOR_TYPE  then F_SyntaxErrorString:=F_SyntaxErrorStringA+'('+F_SyntaxErrorString+')';

  SN:=nil;  St1:='';
  //для операций
  if Node^.COP = _COP then
  begin
   F_SyntaxErrorCode:=E_NOT_DEFINED_OPERATION_FOR_TYPE;
   F_SyntaxErrorStringA:=Alg.Opr[Node^.NCOP].Name;

     //исключение для MOD, IDIV, AND,OR,XOR:
     if (Node^.NFunc = CM_MOD)  or (Node^.NFunc = CM_IDIV) or
        (Node^.NFunc = CM_AND)  or (Node^.NFunc = CM_OR)   or (Node^.NFunc = CM_XOR) or
        (Node^.NFunc = CM_NAND)  or (Node^.NFunc = CM_NOR)   or (Node^.NFunc = CM_XNOR)
     then
     begin
       F_SyntaxErrorCode:=E_NOT_DEFINED_FUNCTION_FOR_TYPE;
       F_SyntaxErrorStringA:=Alg.ExFunc[Node^.NFunc].Name;
     end;
  end
  else
  //для ф-ий
  begin
   F_SyntaxErrorCode:=E_NOT_DEFINED_FUNCTION_FOR_TYPE;
   F_SyntaxErrorStringA:=Alg.ExFunc[Node^.NFunc].Name;
  end;

  F_SyntaxErrorString:='';
  //FindNumberLevel(ANL);
  GetAllChilds(Node,NCHLD);
  for j:=0 to Node^.Stack.N-1 do
  begin
     if j > 0 then  F_SyntaxErrorString:=F_SyntaxErrorString+',';
   //F_SyntaxErrorString:=F_SyntaxErrorString+NameTypes[Interp[ANL[j]].TypeF];

    if NCHLD[j]^.TypeF = T_Array then
    begin
         if Alg.Obj[NCHLD[j]^.NObj].MType = _Integer  then  St1:='Array Integer'  else
         if Alg.Obj[NCHLD[j]^.NObj].MType = _Double   then  St1:='Array Double'   else
         if Alg.Obj[NCHLD[j]^.NObj].MType = _Extended then  St1:='Array Extended' else
         if Alg.Obj[NCHLD[j]^.NObj].MType = _Single   then  St1:='Array Single'   else
         if Alg.Obj[NCHLD[j]^.NObj].MType = _Pointer  then  St1:='Array Pointer';
    end
    else
    St1:=NameTypes[NCHLD[j]^.TypeF];

    F_SyntaxErrorString:=F_SyntaxErrorString+St1;
    SetLength(SN,Length(SN)+1);
    SN[High(SN)]:=St1;
   end;

  //if F_SyntaxErrorCode = E_NOT_DEFINED_FUNCTION_FOR_TYPE  then F_SyntaxErrorString:=F_SyntaxErrorStringA+'('+F_SyntaxErrorString+')';



if F_SyntaxErrorCode = E_NOT_DEFINED_FUNCTION_FOR_TYPE   then
begin

  SubExpr:=Node^.Expression;
  SA:=F_SyntaxErrorString;
  SF:=F_SyntaxErrorStringA;


  //St:=LowerCase(SA);
                           // ifp(z1<z2,x=1;z1=z2);x
                           // iff(z1<z2,x,z1);x
                           // iff(x<y,x,z1);x
  //PF:=Pos('ifnop(',St);
  if  Node^.NFunc = CM_IF {SF = SCif} then
  begin
     if Length(SN) = 6 then
     begin
        SA:=SN[0]+','+SN[1]+','+SN[3]+','+SN[5];
     end
     else
     if Length(SN) = 4 then
     begin
        SA:=SN[0]+','+SN[1]+','+SN[3];
     end ;


     Delete(F_SyntaxErrorStringA,1,1);//#
   

     SF:='if'+'('+SA+')';
     F_SyntaxErrorString:=SF+' in '+ '  "'+SubExpr+'"  ';
  end
  else
  if Node^.NFunc = CM_LDSVX {SF = 'ldsvx'} then
  begin
     //vd[z1+1]
     //vd[i+1]
     //St:=F_SyntaxErrorStringA+'('+F_SyntaxErrorString+')';
     //F_SyntaxErrorString:=St+' in '+SubExpr ;
     F_SyntaxErrorString:=SubExpr ;
     F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT;
  end
  else
  if  Node^.NFunc =  CM_SAVE {SF = SCsave} then
  begin
    //vd[i+1]=x;x
     Delete(F_SyntaxErrorStringA,1,1);//#
     St:=F_SyntaxErrorStringA+'('+F_SyntaxErrorString+')';
     F_SyntaxErrorString:=St+' in '+SubExpr ;

     if (Length(NCHLD) = 1) then
     begin
       if NCHLD[0]^.TypeF = T_None then
       begin
          F_SyntaxErrorCode := E_NO_RETURN_NUMBER;
          F_SyntaxErrorString:=NCHLD[0]^.Expression+'  in expsession:   '+SubExpr ;
       end;

     end;
  end
  else       {.395}
  if Node^.NFunc = CM_IROOT3 {SF = '#iroot3'} then           // root(Arg,IntArg1,IntArg2)-> #iroot3(Arg)
  begin
     // root(x+y,j,k)
      F_SyntaxErrorString:='"'+'root('+F_SyntaxErrorString+',Real,Real)'+'"'+'  in expsession:   '+#13#10+'"'+SubExpr+'"';
  end
  else
  begin
    F_SyntaxErrorString:=F_SyntaxErrorStringA+'('+F_SyntaxErrorString+')';
    F_SyntaxErrorString:='"'+F_SyntaxErrorString+'"'+'  in expsession:   '+#13#10+'"'+SubExpr+'"'; {.323}
  end;

end
else
//{.346}
if F_SyntaxErrorCode = E_NOT_DEFINED_OPERATION_FOR_TYPE  then
begin
   SubExpr:=Node^.Expression;
   F_SyntaxErrorString:=F_SyntaxErrorStringA+'('+F_SyntaxErrorString+')'+'  in expsession:   '+#13#10+SubExpr;
end
else
F_SyntaxErrorString:=F_SyntaxErrorStringA+'('+F_SyntaxErrorString+')';


  //if F_SyntaxErrorCode = E_NOT_DEFINED_FUNCTION_FOR_TYPE  then F_SyntaxErrorString:=F_SyntaxErrorStringA+'('+F_SyntaxErrorString+')';

end;



function TForevalH.GetLevelsCS(Node: PNode{num: Integer}): Cardinal;
var   //размер кода вытекающих узлов
j,IdN: Integer;
CS: Cardinal;
ANL: TArrayC;
Chld: PNode;
begin

 {
IdN:=Interp[num].IdN;
for j:=1 to LFunc-1 do
begin
   if IdN = Interp[j].IdL then
   begin
    SetLength(ANL,Length(ANL)+1);
    ANL[High(ANL)]:=j;
   end;
end;

CS:=0;
for j:=0 to High(ANL) do
begin
   CS:=CS+Interp[ANL[j]].CS;
end;
}
CS:=0;
Chld:=Node^.Ch;
while Chld <> nil do
begin
 CS:=CS+Chld^.CS;
 Chld:=Chld^.Nb;
end;

GetLevelsCS:=CS;
end;



function TForevalH.GetReturnedFuncType(Node: PNode): Integer;
label outf,outf1,endp;
var
  i,L,N,NF: Integer;
  RetType,t1,t2,TypeArg: Integer;
begin
{
Определение возвращаемого типа нестандартных внутренних команд и
 перекодировка (оптимизация) одних в другие в зависимости от типов аргументов.
}

RetType:=_ABSENT;

   if Node^.NFunc = CM_POLYU   then
   {
   Возвращаемый тип определяется типами коэфф-ов и типом выражения переменной.
   Если хотя бы один из них - комплексный, то возвращаемый тип - комплексный. Иначе - действительный
   За исключением случая  poly(RealConst,ComplexExpr)
   Числовые коэфф-ты содержатся в массиве. Коэфф-ты , заданные выражениями - в вытекающих узлах
   }
   begin
     RetType:=T_Real;
     L:=Length(Node^.VFP);
     for i := 0 to L-1 do
     begin
       if (Node^.VFP[i].Im <> 0) and (Node^.VFP[i].indx >= 0) then
       begin
        RetType:=T_Complex;
        goto outf;
       end;

     end; //for

     L:=Length(Node^.ArgTypes);
     for i := 0 to L-1 do
     begin
       if Node^.ArgTypes[i] = T_Complex then
        begin
          RetType:=T_Complex;
          goto outf;
        end;
     end; //for

     outf:
     if (L = 1) then    //poly(2*a+b,z) = 2*a+b   poly(2*ai+bi,z) = 2*ai+bi  poly(2*a+b,x) = 2*a+b   poly(2*ai+bi,x) = 2*ai+bi
     begin
        if Node^.VFP[0].indx >= 0 then  RetType:=Node^.VFP[0].tc
        else                            RetType:=Node^.ArgTypes[0];
     end;


   end
   else
   if Node^.NFunc = CM_POLY   then
   {
   Возвращаемый тип определяется типами коэфф-ов и типом выражения переменной.
   Если хотя бы один из них - комплексный, то возвращаемый тип - комплексный. Иначе - действительный
   За исключением случая poly(RealConst,ComplexExpr)
   Числовые коэфф-ты содержатся в массиве.
   }
   begin
     N:=Node^.NFunc;
     NF:=Node^.NF;

     RetType:=T_Real;
     L:=Length(Node^.VFP);
     for i := 0 to L-1 do
     begin
       if (Node^.VFP[i].Im <> 0) {and (Node^.VFP[i].indx >= 0)} then
       begin
        RetType:=T_Complex;
        goto outf1;
       end;
     end; //for

     outf1:
     if Node^.Ch^.TypeF = T_Complex   then     RetType := T_Complex;
     //if Alg.ExFunc[N].Func[NF].TV[0]= T_Complex   then     RetType := T_Complex;


   end
   else
   if Node^.NFunc = CM_CZPWR   then     {.361}
   begin
     //Const(Real,Complex)^(Real,Complex)
     RetType:=T_Real; t1:=0;
     if Node^.AI = 1 then t1:=T_Real else
     if Node^.AI = 2 then t1:=T_Complex;
     t2:=Node^.Ch^.TypeF;
     Node^.TypeA:=t2;//тип аргумента в TypeA вместо автоопределения, т.к. ф-ия задана неоднозначно
     if (t1 = T_Complex) or (t2 = T_Complex) then  RetType := T_Complex;
   end
   else

   //перекодировка команды (-1+0i)^Arg  в (-1+0i)^Real
   if (Node^.NFunc = CM_IPWRSGN)   then    {.361}
   begin

      RetType := Node^.TypeF;
      if (Node^.AI = 2) then
      begin
         TypeArg:=Node^.Ch^.TypeF; //(-1)^(Stack)    //N > 0 !!!
         if (TypeArg = T_Real) then
         begin
            Node^.NF:=GetIdArgFunc1A(Node^.NFunc,1,T_Real);
            //Node^.AI:=3;
            Node^.TypeA:=T_Real;
            Node^.TypeF:=T_Complex;
            RetType := T_Complex;
          end
          else    //(-1+0i)^Complex
          if TypeArg = T_Complex then
          begin
            Node^.AI:=0;
            Node^.NF:=GetIdArgFunc1A(Node^.NFunc,1,T_Complex);
          end;
     end;

   end

   else
   if Node^.NFunc = CM_CRZLOG   then     {.377}
   begin
     //LOG(Const(Real),(Real,Complex))
     RetType:=T_Real; t1:=0;
     if Node^.AI = 1 then t1:=T_Real else
     if Node^.AI = 2 then t1:=T_Complex;
     t2:=Node^.Ch^.TypeF;
     Node^.TypeA:=t2;//тип аргумента в TypeA вместо автоопределения, т.к. ф-ия задана неоднозначно
     if (t1 = T_Complex) or (t2 = T_Complex) then  RetType := T_Complex;
   end

   else
   if Node^.NFunc = CM_CR2ZLOG   then     {.377}
   begin
     //  LOG(Const(Real),(Real,Complex))
     RetType:=T_Real; t1:=0;
     if Node^.AI = 1 then t1:=T_Real else
     if Node^.AI = 2 then t1:=T_Complex;
     t2:=Node^.Ch^.TypeF;
     Node^.TypeA:=t2;//тип аргумента в TypeA вместо автоопределения, т.к. ф-ия задана неоднозначно
     if (t1 = T_Complex) or (t2 = T_Complex) then  RetType := T_Complex;
   end

   else
   if Node^.NFunc = CM_CRZIROOT then
   begin
     if Node^.AI = 1 then  RetType:=T_Real else
     if Node^.AI = 2 then  RetType:=T_Complex;
   end;




 endp:
 GetReturnedFuncType:=RetType;
end;





procedure TForevalH.GetChildWithNum(Node: PNode; NumCh: Integer; var ChildNum: PNode);
label endp;
var
//возвращает потомка (child) с указанным номером NumCh (порядковый номер на уровне ). Отсчёт с 1 !!!
j: Integer;
NodeCh: PNode;
begin

NodeCh:=Node^.Ch;
j:=1;
while NodeCh <> nil do
begin
  //S:=HTree^.ExpressionArg;
  if j = NumCh then  goto endp;
  NodeCh:=NodeCh^.Nb;
  inc(j);
end;

endp:
ChildNum:=NodeCh;

if ChildNum = nil then
begin
  F_InternalError:=E_AccessViolation;
  F_SyntaxErrorCode:=E_INTERNAL_ERROR;
end;

end;




function TForevalH.IsInvalidFPULoad(Node: PNode): Boolean;
label endp;
   {
     Проверка стека FPU после выполнения команды , являющейся аргументом в PROG
     Стек FPU перед ними и после должен быть пуст, за исключением последней команды, если она возвращает число в FPU
     Если стек FPU в таких случаях не пуст,  команда  загружает его и не освобождает: это  ошибка.
   }
var
    Answ: Boolean;
    NCHLD: TArrayPN;
    j,L: Integer;
    NodeCh: PNode;
begin
 // x=1; y+1; x=2; x               // y+1 - загружает стек без возврата/очистки


 {
     pfunc1(x1:ext):none  =   x=2*x1
     pfunc1(x,y:ext):real =   x+y

     x=1; y=2; pfunc1(x); x+y            // ошибки нет, pfunc1 - процедура
     x=1; y=2; pfunc1(x,y); x+y          // ошибка, pfunc1 - функция (загружает результат в FPU )

 }


Answ:=False;

 // если команда является аргументом PROG
if Node^.NFunc = CM_PROG then
begin


  L:=Length(Node^.ArgTypes);

  // если команда - не последняя исполняемая  (L-1)
  for j := 0 to L-2 do
  begin

     // если есть загрузка стека FPU после выполнения команды
    if (Node^.ArgTypes[j] = T_Real) or  (Node^.ArgTypes[j] = T_Complex) then
    begin
        GetChildWithNum(Node, j+1, NodeCh);   // отсчёт с 1
        Answ:=True;
        F_SyntaxErrorString:=NodeCh^.Expression;
        F_SyntaxErrorCode:=E_INVALID_FPU_LOADING;
        goto endp;
    end;

  end;


end;


endp:
IsInvalidFPULoad:=Answ;
end;


 


