procedure TForevalH.PowerAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var BEF, EOFN: Boolean);
label endp,PwrCnstFloat;
var
C,Im: TFloat;
VC1,VC2,TC,SC: Integer;
S,NA,TV: Integer;
Sgn:Integer;
i: Integer;
nv1,nv2,tv1,tv2,tm,Len,mt2: Integer;
FD1,FD2,FD1i: extended;
Str,Str1,Str2,Sindx: String;
adr: Cardinal;
BH,BAnsw,SB: Boolean;
code2,IC1: Integer;
AIVP1: TArrayIntVarProd;
FRes,FArg1,FArg2: TComplex;
NDA: TDataNode;
ni, TypeV, TypeIndx :Integer;
Addr: Cardinal;
CX,Arg1,Arg2,ResCX: TComplex;
begin
if F_SyntaxErrorCode <> 0 then goto endp;

TryFPUMask; {.229}

Len:=Length(LV);
if Len <> 2 then
begin
  {.333}
 {F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
 F_SyntaxErrorString:=F_CurrentString; }
 goto endp;
end;

LV1:=LV;
ND1:=ND;
EOFN:=False;
BEF:=False;     //=True - распознана , как внутренняя. для переопределения (overload) power с другими аргументами
BH:=False;
//ND1.COP:=_FUNC;
 //F_IdN не изменилась = ND1.F_IdN!!! (StringAnalizator)


//VC = _Const(FD); = _Var(nf); = _None(Stack);
Str2:=LV[1].Expression;
Str1:=LV[0].Expression;

DeleteExternalBracketPS(@Str1); {.219}
DeleteExternalBracketPS(@Str2); {.219}

FD1:=0; FD1i:=0; FD2:=0;

//FindVarConstPS(@Str1,nv1,FD1,VC1);
FindVarConstCxPS(@Str1, nv1, FD1, FD1i, VC1, TC);

ND1.ExpressionArg:=Str1+','+Str2; {.216}
NA:=2; {.231}

WriteFindExtArgInt1PS(@Str2, _Second, ND1, IntegerVarForm, ND1, BAnsw);
code2:=ND1.TA2;

VC2:=_none;  TV := _NOT_FOUND; {.346}
if code2 = _IntConst then begin FD2:=ND1.IC2; VC2:=_Const; end
else
if code2 = _NOT_FOUND then SubstParamPS(@Str2,FD2,Im,TV);  //Str2 = FloatConst ?
if TV = T_Real then VC2:=_Const;
//if SB = True then VC2:=_Const;



//FindExtArgInt(@Str2, code2, AIVP1, NV1, IC1);

//if  (VC2 = _Var)  then mt2:=Alg.Obj[nv2].MType;


//s1^intvar
//if  (VC2 = _FVar) and (mt2 = _Integer) and (VC1 <> _Const) then

if (VC1 = _Const) and (VC2 = _Const) then       //RealConst^RealConst
begin
     ND1.FD:=_POWER(FD1,FD2);//power(FD1,FD2);
     ND1.COP:=_LDSC;
     ND1.NFunc:=0;
     BH:=True;
     EOFN:=True;
     LV1:=nil;
     ND1.N:=0;
     BEF:=True;
end
{else
if (VC1 = _ConstComplex) and (VC2 = _Const) then       //ComplexConst^RealConst
begin

     Arg1.re:=FD1;   Arg1.im:=FD1i;
     Arg2.re:=FD2;   Arg2.im:=0;

      _EvalFunc2Cx(@Z_CxReFPWR,Arg1,Arg2,T_Complex,T_Real,ResCX);


      ND1.COP:=_LDSCX;
      ND1.TC:=T_Complex;
      ND1.FDC.re:=ResCX.re;
      ND1.FDC.im:=ResCX.im;
      ND1.FD:=ResCX.re;
      ND1.NFunc:=0;
      EOFN:=True;
      BH:=True;
      BEF:=True;
      ND1.N:=0;
      SetLength(LV1,0);
end
}
else
if  (VC1 <> _Const) and (code2 <> _NOT_FOUND) then    //Expr^IntForm
begin

         //i^IntArg; (-i)^IntArg      {.361}
         if CheckImUnit(@LV1[0].Expression,Sgn) = true then
         begin
           if code2 = _IntConst then //eval const
           begin
               FArg1.re:=0;
               FArg1.im:=1;
               if Sgn = _Negative then FArg1.im:=-1;
               FArg2.re:=FD2;
               FArg2.im:=0;
               _EvalFunc2Cx(@Z_CxReFPWR,FArg1,FArg2,T_Complex,T_Real,FRes);

               ND1.COP:=_LDSCX;
               ND1.NFunc:=0;
               EOFN:=True;
               ND1.N:=0;
               ND1.TC:=C_Complex;
               ND1.FDC.re:=FRes.re;
               ND1.FDC.im:=FRes.im;
               SetLength(LV1,0);
               BEF:=True;
               goto endp;
           end;

           ND1.NFunc:=CM_ImUIPwr;
           ND1.AI:=1;  {.369}  //i^IntForm
           ND1.BI:=Sgn;
           EOFN:=True;
           ND1.N:=0;
           ND1.COP:=_FUNC;
           SetLength(LV1,0);
           BEF:=True;
           goto endp;
         end;


         {.395A}
         if (VC1 = _ConstComplex) and (VC2 = _Const) then       //ComplexConst^RealIntConst
         begin

             Arg1.re:=FD1;   Arg1.im:=FD1i;
             Arg2.re:=FD2;   Arg2.im:=0;

            _EvalFunc2Cx(@Z_CxReFPWR,Arg1,Arg2,T_Complex,T_Real,ResCX);


            ND1.COP:=_LDSCX;
            ND1.TC:=T_Complex;
            ND1.FDC.re:=ResCX.re;
            ND1.FDC.im:=ResCX.im;
            ND1.FD:=ResCX.re;
            ND1.NFunc:=0;
            EOFN:=True;
            BH:=True;
            BEF:=True;
            ND1.N:=0;
            SetLength(LV1,0);

         end

         else

         begin

           ND1.NFunc:=CM_IPWR;
           ND1.AI:=2;
           EOFN:=False;
           ND1.N:=1;
           ND1.COP:=_FUNC;
           SetLength(LV1,1);
           LV1[0].Expression:=Copy(Str1,1,Length(Str1));
           LV1[0].NL:=1;
           BEF:=True;

           //if VC2 = _Const then
           begin
             if (code2 = _IntConst) and (abs(FD2) <= 16) then
             begin
               ND1.NFunc:=CM_IPWR16;  NA:=0;  BH:=True;
               ND1.AI:=Trunc(FD2);
               if FD2 = 2  then  ND1.NFunc:=CM_SQR;
             end
           end;

         end;




end
else
if  (VC1 = _Const) and (code2 <> _NOT_FOUND) then      //RealConst^IntForm
begin

         ND1.AI:=1;
         ND1.FD:=FD1;
         EOFN:=True;
         ND1.N:=0;
         ND1.TypeF:=T_Real;
         ND1.COP:=_FUNC;
         SetLength(LV1,0);
         BEF:=True;

         //if FD1 = -1 then    ND1.NFunc:=CM_IPWRSGN  else     // (-1)^IntForm
         if FD1 = -1 then    ND1.NFunc:=CM_REUNEGIPWR  else      // (-1)^IntForm      {.361}
         if FD1 = 2  then    ND1.NFunc:=CM_F2PWR      else     // 2^IntForm
                             ND1.NFunc:=CM_IPWR;             // num^IntForm


end
else
if  (VC1 <> _Const) and (VC2 = _Const) then  //Expr^RealFloatConst
begin
       {.395}
       if VC1 = _ConstComplex then    // Power(ConstComplex,ConstReal)
       begin
           Arg1.re:=FD1;   Arg1.im:=FD1i;
           Arg2.re:=FD2;   Arg2.im:=0;

           if  FD2 = 0.5 then             {.395A}
           begin
             _EvalFunc1Cx(@Z_SQRT,Arg1,ResCX);
           end
           else
           if  FD2 = 0.25 then                    {.395A}
           begin
              _EvalFunc1Cx(@Z_SQRT,Arg1,ResCX);
              _EvalFunc1Cx(@Z_SQRT,ResCX,ResCX);
           end
           else
           if  FD2 = 0.125 then                    {.395A}
           begin
              _EvalFunc1Cx(@Z_SQRT,Arg1,ResCX);
              _EvalFunc1Cx(@Z_SQRT,ResCX,ResCX);
              _EvalFunc1Cx(@Z_SQRT,ResCX,ResCX);
           end
           else
           begin
              _EvalFunc2Cx(@Z_CxReFPWR,Arg1,Arg2,T_Complex,T_Real,ResCX);
           end;

            ND1.COP:=_LDSCX;
            ND1.TC:=T_Complex;
            ND1.FDC.re:=ResCX.re;
            ND1.FDC.im:=ResCX.im;
            ND1.FD:=ResCX.re;

            ND1.NFunc:=0;
            EOFN:=True;
            ND1.N:=0;
            SetLength(LV1,0);
       end
       else
        {.395A}
       //  power(Expr, <1/2,1/4,1/8,1/16>)  перенесено в компиляцию IROOT_C   root(Expr, <2,4,8,16>)
       if (FD2 = 0.5) or (FD2 = 0.25) or (FD2 = 0.125) or (FD2 = 0.0625) then
       begin

            ND1.NFunc:=CM_IROOT;
            ND1.TA2 :=_IntConst;
            ND1.IC2:=Trunc(1/FD2);
            ND1.AI:=2;
            EOFN:=False;
            ND1.N:=1;
            ND1.COP:=_FUNC;
            SetLength(LV1,1);
            LV1[0].Expression:=Copy(Str1,1,Length(Str1));
            LV1[0].NL:=1;

           {
           if FD2 = 0.5 then
           begin
              ND1.NFunc:=CM_SQRT;
              EOFN:=False;
              ND1.N:=1;
              ND1.COP:=_FUNC;
              SetLength(LV1,1);
              LV1[0].Expression:=Copy(Str1,1,Length(Str1));
              LV1[0].NL:=1;
              BEF:=True;
           end
           else
           if FD2 = 0.25 then             // = sqrt(sqrt(Expr))
           begin
              ND1.NFunc:=CM_SQRT;
              EOFN:=False;
              ND1.N:=1;
              ND1.COP:=_FUNC;
              SetLength(LV1,1);
              LV1[0].NL:=1;
              Str1:='sqrt('+Str1+')';
              LV1[0].Expression:=Copy(Str1,1,Length(Str1));
              BEF:=True;
           end
           else
           if FD2 = 0.125 then             // = sqrt(sqrt(sqrt(Expr)))
           begin
              ND1.NFunc:=CM_SQRT;
              EOFN:=False;
              ND1.N:=1;
              ND1.COP:=_FUNC;
              SetLength(LV1,1);
              LV1[0].NL:=1;
              Str1:='sqrt(sqrt('+Str1+'))';
              LV1[0].Expression:=Copy(Str1,1,Length(Str1));
              BEF:=True;
           end
           }
       end;

end
else
if (VC1 = _Const) and (code2 = _NOT_FOUND)  then      //Const(Re)^Expr
begin

  // (-1)^IntArray[indx]
  if FD1 = -1 then      {.369}
  begin
      if FindArray(@Str2, NDA, ni, TypeV, TypeIndx, Addr, Sindx) = True then
      begin
           if (TypeV = _Integer) and ((TypeIndx = _IntVar) or (TypeIndx =_IntConst) or (TypeIndx = _IntForm) ) then
           begin
            ND1.NFunc:=CM_REUNEGIPWR;//CM_IPWRSGN;
            ND1.COP:=_FUNC;
            ND1.AI:=3;
            ND1.NObj2:=ni;
            ND1.DI:=NDA.AI; //тип аргумента массива в DI !!
            ND1.AIVP1:=Copy(NDA.AIVP1,0,Length(NDA.AIVP1));
            ND1.FD:=NDA.FD; //константа аргумента массива @vec[IntConst]
            ND1.NV2:=NDA.NV1; //переменная аргумента массива @vec[Intconst]

            SetLength(LV1,0);
            EOFN:=True;
            ND1.N:=0;
            BEF:=True;
            goto endp;
         end
      end
  end;

  if FD1 = 2 then
  begin
       // (2)^IntArray[indx]
      if FindArray(@Str2, NDA, ni, TypeV, TypeIndx, Addr, Sindx) = True then
      begin
           if (TypeV = _Integer) and ((TypeIndx = _IntVar) or (TypeIndx =_IntConst) or (TypeIndx = _IntForm) ) then
           begin
            ND1.NFunc:=CM_F2PWR;
            ND1.COP:=_FUNC;
            ND1.AI:=3;
            ND1.NObj2:=ni;
            ND1.DI:=NDA.AI; //тип аргумента массива в DI !!
            ND1.AIVP1:=Copy(NDA.AIVP1,0,Length(NDA.AIVP1));
            ND1.FD:=NDA.FD; //константа аргумента массива @vec[IntConst]
            ND1.NV2:=NDA.NV1; //переменная аргумента массива @vec[Intconst]

            SetLength(LV1,0);
            EOFN:=True;
            ND1.N:=0;
            BEF:=True;
            goto endp;
         end
      end;
        (*
       // goto  PwrCnstFloat;      {.379}
        //     2^(Expr) не работает для комплексного арг. 2^Real -> CM_CZPWR;
         // 2^ Float
         ND1.NFunc:=CM_F2PWR;
         ND1.COP:=_FUNC;
         ND1.AI:=0;
         SetLength(LV1,1);
         EOFN:=False;
         ND1.N:=1;
         LV1[0].Expression:=Copy(Str2,1,Length(Str2));
         BEF:=True;
         goto endp;
       *)

  end;

    //const(Re)^IntArray[]   {.369}
       if FindArray(@Str2, NDA, ni, TypeV, TypeIndx, Addr, Sindx) = True then
       begin
           if (TypeV = _Integer) and ((TypeIndx = _IntVar) or (TypeIndx =_IntConst) or (TypeIndx = _IntForm) ) then
           begin
            ND1.NFunc:=CM_IPWR;
            ND1.COP:=_FUNC;
            ND1.AI:=4;  //
            ND1.NObj2:=ni;
            ND1.DI:=NDA.AI; //тип аргумента массива в DI !!
            ND1.AIVP1:=Copy(NDA.AIVP1,0,Length(NDA.AIVP1));
            ND1.FD:=NDA.FD; //константа аргумента массива @vec[IntConst]
            ND1.NV2:=NDA.NV1; //переменная аргумента массива @vec[Intconst]

            ND1.FD1:=FD1;
            SetLength(LV1,0);
            EOFN:=True;
            ND1.N:=0;
            BEF:=True;
            goto endp;
         end
       end;


   PwrCnstFloat:
   //const(Re)^Re; const(Re)^Complex

  // if F_ReduceArgOptimizatorF = True then     {.361} {.395}
  //begin

    //const(Re)^Re; const(Re)^Complex
      {.395}
         SubstParamCXPS(@Str2,CX,SC);        //SC=C_None{no},C_Real(real),C_Image(image),C_Complex(complex)
         if (SC = C_Complex) or (SC = C_Image) then       // power(7,2+3i)
         begin
                Arg1.re:=FD1;   Arg1.im:=0;
                Arg2.re:=CX.re; Arg2.im:=CX.im;
                _EvalFunc2Cx(@Z_ReCxFPWR,Arg1,Arg2,T_Real,T_Complex,ResCX);

                 ND1.COP:=_LDSCX;
                 ND1.TC:=T_Complex;
                 ND1.FDC.re:=ResCX.re;
                 ND1.FDC.im:=ResCX.im;
                 ND1.FD:=ResCX.re;

                 ND1.NFunc:=0;
                 EOFN:=True;
                 ND1.N:=0;
                 SetLength(LV1,0);
         end
         else
         if F_ReduceArgOptimizatorF = True then     {.361} {.395}
         begin
             ND1.NFunc:=CM_CZPWR;
             ND1.COP:=_FUNC;
             ND1.AI:=1; //Const(Re)
             ND1.FD:=FD1;
             //ND1.FD1:=fc_Log2(FD1);
             SetLength(LV1,1);
             EOFN:=False;
             ND1.N:=1;
             LV1[0].Expression:=Copy(Str2,1,Length(Str2));
             BEF:=True;

             if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
             //if FD1 = -1.0 then dec(Db_NumberReductions);
         end
         else  // вывести выражения (-1)^Real/Complex за ReduceArgOptimizatorF
         if (FD1 = -1.0)  then
         begin
              ND1.NFunc:=CM_IPWRSGN;
              ND1.COP:=_FUNC;
              ND1.AI:=0;      //(-1)^(arg)
              SetLength(LV1,1);
              EOFN:=False;
              ND1.N:=1;
              LV1[0].Expression:=Copy(Str2,1,Length(Str2));
              BEF:=True;
         end;
  //end;


end
else   {.361}              // 395x
if (VC1 = _ConstComplex) and (code2 = _NOT_FOUND)  then      //Const(Complex)^Expr
begin

    if (FD1 = -1) and (FD1i = 0) then
    begin
         ND1.NFunc:=CM_IPWRSGN;
         ND1.COP:=_FUNC;
         ND1.AI:=2;      //(-1+0i)^(arg)
         SetLength(LV1,1);
         EOFN:=False;
         ND1.N:=1;
         LV1[0].Expression:=Copy(Str2,1,Length(Str2));
         BEF:=True;
    end
    else
    if ((FD1 = 0) and (FD1i = 1)) or ((FD1 = 0) and (FD1i = -1)) then
    begin

           //(-i)^IntArray[indx] {.369}
         if FindArray(@Str2, NDA, ni, TypeV, TypeIndx, Addr, Sindx) = True then
         begin
             if (TypeV = _Integer) and ((TypeIndx = _IntVar) or (TypeIndx =_IntConst) or (TypeIndx = _IntForm) ) then
             begin

               ND1.NFunc:=CM_ImUIPwr;
               ND1.COP:=_FUNC;
               ND1.AI:=3;  {.369}  //i^IntArray[]
               ND1.BI:=_NEGATIVE; //-i
               ND1.NObj2:=ni;
               ND1.DI:=NDA.AI; //тип аргумента массива в DI !!
               ND1.AIVP1:=Copy(NDA.AIVP1,0,Length(NDA.AIVP1));
               ND1.FD:=NDA.FD; //константа аргумента массива @vec[IntConst]
               ND1.NV2:=NDA.NV1; //переменная аргумента массива @vec[Intconst]

               SetLength(LV1,0);
               EOFN:=True;
               ND1.N:=0;
               BEF:=True;
               goto endp;

             end
         end;


         ND1.NFunc:=CM_IMURZPWR;       //(+-i)^(Real,Complex)
         ND1.COP:=_FUNC;
         if FD1i = 1 then ND1.AI:=1 else  ND1.AI:=2;
         ND1.FD:=FD1;
         ND1.FDC.re:=FD1;
         ND1.FDC.im:=FD1i;
         SetLength(LV1,1);
         EOFN:=False;
         ND1.N:=1;
         LV1[0].Expression:=Copy(Str2,1,Length(Str2));
         BEF:=True;


    end
    else
    begin
         {.395}
         SubstParamCXPS(@Str2,CX,SC);        //SC=C_None{no},C_Real(real),C_Image(image),C_Complex(complex)
         if (SC = C_Complex) or (SC = C_Image) then
         begin
                Arg1.re:=FD1;   Arg1.im:=FD1i;
                Arg2.re:=CX.re; Arg2.im:=CX.im;
               _EvalFunc2Cx(@ZPWR,Arg1,Arg2,T_Complex,T_Complex,ResCX);

                 ND1.COP:=_LDSCX;
                 ND1.TC:=T_Complex;
                 ND1.FDC.re:=ResCX.re;
                 ND1.FDC.im:=ResCX.im;
