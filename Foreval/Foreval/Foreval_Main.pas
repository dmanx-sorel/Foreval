           //AND_EAX_EBX(_IntVar,0,AddrA2,True);
        end
        else           // and(IntForm1,IntForm2)
        begin
           LoadLineFormEAX(_Second);                          // and(5*j+7*k+11*n+960,2*j+4*k+12327)
           MOVREG(R_EAX,R_ESI);         //IntForm2 -> ESI
