(*
bp:=0;  L:=Length(PS^);

nxt:
if PS^ = '' then
begin
 goto outf;
end;


inc(bp);
if (PS^[bp] = '(') and (PS^[L-bp+1] = ')') then
begin

  b:=0;
  for i:=bp to L-bp do
  begin
    if PS^[i] = '(' then dec(b);
    if PS^[i] = ')' then inc(b);
    if b = 0 then  goto outf;
  end;
  goto nxt;

end;

outf:
dec(bp);
if bp > 0 then
begin
 Delete(PS^,L-bp+1,bp);
 Delete(PS^,1,bp);
end;
*)

Answ:=False;
nxt:
