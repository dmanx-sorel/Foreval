procedure TForevalH.CZPWR_C;
var
t1,N,NF,S,tma,tva: Integer;
AdrA: Cardinal;
FD: Extended;
begin
//Const(Real,Complex)^(Real,Complex)

 {
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;   }

 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 t1:=GNode^.TypeA; //Alg.ExFunc[N].Func[NF].TV[0];

 LoadArg1;

 if GNode^.AI = 1 then        //Const(Real)
 begin
   if t1 = T_Real then          //Const(Real)^Real
   begin

     if GNode^.FD = 2 then        {.395}
     begin
         MOVAadr(Cardinal(@R_F2PWR));
         CALLA;
         CheckStack(2);
         CheckStack(-2);
     end
     else
     if GNode^.FD = -1.0 then
     begin
           MOVAadr(Cardinal(@R_IPWRSGN));
           CALLA;
           CheckStack(1);
           CheckStack(-1);
     end
     else
     if GNode^.FD > 0  then
     begin
        GNode^.FD1:=fc_Log2(GNode^.FD);

        FLD(WriteDataA(GNode^.FD,_Extended),_Extended);
        FLD(WriteDataA(GNode^.FD1,_Extended),_Extended);

        MOVAadr(Cardinal(@R_CR_FPWR));
        CALLA;

        CheckStack(2);
        CheckStack(-4);
     end
     else
     begin
        FLD(WriteDataA(GNode^.FD,_Extended),_Extended);
        MOVAadr(Cardinal(@FPWR));
        CALLA;
        CheckStack(2);
        CheckStack(-3);
     end;
   end
   else
   if t1 = T_Complex then       //Const(Real)^Complex
   begin
      {.395}
       if GNode^.FD = -1.0 then
       begin
          MOVAadr(Cardinal(@Z_IPWRSGN));
          CALLA;
          CheckStack(2);
          CheckStack(-2);
       end
       else
       begin

          GNode^.FD1:=fc_Ln(abs(GNode^.FD));

          FLD(WriteDataA(GNode^.FD,_Extended),_Extended);
          FLD(WriteDataA(GNode^.FD1,_Extended),_Extended);

          MOVAadr(Cardinal(@Z_CRe_CxFPWR));
          CALLA;
          CheckStack(-2);

       end;
   end;
 end
 else
 if GNode^.AI = 2 then        //Const(Complex)
 begin
    if t1 = T_Real then     //Const(Complex)^Real
    begin
        FLD(WriteDataA(arctan2_acc(GNode^.FDC.im,GNode^.FDC.re),_Extended),_Extended);
        FLD(WriteDataA(fc_ln(sqrt(sqr(GNode^.FDC.im)+sqr(GNode^.FDC.re))),_Extended),_Extended);
        FLD(WriteDataA(GNode^.FDC.im,_Extended),_Extended);
        FLD(WriteDataA(GNode^.FDC.re,_Extended),_Extended);

        MOVAadr(Cardinal(@Z_CCxRe_FPWR));
        CALLA;
        CheckStack(-3);
    end
    else
    if t1 = T_Complex then    //Const(Complex)^Complex
    begin
         FLD(WriteDataA(fc_ln(sqrt(sqr(GNode^.FDC.im)+sqr(GNode^.FDC.re))),_Extended),_Extended);
         FLD(WriteDataA(arctan2_acc(GNode^.FDC.im,GNode^.FDC.re),_Extended),_Extended);
         MOVAadr(Cardinal(@Z_CCx_CxFPWR));
         CALLA;
         CheckStack(1);
         CheckStack(-3);
    end
 end;

 SetReg(1); SetReg(2); SetReg(3); SetReg(4);
end;





