if F_EnableUsePointer = True then
begin
 if PS^[1] = '@' then
 begin
   BH:=FindAddrObj(PS,ND,ND);
   if BH = True then
   begin
      ND.COP:=_LDSA;
      ND.TypeF:=T_Pointer;//T_Real;//T_Integer//T_Pointer;
      EOFN:=True;
      goto endp;
   end;
 end;
end;
*)


{.301}
 //далее только константы
if M_ParseMode = M_ParseDiffExpr then
begin
 ND.SDiff:='0';
 EOFN:=True;
 //условно:        {.327}
 ND.COP:=_LDSC;
 ND.TC:=C_None;
 ND.FDC.re:=0;
 ND.FDC.im:=0;
 ND.FD:=0;

 goto endp;
end;


//SubstParam(S,C,SB);
//поиск константы
SubstParamCXPS(PS,CX,SB);
if SB <> C_None then
begin
    ND.TC:=SB;
    ND.FDC.re:=CX.re;
    ND.FDC.im:=CX.im;
    ND.FD:=CX.re;
   //inc(F_IdN);
   //ND.IdN:=F_IdN;
    if SB = C_Real  then ND.COP:=_LDSC else  ND.COP:=_LDSCX;
    //ND.SDiff:='0'; //{.301}
    EOFN:=True;
    goto endp;
end;




//поиск служебных (внутренних команд)
FindControlComPS(PS,code,ni,BH);
if BH = True then
begin
 if code = _FLD then
 begin
   ND.COP:=_FLD;
 end
 else
 if code = _JMP then
 begin
   ND.COP:=_FUNC;
   ND.NFunc:=CM_JMP;
 end
 else
 if code = CM_NOP then  {.203}
 begin
   ND.COP:=_FUNC;
   ND.NFunc:=CM_NOP;
   ND.N:=0;
 end
 else
 if code = CM_VOID then  {.303}
 begin
   ND.COP:=_FUNC;
   ND.NFunc:=CM_VOID;
   ND.N:=0;
 end;

 ND.N:=0;
 ND.AI:=ni;
 EOFN:=True;

 goto endp;
end;

{
FindJMP(S,ni);
if ni <> 0 then
begin
 ND.COP:=_JMP;
 ND.AI:=ni;
 EOFN:=True;
 goto endp;
end;
}

//TranslateCommonError(PS);   {.369}

// x$h

{.383}

// Из FindMainOperationPS:
if (G_NCop = _ABSENT) and (F_PresentOperation = True) then
begin
   if G_FirstOP <> _ABSENT then
   begin
     if (Alg.Opr[G_FirstOP].NArg = 2)  then
     begin
          F_SyntaxErrorCode:=E_MISSING_EXPRESSION;
          F_SyntaxErrorString:=Copy(PS^,1,Length(PS^));
          if   Tree^.Pr <> nil then  F_SyntaxErrorString:= '  "'+F_SyntaxErrorString + '"'+#13#10+ '   in:' +#13#10+ Tree^.Pr^.Expression+'"    ';
          goto endp;
     end
     else
     if (Alg.Opr[G_FirstOP].NArg = 1)  then
     begin
          // если задняя операция в середине или впереди
         if (Alg.Opr[G_FirstOP].Pos = _After) and  (Alg.Opr[G_FirstOP].LenOp -1 + G_PosOP  < G_LenSubExpr)  then
         begin
           F_SyntaxErrorCode:=E_WRONG_PLACEMENT_OPERATOR;
           F_SyntaxErrorString:=Copy(PS^,1,Length(PS^));
           if   Tree^.Pr <> nil then  F_SyntaxErrorString:= '  "'+F_SyntaxErrorString + '"'+ #13#10+ '   in:' +#13#10+ Tree^.Pr^.Expression+'"    ';
           goto endp;
         end
         else
          // если передняя операция  в середине или сзади
         if  (Alg.Opr[G_FirstOP].Pos = _Before) and (G_PosOP  > 1) then
         begin

            F_SyntaxErrorString:=Copy(PS^,1,Length(PS^));  Lt:=Length(CS_Shex);
            St:= Copy(F_SyntaxErrorString,Length(F_SyntaxErrorString)-Lt+1,Lt);

            if  (St = CS_Sbin) or (St = CS_Shex) then                              {.395}
            begin
                F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT ;
                S1:=Copy(F_SyntaxErrorString,1,Length(F_SyntaxErrorString)-Lt);
                F_SyntaxErrorString:= '  "'+S1 +'"' + #13#10+ '   in:' +#13#10+ F_SyntaxErrorString+'"    ';
            end
            else
            begin
                F_SyntaxErrorCode:=E_WRONG_PLACEMENT_OPERATOR;
                if   Tree^.Pr <> nil then  F_SyntaxErrorString:= '  "'+F_SyntaxErrorString +'"' + #13#10+ '   in:' +#13#10+ Tree^.Pr^.Expression+'"    ';
            end;
            goto endp;
         end;
     end;
   end
end;

// конечная общая ошибка
 F_SyntaxErrorCode:=E_UNKNOWN_SYMBOL;         //неизвестный символ
 F_SyntaxErrorString:=Copy(PS^,1,Length(PS^));
 {.387}
 if   Tree^.Pr <> nil then  F_SyntaxErrorString:= '   "'+F_SyntaxErrorString + '"' +#13#10+ '   in:  ' +#13#10+ '"'+Tree^.Pr^.Expression+'"    ';





EOFN:=False;



endp:
end;








procedure TForevalH.TranslateCommonError(PS: PString);
var
 Sf,Sa: String;
 nf: Integer;
 FH: Boolean;
begin
  FindFuncBrPS(PS,'(',')',Sf,Sa,FH);
  if FH = True then
  begin
    FindFuncPS(@Sf,nf);
    if (nf = CM_JMP) or (nf = CM_GOSUB) then
    begin
      F_SyntaxErrorCode:=E_LABEL_IN_GOTO_NOT_SET;
    end
    else
    begin
      F_SyntaxErrorCode:=E_UNKNOWN_FUNCTION;
    end;
  end
  else
  begin
    F_SyntaxErrorCode:=E_UNKNOWN_SYMBOL;
  end;


  F_SyntaxErrorString:=Copy(PS^,1,Length(PS^));
end;



