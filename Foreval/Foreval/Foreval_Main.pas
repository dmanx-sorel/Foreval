              if ResT = _ANY then
              begin

                BH:=True;
                for m := 0 to NArgFL - 1 do     //сравнение типов аргументов
                begin
                  if (Alg.ExFunc[i].Func[k].TV[m] <> TV[m]) and (TV[m] <> _ANY)  then BH:=False
                  else
                  if (Alg.ExFunc[i].Func[k].TM[m] <> TM[m]) and (TM[m] <> _ANY) then BH:=False;
                end;

                if BH = True then
                begin
                  NF:=k; goto endp;
                end;

              end
              else
              if (NArgFL = NArg) and (ResT = TypeFL) then
              begin

                BH:=True;
                for m := 0 to NArgFL - 1 do     //сравнение типов аргументов
                begin
                  if (Alg.ExFunc[i].Func[k].TV[m] <> TV[m]) and (TV[m] <> _ANY)  then BH:=False
                  else
                  if (Alg.ExFunc[i].Func[k].TM[m] <> TM[m]) and (TM[m] <> _ANY) then BH:=False;
                end;

                if BH = True then
                begin
                  NF:=k; goto endp;
                end;

              end;


            end;

            goto endp;
          end;

       end;
 end;


endp:
end;





