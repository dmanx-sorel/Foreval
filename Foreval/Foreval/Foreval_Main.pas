procedure TForevalH.FindAddSubNumInArgPS(PS: PString ;  var fx: extended; var answ: integer);
label beginp;

var
 L,b,i,p,cop: Integer;
 Sn: String;                               //E1 op N1 op ... En/Nn ... ; op=+,- ;N-number, E- expression ->  S = E1op...opEn; fx=N1op...opNn
 ft: extended;
begin                                    //1-E1+2-4+E2-E3+5 -> S=-E1+E2-E3; fx=4   _num
fx:=0;                                   //1+2-3+4; -> S=''; fx=4; _const
                                         //E1+E2-E3+E4 -> S=E1+E2-E3+E4; fx=0; _none
answ:=_none;
SaveSW; {.229} {TryStrToFloat damage SW}
beginp:

b:=0; L:=Length(PS^); p:=1;

for i:=1 to L  do
begin
 (*
 if PS^[i] = '(' then b:=b-1 else
 if PS^[i] = ')' then b:=b+1 else
 if PS^[i] = '[' then b:=b-1 else
 if PS^[i] = ']' then b:=b+1 else
 if PS^[i] = '{' then b:=b-1 else
 if PS^[i] = '}' then b:=b+1;
 *)
 if PS^[i] in OpenBracket then  dec(b)
 else
 if PS^[i] in CloseBracket then inc(b);

 if b = 0 then
 begin

    if (PS^[i] = '+') or (PS^[i] = '-') then
    begin
      Sn:=Copy(PS^,p,i-p);
      //SaveSW; {.229} {TryStrToFloat damage SW}
      if TryStrToFloat(Sn,ft,G_FMT) = true then
      begin
         fx:=fx+ft ;
         Delete(PS^,p,i-p);
         p:=i;
         answ:=_num;
         goto beginp;
      end;
    p:=i;
    end;



 end;

end;

//SaveSW; {.229} {TryStrToFloat damage SW}
//last expr:
if TryStrToFloat(PS^,ft,G_FMT) = true then
begin
      fx:=fx+ft;
      PS^:='';
      answ:=_const;
end
else
begin
  Sn:=Copy(PS^,p,L-p+1);
  if TryStrToFloat(Sn,ft,G_FMT) = true then
  begin
      fx:=fx+ft;
      Delete(PS^,p,L-p+1);
      answ:=_num;
  end;
  if PS^[1] = '+' then Delete(PS^,1,1); //+Expr->Expr


end;




end;



procedure  TForevalH.IsNumLastPS(PS: PString; var fx: extended; var Op: Integer);
label fnum,endp;
var                                      //Op=0: none; _add,_sub,_mul,_div,_num
 S3: String;
 Neg,LS,p,i: Integer;
begin


Op:=0;
fx:=0;
S3:='';
p:=0;

SaveSW; {.229} {TryStrToFloat damage SW}
if TryStrToFloat(PS^,fx,G_FMT) = true then
begin
   Op:=_num;
   goto endp;
end ;


LS:=Length(PS^);
for i := LS  downto 1   do
begin
  if (PS^[i] = ')') or  (PS^[i] = ']') then  goto endp
  else
  if (PS^[i] = '-')  then //только Expr-num, Expr+num
  begin
    p:=i; Op:=_sub; goto fnum;
  end
  else
  if  (PS^[i] = '+') then //только Expr-num, Expr+num
  begin
    p:=i; Op:=_add; goto fnum;
  end;


end;

fnum:
if Op <> 0 then      {.375D}
 S3:=Copy(PS^,p+1,LS-p);


{.203}
if TryStrToFloat(S3,fx,G_FMT) = true then
begin
    //fx:=StrToFloat(S3,G_FMT);
    Delete(PS^,p,LS-p+1);
    if Op = _sub then  fx:=(-1)*fx;
end
else
Op:=0;

endp:
end;



procedure TForevalH.SetTemplateDiffFunc(NFunc,NF: integer; TmplDiffFunc: String);
begin                                                            //idName=NFunc; idArg=NF

  //Alg.ExFunc[NFunc].TemplateDiffFunc:=TmplDiffFunc;
  if (NFunc < Length(Alg.ExFunc)) and (NF < Length(Alg.ExFunc[NFunc].Func)) and (NF >= 0) and (NFunc >= 0) then
  begin
    {
    Alg.ExFunc[NFunc].Func[NF].TemplateDiffFunc:=TmplDiffFunc;
    Alg.ExFunc[NFunc].Func[NF].DFTmpl:=_YES;
    }

    //ограничение версии 9.0; шаблон дифференцирования задаётся ОДИН на все overload ф-ии и прописывается в первую ф-ию:  {.327}
    Alg.ExFunc[NFunc].Func[0].TemplateDiffFunc:=TmplDiffFunc;
