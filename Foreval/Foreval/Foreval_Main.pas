procedure TForevalH.ReadTreeDBG;
label endp;
var
Tree: PNode;
NNode: Cardinal;
  i,nc: Integer;
  S: String;
  Vnc: TArrayC;
begin

(*
   Tree:=BeginTree;
   Tree:=GetLowLeftNode(Tree);
        // TProcTree(CallProc)(Tree);
       //if CallProc(Tree) = True then goto endp;

   while Tree^.Pr <> nil do
   begin
      Tree:=GetNextNode(Tree);
      //TProcTree(CallProc)(Tree);
       // if CallProc(Tree) = True then goto endp;
   end;
*)

 nc:=0;      SetLength(Vnc,0);
 Tree:=FirstNode;
 while Tree <> nil do
 begin

   NNode:=Tree^.NNode;
   for i := 0 to Length(Vdbg)-1 do
   begin
     if NNode = Vdbg[i] then
     begin
        S:=Tree^.Expression;
        inc(nc);
        SetLength(Vnc,Length(Vnc)+1);
        Vnc[High(Vnc)]:=NNode;
     end;

   end;
   Tree:=Tree^.Next;
 end;

  if nc <> 0 then
    nc:=Length(Vdbg)-nc;

endp:
end;


