begin
  if Alg.ExFunc[NFunc].Func[i].NArg  = NArg then
  begin
    if Alg.ExFunc[NFunc].Func[i].TV[0] = TypeArg then
    begin
      idArg:=i;
      goto endp;
    end;
  end;

end;

endp:
GetIdArgFunc1A:=idArg;
end;




procedure TForevalH.SetNewFunc(NameF: String; NFunc,NF: Integer; FS:TIntFunc; Com: Integer; var idName,idArg: Integer);

       function _FindDeletedSubFunction(NFunc: Integer): Integer;
       label endp;
       var
        ni,NF: Integer;
       begin
          NF:=_NOT_FOUND; //=-1 !!!
          for ni := 0 to High(Alg.ExFunc[NFunc].Func) do
          begin
            if Alg.ExFunc[NFunc].Func[ni].Enable = _DELETED then
            begin
               NF:=ni; goto endp;
            end;
          end;

          endp:
          _FindDeletedSubFunction:=NF;
       end;
var
 j,m,NF1,ExeF: integer;
begin

  if Com = _New then
  begin
    NFunc:=Length(Alg.ExFunc);
    SetLength(Alg.ExFunc,NFunc+1);
    NF:=0;
    SetLength(Alg.ExFunc[NFunc].Func,NF+1);
    Alg.ExFunc[NFunc].Name:=Copy(NameF,1,Length(NameF));
  end
  else
  if Com = _NewOverload then
  begin
  //*******************************************
    {.365}
    NF:=_FindDeletedSubFunction(NFunc);
    if NF =  _NOT_FOUND then
    begin
      NF:=Length(Alg.ExFunc[NFunc].Func);
      SetLength(Alg.ExFunc[NFunc].Func,NF+1);
    end;
    {
    NF:=Length(Alg.ExFunc[NFunc].Func);
    SetLength(Alg.ExFunc[NFunc].Func,NF+1);
    }
  end
  else
  if Com = _Internal then  //NFunc - задан ( только для внутренних, имеющих предустановленный номер команды в массиве  Alg.ExtFunc[NFunc] )
  begin
    FS.IntF:=_Internal;     {.395}  // установка ТОЛЬКО внутренних функций,
    Alg.ExFunc[NFunc].Name:=Copy(NameF,1,Length(NameF));
    NF:=Length(Alg.ExFunc[NFunc].Func);
    SetLength(Alg.ExFunc[NFunc].Func,NF+1);
  end
  else
  if Com = _ExternalAsInternal then  //NFunc - задан ( только для внутренних, имеющих предустановленный номер команды в массиве  Alg.ExtFunc[NFunc] )
  begin
    FS.IntF:=_External;     {.395}
    Alg.ExFunc[NFunc].Name:=Copy(NameF,1,Length(NameF));
    NF:=Length(Alg.ExFunc[NFunc].Func);
    SetLength(Alg.ExFunc[NFunc].Func,NF+1);
  end;




  {K:=High(Alg.ExFunc);
  N:=High(Alg.ExFunc[K].Func);
  SetLength(Alg.ExFunc[K].Func,Length(Alg.ExFunc[K].Func)+1);
  N:=N+1; }

  Alg.ExFunc[NFunc].Func[NF].TypeF:=FS.TypeF;
  Alg.ExFunc[NFunc].Func[NF].TypeM:=FS.TypeM;   {.353}
  Alg.ExFunc[NFunc].Func[NF].CallT:=FS.CallT;
  Alg.ExFunc[NFunc].Func[NF].Addr:=FS.Addr;
  Alg.ExFunc[NFunc].Func[NF].Arrow:=FS.Arrow;
  Alg.ExFunc[NFunc].Func[NF].CLST:=FS.CLST;
  Alg.ExFunc[NFunc].Func[NF].SDeep:=FS.SDeep;
  Alg.ExFunc[NFunc].Func[NF].NArg:=FS.NArg;
  //Alg.ExFunc[NFunc].NArg:=FS.N; {.301}
  //Alg.ExFunc[NFunc].DFTmpl:=_NO; {.301}
  Alg.ExFunc[NFunc].Func[NF].DFTmpl:=_NO; {.301}
  Alg.ExFunc[NFunc].Func[NF].CalcConst:=FS.CalcConst;
  Alg.ExFunc[NFunc].Func[NF].IntF:=FS.IntF;
  Alg.ExFunc[NFunc].Func[NF].ExeF:=FS.ExeF; {.395}//_YES
  Alg.ExFunc[NFunc].Func[NF].SaveReg:=FS.SaveReg;
  Alg.ExFunc[NFunc].Func[NF].CodeSize:=FS.CodeSize;   {.365}
  Alg.ExFunc[NFunc].Func[NF].IsInline:=FS.IsInline;    {.365}
  Alg.ExFunc[NFunc].Func[NF].Enable:=_YES;              {.365}


  SetLength(Alg.ExFunc[NFunc].Func[NF].TV,Length(FS.TV));
  SetLength(Alg.ExFunc[NFunc].Func[NF].TM,Length(FS.TM));
  for j:=0 to High(FS.TV) do
  begin
   Alg.ExFunc[NFunc].Func[NF].TV[j]:=FS.TV[j];
   Alg.ExFunc[NFunc].Func[NF].TM[j]:=FS.TM[j];
  end;
  if FS.CallT = _Compiled  then
    begin
     SetLength(Alg.ExFunc[NFunc].Func[NF].ArgAdr,Length(FS.ArgAdr));
     for m:=0 to High(FS.ArgAdr) do
         Alg.ExFunc[NFunc].Func[NF].ArgAdr[m]:=FS.ArgAdr[m];
    end;
    FS.ArgAdr:=nil;
  {.191}
  if Length(Alg.ExFunc[NFunc].NameEx) = 0 then
  begin
    SetLength(Alg.ExFunc[NFunc].NameEx,1);
    Alg.ExFunc[NFunc].NameEx[0]:=Copy(NameF,1,Length(NameF));
  end;

  Alg.ExFunc[NFunc].Enable:=_YES;
  Alg.ExFunc[NFunc].ReplFunc:=FS.ReplFunc;     {.193}
  Alg.ExFunc[NFunc].Func[NF].Set_ID:=FS.Set_ID;
  Alg.ExFunc[NFunc].Func[NF].Id_Func:=FS.ID_Func;
  //Alg.ExFunc[NFunc].XchArg  := FS.XchArg;

  idName:=NFunc;
  idArg:=NF;
end;



procedure TForevalH.SetFunction(Name: String; FS:TIntFunc);
label endp,newf,nxtf;                      //TV - массив с типами переменных (array of types of variables) T_Real,T_Complex,T_Array
var                                         //TypeF - возвращаемый тип функции (returned  type of function) T_Real,T_Complex
                                          //TM - массив с типами переменных (array of types of variables) _Double,_Extended,_Integer
N,K,i,j,m,bf,nf,m1,NFunc,idName,idArg,Place: Integer;
begin

G_idName:=-1;
G_idArg:=-1;

if CheckName(Name) = false then begin F_SyntaxErrorCode:=E_WRONG_NAME; F_SyntaxErrorString:=Name; IntException; goto endp; end;

Place:=FS.Place;

   FindFuncID(Name,FS.NArg,FS.TypeF,FS.TV,FS.TM,NFunc,NF);

   if Place = _ReWrite then
   begin

    if NFunc = _NOT_FOUND then    //установка новой ф-ии с новым именем:
       SetNewFunc(Name,_ANY,_ANY, FS, _New, idName,idArg)
    else
    if NF = _NOT_FOUND then       //установка новой ф-ии с таким же именем: (с другим набором аргументов)
       SetNewFunc(Name,NFunc,_ANY, FS, _NewOverload, idName,idArg)
    else                        //переустановка аналогичной ф-ии:    (с таким-же набором аргументов)
       SetNewFunc(Name,NFunc,NF,FS,_ReWrite,idName,idArg);

   end
   else     {.308}
   if Place = _New then
   begin

    if NFunc = _NOT_FOUND then    //установка новой ф-ии с новым именем:
       SetNewFunc(Name,_ANY,_ANY, FS, _New, idName,idArg)
    else
    if NF = _NOT_FOUND then       //установка новой ф-ии с таким же именем: (с другим набором аргументов)
       SetNewFunc(Name,NFunc,_ANY, FS, _NewOverload, idName,idArg)
    else                        // установка новой ф-ии с таким же именем:    (с таким-же набором аргументов)
       SetNewFunc(Name,_ANY,_ANY, FS, _New, idName,idArg)

   end;





endp:
G_idName:=idName;
G_idArg:=idArg;

end;



 {
   установка ТОЛЬКО внутренних функций, имеющих предустановленный номер команды в массиве  Alg.ExtFunc
