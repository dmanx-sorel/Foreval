    if  ArgForm1 = _IntConst then
    begin
      PlacementArg:=20;  //Arg2->EAX         // idiv(93,y)     idiv(2,y/5)
      funcInt2Cmpl(ComCode,_IntConst,IC1,0,True,PlacementArg) ;
      //AND_EAX_EBX(_IntConst,IC1,0,True) ; // and(1010,y)   //y=12345
    end
    else
    if  ArgForm1 = _IntVar then
    begin
       AddrA1:=Alg.Obj[GNode^.NV1].Addr;      //and(n,y)   //y=12345 n=1010
       PlacementArg:=20;  //Arg2->EAX         // idiv(j,y/3)
       funcInt2Cmpl(ComCode,_IntVar,0,AddrA1,True,PlacementArg);
       //AND_EAX_EBX(_IntVar,0,AddrA1,True);
    end
    else
    if  ArgForm1 = _IntForm then
    begin
       MOVREG(R_EAX,R_ESI);
       LoadLineFormEAX(_First);                // and(2*j+4*k+12327,y)  //y=1010
       MOVREG(R_ESI,R_EBX);
       funcInt2Cmpl(ComCode,0,0,0,True,PlacementArg);   // idiv(2*j+3*k+4*n+11,y)
       //AND_EAX_EBX(0,0,0,True);
    end;

        
end
else
//********* funcINT2(IntArray1[IntForm1],IntArray2[IntForm2])

 // and (IntArray1[IntForm1],IntArray2[IntForm2])
if GNode^.AI = 5 then               {.379}
begin

    AddrA1:=Alg.Obj[GNode^.NObj].Addr;
    AddrA2:=Alg.Obj[GNode^.NObj2].Addr;
    ArgForm1:=GNode^.TA1;
    ArgForm2:=GNode^.TA2;


    LoadArrayElemLineForm(_Integer,_Second,R_ESI, AddrA2);  //IntArray2[IntForm2] -> R_ESI
    LoadArrayElemLineForm(_Integer,_First, R_EAX, AddrA1);  //IntArray1[IntForm1] -> R_EAX
    MOVREG(R_ESI,R_EBX);                                    //IntArray2[IntForm2] -> R_EBX

    funcInt2Cmpl(ComCode,0,0,0,True,PlacementArg);         // idiv(vi2[9*j+7*k+4*m+51],vi1[2*j+3*k+5*n-7])
    //AND_EAX_EBX(0,0,0,True);             // vi1[2*j+3*k+5*n+7] = 12345; vi2[9*j+7*k+4*m+11] = 1010;  and(vi1[2*j+3*k+5*n+7],vi2[9*j+7*k+4*m+11])

   
end
else
//********* funcINT2(IntForm1,IntArray2[IntForm2])

// and(IntForm1,IntArray2[IntForm2])
if GNode^.AI = 6 then       {.379}
begin
     

       AddrA2:=Alg.Obj[GNode^.NObj].Addr;
       ArgForm1:=GNode^.TA1;
       ArgForm2:=GNode^.TA2;
       IC1:=GNode^.IC1;

       if  ArgForm1 = _IntConst then
       begin
          LoadArrayElemLineForm(_Integer,_Second, R_EAX, AddrA2);  //IntArray2[IntForm2] -> R_EAX
          PlacementArg:=20;  //Arg2->EAX                      // idiv(93, vi1[2*j+3*k+5*n-7])
          funcInt2Cmpl(ComCode,_IntConst,IC1,0,True,PlacementArg) ;
          //AND_EAX_EBX(_IntConst,IC1,0,True) ;
          // vi2[9*j+7*k+4*m+11] = 1010;  and(12345,vi2[9*j+7*k+4*m+11])
       end
       else
       if  ArgForm1 = _IntVar then
       begin
          LoadArrayElemLineForm(_Integer,_Second, R_EAX, AddrA2);  //IntArray2[IntForm2] -> R_EAX
          AddrI1:=Alg.Obj[GNode^.NV1].Addr;
          PlacementArg:=20;  //Arg2->EAX                   // idiv(j, vi1[2*m+3*k-5*n+6])
          funcInt2Cmpl(ComCode,_IntVar,0,AddrI1,True,PlacementArg);
          //AND_EAX_EBX(_IntVar,0,AddrI1,True);
          // vi2[9*j+7*k+4*m+11] = 1010; n=12345; and(n,vi2[9*j+7*k+4*m+11])
       end
       else
       if  ArgForm1 = _IntForm then
       begin
          LoadArrayElemLineForm(_Integer,_Second, R_ESI, AddrA2);  //IntArray2[IntForm2] -> R_ESI
          LoadLineFormEAX(_First);
          MOVREG(R_ESI,R_EBX);
          funcInt2Cmpl(ComCode,0,0,0,True,PlacementArg);         // idiv(3*j+6*k+9*n+21,vi2[9*j+7*k+8*m-31])
          //AND_EAX_EBX(0,0,0,True);
          // vi2[9*j+7*k+4*m+11] = 1010;  and(2*j+4*k+12327,vi2[9*j+7*k+4*m+11])
       end;


end
else
//********* funcINT2(IntArray1[IntForm1],IntForm2)

if GNode^.AI = 7 then       {.379}
begin

       AddrA1:=Alg.Obj[GNode^.NObj].Addr;
       ArgForm1:=GNode^.TA1;
       ArgForm2:=GNode^.TA2;
       IC2:=GNode^.IC2;

       if  ArgForm2 = _IntConst then
       begin
          LoadArrayElemLineForm(_Integer,_First, R_EAX, AddrA1);  //IntArray1[IntForm1] -> R_EAX
          funcInt2Cmpl(ComCode,_IntConst,IC2,0,True,PlacementArg) ;     //  idiv(vi2[9*j+7*k+4*m+51],3)     //  idiv(vi2[9*j+7*k+4*m+51],2)
          //AND_EAX_EBX(_IntConst,IC2,0,True) ;
          // vi2[9*j+7*k+4*m+11] = 1010;  and(vi2[9*j+7*k+4*m+11],12345)
       end
       else
       if  ArgForm2 = _IntVar then
       begin
          LoadArrayElemLineForm(_Integer,_First, R_EAX, AddrA1);  //IntArray1[IntForm1] -> R_EAX
          AddrI2:=Alg.Obj[GNode^.NV2].Addr;
          funcInt2Cmpl(ComCode,_IntVar,0,AddrI2,True,PlacementArg);          //  idiv(vi2[9*j+7*k+4*m+51],k)
          //AND_EAX_EBX(_IntVar,0,AddrI2,True);
          // vi2[9*j+7*k+4*m+11] = 1010; n=12345; and(vi2[9*j+7*k+4*m+11],n)
       end
       else
       if  ArgForm2 = _IntForm then
       begin
          LoadArrayElemLineForm(_Integer,_First, R_ESI, AddrA1);  //IntArray1[IntForm1] -> R_ESI
          LoadLineFormEAX(_Second);
          MOVREG(R_ESI,R_EBX);
          PlacementArg:=21;    //Arg1->EAX; Arg2->EBX               // idiv(vi2[9*j+7*k+4*m+51],3*j-6*k-1)
          funcInt2Cmpl(ComCode,0,0,0,True,PlacementArg);
          //AND_EAX_EBX(0,0,0,True);
          // vi2[9*j+7*k+4*m+11] = 1010;  and(vi2[9*j+7*k+4*m+11],2*j+4*k+12327)
       end;

end;





end;





