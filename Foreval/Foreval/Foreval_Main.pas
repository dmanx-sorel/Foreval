             SetLength(LV1,0); ND1.N:=0; ND1.COP:=_Func;  ND1.NFunc:=nf;  ND1.NF:=ni;  BEF:=True;  EOFN:=True;
              //ND.SFunc:=SFunc; {.301}
             //goto intf;    ???
           end
