{.340}
function TForevalH.FindOperationPS(PS: PString; pos: Integer; NArg: Integer): integer;
label 1,nxtop;
var                                               //поиск операции в PS^ , расположенной начиная  с pos; Narg = 1,2 число аргументов в операции
i,NCOP,NCOP1,IDF,LenS,MaxLenOp,Lc: Integer;
begin
NCOP:=-1;
NCOP1:=-1;
LenS:=Length(PS^);
MaxLenOp:=LenS-pos;

for i:=0 to High(Alg.Opr) do
begin

   if (MaxLenOp >= Alg.Opr[i].LenOp) and (Alg.Opr[i].Enable = True) and (Alg.Opr[i].NArg = NArg) then
   begin                                          {.339}
       // if (S = Alg.Opr[i].Name) and (Alg.Opr[i].Enable = True) then
       Lc:=Alg.Opr[i].LenOp;
       if  CompareStingPartPS(PS,pos,@Alg.Opr[i].Name, Lc) = True  {(Copy(PS^,pos, Alg.Opr[i].LenOp) =  Alg.Opr[i].Name)} then
       begin

         {
          //искать самую длинную операцию из подобных x*y x**y x***y ...
          if NCOP1 = -1 then  NCOP1:=i
             else
             if Alg.Opr[i].LenOp > Alg.Opr[NCOP1].LenOp then NCOP1:=i;
          }

          {.379}
          //  Если на первой позиции найдена одноарг. операция с задним расположением символа (_After), то не выбирать
          //  Если на последней позиции найдена одноарг. операция с передним расположением символа (_Before), то не выбирать
          if NCOP1 = -1 then   //первая найденная
          begin
             if  (Alg.Opr[i].Pos = _After) and  (pos = 1)  then goto nxtop
             else
             if (Alg.Opr[i].Pos = _Before) and (Alg.Opr[i].LenOp + pos - 1 = LenS)  then goto nxtop
             else
             NCOP1:=i;
          end
          else
          begin
             if (Alg.Opr[i].Pos = _After) and (pos = 1) then goto nxtop
             else
             if (Alg.Opr[i].Pos = _Before) and (Alg.Opr[i].LenOp + pos - 1 = LenS)  then goto nxtop
             else
               if Alg.Opr[i].LenOp > Alg.Opr[NCOP1].LenOp then NCOP1:=i;  //искать самую длинную операцию из подобных x*y x**y x***y ...
          end;


       end;
   end;

 nxtop:
end;

1:                                                                            {.339}
//if  ((F_SyntaxExtension = False) and (Alg.Opr[NCOP].SE <> 0)) or (Alg.Opr[NCOP].Enable = False) then NCOP:=-1;

if NCOP1 <> -1 then                    {.195}
begin
 NCOP:=NCOP1;
 IDF:=Alg.Opr[NCOP].NFunc;
 if Alg.ExFunc[IDF].Enable =_NO then NCOP:=-1;
end;

FindOperationPS:=NCOP;
end;





