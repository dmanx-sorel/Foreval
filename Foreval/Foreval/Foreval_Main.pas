{.377}
procedure TForevalH.LogAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var BEF, EOFN: Boolean);
label endp;
var
C,Im: TFloat;
VC1,VC2,TC1,TC2: Integer;
S,NA,TV: Integer;
Sgn:Integer;
i: Integer;
nv1,nv2,tv1,tv2,tm,Len,mt2: Integer;
FD1,FD2,FD1i: extended;
Str,Str1,Str2,Sindx: String;
adr: Cardinal;
BH,BAnsw,SB: Boolean;
code2,IC1: Integer;
AIVP1: TArrayIntVarProd;
FRes,FArg1,FArg2: TComplex;
NDA: TDataNode;
ni, TypeV, TypeIndx :Integer;
Addr: Cardinal;
CX1,CX2: TComplex;
begin
if F_SyntaxErrorCode <> 0 then goto endp;

TryFPUMask; {.229}

Len:=Length(LV);
if Len <> 2 then
begin
  {.333}
 {F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
 F_SyntaxErrorString:=F_CurrentString; }
 goto endp;
end;

LV1:=LV;
ND1:=ND;
EOFN:=False;
BEF:=False;
BH:=False;


if F_ReduceArgOptimizatorF = True then
begin

   Str2:=LV[1].Expression;
   Str1:=LV[0].Expression;

   DeleteExternalBracketPS(@Str1); {.219}
   DeleteExternalBracketPS(@Str2); {.219}

   ND1.ExpressionArg:=Str1+','+Str2; {.216}

  {
    SubstParamCXPS(PS: PString;  var CX: TComplex; var SB: Integer);
    //SB=C_None,C_Real(real),C_Image(image),C_Complex(complex)
  }
   SubstParamCXPS(@Str1, CX1, TC1);
   SubstParamCXPS(@Str2, CX2, TC2);
   // TC=C_None(NoConst), C_Real(RealConst), C_Image(ImageConst), C_Complex(ComplexConst)

   //  Log(const(Real),Real);    Log(const(Real),Complex)
   //  Log(const(Complex),Real); Log(const(Complex),Complex)                                                            {.395}
   if   (TC2 = C_None) and  ( (TC1 = C_Real) or  ( (TC1 = C_Complex) or (TC1 = C_Image))  )  then    // log(a,x) log(ai,x)   log(a,z1) log(ai,z1)
   begin
   //if F_ReduceArgOptimizator = True then
      begin
           ND1.NFunc:=CM_CRZLOG;
           ND1.COP:=_FUNC;

           SetLength(LV1,1);
           EOFN:=False;
           ND1.N:=1;
           LV1[0].Expression:=Copy(Str2,1,Length(Str2));

           if  (TC1 = C_Real) then                         // log(a,x)    log(a,z1)
           begin
              ND1.AI:=1; //Const(Real)
              ND1.FD:=CX1.re;
           end
           else
           if  (TC1 = C_Complex) or (TC1 = C_Image) then     // log(ai,x)  log(ai,z1)
           begin
              ND1.AI:=2; //Const(Complex)
              ND1.FD:=CX1.re;
              ND1.FDC.re:=CX1.re;
              ND1.FDC.im:=CX1.im;
           end;

          if M_ParseMode  = M_Compile then inc(Db_NumberReductions);

       end;

    end
   {.395}
    else
      // Log(Real ,const(Real));     Log(Complex,const(Real)) ;
      // Log(Real ,const(Complex));  Log(Complex,const(Complex));                                                           {.395}
    if (TC1 = C_None) and ((TC2 = C_Real) or ( (TC2 = C_Complex) or (TC2 = C_Image))   ) then    // log(x,a)  log(z1,a)  log(x,ai)  log(z1,ai)
    begin
      //if F_ReduceArgOptimizator = True then
      begin

            ND1.NFunc:=CM_CR2ZLOG;
            ND1.COP:=_FUNC;
            SetLength(LV1,1);
            EOFN:=False;
            ND1.N:=1;
            LV1[0].Expression:=Copy(Str1,1,Length(Str1));

            if  (TC2 = C_Real) then                         // log(x,a)    log(z1,a)
            begin
               ND1.AI:=1; //Const(Real)
               ND1.FD:=CX2.re;
            end
            else
            if  (TC2 = C_Complex) or (TC2 = C_Image) then     // log(x,ai)  log(z1,ai)
            begin
               ND1.AI:=2; //Const(Complex)
               ND1.FD:=CX2.re;
               ND1.FDC.re:=CX2.re;
               ND1.FDC.im:=CX2.im;
            end;

         if M_ParseMode  = M_Compile then inc(Db_NumberReductions);

      end;
    end;


end;



endp:
TryCatchFPUException;    {.229}
end;






function TForevalH._POWER(x,y: extended): extended;
var res: extended;
begin

try

 TryFPUMask;
 asm
   fld  tbyte  ptr [y]
   fld  tbyte  ptr [x]
   call FPWR
   fstp res
 end;


  TryCatchFPUException;
except
 on E: EZeroDivide      do F_InternalError:=E_ZeroDivide;
 on E: EInvalidOp       do F_InternalError:=E_InvalidOp;
 on E: EOverFlow        do F_InternalError:=E_OverFlow;
 on E: EUnderFlow       do F_InternalError:=E_UnderFlow;
 on E: EIntOverFlow     do F_InternalError:=E_IntOverFlow;
 on E: EAccessViolation do F_InternalError:=E_AccessViolation;
 on E: EOutOfMemory     do F_InternalError:=E_OutOfMemory;
 on E: EStackOverFlow   do F_InternalError:=E_StackOverFlow;
end;

   if F_InternalError <> 0 then
      F_SyntaxErrorCode:=E_INTERNAL_ERROR_AT_CALCULATION;



 _POWER:=res;
end;





function TForevalH._ROOT(x,y: extended): extended;
var s,d: double;
res :Extended;
begin


try

 TryFPUMask;
 asm
   fld  tbyte  ptr [y]
   fld  tbyte  ptr [x]
   call R_FROOT
   fstp res
 end;


  TryCatchFPUException;
except
 on E: EZeroDivide      do F_InternalError:=E_ZeroDivide;
 on E: EInvalidOp       do F_InternalError:=E_InvalidOp;
 on E: EOverFlow        do F_InternalError:=E_OverFlow;
 on E: EUnderFlow       do F_InternalError:=E_UnderFlow;
 on E: EIntOverFlow     do F_InternalError:=E_IntOverFlow;
 on E: EAccessViolation do F_InternalError:=E_AccessViolation;
 on E: EOutOfMemory     do F_InternalError:=E_OutOfMemory;
 on E: EStackOverFlow   do F_InternalError:=E_StackOverFlow;
end;

   if F_InternalError <> 0 then
      F_SyntaxErrorCode:=E_INTERNAL_ERROR_AT_CALCULATION;



 _ROOT:=res;

 (*
s:=1;


 if (x = 0) and (y <= 0) then d:=sqrt(-1); {.215}  //call error

if (x < 0) and  (Trunc(y) = y) and (Trunc(y/2) <> y/2) then
  begin
    s:=-1;
    _ROOT:=s*power(abs(x),1/y);

  end
else
_ROOT:=s*power(x,1/y);   {.195}
  *)


end;




procedure TForevalH.RootAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var BEF,EOFN: Boolean);
label endp;
var
C,Im: TFloat;
VC1,VC2: Integer;
S,NA,TV,TC: Integer;
i: Integer;
nv1,nv2,tv1,tv2,tm,P,RP,Len,code2: Integer;
FD1,FD2,FD1i: extended;
Str,Str1,Str2,Str3: String;
adr: Cardinal;
BH,BAnsw,SB: Boolean;
Arg1,Arg2,ResCX: TComplex;
begin
if F_SyntaxErrorCode <> 0 then goto endp;


TryFPUMask; {.229}

Len:=Length(LV);
if (Len <> 2) and (Len <> 3) then
begin
   {.333}
 {F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
 F_SyntaxErrorString:=F_CurrentString;}
 goto endp;
end;

LV1:=LV;
ND1:=ND;
EOFN:=False;
BEF:=False;
BH:=False;

{.195}
//if Len = 3 then goto endp;

//ND1.COP:=_FUNC;
 //F_IdN не изменилась = ND1.F_IdN!!! (StringAnalizator)


if Len = 2 then
begin
   //VC = _Const(FD); = _Var(nf); = _None(Stack);
   Str2:=LV[1].Expression;
   Str1:=LV[0].Expression;
   //FindExternalBracket(Str1,Str1);
   DeleteExternalBracketPS(@Str1); {.219}
   //FindExternalBracket(Str2,Str2);
   DeleteExternalBracketPS(@Str2); {.219}


        // ROOT(Arg,IntArray[]) !!!!!!!!


   //FindVarConstPS(@Str1,nv1,FD1,VC1);
   FindVarConstCxPS(@Str1, nv1, FD1, FD1i, VC1, TC);
   ND1.ExpressionArg:=Str1+','+Str2;


   WriteFindExtArgInt1PS(@Str2, _Second, ND1, IntegerVarForm, ND1, BAnsw);
   code2:=ND1.TA2;

   VC2:=_None; TV:=_NOT_FOUND; {.346}
   RP:=0;
   if code2 = _IntConst then begin FD2:=ND1.IC2; RP:=ND1.IC2; VC2:=_Const; end
   else
   if code2 = _NOT_FOUND then SubstParamPS(@Str2,FD2,Im,TV);  //Str2 = FloatConst ?
   if TV = T_Real then VC2:=_Const;
   //if SB = True then VC2:=_Const;




{
NumberAnalizatorA(Str2,nv2,FD2,VC2);
NumberAnalizatorA(Str1,nv1,FD1,VC1);
}



   if (VC1 = _ConstReal) and (VC2 = _ConstReal) then       //Root(RealConst,RealConst)
   begin

        {.395A}
        if FD2 = 2.0 then
        begin
          ND1.FD:=sqrt(FD1);
        end
        else
        if FD2 = 4.0 then
        begin
          ND1.FD:=sqrt(sqrt(FD1));
        end
        else
        if FD2 = 8.0 then
        begin
          ND1.FD:=sqrt(sqrt(sqrt(FD1)));
        end
        else
        if FD2 = 16.0 then
        begin
          ND1.FD:=sqrt(sqrt(sqrt(sqrt(FD1))));
        end
        else
        begin
           ND1.FD:=_ROOT(FD1,round(FD2));//power(FD1,1/FD2);
        end;


        ND1.COP:=_LDSC;
        ND1.NFunc:=0;
        BH:=True;
        EOFN:=True;
        LV1:=nil;
        ND1.N:=0;
   end
   else
   // IROOT_C используется также в PowerAnalizator
   if (VC1 = _ConstComplex) and (VC2 = _ConstReal) then       //Root(constComplex,constReal)
   begin
        Arg1.re:=FD1;    Arg1.im:=FD1i;
        Arg2.re:=FD2;    Arg2.im:=0;

        {.395A}
        if FD2 = 2.0 then
        begin
              _EvalFunc1Cx(@Z_SQRT,Arg1,ResCX);
        end
        else
        if FD2 = 4.0 then
        begin
              _EvalFunc1Cx(@Z_SQRT,Arg1,ResCX);
              _EvalFunc1Cx(@Z_SQRT,ResCX,ResCX);
        end
        else
        if FD2 = 8.0 then
        begin
              _EvalFunc1Cx(@Z_SQRT,Arg1,ResCX);
              _EvalFunc1Cx(@Z_SQRT,ResCX,ResCX);
              _EvalFunc1Cx(@Z_SQRT,ResCX,ResCX);
        end
        else
        if FD2 = 16.0 then
        begin
              _EvalFunc1Cx(@Z_SQRT,Arg1,ResCX);
              _EvalFunc1Cx(@Z_SQRT,ResCX,ResCX);
              _EvalFunc1Cx(@Z_SQRT,ResCX,ResCX);
              _EvalFunc1Cx(@Z_SQRT,ResCX,ResCX);
        end
        else
        begin
           _EvalFunc1CxInt(@Z_CxIROOT,Arg1,round(Arg2.re),ResCX);
        end;


        ND1.COP:=_LDSCX;
        ND1.TC:=T_Complex;
        ND1.FDC.re:=ResCX.re;
        ND1.FDC.im:=ResCX.im;
        ND1.FD:=ResCX.re;

        ND1.NFunc:=0;
        EOFN:=True;
        ND1.N:=0;
        SetLength(LV1,0);
        BH:=True;

   end
   else
   if  (VC1 <> _Const) and (code2 <> _NOT_FOUND) then    //IRoot(Expr,IntForm)
   begin


         if  (VC1 = _ConstComplex) then   //IRoot(ConstCompolex,IntForm)
         begin
             //  root(+-i,IntForm)
             if ((FD1 = 0) and (FD1i = 1)) or ((FD1 = 0) and (FD1i = -1)) then
             begin
                   ND1.NFunc:=CM_ImUIROOT;
                   ND1.AI:=1;         // ^IntForm
                   ND1.NF:=0;
                   ND1.N:=0;
                   ND1.TypeF:=T_Complex;
                   ND1.COP:=_FUNC;
                   EOFN:=True;
                   SetLength(LV1,0);

                   ND1.BI:=_POSITIVE; //+i
                   if FD1i = -1 then  ND1.BI:=_NEGATIVE; //-i

                   goto endp;
             end
             else //  root(-1+0i,IntForm)
             if (FD1 = -1) and (FD1i = 0) then  // root(-1+0i,k)
             begin

                ND1.NFunc:=CM_RUNIROOT;
                ND1.AI:=1;         // ^IntForm
                ND1.NF:=0;
                ND1.N:=0;
                ND1.TypeF:=T_Complex;
                ND1.COP:=_FUNC;
                EOFN:=True;
                SetLength(LV1,0);

             end
             else      // root(2+3i,k)
             begin

               if F_ReduceArgOptimizatorF = True then
               begin
                  ND1.NFunc:=CM_CRZIROOT;
                  ND1.NF:=GetIdArgFunc1A(ND1.NFunc,1,T_Complex);
                  //ND1.NF:=1;
                  ND1.AI:=2;        // Complex const
                  ND1.FD:=FD1;
                  ND1.FDC.re:=FD1;
                  ND1.FDC.im:=FD1i;
                  EOFN:=True;
                  ND1.N:=0;
                  ND1.TypeF:=T_Complex;
                  ND1.COP:=_FUNC;
                  SetLength(LV1,0);

                  if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
               end;

             end;
         end
         else   //   IRoot(Real/Complex Expr, IntForm)
         begin

            //  root(+-i,IntForm)
            if (VC1 = _ComplexVar) and (TC = C_Image) then
            begin
              if ((FD1 = 0) and (FD1i = 1)) or ((FD1 = 0) and (FD1i = -1)) then
              begin
                   ND1.NFunc:=CM_ImUIROOT;
                   ND1.AI:=1;         // ^IntForm
                   ND1.NF:=0;
                   ND1.N:=0;
                   ND1.TypeF:=T_Complex;
                   ND1.COP:=_FUNC;
                   EOFN:=True;
                   SetLength(LV1,0);

                   ND1.BI:=_POSITIVE; //+i
                   if FD1i = -1 then  ND1.BI:=_NEGATIVE; //-i

                 goto endp;
              end;
            end;


            ND1.NFunc:=CM_IROOT;
            ND1.AI:=2;
            EOFN:=False;
            ND1.N:=1;
            ND1.COP:=_FUNC;
            SetLength(LV1,1);
            LV1[0].Expression:=Copy(Str1,1,Length(Str1));
            LV1[0].NL:=1;


            {.395A} // перенесено  в стадию компиляции -  IROOT_C;
            {
            if RP = 2 then
            begin
                ND1.NFunc:=CM_SQRT;
                EOFN:=False;
                ND1.N:=1;
                ND1.COP:=_FUNC;
                SetLength(LV1,1);
                LV1[0].Expression:=Copy(Str1,1,Length(Str1));
                LV1[0].NL:=1;
            end
            else
            if RP = 4 then             // = sqrt(sqrt(Expr))
            begin
                ND1.NFunc:=CM_SQRT;
                EOFN:=False;
                ND1.N:=1;
                ND1.COP:=_FUNC;
                SetLength(LV1,1);
                LV1[0].NL:=1;
                Str1:='sqrt('+Str1+')';
                LV1[0].Expression:=Copy(Str1,1,Length(Str1));
            end
            else
            if RP = 8 then             // = sqrt(sqrt(sqrt(Expr)))
            begin
                ND1.NFunc:=CM_SQRT;
                EOFN:=False;
                ND1.N:=1;
                ND1.COP:=_FUNC;
                SetLength(LV1,1);
                LV1[0].NL:=1;
                Str1:='sqrt(sqrt('+Str1+'))';
                LV1[0].Expression:=Copy(Str1,1,Length(Str1));
            end;
            }
         end;


   end
   else
   if  (VC1 = _ConstReal) and (code2 <> _NOT_FOUND) then      // IRoot(constReal,IntForm)
   begin

      if F_ReduceArgOptimizatorF = True then
      begin
         ND1.NFunc:=CM_CRZIROOT;                 // root(3,k)
         ND1.NF:=GetIdArgFunc1A(ND1.NFunc,1,T_Real);
         //ND1.NF:=0;
         ND1.AI:=1;
         ND1.FD:=FD1;       // Real const
         EOFN:=True;
         ND1.N:=0;
         ND1.TypeF:=T_Real;
         ND1.COP:=_FUNC;
         //ND1.NFunc:=CM_IROOT;
         SetLength(LV1,0);

         if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
      end;
   end;


end //of len = 2

else

if Len = 3 then        //root(z1,j+2,n+k)
begin
   Str1:=LV[0].Expression;
   Str2:=LV[1].Expression;
   Str3:=LV[2].Expression;

   DeleteExternalBracketPS(@Str1);
   DeleteExternalBracketPS(@Str2);
   DeleteExternalBracketPS(@Str3);

   FindVarConstCxPS(@Str1, nv1, FD1, FD1i, VC1, TC);

   WriteFindExtArgInt2PS(@Str2,@Str3,ND1, IntegerVarForm, ND1,BAnsw);
   if BAnsw = True then
   begin
         if (VC1 = _ConstComplex) or                        // root(2+3i,k,n)  root(i,k,n)  root(-i,k,n)
            ((VC1 = _ComplexVar) and (TC = C_Image) and (FD1i = 1))
         then
         begin

             if F_ReduceArgOptimizatorF = True then
             begin
               ND1.NFunc:=CM_CZIROOT3;
               ND1.NF:=0; // только одна ф-ия - T_Complex
               //ND1.NF:=GetIdArgFunc1A(ND1.NFunc,1,T_Complex);
               ND1.AI:=1;
               ND1.FD:=FD1;
               ND1.FDC.re:=FD1;
               ND1.FDC.im:=FD1i;
               EOFN:=True;
               ND1.N:=0;
               ND1.TypeF:=T_Complex;
               ND1.COP:=_FUNC;
               SetLength(LV1,0);

               if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
             end;

         end
         else
         begin
           {
            ND1.AI:=3;
            ND1.NFunc:=CM_IROOT;
            EOFN:=False;
            ND1.N:=1;
            ND1.COP:=_FUNC;
            SetLength(LV1,1);
            LV1[0].Expression:=Copy(Str1,1,Length(Str1));
            LV1[0].NL:=1;
           }
            {.395}
            ND1.AI:=1;
            ND1.NFunc:=CM_IROOT3;
            EOFN:=False;
            ND1.N:=1;
            ND1.COP:=_FUNC;
            SetLength(LV1,1);
            LV1[0].Expression:=Copy(Str1,1,Length(Str1));
            LV1[0].NL:=1;
         end;
   end;

end;





endp:
TryCatchFPUException;    {.229}
end;






procedure TForevalH.IFAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode);

    function _CheckIFFArg(PS: PString; DisSet: TSetChar): Boolean;
    label endp;
    var
    j,br1,br2: integer;
    BE: boolean;
    begin

       BE:=True;
       br1:=0; br2:=0;
       for j := 1 to Length(PS^) do
       begin
        if PS^[j] in OpenBracket  then inc(br1)
        else
        if PS^[j] in CloseBracket then inc(br2)
        else
        if (br1 = br2)   then
        begin
           if  PS^[j] in DisSet {(PS^[j] = ';') or  (PS^[j] = '=')}   then
           begin
              BE:=False;
              F_SyntaxErrorCode:=E_NO_FUNCTION_ARGUMENT;
              F_SyntaxErrorString:='"'+PS^+'"'+ #13#10+'   in:  '+#13#10+'"'+F_CurrentString+'"    ';
              goto endp;
           end;
        end
       end;

    endp:
    _CheckIFFArg:=BE;
    end;



label 1,endp,endpp;
var
C: TFloat;
br,cif,tif: Integer;
i,P,L: Integer;
nf: Integer;
FD1,FD2: extended;
Str,Str1,Str2,Expr: String;
Sv1,Sa1,Sv2,Sa2: String;
adr: Cardinal;
code1,code2,nv1,nv2,ic1,ic2: Integer;
AIVP1,AIVP2: TArrayIntVarProd;
BAnsw: Boolean;
DisSet: TSetChar;
MType1,ni1,MType2,ni2,Hi: Integer;
begin                                                                //tif: 7  4  3   2     5       6
//IF(Arg1 op Arg2, Arg3, Arg4)  => if Arg1 op Arg2 then Arg3 else Arg4  op: =, <, >, <>, <=, =<, >=, =>
//IF При разборе переходит в  IFNOP(Arg1,Arg2,CJMP,Arg3,JMP,ARG4)

//IF(Arg1 op Arg2)  = 1 или 0(если if не выполняется)  op: =, <, >, <=, =<, >=, =>
//IF При разборе переходит в  IFNOP(Arg1,Arg2,CJMP,FLD1,JMP,FLDZ)

//IF(Arg1 op Arg2, Arg3)  = Arg3(если if  выполняется) или 0(если if не выполняется)  op: =, <, >, <=, =<, >=, =>
//IF При разборе переходит в  IFNOP(Arg1,Arg2,CJMP,ARG3,JMP,FLDZ)


if F_SyntaxErrorCode <> 0 then goto endpp;

LV1:=LV;
ND1:=ND;
L:=Length(LV);

 {.346}
if L = 1 then
begin
 DisSet := [';'];
  if _CheckIFFArg(@LV[0].Expression,DisSet) = false then goto endp;
end
else
if L = 2 then
begin
   DisSet := [';','='];
   if _CheckIFFArg(@LV[1].Expression,DisSet) = false then goto endp;
end
else
if L = 3 then
begin
   DisSet := [';','='];
   if _CheckIFFArg(@LV[1].Expression,DisSet) = false then goto endp;
   if _CheckIFFArg(@LV[2].Expression,DisSet) = false then goto endp;
end;

  {
if(x>=y,x=x-1)
if(x>=y,cos(x);sin(x))
if(x>=y,cos(x),x=x-1)
Во 2м 3м арг не должно быть ; =
if Len then

  }



if ((L <> 3) and (L <> 1) and (L <> 2)) then
begin
  F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
  F_SyntaxErrorString:=F_CurrentString;
  goto endpp;
end;

//nf= 1       2      3       4      5      6     7
//  #JMP, #JMPE, #JMPEL, #JMPEB, #JMPB, #JMPL, #JMPNE

br:=0;  nf:=0; cif:=0;   ND1.BI:=_FloatArg;  ND1.CI:=0; ND1.DI:=0;
Str:=LV[0].Expression;
//FindExternalBracket(Str,Str);
DeleteExternalBracketPS(@Str); {.219}

for i := 1 to Length(Str) do
begin
(*
 if (Str[i] = '(') or (Str[i] = '[') or (Str[i] = '{') then  br:=br+1 else
 if (Str[i] = ')') or (Str[i] = ']') or (Str[i] = '}') then  br:=br-1;
*)
 if Str[i] in OpenBracket then  inc(br)
 else
 if Str[i] in CloseBracket then dec(br);

 if br = 0 then
 begin
   //>= , =>
   if ((Str[i] = '>') and (Str[i+1] = '=')) or ((Str[i] = '=') and (Str[i+1] = '>')) then
   begin
     nf:=6;  Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+2,Length(Str)-i);
     goto 1;
   end
   else
   //<=, =<
   if ((Str[i] = '<') and (Str[i+1] = '=')) or ((Str[i] = '=') and (Str[i+1] = '<')) then
   begin
     nf:=5; P:=i;  Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+2,Length(Str)-i);
     goto 1;
   end
   else
   //<>
   if ((Str[i] = '<') and (Str[i+1] = '>')) then
   begin
     nf:=2; P:=i;  Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+2,Length(Str)-i);
     goto 1;
   end
   else
   //><
   if ((Str[i] = '>') and (Str[i+1] = '<')) then
   begin
     nf:=2; P:=i;  Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+2,Length(Str)-i);
     goto 1;
   end
   else
   // =
   if (Str[i] = '=') then
   begin
     nf:=7;  P:=i;    Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+1,Length(Str)-i);
     goto 1;
   end
   else
   // >
   if (Str[i] = '>') then
   begin
     nf:=3; P:=i;    Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+1,Length(Str)-i);
     goto 1;
   end
   else
   // <
   if (Str[i] = '<') then
   begin
     nf:=4; P:=i;   Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+1,Length(Str)-i);
     goto 1;
   end
 end;
end;


1:
if (nf = 0) and (L = 3) then
begin
  nf:=3; Str1:=Str; Str2:='0';
end
else
if (nf = 0) and (L = 1) then
begin
  nf:=3; Str1:=Str; Str2:='0';
end
else
if (nf = 0) and (L = 2) then            //if(arg1,arg2) ->  if(arg1 > 0,arg2)
begin
  nf:=3; Str1:=Str; Str2:='0';
end
else
if nf = 0 then
begin
  F_SyntaxErrorCode:=5;
  goto endp;
end;


{
   2: LV1[2].Expression:='#JMPE';
   3: LV1[2].Expression:='#JMPEL';
   4: LV1[2].Expression:='#JMPEB';
   5: LV1[2].Expression:='#JMPB';
   6: LV1[2].Expression:='#JMPL';
   7: LV1[2].Expression:='#JMPNE';
}

{F_IntegerOptimization}
  //---------------------------------------------------------
 //if F_EnableExternalPointerMath = True then F_EnablePointerMath:=True;  {.367}
 //F_EnablePointerMath:=True;  {.367}
   WriteFindExtArgInt2PS(@Str1,@Str2,ND1, PointerVarForm, ND1,BAnsw);
  //F_EnablePointerMath:=False;

  // сравнение IntArray1[] vs  IntArray2[]
   {
   if BAnsw = False then
   begin

      // if(vi1[k]>vi2[n],1,0)
      //if(vi2[j]>vi1[k],1,0)

      FindExtractArray(@Str1, Sv1,Sa1, MType1, ni1);
      FindExtractArray(@Str2, Sv2,Sa2, MType2, ni2);


      if (MType1 = _Integer) and (MType2 = _Integer) then
      begin
        WriteFindExtArgInt2PS(@Sa1, @Sa2, ND1, IntegerVarForm, ND1, BAnsw);
        if BAnsw = True then
        begin
         ND1.BI:= _IntArray;
         ND1.NObj2:=ni2;
         ND1.NObj:=ni1;
        end;

      end;

   end;
   }


{
FindExtArgInt(@Str1, code1, AIVP1, NV1, IC1);
FindExtArgInt(@Str2, code2, AIVP2, NV2, IC2);
if (code1 <> _NOT_FOUND) and (code2 <> _NOT_FOUND) then
begin
          if code1 = _IntConst then
          begin
            ND1.IC1:=IC1;
          end
          else
          if code1 = _IntVar then
          begin
            ND1.NV1:=NV1;
          end
          else
          if code1 = _IntForm then
          begin
            ND1.AIVP1:=Copy(AIVP1,0,Length(AIVP1));
            ND1.IC1:=IC1;
          end ;

           if code2 = _IntConst then
          begin
            ND1.IC2:=IC2;
          end
          else
          if code2 = _IntVar then
          begin
            ND1.NV2:=NV2;
          end
          else
          if code2 = _IntForm then
          begin
            ND1.AIVP2:=Copy(AIVP2,0,Length(AIVP2));
            ND1.IC2:=IC2;
          end ;

          ND1.TA1:=code1;
          ND1.TA2:=code2;
          ND1.BI:=_IntArg;
end;
}


    //---------------------------------------------------------

if L = 2 then         //IF(Arg1 op Arg2, Arg3) -> IFNOP(Arg1,Arg2,CJMP,ARG3,JMP,FLDZ)
begin
 //P:=Pos('goto(',lowercase(LV[1].Expression));
 P:=Pos('goto(',LV[1].Expression);
  if P > 0 then                  //IF(Arg1 op Arg2,goto(lab))
 begin
  SetLength(LV1,4);
     //IFNOP(Arg1,Arg2,CJMP,JMP)

  LV1[0].Expression:=Copy(Str1,1,Length(Str1));
  LV1[1].Expression:=Copy(Str2,1,Length(Str2));
  case nf of
   2: LV1[2].Expression:='#jmpe';
   3: LV1[2].Expression:='#jmpel';
   4: LV1[2].Expression:='#jmpeb';
   5: LV1[2].Expression:='#jmpb';
   6: LV1[2].Expression:='#jmpl';
   7: LV1[2].Expression:='#jmpne';
 end;
 LV1[3].Expression:=Copy(LV[1].Expression,1,Length(LV[1].Expression));
 //LV1[3].Expression:='#JMP';
 //LV1[5].Expression:='#FLDZ';


   ND1.N:=4;
   ND1.DI:=ND1.N;
   ND1.CI:=_FloatArg;
   ND1.COP:=_FUNC;
   ND1.NFunc:=CM_IF;

   {.395if}
   {
   LV1[0].AlwaysEval:=_YES;
   LV1[1].AlwaysEval:=_YES;
   LV1[2].AlwaysEval:=_NO;
   LV1[3].AlwaysEval:=_NO;
   }



   cif:=3;  {.301}
   goto endp;
 end;

end;



SetLength(LV1,6);


if L = 3 then    //IF(Arg1 op Arg2, Arg3, Arg4) -> IFNOP(Arg1,Arg2,CJMP,Arg3,JMP,ARG4)
begin
 LV1[0].Expression:=Copy(Str1,1,Length(Str1));
 LV1[1].Expression:=Copy(Str2,1,Length(Str2));
 case nf of
   2: LV1[2].Expression:='#jmpe';
   3: LV1[2].Expression:='#jmpel';
   4: LV1[2].Expression:='#jmpeb';
   5: LV1[2].Expression:='#jmpb';
   6: LV1[2].Expression:='#jmpl';
   7: LV1[2].Expression:='#jmpne';
 end;
 LV1[3].Expression:=Copy(LV[1].Expression,1,Length(LV[1].Expression));
 LV1[4].Expression:='#jmp';
 LV1[5].Expression:=Copy(LV[2].Expression,1,Length(LV[2].Expression));

 cif:=2;  {.301}

  {.395if}
  {
   LV1[0].AlwaysEval:=_YES;
   LV1[1].AlwaysEval:=_YES;
   LV1[2].AlwaysEval:=_NO;
   LV1[3].AlwaysEval:=_NO;
   LV1[4].AlwaysEval:=_NO;
   LV1[5].AlwaysEval:=_NO;
  }

end
else
if L = 1 then     // IF(Arg1 op Arg2) -> IFNOP(Arg1,Arg2,CJMP,FLD1,JMP,FLDZ)
begin
 LV1[0].Expression:=Copy(Str1,1,Length(Str1));
 LV1[1].Expression:=Copy(Str2,1,Length(Str2));
 case nf of
   2: LV1[2].Expression:='#jmpe';
   3: LV1[2].Expression:='#jmpel';
   4: LV1[2].Expression:='#jmpeb';
   5: LV1[2].Expression:='#jmpb';
   6: LV1[2].Expression:='#jmpl';
   7: LV1[2].Expression:='#jmpne';
 end;
 LV1[3].Expression:='#fld1';
 LV1[4].Expression:='#jmp';
 LV1[5].Expression:='#fldz';

  {.395if}
  {
   LV1[0].AlwaysEval:=_YES;
   LV1[1].AlwaysEval:=_YES;
   LV1[2].AlwaysEval:=_NO;
   LV1[3].AlwaysEval:=_NO;
   LV1[4].AlwaysEval:=_NO;
   LV1[5].AlwaysEval:=_NO;
  }

 cif:=0;    {.301}
end
else
if L = 2 then      //IFNOP(Arg1,Arg2,CJMP,ARG3,JMP,FLDZ)
begin
  LV1[0].Expression:=Copy(Str1,1,Length(Str1));
  LV1[1].Expression:=Copy(Str2,1,Length(Str2));
  case nf of
   2: LV1[2].Expression:='#jmpe';
   3: LV1[2].Expression:='#jmpel';
   4: LV1[2].Expression:='#jmpeb';
   5: LV1[2].Expression:='#jmpb';
   6: LV1[2].Expression:='#jmpl';
   7: LV1[2].Expression:='#jmpne';
 end;
 LV1[3].Expression:=Copy(LV[1].Expression,1,Length(LV[1].Expression));
 LV1[4].Expression:='#jmp';
 LV1[5].Expression:='#fldz';

 {.395if}
 {
   LV1[0].AlwaysEval:=_YES;
   LV1[1].AlwaysEval:=_YES;
   LV1[2].AlwaysEval:=_NO;
   LV1[3].AlwaysEval:=_NO;
   LV1[4].AlwaysEval:=_NO;
   LV1[5].AlwaysEval:=_NO;
  }
 cif:=1;  {.301}
end;


ND1.N:=6;
ND1.DI:=ND1.N;
ND1.CI:=_FloatArg;
ND1.COP:=_FUNC;
ND1.NFunc:=CM_IF;

endp:
//ND1.SFunc:='if'; {.301}
ND1.cif:=cif;
ND1.tif:=nf;

 {.395if}
Hi:=High(LV1);
LV1[Hi].EndIf:=_YES;
if Hi >=1 then
begin
    LV1[0].AlwaysEval:=_YES;
    LV1[1].AlwaysEval:=_YES;

    for i := 2 to Hi do
    begin
       LV1[i].AlwaysEval:=_NO;
    end;

end;

if (ND1.BI = _IntArg) or (ND1.BI = _IntArray)  then      //BAnsw = True
begin
     LV1[0].Expression:=SCvoid;
     LV1[1].Expression:=SCvoid;
end;

endpp:
end;





procedure TForevalH.SWAPIFAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);

label 1,endp;
var
C: TFloat;
br,cif,tif: Integer;
i,P,L: Integer;
nf: Integer;
FD1,FD2: extended;
Str,Str1,Str2,Expr: String;
adr: Cardinal;
code1,code2,nv1,nv2,ic1,ic2: Integer;
AIVP1,AIVP2: TArrayIntVarProd;
BAnsw: Boolean;
DisSet: TSetChar;
begin                                                                //tif: 7  4  3   2     5       6
//IF(Arg1 op Arg2, Arg3, Arg4)  => if Arg1 op Arg2 then Arg3 else Arg4  op: =, <, >, <>, <=, =<, >=, =>
//IF При разборе переходит в  IFNOP(Arg1,Arg2,CJMP,Arg3,JMP,ARG4)

//IF(Arg1 op Arg2)  = 1 или 0(если if не выполняется)  op: =, <, >, <=, =<, >=, =>
//IF При разборе переходит в  IFNOP(Arg1,Arg2,CJMP,FLD1,JMP,FLDZ)

//IF(Arg1 op Arg2, Arg3)  = Arg3(если if  выполняется) или 0(если if не выполняется)  op: =, <, >, <=, =<, >=, =>
//IF При разборе переходит в  IFNOP(Arg1,Arg2,CJMP,ARG3,JMP,FLDZ)


if F_SyntaxErrorCode <> 0 then goto endp;

LV1:=LV;
ND1:=ND;
L:=Length(LV);




if (L <> 1)  then
begin
  F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
  F_SyntaxErrorString:=F_CurrentString;
  goto endp;
end;


br:=0;  nf:=0;    ND1.BI:=_FloatArg;  ND1.CI:=0; ND1.DI:=0;
Str:=LV[0].Expression;  Str1:=''; Str2:='';
//FindExternalBracket(Str,Str);
DeleteExternalBracketPS(@Str); {.219}

//SWAPIF(Arg1 > Arg2);
//SWAPIF(Arg1 <> Arg2) ;

for i := 1 to Length(Str) do
begin
 (*
 if (Str[i] = '(') or (Str[i] = '[') or (Str[i] = '{') then  br:=br+1 else
 if (Str[i] = ')') or (Str[i] = ']') or (Str[i] = '}') then  br:=br-1;
 *)
 if Str[i] in OpenBracket then  inc(br)
 else
 if Str[i] in CloseBracket then dec(br);

 if br = 0 then
 begin
   //>= , =>
   if ((Str[i] = '>') and (Str[i+1] = '=')) or ((Str[i] = '=') and (Str[i+1] = '>')) then
   begin
     Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+2,Length(Str)-i);
     //nf:=6;
     nf:=3;
     goto 1;
   end
   else
   //<=, =<
   if ((Str[i] = '<') and (Str[i+1] = '=')) or ((Str[i] = '=') and (Str[i+1] = '<')) then
   begin
     Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+2,Length(Str)-i);
     //Str2:=Copy(Str,1,i-1); Str1:=Copy(Str,i+2,Length(Str)-i);
     //nf:=5;
     nf:=4;
     P:=i;
     goto 1;
   end
   else
   //<>
   if ((Str[i] = '<') and (Str[i+1] = '>')) then
   begin
     nf:=2; P:=i;  Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+2,Length(Str)-i);
     goto 1;
   end
   else
   //><
   if ((Str[i] = '>') and (Str[i+1] = '<')) then
   begin
     nf:=2; P:=i;  Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+2,Length(Str)-i);
     goto 1;
   end
   else
   // =
   if (Str[i] = '=') then
   begin
     nf:=7;  P:=i;    Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+1,Length(Str)-i);
     goto 1;
   end
   else
   // >
   if (Str[i] = '>') then
   begin
     nf:=3;
     P:=i;
     Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+1,Length(Str)-i);
     goto 1;
   end
   else
   // <
   if (Str[i] = '<') then
   begin
     nf:=4;
     //nf:=3;
     P:=i;
     Str1:=Copy(Str,1,i-1); Str2:=Copy(Str,i+1,Length(Str)-i);
     //Str2:=Copy(Str,1,i-1); Str1:=Copy(Str,i+1,Length(Str)-i);
     goto 1;
   end
 end;
end;


if nf = 0 then
begin
  F_SyntaxErrorCode:=5;
  goto endp;
end;



  1:

 SetLength(LV1,2);
 LV1[0].Expression:=Copy(Str1,1,Length(Str1));
 LV1[1].Expression:=Copy(Str2,1,Length(Str2));
 ND1.N:=2;

 SWAPAnalizator(LV1,ND1,LV1,ND1,EOFN);

 if ND1.AI = 3 then      //swapif(ComplexVar1 <=> ComplexVar2)
 begin
   F_SyntaxErrorCode:=E_WRONG_TYPE;
   goto endp;
 end;

 ND1.NFunc:=CM_SWAPIF;
 ND1.COP:=_FUNC;
 ND1.tif:=nf;

endp:
end;







procedure TForevalH.SAVEAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);
label 1,3,endp,endc, L_IntArrEQExpr1, L_VarEQExpr;
var
C: TFloat;
TF,TF2: Integer;
i,P,L,tv1,tm1,LenV,TV,MType2,ni2,nf2,tv2,tm2,TypeF, MType, ReIm,ImU,TypeAddr,VecMathType: Integer;
nf,ni,nv,ni1,ni3,ts3,ts2,SB,NFunc,TypeV, TypeIndx,code,IC,SrcDef,NFA,CM_NF: Integer;
FD1,FD2,FD3,Re,Im: extended;
Str,Str1,Str2,Str3,S1,S2,S3,Sv2,Sa2,Sf,Sa,Sv,Sindx,Err_Str,Stmp1: String;
adr,adr1,AddrObj,AddrIM,addr2,AddrI2: Cardinal;
BAnsw,BSavePtr,BFH,FH,BH,Bhi,BLe,Bidiv,Bmod,BRNDin: Boolean;
NDA: TDataNode;
AIVP:  TArrayIntVarProd;
begin



{int=@Func; int=@var; VecInt[]=@Func; VecInt[]=@var}  //  ***** {.347}


  EOFN:=False;
  ND1.AI:=0;

if F_SyntaxErrorCode <> 0 then goto endp;

LenV:=Length(LV);

LV1:=LV;
ND1:=ND;

if (LenV <> 2) and (LenV <> 3) then
begin
      F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
      F_SyntaxErrorString:=F_CurrentString;
      goto endp;
end;

SetLength(LV1,1);
Str1:=LV[0].Expression;
Str2:=LV[1].Expression;
LV1[0].Expression:=Copy(Str2,1,Length(Str2));

FindReIm(Str1,S1,TF);
//FindVar(S1,nf);
FindVarPS(@S1,nf);        {.333}
if nf <> -1 then  GetVar1(nf,adr1,tv1,tm1);




//Save(Var,Expr)
if (nf <> -1) and (tv1 <> IM_UNIT) and (LenV = 2) and (tv1 <> T_Array) then
begin

 BAnsw:=False;
 //if (tv1 = T_Real) and (tm1 = _Integer) then WriteFindExtArgInt1PS(@Str2, _First, ND1,ND1,BAnsw);    //save(IntVar,IntForm)

 (*
 if tv1 = T_Pointer then  F_EnablePointerMath := True;    //{.367}
  //save(IntVar,IntForm)                    //{.367}    save(PointerVar,IntForm of Pointers)
 if ((tv1 = T_Real) and (tm1 = _Integer)) or ((F_EnablePointerMath = True) and (tv1 = T_Pointer)) then WriteFindExtArgInt1PS(@Str2, _First, ND1,ND1,BAnsw);
 F_EnablePointerMath := False;
 *)

 if ((tv1 = T_Real) and (tm1 = _Integer)) then  WriteFindExtArgInt1PS(@Str2, _First, ND1, IntegerVarForm, ND1,BAnsw)
  else
 if (tv1 = T_Pointer) then WriteFindExtArgInt1PS(@Str2, _First, ND1, PointerVarForm, ND1,BAnsw);





 if BAnsw = True then
 begin
   ND1.AI:=3;
   SetLength(LV1,0);
   ND1.NObj:=nf;
   ND1.N:=0;
   EOFN:=True;
   goto endc;

   //ND2.IC1
 end
 else
 begin


   // <...> = addr() ; ptr = @<...>;  ptr = addr(<...>)  ;

    {
       Save(Addr):
           Save(PointerVar,@<Var,Array,Func>)  PointerVar = @<Var,Array,Func>
           Save(IntVar,@<Var,Array,Func>)      IntVar = @<Var,Array,Func>
    }

    BSavePtr:=False;
    if   (Str2[1] = '@') and (Alg.Opr[COP_ADDR].Enable = True) then    // = @<...>
    begin
         S2:=Str2;
         Delete(S2,1,1);
         BSavePtr:=True;
    end
    else   // = Addr<...>
    begin
        FindFuncBrPS(@Str2,'(',')',Sf,Sa,BFH);
        if BFH = True then
        begin
           if (Alg.ExFunc[CM_ADDR].Name = Sf) and (Alg.ExFunc[CM_ADDR].Enable = _Yes) then
           begin
              S2:=Sa;
              BSavePtr:=True;
           end;
        end;
    end;


    if BSavePtr = True then
    begin

        if (tv1 = T_Pointer) or ((tv1 = T_Real) and (tm1 = _Integer) and (F_EnableUseIntegerPointer = True))  then        {.353}
        begin
           TypeAddr:=0; TypeIndx:=0;
           //Find Data Addr
           FindVarExPS(@S2, nf2, AddrObj, AddrIM, TypeF, MType, ReIm,ImU);
           if nf2 <> -1 then
           begin
              if ReIm = _IM then AddrObj:=AddrIM;
              case TypeF of
                 T_Real:       TypeAddr:=tc_AddrVar;
                 T_Complex:    TypeAddr:=tc_AddrVar;
                 T_Array:      TypeAddr:=tc_AddrArray;
                 T_Pointer:    TypeAddr:=tc_AddrVar;
              end;
           end
           else   //@Function
           begin
              FindFuncPS(@S2,NFunc);
              if NFunc <> _NOT_FOUND then
              begin
                   //AddrObj:=Alg.ExFunc[NFunc].Func[0].Addr;    //func[0] - берётся только первая ф-ия в списке
                   FindFuncB(S2,0,_ANY,NFunc,NFA);   {.378} //искать вначале func/proc без аргументов
                   if NFA = _NOT_FOUND then NFA:=0;
                   AddrObj:=Alg.ExFunc[NFunc].Func[NFA].Addr;

                   TypeAddr:=tc_AddrFunc;
              end
              else  //ptr=@array[indx]
              if FindArray(@S2, NDA, ni, TypeV, TypeIndx, AddrObj, Sindx) = True then
              begin
                   TypeAddr:=tc_AddrArrayElem;
                   //ND1.CI:=TypeAddr;
                   //ND1.Addr1:=AddrObj;
                   ND1.NObj2:=ni;

                   {
                   EOFN:=True;
                   ND1.N:=0;
                   SetLength(LV1,0);
                   }
                   ND1.DI:=NDA.AI; //тип аргумента массива в DI !!
                   ND1.AIVP1:=Copy(NDA.AIVP1,0,Length(NDA.AIVP1));
                   ND1.FD:=NDA.FD; //константа аргумента массива @vec[IntConst]
                   ND1.NV2:=NDA.NV1; //переменная аргумента массива @vec[Intconst]

                   if TypeIndx = _Stack then
                   begin
                    {
                    EOFN:=False;
                    ND1.N:=1;
                    SetLength(LV1,1);
                    LV1[0].Expression:=Sindx;  // в стек - только индекс
                    ND1.DI:=0;
                    }
                     {.367}
                     //все нераспознаваемые @vec[indx] целиком !!! в стек
                     TypeAddr:=tc_AnyPointerExpression;
                     EOFN:=False;
                     ND1.N:=1;
                     SetLength(LV1,1);
                     LV1[0].Expression:='@'+S2;
                     ND1.DI:=0;
                   end;
              end
              else
              begin
                 F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT;
                 F_SyntaxErrorString:=Str1+'='+Str2;//Copy(F_CurrentString,1,Length(F_CurrentString));
                 F_SyntaxErrorStringA:=Copy(Str2,1,Length(Str2));
                 goto endp;
              end;
           end;


          ND1.AI:=10;         //Save  Addr
          ND1.NObj:=nf;       //PointerVar, IntVar
          ND1.Addr1:=AddrObj; //Addr
          ND1.BI:=_IntVar;     //Save  Addr -> PointerVar, IntVar
          ND1.CI:=TypeAddr;
          if  (TypeIndx <> _Stack) then   //@var,@vec,@func,@vec[IntForm]
          begin
             ND1.N:=0;
             SetLength(LV1,0);
             EOFN:=True;
          end;

          goto endc;

      end
      else
      begin
          F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT;
          F_SyntaxErrorString:=Str1+'='+Str2;//Copy(F_CurrentString,1,Length(F_CurrentString));
          F_SyntaxErrorStringA:=Copy(Str2,1,Length(Str2));
          goto endp;
      end;

    end     //BSavePtr = True
    else
    begin           //все остальные присвоения
                    //IntVar,RealVar,ComplexVar =  <IntExpr,RealExpr,ComplexExpr>  в любом сочетании
                    //PointerVar = <PointerVar,IntVar>
                    //IntVar = <PointerVar,IntVar>

          //IntVar = PointerVar
         if (tv1 = T_Real) and (tm1 = _Integer) and (F_EnableUseIntegerPointer = True) then
         begin
            FindVarAPS(@Str2,nf2,Addr2,tv2,tm2);
            if tv2 = T_Pointer then           //j=ptr1
            begin
               ND1.TA1:=_IntVar;
               ND1.AI:=3;
               ND1.NObj:=nf;
               ND1.NV1:=nf2;
               SetLength(LV1,0);
               ND1.N:=0;
               EOFN:=True;
               goto endc;
            end;
         end
         else
         // PointerVar =  <PointerVar, IntVar>
         if (tv1 = T_Pointer) then
         begin
             FindVarAPS(@Str2,nf2,Addr2,tv2,tm2);
             //PointerVar = PointerVar
             if tv2 = T_Pointer then
             begin
                ND1.TA1:=_IntVar;
                ND1.AI:=3;
                ND1.NObj:=nf;
                ND1.NV1:=nf2;
                SetLength(LV1,0);
                ND1.N:=0;
                EOFN:=True;
                goto endc;
             end
             else
              // PointerVar =   IntVar
             if (tv2 = T_Real) and (tm2 = _Integer) and (F_EnableUseIntegerPointer = True) then
             begin
                ND1.TA1:=_IntVar;
                ND1.AI:=3;
                ND1.NObj:=nf;
                ND1.NV1:=nf2;
                SetLength(LV1,0);
                ND1.N:=0;
                EOFN:=True;
                goto endc;
             end;
         end;



            //поиск IntVar = IntArray[IntForm]
            if (tv1 = T_Real) and (tm1 = _Integer) then
               if FindArray(@Str2, NDA, nf2, TypeV, TypeIndx, Addr2, Sindx) = True then
                 if (TypeV = _Integer) and ((TypeIndx = _IntVar) or (TypeIndx =_IntConst) or (TypeIndx = _IntForm) ) then
                 begin
                   ND1.NV1:=nf;   //NV1=intarray[indx]

                   ND1.NObj2:=nf2;
                   ND1.DI:=NDA.AI; //тип аргумента массива в DI !!
                   ND1.AIVP1:=Copy(NDA.AIVP1,0,Length(NDA.AIVP1));
                   ND1.FD:=NDA.FD; //константа аргумента массива @vec[IntConst]
                   ND1.NV2:=NDA.NV1; //переменная аргумента массива @vec[Intconst]


                   ND1.AI:=60;    //IntVar = IntArray[IntForm]

                   ND1.N:=0;
                   SetLength(LV1,0);
                   EOFN:=True;
                   goto endc;
                 end;


             //поиск выражений IntVar=Length(Array); IntVar=High(Array):
            if (tv1 = T_Real) and (tm1 = _Integer) then
            begin

              //FindFuncBrInExprPS(@Str2, NFunc, Sa, BH);
              FindFuncBrPS(@Str2,'(',')',Sf,Sa,BH);
              if BH = True then
              begin
                {BLe:=False;  BHi:=False;
                BHi:=FindTheFuncPS(@Sf, CM_HIGH);
                if BHi = False then
                BLe:=FindTheFuncPS(@Sf, CM_LENGTH);
                }
                FindFuncPS(@Sf, CM_NF);
                if (CM_NF = CM_HIGH) or (CM_NF = CM_LENGTH) then
                //if (BHi = True) or (BLe = True) then
                begin
                    {
                    if BHi =  True then NFunc:= CM_HIGH else
                    if BLe =  True then NFunc:= CM_LENGTH;
                     }

                    FindVarAPS(@Sa,nf2,Addr2,tv2,tm2);
                    if tv2 = T_Array then
                    begin
                      SetLength(LV1,0);
                      ND1.NObj:=nf;
                      ND1.NObj2:=nf2;
                      ND1.N:=0;
                      ND1.AI:=40;
                      ND1.EI:=CM_NF;
                      {
                      if NFunc = CM_HIGH then    ND1.AI:=50 else
                      if NFunc = CM_LENGTH then  ND1.AI:=51;
                      }
                      EOFN:=True;
                      goto endc;
                    end
                    else
                    begin
                       F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT;
                       F_SyntaxErrorString:=Str1+'='+Str2;
                       F_SyntaxErrorStringA:=Copy(Str2,1,Length(Str2));
                       goto endp;
                    end
                end;
                  //(AAA)


            // ************************************************** //
             // IntVar1 = idiv, mod, or, and, xor, nor, xnor, nand (IntForm2/IntArray2[IntForm2], IntVar3/IntConst);
            // ************************************************** //


                if (CM_NF = CM_IDIV) or (CM_NF = CM_MOD) or
                   (CM_NF = CM_OR)   or (CM_NF = CM_AND) or
                   (CM_NF = CM_XOR)  or (CM_NF = CM_NOR) or
                   (CM_NF = CM_XNOR) or (CM_NF = CM_NAND)
                then
                begin
                  FindManyArgPS(@Sa,ArgM);

                  if Length(ArgM) = 2 then
                  begin


                     FindVarConstPS(@ArgM[1], ni3,  FD3,  ts3);
                     if (ts3 =  _IntVar) or  ((ts3 =  _Const) and (FD3 = Trunc(FD3))) then    //IntVar1 = FuncInt2(Expr, IntVar3/IntConst)
                     begin

                          WriteFindExtArgInt1PS(@ArgM[0], _second,   ND1, IntegerVarForm,  ND1,  BAnsw);
                          if BAnsw = True then    //IntVar1 = FuncInt2(IntForm2,IntVar3/IntConst)
                          begin

                             if ts3 = _IntVar then
                             begin
                               ND1.NV3:=ni3;
                               ND1.CI:=1;             // IntVar1 = FuncInt2 (IntForm2, IntVar3)
                             end
                             else    // IntConst
                             begin
                               ND1.FD:=FD3;
                               ND1.CI:=2;             // IntVar1 = FuncInt2 (IntForm2, IntConst)
                             end;

                             ND1.AI:=50;
                             ND1.NV1:=nf;
                             ND1.EI:=CM_NF;


                             ND1.N:=0;
                             SetLength(LV1,0);
                             EOFN:=True;
                             goto endc;

                          end     //if BAnsw = True
                          else
                          begin
                               //IntVar1 = FuncInt2 (IntArray2[IntForm2],IntVar3/IntConst)
                              if FindExtractArray(@ArgM[0], Sv2, Sa2, MType2, ni2) = True then
                              begin

                                   if  (MType2 = _Integer) then
                                   begin

                                       WriteFindExtArgInt1PS(@Sa2, _second,   ND1, IntegerVarForm,  ND1,  BAnsw);
                                       if BAnsw = True then    //IntVar1 = FuncInt2 (IntArray2[IntForm2],IntVar3/IntConst)
                                       begin
                                                          // n = idiv(vi2[15*j+k+10],2); n
                                                          // n = idiv(vi2[15*j+k+10],k); n
                                                          // n = idiv(vi2[87],2); n
                                            if ts3 = _IntVar then
                                            begin
                                               ND1.NV3:=ni3;
                                               ND1.CI:=3;             // IntVar1 = FuncInt2 (IntArray2[IntForm2], IntVar3)
                                            end
                                            else    // IntConst
                                            begin
                                               ND1.FD:=FD3;
                                               ND1.CI:=4;              // IntVar1 = FuncInt2 (IntArray2[IntForm2], IntConst)
                                            end;

                                            ND1.AI:=50;
                                            ND1.NV1:=nf;
                                            ND1.NObj:=ni2;
                                            ND1.EI:=CM_NF;

                                            ND1.N:=0;
                                            SetLength(LV1,0);
                                            EOFN:=True;
                                            goto endc;

                                      end   //if BAnsw = True
                                      else       goto L_VarEQExpr;


                                   end //  if  (MType2 = _Integer)
                                   else       goto L_VarEQExpr;

                              end  //if  FindExtractArray(@ArgM[0], Sv2, Sa2, MType2, ni2)
                              else       goto L_VarEQExpr;
                          end;



                     end   // if (ts3 =  _IntVar) or  ((ts3 =  _Const) and (FD3 = Trunc(FD3))) then
                     else
                     goto L_VarEQExpr;

                  end // of  if Length(ArgM) = 2 then
                  else
                  goto L_VarEQExpr;

                end  //of  <  if (CM_NF = CM_IDIV) or (CM_NF = CM_MOD) then >
                else


                //IntVar1 = nop(IntForm2);
                if (CM_NF = CM_NOT) then
                begin
