   begin      //  tan(z1)+sec(z1)+sin(z1)

      FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);     // -> IM(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);
