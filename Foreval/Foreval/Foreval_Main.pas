// Присвоить полю AlwaysEval = _NO всех  вытекающих аргументов из  условно вычисляемого агрумента IF  c AlwaysEval=_NO
{ IF (Arg1 cmp Arg2, Arg3, Arg4)
      Arg1.AlwaysEval, Arg2.AlwaysEval = _YES   - вычисляются всегда
      Arg3.AlwaysEval, Arg3.AlwaysEval = _NO    - условно вычисляемые аргументы
