procedure TForevalH.SIN_C;
var
t1,N,NF,S: Integer;
Addr: TAddress;
L1,L2,L_ZSIN,L_ZSIN_END: Integer;
AddrRe1,AddrIm1,AddrRe2,AddrIm2: TAddress;
begin
 {N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 S:=Interp[NFunc].S; }
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 t1:=Alg.ExFunc[N].Func[NF].TV[0];

 LoadArg1;
  if t1 = T_Real then
  begin
    if GNode^.WRF_CS = rf_COSSINR_REPLACE    then
    begin
      FSINCOS;
      Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]); // -> cos
      FSTPM(Addr,F_DataType);
      Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);   // -> sin
      FSTM(Addr,F_DataType);
    end
    else
    FSIN;
  end
  else
  if t1 = T_Complex then
  begin

  if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE) then
   begin
        MOVAadr(Cardinal(@Z_SIN));
        CALLA;
        CheckStack(2);
        CheckStack(-2);
   end
   else
   begin
   if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_EXPZ2_REPLACE)    then
   begin                                     //sin(z1)+tan(z1)
      // L1:=Length(ICOMP);

       {.377}
        AddrRe1:=TAddress(@Func.RFStack[GNode^.MWF_CS-3]);               //  RE(exp)    ->
        AddrIm1:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);               //  IM(exp)    ->
        AddrRe2:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);               //  RE(exp^-1) ->
        AddrIm2:=TAddress(@Func.RFStack[GNode^.MWF_CS]);                 //  IM(exp^-1) ->

        //ZZ_EXPIZ_EXPNIZ;
        ZMUL_i;
        ZZ_EXPZ_EXPNZ;

        ZZ_SAVE(AddrRe1,AddrIm1,AddrRe2,AddrIm2,F_DataType);

        FSUBP2;
        FSUBRP2;
        FMUL_C05;
        FXCH1;
        FMUL_C05;


      {.335}
      (*
      if F_DataType = _Extended then
        begin
          L_ZSIN:=49;       //size of code
          L_ZSIN_END:=97;   //size of code
        end
        else
         if F_DataType = _Double then
        begin
          L_ZSIN:=41;       //size of code
          L_ZSIN_END:=89;   //size of code
        end;

      //If Z.Im = 0 then: ... else goto @@zsin
      FLDZ;
      FCOMIP2;
      JMPCI(L_ZSIN,_JNZ); //jnz @@zsin
         L1:=Length(IComp);
      //L_ZSIN - size of:
      FSINCOS;   //cos(re), sin(re) ,im(=0)
        Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-3]);               //  RE(exp) ->
      FSTM(Addr,F_DataType);
        Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-1]);               //  RE(exp^-1) ->
      FSTM(Addr,F_DataType);
      FXCH1; //sin(re), cos(re), 0
        Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-2]);               //  IM(exp) ->
      FSTM(Addr,F_DataType);
      FCHS;
        Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS]);                 //  IM(exp^-1) ->
      FSTM(Addr,F_DataType);
      FCHS;
      FXCH1;
      FSTP0;  //sin,0
      JMP(L_ZSIN_END);//jmp @@end
          L2:=Length(IComp);
          L2:=L2-L1;


          L1:=Length(IComp);
        //full complex z
        //L_ZSIN_END - size of:
       { @@zsin: }
       ZMUL_i;
       FEXP;
       FLD0;
       FDIVR_C1;
       FXCH2;
       FSINCOS;
       FLD0;
       FMUL03;   //st(0):RE(exp)
          Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-3]);               //  RE(exp) ->
       FSTM(Addr,F_DataType);
       FXCH1;
       FMUL04;    //st(0):RE(exp^-1)
          Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-1]);               //  RE(exp^-1) ->
       FSTM(Addr,F_DataType);
       FXCH3;
       FMUL02;    //st(0):IM(exp)
          Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-2]);               //  IM(exp) ->
       FSTM(Addr,F_DataType);
       FXCH2;
       FMULP4;       //  RE(exp),IM(exp),RE(exp^-1),IM(exp^-1)
       FSUBRP2;
       FXCH2;       //st(0):IM(exp^-1)
       FCHS;
          Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS]);                 //  IM(exp^-1) ->
       FSTM(Addr,F_DataType);
       FSUBP2;
       FMUL_C05;
       FXCH1;
       FMUL_C05;
       FXCH1;
       ZDIV_i;
      { @@end:  }
          L2:=Length(IComp);
          L2:=L2-L1;

     *)
   end
   else
   if (GNode^.RRF = rf_EXPZ2_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE)   then
   begin
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-2]),F_DataType);    // -> IM(exp)
        FSUB(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);      // IM(exp)-IM(exp^-1)
        FMUL_C05; // st(0):IM
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-3]),F_DataType);    // -> RE(exp)
        FSUB(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);      // RE(exp)-RE(exp^-1)
        FMUL_C05; // st(0):RE;  st(1):IM
        ZDIV_i;
   end
   else
   if (GNode^.RRF = rf_EXPZ1_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE)   then        //tan(z1)+sin(z1)
   begin
       FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);   // -> IM(exp)
       FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);     // -> RE(exp)
       ZPUSH;
       ZDIVR_C1;        // ->  RE(exp^-1),IM(exp^-1),RE(exp),IM(exp)
       FSUBP2;
       FXCH2;
       FSUBRP2;
       FMUL_C05;
       FXCH1;
       FMUL_C05;
       FXCH1;
       ZDIV_i;

   end
   else
   if (GNode^.RRF = rf_EXPZ1_REPLACE) and (GNode^.WRF_CS = rf_EXPZ2_REPLACE)    then
   begin                                                                        //tan(z1)+sin(z1)+cos(z1)
      FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);     // -> IM(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);
         FSTM(Addr,F_DataType);                                          //  IM(exp) ->
      FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);   // -> RE(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-3]);
         FSTM(Addr,F_DataType);                                          //  RE(exp) ->
      ZPUSH;
      ZDIVR_C1;        // ->  RE(exp^-1),IM(exp^-1),RE(exp),IM(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);
         FSTM(Addr,F_DataType);                                          //  RE(exp^-1) ->
      FSUBP2;
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);
         FSTM(Addr,F_DataType);                                          //  IM(exp^-1) ->
      FXCH2;
      FSUBRP2;
      FMUL_C05;
      FXCH1;
      FMUL_C05;
      FXCH1;
      ZDIV_i;

   end;


 end;
  end;
end;



procedure TForevalH.COS_C;
var
t1,N,NF,S,L_ZCOS_END,L_ZCOS: Integer;
Addr: TAddress;
L1,L2: Integer;
AddrRe1,AddrIm1,AddrRe2,AddrIm2: TAddress;
begin
 {N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 S:=Interp[NFunc].S;}
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 t1:=Alg.ExFunc[N].Func[NF].TV[0];


 LoadArg1;
 if t1 = T_Real then
 begin
  if GNode^.WRF_CS = rf_COSSINR_REPLACE    then
    begin
      FSINCOS;
      Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]); // -> cos
      FSTM(Addr,F_DataType);
      FXCH1;
      Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);   // -> sin
      FSTPM(Addr,F_DataType);
    end
    else
    FCOS;
 end
 else
 if t1 = T_Complex then
 begin
 if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE) then
   begin
        MOVAadr(Cardinal(@Z_COS));
        CALLA;
        CheckStack(2);
        CheckStack(-2);
   end
   else
   begin
   if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_EXPZ2_REPLACE)    then
   begin                   //  cos(z1)+tan(z1)

        AddrRe1:=TAddress(@Func.RFStack[GNode^.MWF_CS-3]);               //  RE(exp)    ->
        AddrIm1:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);               //  IM(exp)    ->
        AddrRe2:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);               //  RE(exp^-1) ->
        AddrIm2:=TAddress(@Func.RFStack[GNode^.MWF_CS]);                 //  IM(exp^-1) ->

        //ZZ_EXPIZ_EXPNIZ;
        ZMUL_i;            // cos(z)=cosh(i*z)
        ZZ_EXPZ_EXPNZ;
        ZZ_SAVE(AddrRe1,AddrIm1,AddrRe2,AddrIm2,F_DataType);

        FADDP2;
        FADDP2;
        FMUL_C05;
        FXCH1;
        FMUL_C05;
        FXCH1;



      {.335}
      (*
