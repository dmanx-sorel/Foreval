procedure   TForevalH.ReplaceFracBr(S: String; var S1: String);    {.323}
label 1,endp;
var
 i,L,p,t,tb,nbr1,nbr2: Integer;
 CF: Boolean;
 Sin: String;
begin
L:=Length(S); p:=1; t:=0;  CF:=True;   nbr1:=0; nbr2:=0;
Sin:=S;
//{{x-1}+{x+1}}-{x-{x+{x-1}-{x+1}}+y}
(*
while p < L do
begin
  for i:=p to L do
  begin
   if S[i] = '{' then
   begin
     p:=i; t:=1; goto 1;
   end
   else
   if S[i] = '}' then
   begin
     p:=i; t:=2; goto 1;
   end;
  end;
  goto endp;
1:

  if t = 1 then
  begin
   Delete(S,p,1); Insert('frac(',S,p); p:=p+4
  end
  else
  if t = 2 then
  begin
    Delete(S,p,1); Insert(')',S,p);
  end;

  L:=Length(S);
end;
*)

p:=pos('{',S);
if p = 0  then p:=pos('}',S);


while p <> 0 do
begin

  p:=pos('{',S);
  if p <> 0 then
  begin
   Delete(S,p,1); Insert('frac(',S,p);  inc(nbr1);
  end
  else
  begin
   p:=pos('}',S);
   if p <> 0 then
   begin
    Delete(S,p,1); Insert(')',S,p); inc(nbr2);
   end;
  end;

end;

endp:
if (nbr1  <>  nbr2) then
begin
   F_SyntaxErrorCode:=E_MISSING_CURLY_BRACKET;
   //F_SyntaxErrorString:=Copy(S,1,Length(S));
   F_SyntaxErrorString:=Copy(Sin,1,Length(Sin));   {.395}
end;
S1:=Copy(S,1,Length(S));
end;

//  not&|not&|k|&or&not&|j|&or&|n||&or&123$h

   // !|!|k|+|k|!|!      ;
   // error : не допустим одинаковый символ операции спереди и сзади (fact , not). Не обрабатывает :(
   // в логических операциях c символом "!" - not, скобки || для abs  не применять  !!!
procedure   TForevalH.ReplaceAbsBr(S: String; var S1: String);
label 1,endp;

             function GetTypeAbsBr(p: Integer; S: String): Integer;
             begin
              if p = 1 then GetTypeAbsBr:=1
              else
              if p = Length(S) then GetTypeAbsBr:=2
              else
              (*
              if (S[p-1] = '+') or (S[p-1] = '-') or (S[p-1] = '*') or
                 (S[p-1] = '/') or (S[p-1] = '^') or (S[p-1] = '(') or
                 (S[p-1] = '[') or (S[p-1] = '{') or (S[p-1] = '=') or      {.353}
                 (S[p-1] = '<') or (S[p-1] = '>') or (S[p-1] = ',') or  (S[p-1] = '$') // or (S[p-1] = '!')
              *)
              if S[p-1] in BeforeBracketEnableSymb = True
                 then GetTypeAbsBr:=1  //открывающая скобка abs - |
                 else
                 GetTypeAbsBr:=2;      //закрывающая скобка abs - |
             end;
           // |func1(|x|,|x|+||y||,|func2(|x|,|x|+y)|,||x|+|y||)|

var
 i,L,p,t,nbr: Integer;
 Sin: String;
begin
L:=Length(S); p:=1; nbr:=0; Sin:=S;
//||x-1|+|x+1||-|x-|x+|x-1|-|x+1||+y|
//||x-1|+||x+1|-|x+2|||-||x-1|+||x+1|^||x+2|-x|+|x+1||+|x+1||
while p < L do
begin
  for i:=p to L do
  begin
   if S[i] = '|' then
   begin
     inc(nbr); p:=i; goto 1;
   end;
  end;
  goto endp;
1:
  t:=GetTypeAbsBr(p,S);
  if t = 1 then
  begin
   Delete(S,p,1); Insert('abs(',S,p); p:=p+3
  end
  else
  if t = 2 then
  begin
    Delete(S,p,1); Insert(')',S,p);
  end;

  L:=Length(S);
end;

endp:
S1:=Copy(S,1,Length(S));

if (nbr mod 2 <>  0) then
begin
   F_SyntaxErrorCode:=E_MISSING_ABS_BRACKET;
   //F_SyntaxErrorString:=Copy(S,1,Length(S));
   F_SyntaxErrorString:=Copy(Sin,1,Length(Sin)); {.395}
end;

end;



function TForevalH.ReplaceAbsBrP(PS: PString): Boolean;
var
 BAns: Boolean;
begin

 BAns:=False;
 if pos('|',PS^) <> 0 then
 begin
  ReplaceAbsBr(PS^,PS^);
  BAns:=True;
 end;

 ReplaceAbsBrP:=BAns;
end;


