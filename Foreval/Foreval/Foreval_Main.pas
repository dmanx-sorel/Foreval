    ND1.NFunc:=CM_SETLEN;
    goto endp;
 end;



 adrV:=Alg.Obj[nm].Addr;



 SetLength(LV1,3);
 //{.357A}
 //LV1[0].Expression:='@'+LV[0].Expression;//IntToStr(adrV);{LV[0].Expression;}
 LV1[0].Expression:='addrarray('+LV[0].Expression+')'; {.378}
 // вместо:     ( чтобы адрес массива передавать через CPU, а не FPU  )
 //LV1[0].Expression:=IntToStr(adrV);   {LV[0].Expression;}

 LV1[1].Expression:=IntToStr(VT);
 LV1[2].Expression:=Copy(LV[1].Expression,1,Length(LV[1].Expression));


  ND1.N:=3;
  ND1.COP:=_FUNC;
  ND1.NFunc:=CM_SETLEN;

 endp:
end;






procedure TForevalH.SWAPAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);
label endp;
var
C: TFloat;
VC1,VC2: Integer;
S,NA: Integer;
i: Integer;
nv1,nv2,tv1,tv2,tm1,tm2,nf1,nf2,tf1,tf2: Integer;
FD1,FD2: extended;
Str,Str1,Str2,S1,S2,Sv1,Sa1,Sv2,Sa2: String;
MType1,ni1,MType2,ni2: Integer;
adr1,adr2: Cardinal;
BH, BAnsw1,BAnsw2,BSwap: Boolean;
begin
//При изменении в SWAP  (.AI) внести изменения в SwapIfAnalizator, SwapIf_C  т.к. используется в них

EOFN:=True;
if F_SyntaxErrorCode <> 0 then goto endp;

BSwap:=False;

if Length(LV) <> 2 then
begin
 F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
 F_SyntaxErrorString:=F_CurrentString;
 goto endp;
 //F_SyntaxErrorString:=Copy(Sf,1,Length(Sf));
end;


LV1:=nil;
ND1:=ND;
ND1.N:=0;


//VC = _Const(FD); = _Var(nf); = _None(Stack);
Str2:=LV[1].Expression;
Str1:=LV[0].Expression;
//FindExternalBracket(Str1,Str1);
DeleteExternalBracketPS(@Str1); {.219}
//FindExternalBracket(Str2,Str2);
DeleteExternalBracketPS(@Str2); {.219}


FindReIm(Str1,S1,TF1);
//FindVar(S1,nf1);    {.333}
FindVarPS(@S1,nf1);
FindReIm(Str2,S2,TF2);
FindVarPS(@S2,nf2);
//FindVar(S2,nf2);


{
if (nf1 = -1) or (nf2 = -1) then
begin
  F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT;
  F_SyntaxErrorString:=F_CurrentString;
  if nf1 = -1  then    F_SyntaxErrorStringA:=Copy(S1,1,Length(S1))
               else    F_SyntaxErrorStringA:=Copy(S2,1,Length(S2));

  goto endp;
end;
}

GetVar1(nf1,adr1,tv1,tm1);
GetVar1(nf2,adr2,tv2,tm2);

if (tv1 = T_Real) and (tv2 = T_Real) and (tm1 <> _Integer) and (tm2 <> _Integer) then
begin
  ND1.NV1:=nf1;
  ND1.NV2:=nf2;
  ND1.AI:=1;       //FloatVar <-> FloatVar
  BSwap:=True;
end
else
if (tv1 = T_Real) and (tv2 = T_Real) and (tm1 = _Integer) and (tm2 = _Integer) then
begin
  ND1.NV1:=nf1;
  ND1.NV2:=nf2;
  ND1.AI:=2;       //IntVar <-> IntVar
  BSwap:=True;
end
else
if (tv1 = T_Complex) and (tv2 = T_Complex) and (tf2 = 0) and (tf1 = 0) then
begin
  ND1.NV1:=nf1;
  ND1.NV2:=nf2;
  ND1.TS1:=TF1;
  ND1.TS1:=TF2;
  ND1.AI:=3;          //ComplexVar <-> ComplexVar
  BSwap:=True;
end
else
if (tv1 = T_Real) and (tv2 = T_Complex) and (tf2 <> 0)  then
begin
  ND1.NV1:=nf1;
  ND1.NV2:=nf2;
  ND1.TS1:=TF1;
  ND1.TS2:=TF2;
  ND1.AI:=4;           //FloatVar <-> ComplexVar(Re,Im)
  BSwap:=True;
end
else
if (tv1 = T_Complex) and (tf1 <> 0) and (tv2 = T_Real)   then
begin
  ND1.NV1:=nf1;
  ND1.NV2:=nf2;
  ND1.TS1:=TF1;
  ND1.TS2:=TF2;
  ND1.AI:=5;                //FloatVar <-> ComplexVar(Re,Im)
  BSwap:=True;
end
else
if (tv1 = T_Complex) and  (tv2 = T_Complex) and (tf2 <> 0) and (tf1 <> 0)    then
begin
  ND1.NV1:=nf1;
  ND1.NV2:=nf2;
  ND1.TS1:=TF1;
  ND1.TS2:=TF2;
  ND1.AI:=6;          //ComplexVar(Re,Im) <-> ComplexVar(Re,Im)
  BSwap:=True;
end
else     //with Array
// IntArray[indx1] <-> IntArray[indx2]; indx1,indx2 = _IntForm, Stack
// IntArray[indx1] <-> IntVar; indx1 = _IntForm, Stack
// FloatArray[indx1](dbl,ext) <-> FloatArray[indx2](dbl,ext); indx1,indx2 = _IntForm, Stack
// FloatArray[indx1](dbl,ext) <-> FloatVar(dbl,ext,Cx.re,CX.im); indx1 = _IntForm, Stack
begin
  if FindExtractArray(@Str1, Sv1,Sa1, MType1,ni1) = True then       //Array1[]<->
  begin
     if FindExtractArray(@Str2, Sv2,Sa2, MType2,ni2) = True then    //Array1[]<->Array2[]
     begin

       if (MType1 = _Integer) and (MType2 = _Integer) then     //IntArray1[]<->IntArray2[]
       begin

            WriteFindExtArgInt1PS(@Sa1, _first,   ND1,  IntegerVarForm, ND1,  BAnsw1);
            WriteFindExtArgInt1PS(@Sa2, _second,  ND1, IntegerVarForm,  ND1,  BAnsw2);
            if (BAnsw1 = True) and (BAnsw2 = True) then   //IntArray1[IntForm1]=IntArray2[IntForm2]
            begin
               ND1.AI:=10;
               SetLength(LV1,0);
               ND1.NObj:=ni1;
               ND1.NObj2:=ni2;
               ND1.N:=0;
               EOFN:=True;
               BSwap:=True;
           end
           else
           if (BAnsw1 = True)and (BAnsw2 = False) then    //IntArray1[IntForm1]=IntArray2[Expr2]
           begin
              ND1.AI:=10;
              SetLength(LV1,1);
              LV1[0].Expression:=Copy(Sa2,1,Length(Sa2));
              ND1.NObj:=ni1;
              ND1.NObj2:=ni2;
              ND1.N:=1;
              EOFN:=False;
              BSwap:=True;
           end
           else
           if (BAnsw1 = False) and (BAnsw2 = True)  then   //IntArray1[Expr1]=IntArray2[IntForm2]
           begin
              ND1.AI:=10;
              SetLength(LV1,1);
              LV1[0].Expression:=Copy(Sa1,1,Length(Sa1));
              ND1.NObj:=ni1;
              ND1.NObj2:=ni2;
              ND1.N:=1;
              EOFN:=False;
              BSwap:=True;
           end
           else          //IntArray1[Expr1]=IntArray2[Expr2]
           begin
              ND1.AI:=10;
              SetLength(LV1,2);
              LV1[0].Expression:=Copy(Sa1,1,Length(Sa1));
              LV1[1].Expression:=Copy(Sa2,1,Length(Sa2));
              ND1.NObj:=ni1;
              ND1.NObj2:=ni2;
              ND1.N:=2;
              EOFN:=False;
              BSwap:=True;
           end;

       end  //of IntArray1[]<->IntArray2[]
       else
       if ((MType1 = _Double) or (MType1 = _Extended) or (MType1 = _Single)) and ((MType2 = _Double) or (MType2 = _Extended) or (MType2 = _Single)) then
       begin            //FloatArray1[]<->FloatArray2[]

            WriteFindExtArgInt1PS(@Sa1, _first,   ND1, IntegerVarForm,  ND1,  BAnsw1);
            WriteFindExtArgInt1PS(@Sa2, _second,  ND1, IntegerVarForm,  ND1,  BAnsw2);
            if (BAnsw1 = True) and (BAnsw2 = True) then   //FloatArray1[IntForm1]=FloatArray2[IntForm2]
            begin
               ND1.AI:=20;
               SetLength(LV1,0);
               ND1.NObj:=ni1;
               ND1.NObj2:=ni2;
               ND1.N:=0;
               EOFN:=True;
               BSwap:=True;
           end
           else
           if (BAnsw1 = True)and (BAnsw2 = False) then    //FloatArray1[IntForm1]=FloatArray2[Expr2]
           begin
              ND1.AI:=20;
              SetLength(LV1,1);
              LV1[0].Expression:=Copy(Sa2,1,Length(Sa2));
              ND1.NObj:=ni1;
              ND1.NObj2:=ni2;
              ND1.N:=1;
              EOFN:=False;
              BSwap:=True;
           end
           else
           if (BAnsw1 = False) and (BAnsw2 = True)  then   //FloatArray1[Expr1]=FloatArray2[IntForm2]
           begin
              ND1.AI:=20;
              SetLength(LV1,1);
              LV1[0].Expression:=Copy(Sa1,1,Length(Sa1));
              ND1.NObj:=ni1;
              ND1.NObj2:=ni2;
              ND1.N:=1;
              EOFN:=False;
              BSwap:=True;
           end
           else          //FloatArray1[Expr1]=FloatArray2[Expr2]
           begin
              ND1.AI:=20;
              SetLength(LV1,2);
              LV1[0].Expression:=Copy(Sa1,1,Length(Sa1));
              LV1[1].Expression:=Copy(Sa2,1,Length(Sa2));
              ND1.NObj:=ni1;
              ND1.NObj2:=ni2;
              ND1.N:=2;
              EOFN:=False;
              BSwap:=True;
           end;
       end;     // of FloatArray1[]<->FloatArray2[]

     end //  of  Array1[]<->Array2[]

     else   //Array1[]<->Var
     begin

        if (MType1 = _Integer) and  (tv2 = T_Real) and  (tm2 = _Integer) then   //IntArray1[]<->IntVar2
        begin
           WriteFindExtArgInt1PS(@Sa1, _first,   ND1, IntegerVarForm,  ND1,  BAnsw1);
           if (BAnsw1 = True)  then   //IntArray1[IntForm1]<->IntVar
           begin
               ND1.AI:=11;
               SetLength(LV1,0);
               ND1.NObj:=ni1;
               ND1.NV2:=nf2;
               ND1.N:=0;
               EOFN:=True;
               BSwap:=True;
               ND1.DI:=_IntArray; //исп-ся в swapif
           end
           else                //IntArray1[Expr1]=IntVar2
           begin
               ND1.AI:=11;
               SetLength(LV1,1);
               LV1[0].Expression:=Copy(Sa1,1,Length(Sa1));
               ND1.NObj:=ni1;
               ND1.NV2:=nf2;
               ND1.N:=1;
               EOFN:=False;
               BSwap:=True;
               ND1.DI:=_IntArray; //исп-ся в swapif
           end;
        end
        else
        if ((MType1 = _Double) or (MType1 = _Extended) or (MType1 = _Single)) and  ( (tv2 = T_Real) or ( (tv2 = T_Complex) and (tf2 <> 0) ) ) then    //FloatArray1[]<->FloatVar2
        begin
           WriteFindExtArgInt1PS(@Sa1, _first,   ND1,  IntegerVarForm, ND1,  BAnsw1);
           if (BAnsw1 = True)  then   //FloatArray1[IntForm1]<->FloatVar
           begin
               ND1.AI:=21;
               SetLength(LV1,0);
               ND1.NObj:=ni1;
               ND1.NV2:=nf2;
               ND1.TS2:=TF2;
               ND1.N:=0;
               EOFN:=True;
               BSwap:=True;
               ND1.DI:=_FloatArray; //исп-ся в swapif
           end
           else                //FloatArray1[Expr1]<->FloatVar2
           begin
               ND1.AI:=21;
               SetLength(LV1,1);
               LV1[0].Expression:=Copy(Sa1,1,Length(Sa1));
               ND1.NObj:=ni1;
               ND1.NV2:=nf2;
               ND1.TS2:=TF2;
               ND1.N:=1;
               EOFN:=False;
               BSwap:=True;
               ND1.DI:=_FloatArray; //исп-ся в swapif
           end;
        end;

     end;

  end    //of  FindExtractArray(@Str1, Sv1,Sa1, MType1,ni1) = True then       //Array1[]<->

  else
  if FindExtractArray(@Str2, Sv2,Sa2, MType2,ni2) = True then      // <-> Array2[]
  begin

     //Var1 <-> Array2[]

     if (MType2 = _Integer) and  (tv1 = T_Real) and  (tm1 = _Integer) then   //IntArray1[]<->IntVar2
        begin
           WriteFindExtArgInt1PS(@Sa2, _first,  ND1, IntegerVarForm,  ND1,  BAnsw1);
           if (BAnsw1 = True)  then   //IntVar1<->IntArray2[IntForm2]
           begin
               ND1.AI:=11;
               SetLength(LV1,0);
               ND1.NObj:=ni2;
               ND1.NV2:=nf1;
               ND1.N:=0;
               EOFN:=True;
               BSwap:=True;
               ND1.DI:=_IntVar; //исп-ся в swapif
           end
           else                //IntVar1<->IntArray2[Expr2]
           begin
               ND1.AI:=11;
               SetLength(LV1,1);
               LV1[0].Expression:=Copy(Sa2,1,Length(Sa2));
               ND1.NObj:=ni2;
               ND1.NV2:=nf1;
               ND1.N:=1;
               EOFN:=False;
               BSwap:=True;
               ND1.DI:=_IntVar; //исп-ся в swapif
           end;
        end
        else
        if ((MType2 = _Double) or (MType2 = _Extended) or (MType2 = _Single)) and  ( (tv1 = T_Real) or ( (tv1 = T_Complex) and (tf1 <> 0) ) ) then    //FloatVar1<->FloatArray2[]
        begin
           WriteFindExtArgInt1PS(@Sa2, _first,   ND1, IntegerVarForm,  ND1,  BAnsw1);
           if (BAnsw1 = True)  then   //FloatVar1<->FloatArray2[IntForm2]
           begin
               ND1.AI:=21;
               SetLength(LV1,0);
               ND1.NObj:=ni2;
               ND1.NV2:=nf1;
               ND1.TS2:=TF1;
               ND1.N:=0;
               EOFN:=True;
               BSwap:=True;
               ND1.DI:=_FloatVar; //исп-ся в swapif
           end
           else                //FloatVar1<->FloatArray2[Expr2]
           begin
               ND1.AI:=21;
               SetLength(LV1,1);
               LV1[0].Expression:=Copy(Sa2,1,Length(Sa2));
               ND1.NObj:=ni2;
               ND1.NV2:=nf1;
               ND1.TS2:=TF1;
               ND1.N:=1;
               EOFN:=False;
               BSwap:=True;
               ND1.DI:=_FloatVar; //исп-ся в swapif
           end;

        end;

  end;

end;

if BSwap = False then
begin
   F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT;
   F_SyntaxErrorString:=F_CurrentString;
   F_SyntaxErrorStringA:=Copy(S1,1,Length(S1))+'  or  '+Copy(S2,1,Length(S2));
end;


endp:
ND1.COP:=_FUNC;
ND1.NFunc:=CM_SWAP;
end;





procedure TForevalH.INT2FUNC_Analizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);
label LStack,LStackV1,LStackV2,endp;
var                                    // idiv, mod, and, or, xor   (IntArg1, IntArg2)
C: TFloat;
VC1,VC2: Integer;
S,NA: Integer;
i: Integer;
nv1,nv2,tv1,tv2,tm1,tm2,Len,code1,code2,code,IC2,MType1,MType2,ni1,ni2: Integer;
FD1,FD2: extended;
Str,Str1,Str2,Sv1,Sa1,Sv2,Sa2: String;
adr: Cardinal;
BH,BAnsw,BAnsw1,BAnsw2,Bvi1,Bvi2: Boolean;
Adr1,Adr2: TAddress;
begin
if F_SyntaxErrorCode <> 0 then goto endp;


//шаблон для разбора: + исполняемые ф-ии. Прописать mod@ !!!

LV1:=LV;
ND1:=ND;  //ND1.NFunc = CM_MOD, CM_IDIV, CM_AND, CM_OR, CM_XOR, CM_NOR, CM_XNOR, CM_NAND
EOFN:=False;
BH:=False;


Len:=Length(LV);
if Len <> 2 then
begin
  {.333}
 {F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
 F_SyntaxErrorString:=F_CurrentString; }
 goto endp;
end;


Str2:=LV[1].Expression;
Str1:=LV[0].Expression;

DeleteExternalBracketPS(@Str1);
DeleteExternalBracketPS(@Str2);

WriteFindExtArgInt2AnyPS(@Str1,@Str2,ND1,ND1,code);



if (F_OperationOptimizatorA2 = False) or (F_SaveInFPU = False) then     {.231}
begin
    ND1.AI:=0;                       // idiv, mod, and, or, xor  (Stack1,Stack2)
    ND1.N:=2;
    ND1.COP:=_COP;   //_COP ?? _FUNC
    //ND1.NFunc:=CM_MOD;
    EOFN:=False;
end
else
if code = _NOT_FOUND then
begin
   {.379}

    // idiv, mod, and, or, xor (IntArray1[LineForm1],IntArray2[LineForm2])
    Bvi1:=FindExtractArray(@Str1, Sv1,Sa1, MType1, ni1);
    Bvi2:=FindExtractArray(@Str2, Sv2,Sa2, MType2, ni2);
    if (Bvi1 = True) and (Bvi2 = True) and (MType1 = _Integer) and (MType2 = _Integer) then
    begin
      WriteFindExtArgInt1PS(@Sa1, _first,    ND1, IntegerVarForm,  ND1,  BAnsw1);
      WriteFindExtArgInt1PS(@Sa2, _second,   ND1, IntegerVarForm,  ND1,  BAnsw2);
      if (BAnsw1 = True) and (BAnsw2 = True) then
      begin
         ND1.AI:=5;               // idiv, mod, and, or, xor (IntArray1[LineForm1],IntArray2[LineForm2])
         SetLength(LV1,0);        // idiv(vi1[n+k],vi2[j*2+m])
         ND1.NObj2:=ni2;
         ND1.N:=0;
         ND1.NObj:=ni1;
         EOFN:=True;
      end
      else
      goto LStack

    end

    else

    begin

    LStack:

      ND1.AI:=0;          // idiv, mod, and, or, xor  (Stack1,Stack2)
      ND1.N:=2;
      ND1.COP:=_COP;   //_COP ?? _FUNC
      //ND1.NFunc:=CM_MOD;
      EOFN:=False;

    end;

end
else
if code = _Both then          // idiv, mod, and, or, xor, nand, nor, xnor (LineForm1,LineForm2)
begin
    code2:=ND1.TA2;  code1:=ND1.TA1;  IC2:=ND1.IC2;
    if (code1 = _IntConst) and (code2 = _IntConst)  then
    begin

    case ND1.NFunc of
       CM_MOD  :     ND1.FD:=ND1.IC1 mod ND1.IC2;
       CM_IDIV :     ND1.FD:=ND1.IC1 div ND1.IC2;
       CM_AND  :     ND1.FD:=ND1.IC1 and ND1.IC2;
       CM_OR   :     ND1.FD:=ND1.IC1 or ND1.IC2;
       CM_XOR  :     ND1.FD:=ND1.IC1 xor ND1.IC2;
       CM_NAND :     ND1.FD:=not(ND1.IC1 and ND1.IC2);
       CM_NOR  :     ND1.FD:=not(ND1.IC1 or ND1.IC2);
       CM_XNOR :     ND1.FD:=not(ND1.IC1 xor ND1.IC2);
    end;




      ND1.COP:=_LDSC;
      ND1.NFunc:=0;
      BH:=True;
      EOFN:=True;
      LV1:=nil;
      ND1.N:=0;
    end
    else
    begin
      ND1.AI:=3;          // idiv, mod, and, or, xor (LineForm1,LineForm2)
      ND1.N:=0;
      ND1.COP:=_COP;   //_COP ?? _FUNC
      //ND1.NFunc:=CM_MOD;
      EOFN:=True;
      LV1:=nil;
    end;
end
else
if code = _First then
begin

    // idiv, mod, and, or, xor  (LineForm1, IntArray2[LineForm2])
    {.379}
     Bvi2:=FindExtractArray(@Str2, Sv2,Sa2, MType2, ni2);
     if (Bvi2 = True)  and (MType2 = _Integer)  then
     begin
         WriteFindExtArgInt1PS(@Sa2, _second,  ND1, IntegerVarForm,  ND1,  BAnsw2);
         if (BAnsw2 = True)  then
         begin
            ND1.AI:=6;                 // idiv, mod, and, or, xor  (LineForm1, IntArray2[LineForm2])
            SetLength(LV1,0);          // idiv(j*2+m, vi2[n+k])
            ND1.NObj:=ni2;
            ND1.N:=0;
            EOFN:=True;
         end
         else
         goto LStackV2;
     end
     else
     begin
       LStackV2:
         ND1.AI:=1;          // idiv, mod, and, or, xor  (LineForm1, Stack2)
         ND1.COP:=_COP;   //_COP ?? _FUNC
         EOFN:=False;
         ND1.N:=1;
         SetLength(LV1,1);
         LV1[0].Expression:=Copy(Str2,1,Length(Str2));
     end;


end
else
if code = _Second then
begin
     // idiv, mod, and, or, xor  (IntArray1[LineForm1],LineForm2)
     {.379}
      Bvi1:=FindExtractArray(@Str1, Sv1,Sa1, MType1, ni1);
      if (Bvi1 = True)  and (MType1 = _Integer)  then
      begin
        WriteFindExtArgInt1PS(@Sa1, _first,    ND1, IntegerVarForm,  ND1,  BAnsw1);
        if (BAnsw1 = True)  then
        begin
           ND1.AI:=7;                    // idiv, mod, and, or, xor  (IntArray1[LineForm1],LineForm2)
           SetLength(LV1,0);            // idiv(vi1[n+k],j*2+m)
           ND1.NObj:=ni1;
           ND1.N:=0;
           EOFN:=True;
        end
        else
        goto LStackV1;
      end
      else
      begin
      LStackV1:
         ND1.AI:=2;     // idiv, mod, and, or, xor  (Stack1, LineForm2)
         ND1.COP:=_COP;   //_COP ?? _FUNC
         EOFN:=False;
         ND1.N:=1;
         SetLength(LV1,1);
         LV1[0].Expression:=Copy(Str1,1,Length(Str1));
      end;
end;



endp:
end;





procedure TForevalH.DataFuncAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var BEF,EOFN: Boolean);
label endp;
var
C: TFloat;
VC1,VC2: Integer;
S,NA: Integer;
i: Integer;
nv1,nv2,tv1,tv2,tm1,tm2,Len: Integer;
FD1,FD2: extended;
Str,Str1,Str2: String;
adr: Cardinal;
BH: Boolean;
Adr1,Adr2: TAddress;
begin
if F_SyntaxErrorCode <> 0 then goto endp;


LV1:=LV;
ND1:=ND;
EOFN:=False;


Len:=Length(LV);
if (Len = 2) or (Len = 3)or (Len = 4)  then
begin
   if ND.NFunc = CM_MAX  then ND1.NFunc := CM_MAX23 else
   if ND.NFunc = CM_MIN  then ND1.NFunc := CM_MIN23 else
   if ND.NFunc = CM_AVR  then ND1.NFunc := CM_AVR23 else
   if ND.NFunc = CM_NORM then ND1.NFunc := CM_NORM23;
   BEF:=True;
end;


endp:
end;





procedure TForevalH.SUMPAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);
label endp;
var
C: TFloat;
VC1,VC2: Integer;
S,NA,ni,TV: Integer;
i: Integer;
nv1,nv2,tv1,tv2,tm1,tm2,Len,code1,code2,code,IC2: Integer;
FD1,FD2: extended;
Str,Str1,Str2: String;
adr: Cardinal;
BH,BAnsw: Boolean;
Adr1,Adr2: TAddress;
begin
if F_SyntaxErrorCode <> 0 then goto endp;


LV1:=LV;
ND1:=ND;
EOFN:=False;



Len:=Length(LV);
if Len <> 2 then
begin
 F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
 F_SyntaxErrorString:=F_CurrentString;
 goto endp;
end;



if Len = 2 then
begin


    Str2:=LV[1].Expression;
    Str1:=LV[0].Expression;

    DeleteExternalBracketPS(@Str1);
    DeleteExternalBracketPS(@Str2);


    FindVarPS(@Str1,ni);
    if ni <> -1 then
    begin
       TV:=Alg.Obj[ni].TypeF;
       if TV = T_Array then
       begin
          ND1.NV1:=ni;
       end
       else
       begin
          F_SyntaxErrorCode:= E_WRONG_TYPE;
          F_SyntaxErrorString:=F_CurrentString;
          goto endp;
       end;
    end
    else            {.395}
    begin
          {F_SyntaxErrorCode:= E_WRONG_EXPRESSION;
          F_SyntaxErrorString:=F_CurrentString;}
          goto endp;
    end;

    WriteFindExtArgInt1PS(@Str2, _Second,  ND1, IntegerVarForm, ND1, BAnsw);


    if Bansw = True then       //SUMP(vec,[_IntConst,_IntVar,_IntForm])
    begin
         ND1.AI:=1;
         ND1.N:=0;
         ND1.NFunc:=CM_SUMP;
         EOFN:=True;
    end
    else                     //SUMP(vec,Expr)
    begin
         ND1.AI:=0;
         ND1.N:=1;
         ND1.NFunc:=CM_SUMP;
         SetLength(LV1,1);
         LV1[0].Expression:=Copy(Str2,1,Length(Str2));
         EOFN:=False;
    end;


end;



endp:
end;





procedure TForevalH.SUMPSAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);
