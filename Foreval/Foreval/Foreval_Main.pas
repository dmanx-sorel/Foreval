            LV1[0].Expression:=Copy(Str2,1,Length(Str2));
            BEF:=True;

            if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
         end;


    end;

end
else
if (VC1 = _ComplexVar) and (TC = C_Image) and (code2 = _NOT_FOUND)  then      //(i)^Expr
begin
      if  (FD1 = 0) and (FD1i = 1) then
      begin

         //i^IntArray[indx] {.369}
         if FindArray(@Str2, NDA, ni, TypeV, TypeIndx, Addr, Sindx) = True then
         begin
             if (TypeV = _Integer) and ((TypeIndx = _IntVar) or (TypeIndx =_IntConst) or (TypeIndx = _IntForm) ) then
             begin

               ND1.NFunc:=CM_ImUIPwr;
               ND1.COP:=_FUNC;
               ND1.AI:=3;  {.369}  //i^IntArray[]
               ND1.BI:=_POSITIVE; //+i
               ND1.NObj2:=ni;
               ND1.DI:=NDA.AI; //тип аргумента массива в DI !!
               ND1.AIVP1:=Copy(NDA.AIVP1,0,Length(NDA.AIVP1));
               ND1.FD:=NDA.FD; //константа аргумента массива @vec[IntConst]
               ND1.NV2:=NDA.NV1; //переменная аргумента массива @vec[Intconst]

               SetLength(LV1,0);
               EOFN:=True;
               ND1.N:=0;
               BEF:=True;
               goto endp;

             end
         end;



         ND1.NFunc:=CM_IMURZPWR;     //i^(Real,Complex)
         ND1.COP:=_FUNC;
         ND1.AI:=1 ;
         ND1.FD:=FD1;
         ND1.FDC.re:=FD1;
         ND1.FDC.im:=FD1i;
         SetLength(LV1,1);
         EOFN:=False;
         ND1.N:=1;
         LV1[0].Expression:=Copy(Str2,1,Length(Str2));
         BEF:=True;
      end;
end
else
begin   //Real^IntArray[IntForm]    {.369}

         if FindArray(@Str2, NDA, ni, TypeV, TypeIndx, Addr, Sindx) = True then
           if (TypeV = _Integer) and ((TypeIndx = _IntVar) or (TypeIndx =_IntConst) or (TypeIndx = _IntForm) ) then
           begin
             ND1.NFunc:=CM_IPWR;
             ND1.COP:=_FUNC;
             ND1.AI:=3;
             ND1.N:=1;
             ND1.NObj2:=ni;
             ND1.DI:=NDA.AI; //тип аргумента массива в DI !!
             ND1.AIVP1:=Copy(NDA.AIVP1,0,Length(NDA.AIVP1));
             ND1.FD:=NDA.FD; //константа аргумента массива @vec[IntConst]
             ND1.NV2:=NDA.NV1; //переменная аргумента массива @vec[Intconst]

             SetLength(LV1,1);
             LV1[0].Expression:=Copy(Str1,1,Length(Str1));
             LV1[0].NL:=1;
             EOFN:=False;
             BEF:=True;
             goto endp;
           end;

end;




