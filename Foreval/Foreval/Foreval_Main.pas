procedure TForevalH.SetParamIntrnl(Name: String; Re,Im: Extended; TypeV: Cardinal; IntExt: Cardinal);
label endp;
var
i: integer;
Name1: String;
begin

if IntExt = _External then
begin
if CheckName(Name) = false then
 begin
  F_SyntaxErrorCode:=E_WRONG_NAME; F_SyntaxErrorString:=Name; IntException; goto endp;
  end;
end;

//if F_LeadToLowerCase = True then Name:=LowerCase(Name);

 for i := 0 to Length(Alg.Param) - 1 do
   begin
     Name1:=Alg.Param[i].Name;

     if (Name1  = Name) then
     begin
       Alg.Param[i].Real:=Re;
       Alg.Param[i].Imag:=Im;
       Alg.Param[i].TypeF:=TypeV;
       goto endp;
     end;

      if Name1 = SChidden then   //удаленная переменная
      begin
        Alg.Param[i].Real:=Re;
        Alg.Param[i].Imag:=Im;
        Alg.Param[i].TypeF:=TypeV;
        Alg.Param[i].Name:=Copy(Name,1,Length(Name));
       goto endp;
      end;
   end;

 SetLength(Alg.Param,Length(Alg.Param)+1);
 Alg.Param[High(Alg.Param)].TypeF:=TypeV;
 Alg.Param[High(Alg.Param)].Real:=Re;
 Alg.Param[High(Alg.Param)].Imag:=Im;
 Alg.Param[High(Alg.Param)].Name:=Copy(Name,1,Length(Name));

 endp:
end;



