procedure TForevalH.SetNodeDeep;
//вычисление загрузки стека FPU каждым узлом  через предварительное компилирование (эмуляция компилирования Cmpl.E_GetFuncLoad(Tree))
label endp;
var
NS,SD,i: Integer;
S: String;
Interp0: TArrayOfTFunc;
begin
  if F_SyntaxErrorCode <> 0 then goto endp;
  Tree:=BeginTree; //не обязательно, т.к. чтение дерева - циклически
  //SetLength(Interp,1);
  //Cmpl.E_Init(Interp0,{InternalFuncList,ExternalFuncList,}FuncList,VarList,F_StackDeep,F_ParamType,F_DataType,C_EmlXchBranch);
  InitCompiler(M_XchBranch);

  Db_XchBrSDeep:=0;
  N_Stack:=0;

  while Tree^.Ch <> nil do
  begin
    Tree:=Tree^.Ch;
  end;
  Tree^.SDeep:=0+xch_GetFuncLoad(Tree);


while Tree^.Pr <> nil do
begin
   while Tree^.Nb <> nil  do
   begin
    Tree:=Tree^.Nb;
    while Tree^.Ch <> nil do
    begin
     Tree:=Tree^.Ch;
    end;
    Tree^.SDeep:=0+xch_GetFuncLoad(Tree);
    end;

 SD:=Tree^.Pr^.Ch^.SDeep; NS:=Tree^.Pr^.Ch^.Stack.S;
 Tree:=Tree^.Pr^.Ch;
 while Tree^.Nb <> nil do
 begin
  Tree:=Tree^.Nb;
  if (Tree^.SDeep+Tree^.Stack.S) > (SD+NS) then
  begin
   SD:=Tree^.SDeep;
   NS:=Tree^.Stack.S;
  end;
 end;

 Tree:=Tree^.Pr;
 Tree^.SDeep:=NS-Tree^.Stack.S+SD+xch_GetFuncLoad(Tree);
end;

Db_XchBrSDeep:=GetMaxStack;

endp:
end;




