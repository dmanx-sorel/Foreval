procedure TForevalH.FreeFuncList;
var
NFunc,nf,j: Integer;
begin

 for NFunc:=0 to High(Alg.ExFunc) do
 begin

     for nf := 0 to High(Alg.ExFunc[NFunc].Func) do
     begin
        Alg.ExFunc[NFunc].Func[nf].TemplateDiffFunc:='';
        Alg.ExFunc[NFunc].Func[nf].TV:=nil;
        Alg.ExFunc[NFunc].Func[nf].TM:=nil;
        Alg.ExFunc[NFunc].Func[nf].ArgAdr:=nil;
     end;


    for j := 0 to High(Alg.ExFunc[NFunc].NameEx) do
    begin
       Alg.ExFunc[NFunc].NameEx[j]:='';
    end;

     Alg.ExFunc[NFunc].NameEx:=nil;
     Alg.ExFunc[NFunc].Name:='';
     Alg.ExFunc[NFunc].Func:=nil;

  end;

  Alg.ExFunc:=nil;
end;


