   else
   //PType(VecPtr[IntForm])
   if GNode^.AI = 3 then
   begin
      //AIVP1 -> EAX;
      LineFormN(GNode^.AIVP1,Trunc(GNode^.FD));
   end
   else
   //PType(VecPtr[IntVar])
   if GNode^.AI = 2 then
   begin
     MOVMA(Adr);

   (*
   LoadArg1;
   //trunc
   PUSHCW;    {.227}
   FLDCW(TAddress(@FCW1));
   MEM:=WriteDataA(0,_Integer);
   FISTP(MEM);
   POPCW;    {.227} //FLDCW(TAddress(@FCW2));
   MOVMC(MEM);
   *)
   end
   else
   if GNode^.AI = 0 then     //VecPtr[Trunc(Stack)]
   begin
     LoadArg1;
     //trunc
     (*
     PUSHCW;    {.227}
     FLDCW(TAddress(@FCW1));
     MEM:=WriteDataA(0,_Integer);
     FISTP(MEM);
     POPCW;    {.227} //FLDCW(TAddress(@FCW2));
     //MOVMC(MEM);
     MOVMA(MEM);
     *)

     //TRUNCR(R_EAX);
      FISTPR(R_EAX); {.387}
 end;





   {
   MOVBadr(AdrM);                    //Addr(VecPtr) -> EBX
    //mov  ebx, [ebx]:
   AddByte($8B); AddByte($1B);      //Addr(VecPtr[0]) -> EBX
   }
   MOVMREG(R_EBX,AdrM); //[VecPtr] -> EBX (= @VecPtr[0])  {.369**}
    //mov eax, [ebx+4*eax]
   AddByte($8B); AddByte($04);AddByte($83);    //VecPtr[indx]->EAX

   FLDREG(R_EAX,TM);

 end;


   //CheckStack(1);
   //CheckStack(-8);
end;





