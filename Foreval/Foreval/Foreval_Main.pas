      MC:=MC*ic;
      code:=_IntConst;
      //goto endp;
    end
    else
    if typeVC = _IntVar then
    begin
      {code := _IntVar;
      MC:=MC*ic;  //-n
      FIN.NV:=nv;
      FIN.A:=MC; }
      SetLength(IVP.NV,Length(IVP.NV)+1);
