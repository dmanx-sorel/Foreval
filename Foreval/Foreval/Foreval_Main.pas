procedure TForevalH.funcInt2Cmpl(_ComCode: Cardinal; _Arg2Type: Integer; _IntConst: Integer; _AddrIntVar: TAddress;  _LoadFPU: Boolean; _PlacementArg: Integer);
begin
    {                     EAX EBX
     _PlacementArg =       1   2
                           2   1
                           1   0
                           0   1
                           2   0
                           0   2

     Номера аргументов. первый (1) должен быть в EAX второй (2) - в EBX
     Исп-ся  в idiv т.к.  _funcInt2Cmpl изменяет порядок аргументов
    }
      case _ComCode of

           CM_IDIV:   IDIV_EAX_EBX( _Arg2Type, _IntConst, _AddrIntVar, False, _LoadFPU, _PlacementArg);
           CM_MOD:    MOD_EAX_EBX ( _Arg2Type, _IntConst, _AddrIntVar, False, _LoadFPU, _PlacementArg);

           CM_AND :   AND_EAX_EBX( _Arg2Type, _IntConst, _AddrIntVar,  False, _LoadFPU );
           CM_OR :    OR_EAX_EBX ( _Arg2Type, _IntConst, _AddrIntVar,  False, _LoadFPU );
           CM_XOR :   XOR_EAX_EBX( _Arg2Type, _IntConst, _AddrIntVar,  False, _LoadFPU );

           CM_NAND :  AND_EAX_EBX( _Arg2Type, _IntConst, _AddrIntVar,  True,  _LoadFPU );
           CM_NOR :   OR_EAX_EBX ( _Arg2Type, _IntConst, _AddrIntVar,  True,  _LoadFPU );
           CM_XNOR :  XOR_EAX_EBX( _Arg2Type, _IntConst, _AddrIntVar,  True,  _LoadFPU );
      end;

end;


