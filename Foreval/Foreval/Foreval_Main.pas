                end
                else
                if code = _IntVar then
                begin
                   ND1.NV1:=NV;
                   ND1.AI:=2;       //Call(IntArray[IntVar])
                   ND1.N:=0;
                   EOFN:=True;
                   F_CallFuncPresent:=True;
                end
