var
C: TFloat;
VC1,VC2: Integer;
S,NA,ni,TV,MT,NV,IC,NF: Integer;
i: Integer;
nv1,nv2,tv1,tv2,tm1,tm2,Len,code1,code2,code,IC2: Integer;
FD1,FD2: extended;
Str,Str1,Str2,Str3,Sf,Sa,Sv: String;
//adr: Cardinal;
BH,BAnsw,FH1,IsSetRepl: Boolean;
Adr1,Adr2,AddrF: TAddress;
AIVP:  TArrayIntVarProd;
begin
if F_SyntaxErrorCode <> 0 then goto endpp;


LV1:=LV;
ND1:=ND;
EOFN:=False;



Len:=Length(LV);
if Len <> 1 then
begin
 F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
 F_SyntaxErrorString:=F_CurrentString;
 goto endp;
end;



    //call(<Addr>) Addr = @Func; IntVar; IntArray[indx]


    Str1:=LV[0].Expression;
    //DeleteExternalBracketPS(@Str1);

    IsSetRepl:=False; {.375B}

 //if (F_EnableUseIntegerPointer = True) and (F_EnableUsePointer = True) then
 begin
    // Call (PointerVar) Call(IntVar)

    FindVarPS(@Str1,ni);
    if ni <> -1 then
    begin
       TV:=Alg.Obj[ni].TypeF;
       MT:=Alg.Obj[ni].MType;
       if (TV = T_Pointer) or
          ( (TV = T_Real) and  (MT = _Integer) and (F_EnableUseIntegerPointer = True))
       then
       begin
           ND1.NV1:=ni;
           //ND1.NFunc:=CM_CALLR;
           BH:=True;
           EOFN:=True;
           ND1.N:=0;
           ND1.AI:=1;  //Call (PointerVar) Call(IntVar)
           SetLength(LV1,0);
       end
       else
       begin
          F_SyntaxErrorCode:= E_WRONG_TYPE;
          F_SyntaxErrorString:=F_CurrentString;
          //goto endp;
       end;
       goto endp;
    end;

 end;



    //Call(Func)
    (*
    FindFuncPS(@Str1,NF);
    if NF <> -1 then
    begin
        if Alg.ExFunc[NF].Func[0].NArg = 0 then   //Call(Func): только ф-ии без аргументов!
        begin
           AddrF:=Alg.ExFunc[NF].Func[0].Addr;
           ND1.Addr1:=AddrF;
           BH:=True;
           EOFN:=True;
           ND1.N:=0;
           ND1.AI:=4;  //Call(Func)
           SetLength(LV1,0);
           F_CallFuncPresent:=True;
        end
        else
        begin
           F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT;
           F_SyntaxErrorString:=Copy(F_CurrentString,1,Length(F_CurrentString));
           //F_SyntaxErrorName:=Copy(Sv,1,Length(Sv));
           F_SyntaxErrorName:=Alg.ExFunc[NF].Name ;
        end;
        goto endp;
    end;
    *)

   //if  (F_EnableUsePointer = True) then
   begin

      //Call(@Func)
    if Str1[1] = '@' then  Str2:=Copy(Str1,2,Length(Str1)-1)
    else   //Call(Addr(func))
    begin
        FindFuncBrPS(@Str1,'(',')',Sf,Sa,FH1);
        if FH1 = True then
        begin
           if Alg.ExFunc[CM_ADDR].Name = Sf then Str2:=Sa
           else
            //вызов сохранённого адреса в стеке. Исп-ся через преобразование типов
               //extf()=sqrt(x)      ptrf:pointer=@extf;  adrI:int=integer(ptrf); callR(pointer(adri))
               // ptrf:pointer=@void;  Ptr1:Ptr=@ptrf; callR(ppointer(ptr1))
           begin
               BH:=True;
               EOFN:=False;
               ND1.N:=1;
               ND1.AI:=6;  //Call(Pointer(Addr)) через преобразование типов
               SetLength(LV1,1);
               LV1[0].Expression:=Str1;
               F_CallFuncPresent:=True;
               goto endp;
              {
              F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT;
              F_SyntaxErrorString:=Copy(F_CurrentString,1,Length(F_CurrentString));
              F_SyntaxErrorName:=Sf;
              }
           end;
        end
        else
        goto callarray;
    end;

    FindFuncPS(@Str2,NF);
    if NF <> -1 then
    begin
        if Alg.ExFunc[NF].Func[0].NArg = 0 then   //Call(@Func): только ф-ии без аргументов!
        begin
           AddrF:=Alg.ExFunc[NF].Func[0].Addr;
           ND1.Addr1:=AddrF;
           ND1.NObj:=NF;
           ND1.IsReplExpr:=Alg.ExFunc[NF].ReplFunc; {.375B}
           IsSetRepl:=True; {.375B}
           BH:=True;
           EOFN:=True;
           ND1.N:=0;
           ND1.AI:=4;  //Call(Func)
           SetLength(LV1,0);
           F_CallFuncPresent:=True;
        end
        else
        begin
           F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT;
           F_SyntaxErrorString:=Copy(F_CurrentString,1,Length(F_CurrentString));
           //F_SyntaxErrorName:=Copy(Sv,1,Length(Sv));
           F_SyntaxErrorName:=Alg.ExFunc[NF].Name ;
