function TForevalH.CheckImUnitAfterBr(const S: String; i: Integer): Boolean;
var
 EnOp: set of  Char;
 Si: String;
 Li: Cardinal;
 St1: String;
begin
//EnOp:=[')','}',']','|','*','/','>','<','+','^','-',',',';'];

  Li:=Length(S_IM_UNIT);

  St1:=S[i];

  if Length(S) > i+Li then
  begin
    {
    Si:=S[i+Li+1];//Copy(S,i,Li);
    if S[i+Li+1] in EnOp then  CheckImUnitAfterBr:=True else CheckImUnitAfterBr:=False;
    }
    {.355}
    Si:=Copy(S,i+1,Li);
    if Si =  S_IM_UNIT then CheckImUnitAfterBr:=True else
       if S[i+1] in AfterFuncEnableSymb {EnOp} then   CheckImUnitAfterBr:=True  else CheckImUnitAfterBr:=False;
                          {.383}
  end
  else
  if Length(S) = i+Li then
  begin
    Si:=Copy(S,i+1,Li);
    if Si =  S_IM_UNIT then CheckImUnitAfterBr:=True else CheckImUnitAfterBr:=False;
  end
  else
  CheckImUnitAfterBr:=False;
end;




procedure TForevalH.PrevTreat(S: String; var S1: String);
(*
    предварительная синтаксическая обработка выражения ( Выполняется предварительно частично также в Foreval_Lib !!!)
    замена:


  |expr|->abs(expr);
  [expr]->trunc(expr)  ;
  {expr}->frac(expr);
  (exp1) and (expr2)-> if(expr1)*if(expr2)
  (exp1) or  (expr2)-> if(expr1)+if(expr2)
  root2(expr), root3(expr),...,rootN(expr)-> root(expr,N)  N -  integer number
  power2(expr), power3(expr),...,powerN(expr)-> power(expr,N)  N -  integer number
  pow2(expr), pow3(expr),...,powN(expr)-> power(expr,N)  N -  integer number

            // expr!!->fact2(expr); expr!->fact(expr);         //замена при разборе, т.к. операторы
            // expr1^expr2 -> power(expr1,expr2)


   поиск ошибки незакрытых скобок и пропущенных операторов
*)

 label endp;
 //const
  //OpSet: set of char = ['*','/','+','-','^'];
 var
  b1,b2,i,ba,bs,bc,br,LC,p1,p2: Integer;
  E: Exception;
  Sin: String;

begin


if S = '' then S:='0';
Sin:=S;

{.341}
//if F_SyntaxExtension = True then
begin      //порядок не менять  (sequnce not to change)

 if F_PipeBracketToAbs = True then
 begin
   if pos('|',S) <> 0 then ReplaceAbsBr(S,S);
   if F_SyntaxErrorCode <> 0 then goto endp;
 end;

 if F_SquareBracketToTrunc = True then
 begin
    if (pos('[',S) <> 0) or (pos(']',S) <> 0)  then ReplaceTruncBr(S,S);
    if F_SyntaxErrorCode <> 0 then goto endp;
 end;

 if F_CurlyBracketToFrac = True then
 begin
    if (pos('{',S) <> 0) or (pos('}',S) <> 0)  then ReplaceFracBr(S,S);
    if F_SyntaxErrorCode <> 0 then goto endp;    {.323}
 end;


 //FindFact2Symb(S,S);
 //FindFactSymb(S,S);

  if F_SkippedIF = True then      {.221}
    ReplaceAndOrSKIP(S,S)    //skipped if
  else
    ReplaceAndOr(S,S);       //complete if

  if F_ReplaceFuncInPart = True then
  begin
    ReplaceFuncIntPart(S,'root',2,S);
    ReplaceFuncIntPart(S,'power',2,S);
    ReplaceFuncIntPart(S,'pow',2,S); {.191}
    ReplaceFuncIntPart(S,'log',1,S); {.377}
  end;

end;
 //ReplaceIff(S,S);


//if F_PreliminarySyntaxError = True then
begin
   F_SyntaxErrorCode:=0;
   b1:=0; b2:=0; ba:=0;  bs:=0; bc:=0;  br:=0;

   for i:=1 to Length(S)-1 do
   begin
     (*
        if (S[i] = ')') and ((S[i+1] <> '*') and  (S[i+1] <> '+') and
        (S[i+1] <> '-') and (S[i+1] <> '/') and (S[i+1] <> '^') and
        (S[i+1] <> '!') and (S[i+1] <> ')') and (S[i+1] <> ',') and
        (S[i+1] <> '}')  and   (S[i+1] <> '.') and
        (S[i+1] <> ']')  and (S[i+1] <> '=') and (S[i+1] <> '<' ) and (S[i+1] <> '>'))
        *)
      if  (S[i] = ')') and (S[i+1]  in BetweenRoundBracketEnableSymb = False )
      then
      begin
        if CheckImUnitAfterBr(S,i) = False then
        begin
          F_SyntaxErrorCode:=E_MISSING_OPERATION;      //отсутствует операция
          LC:=10; //условно
          if i < LC  then  p1:=i else p1:=LC;
          if Length(S)-i < LC then p2:=Length(S)-i else p2:=LC;

          F_SyntaxErrorString:=Copy(S,i-p1+1,p1+p2);
          goto endp;
        end;
      end;

     if  (S[i] = ']') and ( ( S[i+1] = '(' ) or ( S[i+1]  in EnableNameSymb = True ) )
     then
     begin
          F_SyntaxErrorCode:=E_MISSING_OPERATION;      //отсутствует операция
          LC:=10; //условно
          if i < LC  then  p1:=i else p1:=LC;
          if Length(S)-i < LC then p2:=Length(S)-i else p2:=LC;

          F_SyntaxErrorString:=Copy(S,i-p1+1,p1+p2);
          goto endp;
     end;


     {.231}        // работает , если используются только односимвольные операции !!

      if (S[i] in Operation2Arg) and (S[i+1] in Operation2Arg) then
      begin
        if F_PreliminarySyntaxError = True then
        begin
           F_SyntaxErrorCode:=E_MISSING_EXPRESSION;
           LC:=10; //условно
           if i < LC  then  p1:=i else p1:=LC;
           if Length(S)-i < LC then p2:=Length(S)-i else p2:=LC;
           F_SyntaxErrorString:=Copy(S,i-p1+1,p1+p2);
           goto endp;
        end;
      end;


      if S[i] = '(' then inc(br);
      if S[i] = ')' then dec(br);

      if S[i] = '[' then inc(bs);
      if S[i] = ']' then dec(bs);

      if S[i] = '{' then inc(bc);
      if S[i] = '}' then dec(bc);
  end;

  if S[Length(S)] = ')' then dec(br);
  if S[Length(S)] = ']' then dec(bs);
  if S[Length(S)] = '}' then dec(bc);

  if br <> 0 then
  begin
    F_SyntaxErrorCode:=E_MISSING_ROUND_BRACKET;
    F_SyntaxErrorString:=Copy(S,1,Length(S));
    //raise E.Create('');
  end
  else
  if bs <> 0 then
  begin
    F_SyntaxErrorCode:=E_MISSING_SQUARE_BRACKET;
    //F_SyntaxErrorString:=Copy(S,1,Length(S));
    F_SyntaxErrorString:=Copy(Sin,1,Length(Sin));     {.395}
    //raise E.Create('');
  end
  else
  if bc <> 0 then
  begin
    F_SyntaxErrorCode:=E_MISSING_CURLY_BRACKET;
    //F_SyntaxErrorString:=Copy(S,1,Length(S));
    F_SyntaxErrorString:=Copy(Sin,1,Length(Sin));   {.395}
    //raise E.Create('');
   end;
end;


(*
if F_SquareBracketToTrunc = False then
begin
    S:=StringReplace(S,'[','(',[rfReplaceAll, rfIgnoreCase]);
    S:=StringReplace(S,']',')',[rfReplaceAll, rfIgnoreCase]);
end;
*)

if F_CurlyBracketToFrac = False then
begin
    S:=StringReplace(S,'{','(',[rfReplaceAll, rfIgnoreCase]);
    S:=StringReplace(S,'}',')',[rfReplaceAll, rfIgnoreCase]);
end;


S1:=Copy(S,1,Length(S));
endp:
end;



  // 395x
procedure TForevalH.SyntaxAnalizatorGT( var ND: TDataNode; var LV:PLevel;  var EOFN: Boolean);
label endp;
var
COP,S: String;
nf: Cardinal;
BH: Boolean;
a,b: TFloat;
Arg,IntFD: Integer;
begin

{
  Главная процедура разбора текущего подвыражения.
  Общий алгоритм:
   1. Поиск главной операции (+ - * / ^ ! ,...) в текущем подвыражении - StringAnalizatorPS
   2. Если не найдена => искать функцию или массив- FindFunctionOrArray:  func(arg1,..);  array[indx]
   3. Если не найдены => искать переменную, прараметр или число- FindVarOrNumberPS.
   4. Если не найдены => ошибка: неизвестный символ/выражение -  FindVarOrNumberPS.

  Возвращает:
   ND - параметры главного родительского узла - текущей идентефицируемой команды - Tree^.Expression
   LV - параметры вытекающих из главного узла ветвей - узлы потомков.
   Число вытекающих потомков = числу аргументов родительской команды = Length(LV)
   LV[].Expression = строковые выражения вытекающих ветвей из главной команды родительского узла
   Если узел - конечный: EOFN=True, Length(LV)=0
}

if F_SyntaxErrorCode <> 0 then goto endp;

S:=Tree^.Expression; //текущее выражение разбора

//if S[1] = '+' then Delete(S,1,1); {.302} // +Expr -> Expr

//F_CurrentSubExpr:=S; {.195}
F_SyntaxErrorString:=S;

// устранение общих лишних вложенных скобок
FindExternalBracketNegPS(@S);  {.302} //on

TryFPUMask; {.229}


EOFN:=False;
InitNode(ND);


if M_ParseMode = M_Compile then    // <> M_ParseDiffExpr  {.301}
begin

 {
   Перед общим разбором:
    a.  перехват сложных (составных) целочисленных  аргументов внешних функций для оптимизации одной исполняемой командой   fint1(5),  fint1(2*n+k)
    b.  искать составные числа вида : 1.123456789E+-1234  ,

    иначе они разбиваются на части (отдельные аргументы) в StringAnalizatorPS
  }
  {.395}
 // a.  {текущая строка - аргумент внешней функции & разрешена оптимизация целочисленных аргементов}
 if (Tree^.ExtFunc > _NOT_FOUND) and (F_IntegerOptimizationF = True) then  FindExtFuncIntArg(ND,EOFN);
 if EOFN = True then goto endp;
 // b.
 FindConstPS(@S,ND,EOFN);
 if EOFN = True then goto endp;

end;



//поиск главной операции в текущем выражении:
StringAnalizatorPS(@S,ND,LV);   {.314}
Arg:=Length(LV);       //число найденных аргументов операции
if F_SyntaxErrorCode = 0 then                     {.195}
begin
If (ND.COP = 0)  then      //операция не найдена => выражение - функция, массив ,переменная, константа
 begin

  //искать функцию или массив:
 // if F_WrongPlacedOperation = False then         {.383}  (если выражение не содержит неверно расположенной операции или управляющего символа )
     FindFunctionOrArrayPS(@LV[0].Expression,ND,LV,BH,EOFN);   {.314}

     if BH = False then //...не найдены, искать переменную или число. Иначе - ошибка: неизвестный символ/выражение
        FindVarOrNumberPS(@LV[0].Expression,ND,EOFN); {.314}


 end
 else  {.353}
 //оптимизация некоторых операций
 if (M_ParseMode = M_Compile)  then
 begin
    if (Arg = 1) then  OperationalAnalizator1(LV,ND,LV,ND,EOFN) else
    if (Arg = 2) then  OperationalAnalizator2(LV,ND,LV,ND,EOFN);
 end;




  {.395}
  if ( (Length(LV) = 0) and (EOFN = False) )  then
  begin
         F_InternalError:=E_AccessViolation;
         F_SyntaxErrorCode:=E_INTERNAL_ERROR;
         F_SyntaxErrorString:=F_SyntaxErrorString;
  end;
  // если срабатывает эта ситуация, то её можно подавить, закрыв её, а вместо неё записать строчку :
     {
      if Length(LV) = 0 then EOFN: = True;
     }

end;


endp:
TryCatchFPUException;    {.229}
end;



{
 Structure of Tree. Example:  node of Tree with 3 childs


          ParentNode
          /    |    \
         /     |     \
        /      |      \
       /       |       \
      V        V        V
   Child1     Child2     Child3



   ParentNode^.Ch -> Child1

   Child1^.Nb     -> Child2
   Child2^.Nb     -> Child3
   Child3^.Nb     -> nil

   Child1^.Pr     -> ParentNode
   Child2^.Pr     -> ParentNode
   Child3^.Pr     -> ParentNode


}


//главная процедура создания синтаксического  дерева выражения
procedure TForevalH.TreeBuilder(S: String);      //creating of tree of expression
label endp;
var
HS: PLevel;
ND: TDataNode;
H,H1: PNode;
EOFN: Boolean;
i: Cardinal;
begin
if F_SyntaxErrorCode <> 0 then goto endp;
New(Tree);
Tree^.Ch:=nil;
Tree^.Nb:=nil;
Tree^.Pr:=nil;
BeginTree:=Tree;
//вершина дерева:
Tree^.Expression:=Copy(S,1,Length(S));
Tree^.Stack.S:=1;
F_IdN:=0;
//Tree^.IdL:=0;
Tree^.ExtFunc:=_NOT_FOUND; {.309}
EOFN:=True;
BeginTree^.AlwaysEval:=_YES; {.395if} // вершина всегда вычисляема

//SyntaxAnalizator(Tree^.Expression,ND,HS,EOFN);
//разбор текущего подвыражения (узла)
SyntaxAnalizatorGT(ND,HS,EOFN);
//спуск до нижнего левого:
//COP<>NOP:
while EOFN <> True do   //EOFN = End OF Node последний узел текущей ветви
begin
 if F_SyntaxErrorCode <> 0 then goto endp;

 New(H);
 Tree^.Ch:=H;
 inc(F_IdN);
 WriteNodeParam(ND);       //запись параметров найденной команды (узла)
 WriteLevelParam(H,HS,0);  //запись параметров вытекающих узлов из главного узла


 H^.Stack.S:=Tree^.Stack.S;
 H^.Pr:=Tree;
 H1:=H;
 H^.Ch:=nil;
 H^.Nb:=nil;

 for i:=1 to High(HS) do
 begin
  New(H);
  H^.Ch:=nil;
  H^.Nb:=nil;
  WriteLevelParam(H,HS,i);
  H^.Stack.S:=H1^.Stack.S+1;
  H1.Nb:=H;
  H^.Pr:=Tree;
  //HS:=HS^.Next;
  H1:=H;
 end;
 Tree:=H^.Pr^.Ch;
 HS:=nil; //??? (освобождение массива уровня)
 //SyntaxAnalizator(Tree^.Expression,ND,HS,EOFN);
 SyntaxAnalizatorGT(ND,HS,EOFN);
end;
//EOFN=True: последняя команда узла (нижний левый)
inc(F_IdN);
WriteNodeParam(ND);

//подъём:
while Tree^.Pr <> nil do
begin
 while Tree^.Nb <> nil  do
 begin
 Tree:=Tree^.Nb;
 //SyntaxAnalizator(Tree^.Expression,ND,HS,EOFN);
 SyntaxAnalizatorGT(ND,HS,EOFN);
//COP<>NOP:
while EOFN<>True do
 begin
 if F_SyntaxErrorCode <> 0 then goto endp;

 New(H);
 Tree^.Ch:=H;
 inc(F_IdN);
 WriteNodeParam(ND);
 WriteLevelParam(H,HS,0);

 H^.Stack.S:=Tree^.Stack.S;
 H^.Pr:=Tree;
 H1:=H;
 H^.Ch:=nil;
 H^.Nb:=nil;
 for i:=1 to High(HS) do
 begin
  New(H);
  H^.Ch:=nil;
  H^.Nb:=nil;
  WriteLevelParam(H,HS,i);

  H^.Stack.S:=H1^.Stack.S+1;
  H1.Nb:=H;
  H^.Pr:=Tree;
  H1:=H;
 end;
 Tree:=H^.Pr^.Ch;
 HS:=nil; //??? (освобождение массива уровня)
 //SyntaxAnalizator(Tree^.Expression,ND,HS,EOFN);
 SyntaxAnalizatorGT(ND,HS,EOFN);
 end;
//EOFN=True:последняя команда узла
inc(F_IdN);
WriteNodeParam(ND);
end;
Tree:=Tree^.Pr;
end;

Tree:=BeginTree;

endp:
end;





procedure TForevalH.OperationalAnalizator1(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);
label endp;
var
ni: Integer;
Str1: String;
BAnsw,BEF: Boolean;
begin
if F_SyntaxErrorCode <> 0 then goto endp;

TryFPUMask; {.229}


LV1:=LV;
ND1:=ND;


EOFN:=False;

//InitNode(ND);
if (F_SaveInFPU = True) and  (F_OperationOptimizatorA1 = True ) then
begin
  if (ND.NFunc = CM_RE) or (ND.NFunc = CM_IM)  then
      ReImAnalizator(LV, ND, LV1, ND1, BEF, EOFN)
  else
  if (ND.NFunc = CM_FACT) or (ND.NFunc = CM_FACT2) or (ND.NFunc = CM_NOT)  then
      INT1FUNC_Analizator(LV, ND, LV1, ND1, EOFN);
end;

if (ND.NFunc = CM_ADDR)      or (ND.NFunc = CM_ADDR_ARRAY) or
   (ND.NFunc = CM_ADDR_FUNC) or (ND.NFunc = CM_ADDR_VAR) then
      AddrAnalizator(LV, ND, LV1, ND1, EOFN); //должен выполняться в любом режиме (F_SaveInFPU ,F_OperationOptimizatorA1)!



endp:
TryCatchFPUException;    {.229}
end;





procedure TForevalH.OperationalAnalizator2(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);
label endp;
var
C: TFloat;
BH,BZ1,BZ2,Answ,BEF: Boolean;
VC1,VC2: Integer;
S: Integer;
i: Integer;
nv1,nv2,tv1,tv2,tm: Integer;
FD1,FD2: extended;
Str: String;
adr: Cardinal;
begin
if F_SyntaxErrorCode <> 0 then goto endp;
if (F_SaveInFPU = False) or  (F_OperationOptimizatorA2 = False) then goto endp;


