        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-2]),F_DataType);    // -> IM(exp)
        FSUB(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);      // IM(exp)-IM(exp^-1)
        FMUL_C05; // st(0):IM
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-3]),F_DataType);    // -> RE(exp)
        FSUB(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);      // RE(exp)-RE(exp^-1)
