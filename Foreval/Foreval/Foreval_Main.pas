       // vi1[5*n+j+1]=idiv(vi2[15*j+k+10],2); vi1[5*n+j+1]
       // vi1[5*n+j+1]=xor(vi2[15*j+k+10],2); vi1[5*n+j+1]
  end;



end
else

{
  IntVar1             = FuncInt1(IntForm2)
  IntVar1             = FuncInt1(IntArray2[IntForm2])
  IntArray1[IntForm1] = FuncInt1(IntForm2)
  IntArray1[IntForm1] = FuncInt1(IntArray2[IntForm2])
}
if GNode^.AI = 51 then
begin
      ComCode:=GNode^.EI;
      ArgForm2:=GNode^.TA2;
      RegRes:=R_EAX;


      // IntVar1  = FuncInt1(IntForm2)
      if (GNode^.CI = 1) then
      begin
          AddrI1:=Alg.Obj[GNode^.NV1].Addr;
          AddrI2:=Alg.Obj[GNode^.NV2].Addr;
          if (ArgForm2 = _IntVar) and (AddrI1 = AddrI2) then    //IntVar=FuncInt1(IntVar)
          begin
              if ComCode = CM_NOT then NOT_RM(_ABSENT,AddrI2);  // not [AddrI2]
          end
          else
          begin
            LoadLineFormEAX(_Second);     //ArgForm2     -> EAX

            if ComCode = CM_NOT then NOT_RM(R_EAX,0);    //not eax

            //EAX -> IntVar1
            MOVREGM(RegRes,AddrI1);
          end;

      end
      else
       // IntVar1  = FuncInt1(IntArray2[IntForm2])
      if (GNode^.CI = 2) then
      begin
          AddrI1:=Alg.Obj[GNode^.NV1].Addr;
          AddrA2:=Alg.Obj[GNode^.NObj2].Addr;
          LoadArrayElemLineForm(_Integer,_Second,R_EAX, AddrA2);  //IntArray2[IntForm2] -> R_EAX

          if ComCode = CM_NOT then NOT_RM(R_EAX,0);    //not eax

          //EAX -> IntVar1
          MOVREGM(RegRes,AddrI1);
      end
      else
      // IntArray[IntForm1]  = FuncInt1(IntForm2)
      if (GNode^.CI = 3) then
      begin
         AddrA1:=Alg.Obj[GNode^.NObj].Addr;

         LoadLineFormEAX(_Second);     //ArgForm2 -> EAX

         if ComCode = CM_NOT then NOT_RM(R_EAX,0);    //not eax

         MOVREG(RegRes,R_ESI);          //EAX -> ESI

         // IntArray1[IntForm1]=
         LoadLineFormEAX(_First);     //ArgForm1     -> EAX
         MOVMREG(R_EBX,AddrA1);       //@IntArray[0] -> EBX
         MOV_EAX_4EBX__ESI;           //ESI -> VecInt1[IntForm1]
      end
      else
       // IntArray1[IntForm1]  = FuncInt1(IntArray2[IntForm2])
      if (GNode^.CI = 4) or (GNode^.CI = 5) then
      begin
         AddrA1:=Alg.Obj[GNode^.NObj].Addr;
         AddrA2:=Alg.Obj[GNode^.NObj2].Addr;

         if GNode^.CI = 5 then     // IntArray1[IntForm1]  = IntArray2[IntForm2]
         begin
            LoadLineFormEAX(_Second);     //IntForm2     -> EAX
            MOVREG(R_EAX,R_ECX);         // IntForm2 -> ECX
            MOVMREG(R_EBX,AddrA2);       //@IntArray2[0] -> EBX


            LoadArrayAddrCell(R_EAX,R_EBX,R_ECX,_Integer);  // @IntArray2[IntForm2] -> EAX

            if ComCode = CM_NOT then NOT_RM(R_EAX,R_EAX);    //not [eax]
                                                             // vi1[2*k+3*j+4]=16; vi1[2*k+3*j+4]=not(vi1[2*k+3*j+4]); vi1[2*k+3*j+4]
         end
         else
         if GNode^.CI = 4 then      //  IntArray1[IntForm1]  <> IntArray2[IntForm2]
         begin
             LoadArrayElemLineForm(_Integer,_Second,R_EAX, AddrA2);  //IntArray2[IntForm2] -> R_EAX

             if ComCode = CM_NOT then NOT_RM(R_EAX,0);    //not eax

             MOVREG(RegRes,R_ESI);          //EAX -> ESI

            // IntArray1[IntForm1]=
             LoadLineFormEAX(_First);     //ArgForm1     -> EAX
             MOVMREG(R_EBX,AddrA1);       //@IntArray[0] -> EBX
             MOV_EAX_4EBX__ESI;           //ESI -> VecInt1[IntForm1]
                                                           // vi2[5*k+6*j+7]=25; vi1[2*k+3*j+4]=not(vi2[5*k+6*j+7]); vi1[2*k+3*j+4]
         end;

      end

end
else
if GNode^.AI = 60 then      //IntVar = IntArray[IntForm]
begin

   LoadArrayElem(tc_LoadIntArrayElemEAX);
   MOVREGM(R_EAX,Alg.Obj[GNode^.NV1].Addr);  // сохранение результата  ->  IntVar1

end;
