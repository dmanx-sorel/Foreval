i,nf: Integer;                             //Операции взывают только 1,2 - аргументные ф-ии
begin                                     //PR - priority; Pos - place (one arg. op. :_before; _after   two arg. op. _between) ;

if (NFunc < Length(Alg.ExFunc)) and (PR > 0) then
begin


  for i:=0 to High(Alg.Opr) do
  begin
    if (OpName = Alg.Opr[i].Name) and (Pos = Alg.Opr[i].Pos) and (NArg = Alg.Opr[i].NArg) then
    begin
     Alg.Opr[i].Name:=OpName;
     Alg.Opr[i].NFunc:=NFunc;
     Alg.Opr[i].PR:=PR;
     Alg.Opr[i].ExeType:=ExeType;
     Alg.Opr[i].Enable:=True;
     //Alg.Opr[i].GS:=GS;
     //Alg.Opr[i].SE:=0;//SE;
     idOp:=i;
     goto endp;
    end;
  end;

  SetLength(Alg.Opr,Length(Alg.Opr)+1);
  Alg.Opr[High(Alg.Opr)].Name:=OpName;
  Alg.Opr[High(Alg.Opr)].NFunc:=NFunc;
  Alg.Opr[High(Alg.Opr)].PR:=PR;
  Alg.Opr[High(Alg.Opr)].Pos:=Pos;
  Alg.Opr[High(Alg.Opr)].NArg:=NArg;
  Alg.Opr[High(Alg.Opr)].ExeType:=ExeType;
  Alg.Opr[High(Alg.Opr)].Enable:=True;
  Alg.Opr[High(Alg.Opr)].LenOp:=Length(OpName);
  idOp:=High(Alg.Opr);

  {.383} //отключает проверку  на предварительный поиск ошибок  из-за ложного срабатывания
  if (NArg = 2) and (Length(OpName) > 1) then F_PreliminarySyntaxError := False;
end;

endp:
