procedure TForevalH.FindExternalBracketNeg(S: String; var SS: String; var Neg: Integer);
label
2,3,endp;
var
b,i,z,a: Integer;
begin
SS:=Copy(S,1,Length(S)); z:=1;
2:
b:=0; a:=1;

if SS = '' then
begin
goto endp;
end;


if SS[1] = '-' then a:=2;
if  SS[a] = '(' then
begin
 b:=-1;
 for i:=a+1 to Length(SS)-1 do
 begin
  if SS[i] = '(' then b:=b-1;
  if SS[i] = ')' then b:=b+1;
  if b = 0 then goto 3
 end;


if SS[Length(SS)] = ')' then
begin
if a = 2 then
begin
Delete(SS,1,1);
z:=z*(-1);
end;
Delete(SS,1,1);
Delete(SS,Length(SS),1);
goto 2;
end;
end;
3:
if z = -1 then  Neg:=1
else  Neg:=0;


endp:
end;





procedure TForevalH.FindExternalBracketNegPS(PS: PString);
label
2,3,outckl,endp;
var
b,i,j,z,a,NdelB,NDelE,L,Nbr,Nbrz,LS: Integer;
Fz: Boolean;
begin

//Упрощение выражений, обёрнутыми во множество внешних скобок, c учётом операции отрицания
//-(((-(-((-(-(Expr)))))))) -> -(Expr)

if PS^ = ''  then goto endp;


NDelB:=0;
NDelE:=0;
NBr:=0;
NBrz:=0;
L:=Length(PS^);
z:=1;
i:=1;
//for i := 1 to Length(S)-1 do
while i <= L-1 do
begin

    if (PS^[i] = '-') and (PS^[i+1] = '(')  then
    begin
       b:=-1;
       LS:=L-NDelE;
       for j := i+2 to LS do
       begin
         if PS^[j] = '(' then b:=b-1 else
         if PS^[j] = ')' then b:=b+1;
         if (j < LS) and (b = 0)  then goto outckl;
       end;
       if b = 0 then
       begin
         NDelB:=NDelB+2;
         inc(NDelE);
         //z:=z*(-1);
         z:=-z;
         inc(NBrz);
       end
       else goto outckl;  {must be error}
       i:=i+2;
    end
    else
    if (PS^[i] = '(')  then
    begin
       b:=-1;
       LS:=L-NDelE;
       for j := i+1 to LS do
       begin
         if PS^[j] = '(' then b:=b-1 else
         if PS^[j] = ')' then b:=b+1;
         if (j < LS) and (b = 0)  then goto outckl;
       end;
       if b = 0 then
       begin
         NDelB:=NDelB+1;
         inc(NDelE);
         inc(NBr);
       end
       else goto outckl;  {must be error}
       i:=i+1;
    end
    else
    goto outckl;
    //inc(i);

end;

outckl:
//if (NBr <= 1)  and (NBrz = 0)  then goto endp;//  (Expr) ->  (Expr)
//if (NBrz <= 1) and (NBr = 0)   then goto endp;// -(Expr) -> -(Expr)

if (NBrz >= 1) or (NBr >= 1) then
begin
  Delete(PS^,1,NDelB);
  Delete(PS^,Length(PS^)-NDelE+1,NDelE);

  if PS^ = '' then   {.375D}
  begin
    F_SyntaxErrorCode:=E_MISSING_EXPRESSION;
    goto endp;
  end;

  Fz:=False;
  if PS^[1] = '-' then
  begin
    Delete(PS^,1,1);
    //z:=z*(-1);
    Fz:=True;
  end;

  if (PS^ = '0')  then
  begin
    PS^:='0';
    goto endp;
  end
  else
  if (PS^ = '1') then
  begin
    if Fz = True then z:=-z;
    if z = -1 then PS^:='-1';
    goto endp;
  end
  else
  if (PS^ = '-1') then
  begin
    if z = -1 then PS^:='1';
    goto endp;
  end;

  if Fz = True then  PS^:='-'+PS^;
  if z = -1 then PS^:='-('+PS^+')';
  //if z = -1 then PS^:='(-('+PS^+'))';

   {
   if z = -1 then
    PS^:='(-('+PS^+'))';  }
  {
   if z = -1 then
    PS^:='(-('+PS^+'))'
   else
    PS^:='('+PS^+')';
   }

  //PS^:='('+PS^+')';
end
else
begin
  if PS^[1] = '-' then
  begin
    Delete(PS^,1,1);
    z:=z*(-1);
  end;

  if (PS^ = '0')  then
  begin
    PS^:='0';
    goto endp;
  end
  else
  if (PS^ = '1') then
  begin
    if z = -1 then PS^:='-1';
    goto endp;
  end
  else
  if (PS^ = '-1') then
  begin
    if z = -1 then PS^:='1';
    goto endp;
  end;

   //if z = -1 then  PS^:='(-('+PS^+'))';
    if z = -1 then  PS^:='-'+PS^;
end;

//PS^:='('+PS^+')';
endp:
{if (PS^ = '-0') or (PS^ = '(-0)') or (PS^ = '-(-0)') or (PS^ = '(0)') then begin PS^:='0'; z:=1;  end
else
if PS^ = '(1)' then PS^:='1';  }

{if z = -1 then  Neg:=1
else  Neg:=0; }


end;


