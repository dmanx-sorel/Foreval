    }

    if (NFunc1 = CM_IPWR) and (NFunc2 = CM_IPWR) then
    begin
        if (Node1^.AI = 2) and (Node2^.AI = 2) and (Node1^.TA2 = _IntForm) and (Node2^.TA2 = _IntForm)
           then  if CompareIntPower(Node1,Node2,@Sc,@Sc1)= False then  goto 2 else goto 3;
    end;


    if Sc <> Sc1  then  goto 2;

    3:
   {
   FindNonReplFuncPS(@Sc1,BH);  //in Arg       //sin(x+rand(x,y)+x)+sin(x+rand(x,y)+x)
   if BH = True then goto 2;
