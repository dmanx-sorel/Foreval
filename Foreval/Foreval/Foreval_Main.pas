      //code = _IntProd;
      MC:=MC*ic;  //-n

      //goto endp;
    end
    else
    begin
      code:=_NOT_FOUND;
      goto endp;
    end;

end;

IVP.A:=MC;
if Length(IVP.NV) = 0 then code := _IntConst else  code := _IntVar;

 {
if  Length(PN.NV) = 0 then
begin
 code := _IntConst;
 FIN.A:=MC;
end
else
if  Length(PN.NV) = 1 then
begin
 code := _IntVar;
 FIN.NV:=PN.NV[0];
 FIN.A:=MC;
end
else
 code := _IntVProd;
}


endp:
end;


procedure TForevalH.WriteFindExtArgInt1PS(PStr1: PString; place: Integer;  ND1: TDataNode; PointerVarMode:  Boolean;   var ND2: TDataNode; var BAnsw: Boolean);
label endp;
var                                  //исп-ся:  ND.BI, NV1, IC1,  NV2, IC2
code1,NV1,IC1: Integer;
AIVP1: TArrayIntVarProd;
begin
if F_SyntaxErrorCode <> 0 then goto endp;

F_EnablePointerMath:=PointerVarMode;

ND2:=ND1;
                                    {.367} //арифм указателей не отключается
if (F_IntegerOptimization = False) and (F_EnablePointerMath = False) then
begin
 ND2.TA1:=_NOT_FOUND;
 ND2.TA2:=_NOT_FOUND;
 BAnsw:=False;
 goto endp;
end;



SetLength(AIVP1,0);

BAnsw:=False;

FindExtArgIntPS(PStr1, code1, AIVP1, NV1, IC1);

if (code1 <> _NOT_FOUND)  then
begin
          if code1 = _IntConst then
          begin

            if place = _First then ND2.IC1:=IC1 else  ND2.IC2:=IC1; {_Second}

          end
          else
          if code1 = _IntVar then
          begin

            if place = _First then ND2.NV1:=NV1 else  ND2.NV2:=NV1; {_Second}

          end
          else
          if code1 = _IntForm then
          begin

            if place = _First then
            begin
              ND2.AIVP1:=Copy(AIVP1,0,Length(AIVP1));
              ND2.IC1:=IC1;
            end
            else    {_Second}
            begin
              ND2.AIVP2:=Copy(AIVP1,0,Length(AIVP1));
              ND2.IC2:=IC1;
            end;

          end ;


          //ND2.TA1:=code1;
          ND2.BI:=_IntArg;

          BAnsw:=True;
end;

    if place = _First then ND2.TA1:=code1 else ND2.TA2:=code1;  {_Second}

endp:
F_EnablePointerMath:=False;
end;




procedure TForevalH.WriteFindExtArgInt2PS(PStr1,Pstr2: PString; ND1: TDataNode; PointerVarMode:  Boolean;  var ND2: TDataNode; var BAnsw: Boolean);
label endp;              //исп-ся:  ND.BI, NV1, IC1,  NV2, IC2
var
code1,code2,NV1,NV2,IC1,IC2: Integer;
AIVP1,AIVP2: TArrayIntVarProd;
begin
if F_SyntaxErrorCode <> 0 then goto endp;

F_EnablePointerMath:=PointerVarMode;

ND2:=ND1;

if F_IntegerOptimization = False then
begin
 ND2.TA1:=_NOT_FOUND;
 ND2.TA2:=_NOT_FOUND;
 BAnsw:=False;
 goto endp;
end;


SetLength(AIVP1,0);
SetLength(AIVP2,0);

BAnsw:=False;

FindExtArgIntPS(PStr1, code1, AIVP1, NV1, IC1);
FindExtArgIntPS(PStr2, code2, AIVP2, NV2, IC2);
if (code1 <> _NOT_FOUND) and (code2 <> _NOT_FOUND) then
begin
          if code1 = _IntConst then
          begin
            ND2.IC1:=IC1;
          end
          else
          if code1 = _IntVar then
          begin
            ND2.NV1:=NV1;
          end
          else
          if code1 = _IntForm then
          begin
            ND2.AIVP1:=Copy(AIVP1,0,Length(AIVP1));
            ND2.IC1:=IC1;
          end ;

           if code2 = _IntConst then
          begin
            ND2.IC2:=IC2;
          end
          else
          if code2 = _IntVar then
          begin
            ND2.NV2:=NV2;
          end
          else
          if code2 = _IntForm then
          begin
            ND2.AIVP2:=Copy(AIVP2,0,Length(AIVP2));
            ND2.IC2:=IC2;
          end ;

          ND2.TA1:=code1;
          ND2.TA2:=code2;
          ND2.BI:=_IntArg;

          BAnsw:=True;
end;

endp:
 F_EnablePointerMath:=PointerVarMode;
end;




procedure TForevalH.WriteFindExtArgInt2AnyPS(PStr1,Pstr2: PString; ND1: TDataNode;  var ND2: TDataNode; var code: Integer);
label endp;
var                                                                                        //code = 3 (_Both)
code1,code2,NV1,NV2,IC1,IC2: Integer;                                                      //code = 1 (_First)
AIVP1,AIVP2: TArrayIntVarProd;                                                             //code = 2 (_Second)
begin                                                                                      //code = _NOT_FOUND
if F_SyntaxErrorCode <> 0 then goto endp;

ND2:=ND1;

if F_IntegerOptimization = False then
begin
 ND2.TA1:=_NOT_FOUND;
 ND2.TA2:=_NOT_FOUND;
 code:=_NOT_FOUND;
 goto endp;
end;


SetLength(AIVP1,0);
SetLength(AIVP2,0);

code:=_NOT_FOUND;

FindExtArgIntPS(PStr1, code1, AIVP1, NV1, IC1);
FindExtArgIntPS(PStr2, code2, AIVP2, NV2, IC2);

if (code1 <> _NOT_FOUND)  then
begin
          if code1 = _IntConst then
          begin
            ND2.IC1:=IC1;
          end
          else
          if code1 = _IntVar then
          begin
            ND2.NV1:=NV1;
          end
          else
          if code1 = _IntForm then
          begin
            ND2.AIVP1:=Copy(AIVP1,0,Length(AIVP1));
            ND2.IC1:=IC1;
          end ;

          ND2.TA1:=code1;

          //ND2.BI:=_IntArg;

end ;

if  (code2 <> _NOT_FOUND) then
begin

           if code2 = _IntConst then
          begin
            ND2.IC2:=IC2;
          end
          else
          if code2 = _IntVar then
          begin
            ND2.NV2:=NV2;
          end
          else
          if code2 = _IntForm then
          begin
            ND2.AIVP2:=Copy(AIVP2,0,Length(AIVP2));
            ND2.IC2:=IC2;
          end ;


          ND2.TA2:=code2;
         // ND2.BI:=_IntArg;

end;

if (code1 <> _NOT_FOUND) and (code2 <> _NOT_FOUND) then code:=_Both
else
if (code1 <> _NOT_FOUND)  then code:=_First
else
if (code2 <> _NOT_FOUND) then code:=_Second;



endp:
end;




procedure TForevalH.FindExtFuncIntArg(var  ND: TDataNode; var EOFN: Boolean);
label endp,nxtf;
var
IntArg: Boolean;
nf,TM,TV,L,NL,ExtFunc,NFunc,IntF: Integer;
S: String;
begin
{Перехватывает целочисленные (и с указателями) аргументы вида _LDINTFORM только для внешних ф-ий}
EOFN:=False;

InitNode(ND);
ExtFunc:=Tree^.ExtFunc;




  //защита AV
  if (ExtFunc >= 0) and (ExtFunc <= High(Alg.ExFunc)) then
  begin
    //IntArg:=True;
    S:=Tree^.Expression;
    NL:=Tree^.NL;                        // ExtFunc(...,NL,...)
    L:=Length(Alg.ExFunc[Extfunc].Func);


    for nf := 0 to L-1 do    //если аргументы всех overload ф-ий (ExtFunc) с порядковым номером NL являются типом _Integer, то поиск IntForm
    begin

         if NL <= Alg.ExFunc[ExtFunc].Func[nf].NArg then
         begin
            TV:=Alg.ExFunc[ExtFunc].Func[nf].TV[NL-1];
            TM:=Alg.ExFunc[ExtFunc].Func[nf].TM[NL-1];
            //if (TV = T_Real) and (TM = _Integer) then begin end else begin  goto endp; end;
            if ((TV = T_Real) and (TM = _Integer)) or (TV = T_Pointer) then begin end else begin  goto endp; end;  {.367}
         end
         else goto nxtf{endp};  {.379}

         //if TV = T_Pointer then F_EnablePointerMath:=True;      {.367}
         if TV = T_Pointer then WriteFindExtArgInt1PS(@S, _First, ND, PointerVarForm, ND, IntArg)
           else WriteFindExtArgInt1PS(@S, _First, ND, IntegerVarForm, ND, IntArg);
         //F_EnablePointerMath:=False;                            {.367}
         if IntArg = True then
         begin
           ND.N:=0;
           ND.COP:=_LDINTFORM;
           ND.NFunc:=0;
           EOFN:=True;
         end;

      nxtf:
    end;

  end;


endp:
end;

