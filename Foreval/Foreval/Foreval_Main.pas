procedure TForevalH.FindReIm(S: String; var S1:String; var TF: Integer);
var
r,i: Integer;
SR,SI,ST: String;
begin
  //r:=pos('.re',LowerCase(S));
  r:=pos('.re',S);
  if (r <> 0) and (r = Length(S)-2) then
  begin
   TF:=_RE; S1:=Copy(S,1,Length(S)-3);
  end
  else
  begin
   //i:=pos('.im',LowerCase(S));
   i:=pos('.im',S);
   if (i <> 0) and (i = Length(S)-2) then
   begin
    TF:=_IM; S1:=Copy(S,1,Length(S)-3);
   end
   else
   begin
    S1:=S; TF:=0;
   end;
  end;



end;



procedure TForevalH.FindReImPS(PS: PString; var TF: Integer);
var
r,i: Integer;
SR,SI,ST: String;
begin
  //r:=pos('.re',LowerCase(S));
  r:=pos('.re',PS^);
  if (r <> 0) and (r = Length(PS^)-2) then
  begin
   TF:=_RE;
   Delete(PS^,Length(PS^)-2,3);
   //S1:=Copy(S,1,Length(PS^)-3);
  end
  else
  begin
   //i:=pos('.im',LowerCase(S));
   i:=pos('.im',PS^);
   if (i <> 0) and (i = Length(PS^)-2) then
   begin
    TF:=_IM;
    Delete(PS^,Length(PS^)-2,3);
    //S1:=Copy(S,1,Length(PS^)-3);
   end
   else
   begin
    //S1:=S;
    TF:=0;
   end;
  end;
end;




procedure TForevalH.FindExprTypePS(PS: PString; var ExprType: Integer);
  //ExprType = _ComplexVar,  _ComplexVarRE, ComplexVarIM, _FloatVar, _IntVar  , _Const, _IntArray, _FloatArray, _IntForm , _NOT_FOUND,
var
  nf,ni: Integer;
  FD: extended;
  TypeS: Integer;
  code: Integer;
  AIVP: TArrayIntVarProd;
  NV,IC,TC: Integer;
  Sv,Sa,Sc: String;
  FH1: Boolean;
begin
ExprType:=_NOT_FOUND;

   FindReIm(PS^,Sc,TC);
   FindVarConstPS(@Sc,nf,FD,TypeS); //TypeS = _ComplexVar, _FloatVar, _IntVar (nf) , _Const(number: FD), _NOT_FOUND
   if TypeS <> _NOT_FOUND then
   begin
     ExprType:=TypeS;
     if (TypeS = _ComplexVar) and (TC = _RE) then   ExprType:=_ComplexVarRE else
     if (TypeS = _ComplexVar) and (TC = _IM) then   ExprType:=_ComplexVarIM;
   end
   else    //find array, IntForm
   begin
      FindFuncBrPS(PS,'[',']',Sv,Sa,FH1);
      if FH1 = True then
      begin
          FindVarPS(@Sv,ni);

          if ni <> -1 then //ni - vector
          begin
             if Alg.Obj[ni].TypeF = T_Array then
             begin
                if (Alg.Obj[ni].MType =  _Double) or (Alg.Obj[ni].MType =  _Extended) then   ExprType:=_FloatArray
                else
                if Alg.Obj[ni].MType =  _Integer   then   ExprType:=_IntArray;
             end;
          end;
      end
      else //find  _IntForm
      begin

           FindExtArgIntPS(PS,code, AIVP, NV,IC);
           {
               code = _IntConst   = IC
               code = _IntVar     = NV
               code = _IntForm    = a1*I1*...Ik+a2*I1*...*In+...+am*I1*...*Im+CI;  AIVP[]=ArrayOf(IVP); IVP.NV=ArrayOf(nv); IVP.A = ai;
               code = _NOT_FOUND;
           }
           ExprType:=code;

      end;
   end;

end;




procedure TForevalH.FindVarConstPS(PS: PString;  var nf: Integer; var FD: extended; var TypeS: Integer);
label endp;
var
S2: String;
ni,TV: Integer;
Re,Im: TFloat;
SB: Boolean;
begin
nf:=_NOT_FOUND;
FD:=0;
TypeS:=_NOT_FOUND;

               //TypeS = _ComplexVar, _FloatVar, _IntVar (nf) , _Const(number: FD), _NOT_FOUND
if F_SyntaxErrorCode <> 0 then goto endp;


FindVarPS(PS,ni); //{P}
if ni >= 0 then
begin
 if  (Alg.Obj[ni].TypeF = T_Complex) then
 begin
  nf:=ni;
  TypeS:=_ComplexVar;
 end
 else
 if (Alg.Obj[ni].TypeF = T_Real) and (Alg.Obj[ni].MType = _Integer) then
 begin
  nf:=ni;
  TypeS:=_IntVar;
 end
 else
 if (Alg.Obj[ni].TypeF = T_Real)  then
 begin
  nf:=ni;
  TypeS:=_FloatVar;
 end
end
else
begin
 SubstParamPS(PS,Re,Im,TV);     {.311}
 if TV = T_Real then
 begin
  FD:=Re;
  TypeS:=_Const;
 end;
end;

endp:
end;



{.361}
procedure TForevalH.FindVarConstCxPS(PS: PString;  var nf: Integer; var Re,Im: extended; var TypeS, TypeC: Integer);
label endp;
var
S2: String;
ni,TV,TC: Integer;
SB: Boolean;
CX: TComplex;
begin
nf:=_NOT_FOUND;
//FD:=0;
TypeS:=_NOT_FOUND;
Re:=0;
Im:=0;
{
 "i" задана ,как переменная, а определяется либо как переменная: i, либо как константа: i, -i, 2i, a+bi,...    !!!
}

               //TypeS = _ComplexVar, _FloatVar, _IntVar (nf) , _Const(real number: Re), _ConstComplex, _NOT_FOUND
if F_SyntaxErrorCode <> 0 then goto endp;


FindVarPS(PS,ni); //{P}
if ni >= 0 then
begin
 if  (Alg.Obj[ni].TypeF = T_Complex) then
 begin
  nf:=ni;
  TypeS:=_ComplexVar;
  //исключение, т.к. "i" задана ,как переменная, а используется, как константа
  if (PS^ = S_IM_UNIT) and (F_RecoverImUnit = False) then
  begin
    Re:=0;
    Im:=1;
    TypeC:=C_Image;
  end;
 end
 else
 if (Alg.Obj[ni].TypeF = T_Real) and (Alg.Obj[ni].MType = _Integer) then
 begin
  nf:=ni;
  TypeS:=_IntVar;
 end
 else
 if (Alg.Obj[ni].TypeF = T_Real)  then
 begin
  nf:=ni;
  TypeS:=_FloatVar;
 end
end
else
begin
 //SubstParamPS(PS,Re,Im,TV);
 SubstParamCXPS(PS,CX, TC);
  //SB=C_None{no},C_Real(real),C_Image(image),C_Complex(complex)
 if TC = C_None then
 begin
   TypeS:=_NOT_FOUND;
   TypeC:=C_None;
 end
 else
 if TC = C_Real then
 begin
  Re:=CX.re;
  Im:=0;
  TypeS:=_Const;      //для совместимости с   FindVarConstPS
  TypeC:=C_Real;
 end
 else
 if TC = C_Image then
 begin
  Re:=0;
  Im:=Cx.im;
  TypeS:=_ConstComplex;
  TypeC:=C_Image;
 end
 else
 if TC = C_Complex then
 begin
  Re:=Cx.re;
  Im:=Cx.im;
  TypeS:=_ConstComplex;
  TypeC:=C_Complex;
 end;

end;

endp:
end;




