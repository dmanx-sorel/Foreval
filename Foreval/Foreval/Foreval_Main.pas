procedure TForevalH.LineForm1;    //use: EAX,EBX,ECX
label endp;
var
LT,L,LA,i: Integer;
ICF,IM,LN,IM1,IM2,HM,tva,tma: Integer;
ra,LF1: Boolean;
AddrI,AddrI1,AddrI2: TAddress;
  j: Integer;
begin
//LF1:=True: LineForm(1 order)   a1*i1+a2*i2+...+an*in+ICF;

ICF:=Trunc(GNode^.FD);
L:=Length(GNode^.AIVP1);
ra:=false;

if L = 0 then     //const
begin
   MOVCREG(R_EAX,ICF);
end
else
//if L = 1 then    //a*i+b
begin
 //L = 1:     a*i+b

 IM:=GNode^.AIVP1[0].A;

 GetVar1(GNode^.AIVP1[0].NV[0],AddrI,tva,TMA);


 if ICF <> 0 then
 begin
   MOVCREG(R_EAX,ICF);
   ra:=true;
 end;

 if ra = true then
 begin   //b+a*i
    MOVMREG(R_EBX,AddrI);
    IMULCREG(R_EBX,abs(IM));
    if IM < 0 then SUBREG(R_EAX,R_EBX) else
                   ADDREG(R_EAX,R_EBX);
 end
 else  //a*i
 begin
   MOVMREG(R_EAX,AddrI);
   IMULCREG(R_EAX,IM);
 end;

 if L = 1 then goto endp;

//L > 1: a1*i1+a2*i2+...+ICF
 (*
 for i := 1 to L - 1 do
 begin
    IM:=GNode^.AIVP1[i].A;
    AddrI:=GNode^.AIVP1[i].NV[0];

    MOVMREG(R_EBX,AddrI);
    IMULCREG(R_EBX,abs(IM));
    if IM < 0 then SUBREG(R_EAX,R_EBX) else
                   ADDREG(R_EAX,R_EBX);

 end;
 *)

 HM:=L-1;
 LN:=HM div 2;

   i:=1;
   while i <= 2*LN do
   begin
     IM1:=GNode^.AIVP1[i].A; GetVar1(GNode^.AIVP1[i].NV[0],AddrI1,tva,TMA);//AddrI1:=GNode^.AIVP1[i].NV[0];
     IM2:=GNode^.AIVP1[i+1].A; GetVar1(GNode^.AIVP1[i+1].NV[0],AddrI2,tva,TMA);//AddrI2:=GNode^.AIVP1[i+1].NV[0];




     if IM1 = 1 then
      ADDMREG(R_EAX,AddrI1)
     else
     if IM1 = -1 then
      SUBMREG(R_EAX,AddrI1)
     else
     begin
      MOVMREG(R_EBX,AddrI1);
      IMULCREG(R_EBX,abs(IM1));
     end;



     if IM2 = 1 then
      ADDMREG(R_EAX,AddrI2)
     else
     if IM2 = -1 then
      SUBMREG(R_EAX,AddrI2)
     else
     begin
       MOVMREG(R_ECX,AddrI2);
       IMULCREG(R_ECX,abs(IM2));
     end;



     if abs(IM1) > 1 then
     begin
       if (IM1 < 0) then SUBREG(R_EAX,R_EBX) else
                         ADDREG(R_EAX,R_EBX);
     end;


     if abs(IM2) > 1 then
     begin
       if (IM2 < 0) then SUBREG(R_EAX,R_ECX) else
                         ADDREG(R_EAX,R_ECX);
     end;


     i:=i+2;
   end;

   if HM mod 2 <> 0 then
   begin
      IM:=GNode^.AIVP1[HM].A; GetVar1(GNode^.AIVP1[HM].NV[0],AddrI,tva,TMA);//AddrI:=GNode^.AIVP1[HM].NV[0];

       if IM = 1 then
         ADDMREG(R_EAX,AddrI)
       else
       if IM = -1 then
         SUBMREG(R_EAX,AddrI)
       else
       begin
         MOVMREG(R_EBX,AddrI);
         IMULCREG(R_EBX,abs(IM));
       end;

       if abs(IM) > 1 then
       begin
          if (IM < 0) then SUBREG(R_EAX,R_EBX) else
                           ADDREG(R_EAX,R_EBX);
       end;
   end;

end;




endp:
end;



//vd[-k-j+5-k*j*3*j*2-j*l*n-k-j*3+n*m*4-k*n*j-l*m*k*5-j+l+k*m*2-4*k*j*l-150-j*m+k*n*3-m+l*2-k*3+50*k*j+100]

procedure TForevalH.LineFormN(AIVP1: TArrayIntVarProd; IC: Integer);    //use: EAX,EBX,ECX,EDX

   function MulIntVar(ANV: TArrayI;  Reg,A: Integer): Boolean;
   var
    L,j,tva,tma: Integer;
    AddrI: TAddress;
    Answ: Boolean;
   begin
     Answ:=False;
     L:=Length(ANV);

     if L > 1 then                     //A*I1*...In
     begin
          GetVar1(ANV[0],AddrI,tva,TMA);
          MOVMREG(Reg,AddrI);   //I1->Reg

          for j := 1 to  L-1 do           //I1*...*In
          begin
             GetVar1(ANV[j],AddrI,tva,TMA);
             IMULMREG(Reg,AddrI);
          end;

          (*
          if A = 1 then             //*A
            ADDREG(R_EAX,Reg)
          else
          if A = -1 then
            SUBREG(R_EAX,Reg)
          else
          begin
            IMULCREG(Reg,abs(A));
          end;
          *)

          {.357}
          //if abs(A) <> 1 then   IMULCREG(Reg,abs(A));
          IMULCREG(Reg,A);

          Answ:=True;
     end;

     MulIntVar:=Answ;
   end;


label endp;
var
LT,L,LA,i,Reg: Integer;
ICF,IM,LN,IM1,IM2,HM,tva,tma: Integer;
ra,LF1: Boolean;
AddrI,AddrI1,AddrI2: TAddress;
  j: Integer;
begin
//LF1:=True: LineForm(1 order)   A1*I1*..*Ik+A2*I1*...*In+...+An*I1*...*Ij+ICF;
{
ICF:=Trunc(GNode^.FD);        //ICF=B
L:=Length(GNode^.AIVP1);   }

if SaveSimpleLineForm2(AIVP1, IC) = True then goto endp;     {.367}

ICF:=IC;
L:=Length(AIVP1);

ra:=false;

if L = 0 then     //const
begin
   MOVCREG(R_EAX,ICF);
end
else
//if L = 1 then    //a*i+b
begin
 //L = 1:     A*I1+B, A*I1*...*In+B

 IM:={GNode^.}AIVP1[0].A;

 GetVar1({GNode^.}AIVP1[0].NV[0],AddrI,tva,TMA);


 if ICF <> 0 then
 begin
   MOVCREG(R_EAX,ICF);
   ra:=true;
 end;

 if ra = true then
 begin   //b+a*i , b+a*i1*...*in ,
    //MOVMREG(R_EBX,AddrI);
    //IMULCREG(R_EBX,abs(IM));
    if MulIntVar({GNode^.}AIVP1[0].NV,R_EBX,abs(IM)) = False then
    begin

         if IM = 1 then
            ADDMREG(R_EAX,AddrI)
          else
          if IM = -1 then
            SUBMREG(R_EAX,AddrI)
          else
          begin
            MOVMREG(R_EBX,AddrI);
            IMULCREG(R_EBX,abs(IM));
          end;

    end
    else
     begin
          if IM = 1 then             //*A
            ADDREG(R_EAX,R_EBX)
          else
          if IM = -1 then
            SUBREG(R_EAX,R_EBX)
     end;

     if abs(IM) > 1 then
     begin
       if (IM < 0) then  SUBREG(R_EAX,R_EBX) else
                         ADDREG(R_EAX,R_EBX);
     end;
 end
 else  //a*i, a*i1*...*in
 begin
   //MOVMREG(R_EAX,AddrI);                       {.357}  //k=-j*n;k
   if MulIntVar({GNode^.}AIVP1[0].NV,R_EAX,{abs(IM)}IM) = False then
   begin
    MOVMREG(R_EAX,AddrI);
    IMULCREG(R_EAX,IM);
   end;

   //IMULCREG(R_EAX,IM);
 end;

 if L = 1 then goto endp;

//L > 1: A1*I1*..*Ik+A2*I1*...*In+...+An*I1*...*Ij+ICF;


 HM:=L-1;
 LN:=HM div 2;

   i:=1;
   while i <= 2*LN do       //multiplication twice at a time  (EBX,ECX)
   begin

    //Reult -> EAX

     // (1) -> EBX   (i)
     IM1:={GNode^.}AIVP1[i].A; GetVar1({GNode^.}AIVP1[i].NV[0],AddrI1,tva,TMA);//AddrI1:=GNode^.AIVP1[i].NV[0];
     // EBX
     Reg:=R_EBX;
     if MulIntVar({GNode^.}AIVP1[i].NV,Reg,abs(IM1)) = False then  // A*I1*...In,  A*I1;
     begin
     // A*I1

          if IM1 = 1 then
            ADDMREG(R_EAX,AddrI1)
          else
          if IM1 = -1 then
            SUBMREG(R_EAX,AddrI1)
          else
          begin
            MOVMREG(Reg,AddrI1);
            IMULCREG(Reg,abs(IM1));
          end;

     end
     else
     begin

     {if IM1 = 1 then
            ADDMREG(R_EAX,AddrI1)
          else
          if IM1 = -1 then
            SUBMREG(R_EAX,AddrI1)  }

          if IM1 = 1 then             //*A
            ADDREG(R_EAX,Reg)
          else
          if IM1 = -1 then
            SUBREG(R_EAX,Reg)
          {else
          begin
            IMULCREG(Reg,abs(A));
          end; }

     end;





     // (2) -> ECX   (i+1)
     IM2:={GNode^.}AIVP1[i+1].A; GetVar1({GNode^.}AIVP1[i+1].NV[0],AddrI2,tva,TMA);//AddrI2:=GNode^.AIVP1[i+1].NV[0];
     // ECX
     Reg:=R_ECX;
     if MulIntVar({GNode^.}AIVP1[i+1].NV,Reg,abs(IM2)) = False then  // A*I1*...In,  A*I1;
     begin
     // A*I1
            if IM2 = 1 then
            ADDMREG(R_EAX,AddrI2)
          else
          if IM2 = -1 then
            SUBMREG(R_EAX,AddrI2)
          else
          begin
            MOVMREG(R_ECX,AddrI2);
            IMULCREG(R_ECX,abs(IM2));
          end;
     end
     else
     begin
          if IM2 = 1 then
            ADDREG(R_EAX,Reg)
          else
          if IM2 = -1 then
            SUBREG(R_EAX,Reg)
     end;



     if abs(IM1) > 1 then
     begin
       if (IM1 < 0) then SUBREG(R_EAX,R_EBX) else
                         ADDREG(R_EAX,R_EBX);
     end;


     if abs(IM2) > 1 then
     begin
       if (IM2 < 0) then SUBREG(R_EAX,R_ECX) else
                         ADDREG(R_EAX,R_ECX);
     end;



     (*
     {I1***In}
     HMV:=Length(GNode^.AIVP1[i].NV);
     if HMV > 1 then                     //a*I1*...In
     begin

          MOVMREG(R_EBX,AddrI1);
          for j := 1 to  HMV do           //I1*...*In
          begin
             GetVar(GNode^.AIVP1[i].NV[j],AddrI,tva,TMA);
             IMULMREG(R_EBX,AddrI);
          end;

          if IM1 = 1 then             //*A
            ADDMREG(R_EAX,R_EBX)
          else
          if IM1 = -1 then
            SUBMREG(R_EAX,R_EBX)
          else
          begin
            IMULCREG(R_EBX,abs(IM1));
          end;

     end
     else //a*I1
     begin
          if IM1 = 1 then
            ADDMREG(R_EAX,AddrI1)
          else
          if IM1 = -1 then
            SUBMREG(R_EAX,AddrI1)
          else
          begin
            MOVMREG(R_EBX,AddrI1);
            IMULCREG(R_EBX,abs(IM1));
          end;
     end;
     *)
     {*****************************}





     //IM2:=GNode^.AIVP1[i+1].A; GetVar(GNode^.AIVP1[i+1].NV[0],AddrI2,tva,TMA);//AddrI2:=GNode^.AIVP1[i+1].NV[0];

     (*
     {I1***In}
     HMV:=Length(GNode^.AIVP1[i+1].NV);
     if HMV > 1 then                     //a*I1*...In
     begin

          MOVMREG(R_ECX,AddrI2);
          for j := 1 to  HMV do           //I1*...*In
          begin
             GetVar(GNode^.AIVP1[i].NV[j],AddrI,tva,TMA);
             IMULMREG(R_ECX,AddrI);
          end;

          if IM2 = 1 then             //*A
            ADDMREG(R_EAX,R_ECX)
          else
          if IM2 = -1 then
            SUBMREG(R_EAX,R_ECX)
          else
          begin
            IMULCREG(R_ECX,abs(IM2));
          end;

     end
     else //a*I1
     begin
          if IM2 = 1 then
            ADDMREG(R_EAX,AddrI2)
          else
          if IM2 = -1 then
            SUBMREG(R_EAX,AddrI2)
          else
          begin
            MOVMREG(R_ECX,AddrI2);
            IMULCREG(R_ECX,abs(IM2));
          end;
     end;
     *)
     {*****************************}


      {

     if abs(IM1) > 1 then
     begin
       if (IM1 < 0) then SUBREG(R_EAX,R_EBX) else
                         ADDREG(R_EAX,R_EBX);
     end;


     if abs(IM2) > 1 then
     begin
       if (IM2 < 0) then SUBREG(R_EAX,R_ECX) else
                         ADDREG(R_EAX,R_ECX);
     end;
     }

     i:=i+2;
   end;

   if HM mod 2 <> 0 then    //Last elements
   begin
      IM:={GNode^.}AIVP1[HM].A; GetVar1({GNode^.}AIVP1[HM].NV[0],AddrI,tva,TMA);//AddrI:=GNode^.AIVP1[HM].NV[0];
      Reg:=R_EBX;
      if MulIntVar({GNode^.}AIVP1[HM].NV,Reg,abs(IM)) = False then  // A*I1*...In,  A*I1;
      begin
      // A*I1

          if IM = 1 then
            ADDMREG(R_EAX,AddrI)
          else
          if IM = -1 then
            SUBMREG(R_EAX,AddrI)
          else
          begin
            MOVMREG(R_EBX,AddrI);
            IMULCREG(R_EBX,abs(IM));
          end;

      end
      else
      begin
          if IM = 1 then
            ADDREG(R_EAX,Reg)
          else
          if IM = -1 then
            SUBREG(R_EAX,Reg)
      end;

      {
       if IM = 1 then
         ADDMREG(R_EAX,AddrI)
       else
       if IM = -1 then
         SUBMREG(R_EAX,AddrI)
       else
       begin
         MOVMREG(R_EBX,AddrI);
         IMULCREG(R_EBX,abs(IM));
       end; }

       if abs(IM) > 1 then
       begin
          if (IM < 0) then SUBREG(R_EAX,R_EBX) else
                           ADDREG(R_EAX,R_EBX);
       end;
   end;

end;




endp:
end;

