       //S:='(('+SD1+')*('+S2+')-('+S1+')*('+SD2+'))/(sqr('+S2+')*(1+sqr(('+S1+')/('+S2+'))))';
       //S:='(('+SD1+')'+'-(('+SD2+')*(('+S1+')/('+S2+'))))/(('+S2+')*(1+'+'sqr(('+S1+')/('+S2+'))'+'))';


