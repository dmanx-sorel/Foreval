procedure TForevalH.InitSequentList;
label endp;
var
Tree,NFirst,NSecond,H: PNode;
Num: Cardinal;
S: String;
begin
  {
   создание последовательного линейного списка чтения дерева и инициализация соответствующих ссылок Next,Prev
   первый узел последовательного линейного списка = нижний левый в дереве.
  }

   Num:=1;
   LastNode:=BeginTree;

   {Last - upper node, top of tree:}
   Tree:=BeginTree;
   Tree^.Next:=nil;


   {1 node:}
   Tree:=GetLowLeftNode(Tree);
   FirstNode:=Tree;
   Tree^.Prev:=nil;
   Tree^.NNode:=Num; inc(Num);
   NFirst:=Tree;

   while Tree^.Pr <> nil do
   begin
      Tree:=GetNextNode(Tree);
      NSecond:=Tree;
      NSecond^.Prev:=NFirst;
      NFirst^.Next:=NSecond;
      NSecond^.NNode:=Num; inc(Num);
      NFirst:=NSecond;
   end;

   {Last:}
   Tree^.NNode:=Num;

   F_SequentList:=True;



(*
      //L:int=len(vd);L
      //L=len(vd);L

//Tree:=FirstNode;
Tree:=GetLowLeftNode(Tree);
while Tree <> nil do
begin
 H:=Tree^.Next;
 FreeNode(Tree);
 Tree:=H;
end;
FirstNode:=nil;
*)


endp:
end;




