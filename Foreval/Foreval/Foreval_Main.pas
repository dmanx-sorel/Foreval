procedure TForevalH.DinamicLoadOptimizator;
{
 Вычисляет и задаёт тип сохранения результата текущего узла в FPU (_FPU) или памяти (_MEM)
  в зависимости от заданной глубины стека FPU: F_StackDeep (макс=8)
  посредством условной компиляции (без генерации кода)
}
label 1,beginp,endp;
var
i,Pn,PML,ML,CNT,k,t2: Integer;
S,S1: String;
Node,MNode,MTNode: PNode;
begin
if F_SyntaxErrorCode <> 0 then goto endp;
if F_InternalError <> 0 then goto endp; {.322}

InitCompiler(M_DinamicLoad);
{F_Opt:=True;}
F_Mode:=M_DinamicLoad;
Db_DinLoadNMem:=0;
//if  F_DinamicLoadOptimization = _Enable then goto beginp;
//if  F_DinamicLoadOptimization = _Auto then
begin
 Db_DinLoadSDeep:=E_GetMaxStackEx;
 if Db_DinLoadSDeep > F_StackDeep then goto beginp else goto endp;
end;


//LFunc:=Length(Interp);     {.233}
beginp:
//CNT:=0;
if F_SyntaxErrorCode <> 0 then goto endp;
PML:=0; PN:=0;  MNode:=nil;
1:
InitCompiler(M_DinamicLoad);
Node:=FirstNode;
//for i:=1 to LFunc-1 do
while Node <> nil do
begin
  //S:=Interp[i].Expression;      //db

  {if Node^.NNode = 95 then
  begin
    S:=Node^.Expression;
  end; }

  ML:=E_GetMaxLoadDL(Node);

  {если переполнение стека в рез-те выталкивания предыдущей комманды (I-1) не устранено, то
   продолжить выталкивание предыдущих комманд (I-2,...1) по одной до тех пор, пока есть
   переполнение в данной комманде (I)}
  if {(ML = PML)}(ML > F_StackDeep) and (MNode = Node{PN = I}) then
  begin

    //MTNode:=Node^.Prev^.Prev;

    {.345}
    MTNode := nil;
    if Node <> nil then
      if Node^.Prev <> nil then
        if Node^.Prev^.Prev <> nil then
           MTNode:=Node^.Prev^.Prev;

    //for k:=I-2 downto 1 do
    while MTNode <> nil do
    begin
       //if Interp[k].SData = _FPU then
       if MTNode.SData = _FPU then
       begin
         if EnableDL(MTNode{k}) then
         begin
          SetLoadMem(MTNode{k});
          goto 1;
         end;
       end;
       MTNode:=MTNode^.Prev;
    end;
    Db_DinLoadOverFlow:=True;
    //защита от зацикливания (возникает, если невозможно сделать загрузку стека < F_StackDeep:
    goto endp;
  end;

  {если произошло переполнение стека в текущем узле, то рез-т передыдущей (I-1) комманды
  выталкивается в память: (т.о. уменьшается на 1 загрузка стека)}
  if ML > F_StackDeep then
  begin
   if {I = 1} Node^.Prev = nil {Node^.NNode = 1} then
   begin
    Db_DinLoadOverFlow:=True;
    //защита от зацикливания:
    goto endp;
   end;
   if EnableDL(Node^.Prev{I-1}) then
   begin
    SetLoadMem(Node^.Prev{I-1});
    //PML:=ML;
    MNode:=Node;//PN:=I;
    goto 1;
   end;
  end;


  Node:=Node^.Next;
end;


endp:
if  (F_SaveInFPU = True) and (Db_DinLoadOverFlow = True) then
begin
  N_Stack:=0;
  _MaxStack:=0;
  ES_OverFlow:=False;
  F_SaveInFPU:=False;
  //FreeData;
  //Db_OverFlow:=True;
end;

//F_Opt:=False;
end;





