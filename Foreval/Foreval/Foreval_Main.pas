function TForevalH.FindAddrObj(PS: PString;  TypeObj: Integer; ND: TDataNode; var ND1: TDataNode): Boolean;
label endp;      //TypeObj =   tobj_any, tobj_func, tobj_array, tobj_var    {.378}
var
 NameObj: String;
 NFunc,NF,ni,TV,TypeF: Integer;
 BH: Boolean;
 Addr,AddrIM: TAddress;
 MType,ReIm,ImU: Integer;
begin
  BH:=False;

    //NameObj:=Copy(PS^,2,Length(PS^)-1);

    ND1:=ND;

    //(@Func)
    {.378}
    if (TypeObj = tobj_any) or (TypeObj =  tobj_Func)   then
    begin

      FindFuncPS(PS,NFunc);
      if NFunc <> -1 then
      begin
        //if Alg.ExFunc[NFunc].Func[0].NArg = 0 then   //Call(@Func): только ф-ии без аргументов!
        begin

           //ND1.Addr1:=Alg.ExFunc[NFunc].Func[0].Addr;   //первая из списка!!
           FindFuncB(PS^,0,_ANY,NFunc,NF);   {.378} //искать вначале func/proc без аргументов
           if NF = _NOT_FOUND then NF:=0;
           ND1.Addr1:=Alg.ExFunc[NFunc].Func[NF].Addr;

           //ND1.NFunc:=NF; {.375B} //!!! может менять NFunc в передаваемой ND !!!
           ND1.IsReplExpr:=Alg.ExFunc[NFunc].ReplFunc; {.375B}
           ND1.AI:=tc_AddrFunc; //@Func
           ND1.N:=0;
           BH:=True;
           F_CallFuncPresent:=True;
        end;

        goto endp;
      end;

    end;


  (*
    //(@Var)
    FindVarPS({@NameObj}PS,ni);
    if ni <> -1 then
    begin
       TV:=Alg.Obj[ni].TypeF;

       if (TV = T_Array)  then
       begin
          ND1.NV1:=ni;
          ND1.Addr1:=Alg.Obj[ni].Addr;
          ND1.AI:=_AddrArray;
          ND1.N:=0;
          BH:=True;
          goto endp;
       end;

       if (TV = T_Real)  then
       begin
          ND1.NV1:=ni;
          ND1.Addr1:=Alg.Obj[ni].Addr;
          ND1.AI:=_AddrVar;
          ND1.N:=0;
          BH:=True;
          goto endp;
       end;

       if (TV = T_Complex)  then
       begin
          ND1.NV1:=ni;
          ND1.Addr1:=Alg.Obj[ni].Addr;
          ND1.AI:=_AddrVar;
          ND1.N:=0;
          BH:=True;
          goto endp;
       end;

       goto endp;
    end;

    *)

    //             TypeObj =   tobj_any, tobj_array, tobj_var
    //(@VarCx.re   @VarCx.im)
    FindVarExPS(PS, ni, Addr, AddrIM, TypeF, MType, ReIm, ImU);    //ReIm = _RE, _IM , 0
    if ni <> _ABSENT then
    begin
      if (TypeF = T_Array) and ((TypeObj =   tobj_any) or  (TypeObj =   tobj_array)) then
       begin
          ND1.NV1:=ni;
          ND1.Addr1:=Addr;//Alg.Obj[ni].Addr;
          ND1.AI:=tc_AddrArray;
          ND1.N:=0;
          BH:=True;
          goto endp;
       end;

       if (TypeF = T_Real)  and ((TypeObj =   tobj_any) or  (TypeObj =   tobj_var))  then
       begin
          ND1.NV1:=ni;
          ND1.Addr1:=Addr;//Alg.Obj[ni].Addr;
          ND1.AI:=tc_AddrVar;
          ND1.N:=0;
          BH:=True;
          goto endp;
       end;

       if (TypeF = T_Complex)  and ((TypeObj =   tobj_any) or  (TypeObj =   tobj_var))  then
       begin
          if ReIm = _IM then ND1.Addr1:=AddrIM else   ND1.Addr1:=Addr;
          ND1.NV1:=ni;
          ND1.TS:=ReIm;
          ND1.AI:=tc_AddrVar;
          ND1.N:=0;
          BH:=True;
          goto endp;
       end;

       if (TypeF = T_Pointer)  and ((TypeObj =   tobj_any) or  (TypeObj =   tobj_var))  then      {.355}
       begin
          ND1.NV1:=ni;
          ND1.Addr1:=Addr;//Alg.Obj[ni].Addr;
          ND1.AI:=tc_AddrVar;
          ND1.N:=0;
          BH:=True;
          goto endp;
       end;


    end;



 endp:
 FindAddrObj:=BH;
end;





function TForevalH.FindArray(PS: PString; var ND: TDataNode;  var ni, TypeV, TypeIndx: Integer; var Addr: Cardinal;   var Sindx: String): Boolean;

//поиск элементов векторов:AI = (1)Vec[IntConst],(2)Vec[IntVar],(3)Vec[IntForm], (0)Vec[Sindx]->Vec[Trunc(Sindx)]
//TypeV = _Extended, _Double, _Single, _Integer, _Pointer
//TypeIndx =   _IntVar, _IntConst, _IntForm, _Stack
var
 i,k,l,j,bb,pf,pr,b1,b2,nf,TV: Integer;        //BH - массив найден да/нет
 S1,Sa,Sf,Sf1,Sfn,Sv: String;
 Neg,SB,TM,code,IC,NV: Integer;
 BH,FH1: Boolean;
 AIVP:  TArrayIntVarProd;
begin


  BH:=False;

  FindFuncBrPS(PS,'[',']',Sv,Sa,FH1);
  if FH1 = True then FindVarPS(@Sv,ni) else ni:=-1;

  if ni <> -1 then //ni - vector
  begin
    if Alg.Obj[ni].TypeF = T_Array then
    begin

        {F_IntegerOptimization}
       //---------------------------------------------------------

       Addr:=Alg.Obj[ni].Addr;
       BH:=True;
       ND.NObj:=ni;
       ND.Addr1:=Addr;
       TypeV:=Alg.Obj[ni].MType;
       FindExtArgIntPS(@Sa, code, AIVP, NV, IC);

       if code <> _NOT_FOUND then
       begin

          if code = _IntConst then
          begin
            ND.FD:=IC;
            ND.AI:=1;
          end
          else
          if code = _IntVar then
          begin
            ND.NV1:=NV;
            ND.AI:=2;
          end
          else
          if  code = _IntForm then
          begin
            ND.AIVP1:=Copy(AIVP,0,Length(AIVP));
            //CopyAIVP(AIVP,ND.AIVP1);
            ND.AI:=3;
            ND.FD:=IC;
          end;

          TypeIndx := code;
       end
       else
       begin   //Vec[expr]
         ND.AI:=0;
         Sindx:=Sa;
         TypeIndx := _Stack;
       end;

         //---------------------------------------------------------

    end
  end;


FindArray:=BH;
end;





