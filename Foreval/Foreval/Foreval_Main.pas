procedure TForevalH.SetOperation(OperatorSymb: String; Func: String; PR: Cardinal; NArg: Integer; Pos: Integer; ExeType: Integer);
label 1;
var
i,nf: Integer;                             //Операции взывают только 1,2 - аргументные ф-ии
begin                                      //PR - priority; Pos - place (one arg. op. :_before; _after   two arg. op. _between) ;
nf:=-1;
for i:=0 to High(Alg.ExFunc) do
begin
 if Func = Alg.ExFunc[i].Name then
 begin
  nf:=i; goto 1;
 end;
end;

1:
if nf = -1 then begin {Error} end;
if PR <= 0 then begin {Error} end;

SetLength(Alg.Opr,Length(Alg.Opr)+1);
Alg.Opr[High(Alg.Opr)].Name:=OperatorSymb{[1]};
Alg.Opr[High(Alg.Opr)].NFunc:=nf;
Alg.Opr[High(Alg.Opr)].PR:=PR;
Alg.Opr[High(Alg.Opr)].Pos:=Pos;
Alg.Opr[High(Alg.Opr)].NArg:=NArg;
//Alg.Opr[High(Alg.Opr)].GS:=GS;
//Alg.Opr[High(Alg.Opr)].SE:=SE;
Alg.Opr[High(Alg.Opr)].Enable:=True;
Alg.Opr[High(Alg.Opr)].LenOp:=Length(OperatorSymb);
Alg.Opr[High(Alg.Opr)].ExeType:=ExeType;

  {.383} //отключает проверку  на предварительный поиск ошибок  из-за ложного срабатывания
  if (NArg = 2) and (Length(OperatorSymb) > 1) then F_PreliminarySyntaxError := False;
end;




{.339}
procedure TForevalH.SetOperationA(OpName: String; NFunc: Cardinal; PR: Cardinal; NArg: Integer; Pos: Integer; ExeType: Integer; var idOp: Integer);
