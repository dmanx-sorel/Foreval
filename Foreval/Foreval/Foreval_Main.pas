procedure TForevalH.insIf(S: String; P,N: Integer; var S1: String);
label endp;
var
i,br: integer;
begin
br:=0;
for I := P downto 1 do
begin
(*
   if (S[i] = '(') or (S[i] = '[') or (S[i] = '{') then  br:=br+1 else
   if (S[i] = ')') or (S[i] = ']') or (S[i] = '}') then  br:=br-1;
*)

 if S[i] in OpenBracket then  inc(br)
 else
 if S[i] in CloseBracket then dec(br);

   if br = 0 then
   begin
    if (S[i-1] <> 'f') and (S[i-2]<> 'i')then
    begin
      insert('if',S,i);
      Delete(S,P+3,N);
      if N=3 then Insert('*if',S,P+3) else
       if N=2 then Insert('+if',S,P+3);
    end
    else
    begin
     Delete(S,P+1,N);
     if N=3 then Insert('*if',S,P+1) else
      if N=2 then Insert('+if',S,P+1);
    end;
    S1:=S;
    goto endp;
   end;

end;

endp:
end;


procedure TForevalH.replaceAndOr(S: String;  var S1: String);
label 1, endp;
var
PA,PO: Integer;
begin

1:
PA:=pos(')and(',S);  PO:=pos(')or(',S);

if (PA <> 0) or (PO <> 0) then
begin

 if (PA <> 0) and (PO <> 0) then
  begin
    if PA < PO then  InsIf(S,PA,3,S)
    else InsIf(S,PO,2,S);
  end
 else
 if (PA <> 0) then
 begin
   InsIf(S,PA,3,S);
 end
 else
 if PO <> 0 then
 begin
   InsIf(S,PO,2,S);
 end;

 goto 1;
end;

S1:=S;
end;






procedure TForevalH.ReplaceAndOrSKIP(S: String;  var S1: String);
{
конвертация boolean элементов входной строки в 'игнорирующие' IF команды
(arg1)and(arg2)         -> if(arg1,if(arg2))
(arg1)and(arg2)and(arg) ->  if(arg1,if(arg2,if(arg3)))
...
(arg1)or(arg2)          -> if(arg1,1,if(arg2))
(arg1)or(arg2)or(arg)   ->  if(arg1,1,if(arg2,1,if(arg3)))
...
}
        procedure _ReplAndOrSKIP(S1,SC: String; var S2: String);
        label endp,nxtlev,rpl,nxtarg;
        var
         i: integer;
         PA,P,P1,C1,C2,C3: integer;
         S,Sins,FS:String;
         br,Cr,indx,LS: integer;
         SLst: array of  String;
         PLst: array of Integer;
        begin
        S:=S1;

        nxtlev:
        LS:=Length(SC);
        FS:=')'+SC+'(';
        P:=pos(FS,S);
        if P = 0 then goto endp;

        SetLength(PLst,0); SetLength(SLst,0);

           br:=0;
           //поиск первого аргумента на уровне    ()op1()op1()op2()op2()op1()
           for i := P downto 1 do
           begin
            (*
             if (S[i] = '(') or (S[i] = '[') or (S[i] = '{') then  br:=br+1 else
             if (S[i] = ')') or (S[i] = ']') or (S[i] = '}') then  br:=br-1;
            *)

            if S[i] in OpenBracket then  inc(br)
            else
            if S[i] in CloseBracket then dec(br);

             if br = 0 then
             begin
              if (i > 2)  and (S[i-1] ='f') and (S[i-2] = 'i') then
              begin
                 P1:=i-2;
              end
              else
                P1:=i;

              SetLength(PLst,Length(PLst)+1);
              PLst[High(PLst)]:=P1;
              goto nxtarg;

             end;
           end;

        nxtarg:
           //поиск остальных элементов на одном уровне
           br:=1;  i:=P;
           while i <= Length(S) do
           begin
             (*
             if (S[i] = '(') or (S[i] = '[') or (S[i] = '{') then  br:=br+1 else
             if (S[i] = ')') or (S[i] = ']') or (S[i] = '}') then  br:=br-1;
              *)

              if S[i] in OpenBracket then  inc(br)
              else
              if S[i] in CloseBracket then dec(br);

              if br = 0 then
              begin

                if i = Length(S) then
                begin
                   SetLength(PLst,Length(PLst)+1);
                   PLst[High(PLst)]:=i;
                   goto rpl;
                end
                else
                if  (i < Length(S)) and ((S[i+1] = ')') or (S[i+1] = ',') or (S[i+1] = ';')) then
                begin
                   SetLength(PLst,Length(PLst)+1);
                   PLst[High(PLst)]:=i;
                   goto rpl;
                end
                else
                if (i < Length(S)-LS) and (Copy(S,i+1,LS) = SC)  and  (S[i+LS+1] = '(') then      //if next op also SC
                begin
                  SetLength(PLst,Length(PLst)+1);
                  PLst[High(PLst)]:=i;
                  i:=i+LS;
                end
                else
                if S[i] = ')' then
                begin
                   SetLength(PLst,Length(PLst)+1);
                   PLst[High(PLst)]:=i;
                   goto rpl;
                end

              end;

             inc(i);
           end;


        rpl:
        if Length(PLst) > 0 then
        begin

          SetLength(SLst,Length(PLst)-1);

          SLst[0]:=Copy(S,PLst[0],PLst[1]-PLst[0]+1);
          for i := 1 to High(SLst)-1 do
          begin
           SLst[i]:=Copy(S,PLst[i]+LS+1,PLst[i+1]-PLst[i]-LS);
          end;

          C1:=PLst[High(PLst)] ;C2:=PLst[High(PLst)-1];  C3:= PLst[High(PLst)-1]+LS+1;
          SLst[High(SLst)]:=Copy(S,C3,C1-C3+1);

          Cr:=High(SLst);
          Sins:='if('+SLst[High(SLst)]+')';

          if SC = 'and' then
          begin
            for i := 0 to High(SLst)-1 do
            begin
             dec(Cr) ;
             Sins:='if('+SLst[Cr]+','+Sins+')';
            end;
          end
          else
          if SC = 'or' then
            begin
            for i := 0 to High(SLst)-1 do
            begin
             dec(Cr) ;
             Sins:='if('+SLst[Cr]+',1,'+Sins+')';
            end;
          end;



          Delete(S,PLst[0],PLst[High(PLst)]-PLst[0]+1);
          Sins:='('+Sins+')';
          Insert(Sins,S,Plst[0]);
        end;


        goto nxtlev;

        endp:
        S2:=S;
        end;

begin
  _ReplAndOrSKIP(S,'and',S1);  //приоритет 'and' выше 'or'
  _ReplAndOrSKIP(S1,'or',S1);
end;





procedure TForevalH.ReplaceFuncIntPart(S,SF: String; Place: Integer; var S1: String);
label 1,2,3,endp;
var
i,p,k,N,P1,br,m,f,L,LS,br1: Integer;
SP,SL: String;
BLog: Boolean;
begin

P:=1;
L:=Length(SF);
if SF = 'log' then BLog:=True else BLog:=False;

1:
//SL:=LowerCase(S);
SL:=S;
P1:=posEx(SF,SL,P);

{.385}
if P1 > 1 then
  if SL[P1-1] in BeforeFuncEnableSymb = False then
    begin  P:=P+L; goto 1; end;


if P1 = 0 then goto endp;
P:=P1;
LS:=Length(S);

2:
k:=0;   F:=0;
 for I := p+L to Length(S) do
   begin
     if S[i] = '(' then
     begin

       SP:=Copy(S,p+L,k);
       //if SP <> '' then

       {.195}
         if TryStrToInt(SP,N) = true then
         begin
            N:=StrToInt(SP);

            br:=0; m:=i;   br1:=0;

           repeat

             if S[m] = '(' then begin br:=br+1; if br1 = 0 then br1:=m;  end
              else
             if S[m] = ')' then br:=br-1;

             if (br = 1) and (S[m] = ',') then begin   P:=P+L; goto 3;   end;

             inc(m);
             if (m > LS) and (br <> 0)  then begin  F:=2; goto 3; end;

           until br = 0;


           if Place =  2 then
           begin
             Insert(','+SP,S,m-1);
             Delete(S,P+L,K);
           end
           else
           if Place =  1 then           //321*log7(x+1)+4
           begin                         //  321*log7(12*log9(x)+y)+4
             if (BLog = true) and ((N = 2) or (N = 10)) then
             begin
                  //исключить для log: log2, log10
             end
             else
             begin
               Insert(SP+',',S, br1+1);
               Delete(S,P+L,K);
             end;
           end;

           3:
         end
         else
         F:=1;

      
         if F=2 then goto endp;

         P:=P+L; goto 1;
     end;
     inc(k);
   end;


endp:
S1:=S;
end;



