procedure TForevalH.ClearNode(Node: PNode);
var
S: String;
begin
if Node <> nil then
begin
   Node^.RData:=nil;
   Node^.Expression:='';
   Node^.ExpressionArg:='';
   Node^.ArgTypes:=nil;
   Node^.VFP:=nil;

  { SetLength(Vdbg,Length(Vdbg)+1);
   Vdbg[High(Vdbg)]:=Node^.NNode;  }
end;
end;



procedure TForevalH.FreeNode(Node: PNode);
var
S: String;
i,db: integer;
begin
if Node <> nil then
begin
   db:=Node^.NNode;
   Node^.RData:=nil;
   Node^.Expression:='';
   Node^.ExpressionArg:='';
   Node^.ArgTypes:=nil;
   Node^.VFP:=nil;
   for i :=0 to Length(Node^.AIVP1)-1  do
   begin
     Node^.AIVP1[i].NV:=nil
   end;
   //Node^.AIVP1:=nil;
   SetLength(Node^.AIVP1,0);
   Node^.Pr:=nil;
   Node^.Ch:=nil;
   Node^.Nb:=nil;
   Node^.Next:=nil;
   Node^.Prev:=nil;
   dispose(Node);
   Node:=nil;

  { SetLength(Vdbg,Length(Vdbg)+1);
   Vdbg[High(Vdbg)]:=Node^.NNode; }
end;
end;




procedure TForevalH.RenameFunction(Name,NewName: String);
label endp;
var
i: Integer;
begin

  for i:=0 to High(Alg.ExFunc) do
  begin
   if Name = Alg.ExFunc[i].Name then
   begin
    Alg.ExFunc[i].Name:=Copy(NewName,1,Length(NewName));
    goto endp;
   end;
  end;

endp:
end;




