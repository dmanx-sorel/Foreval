procedure TForevalH.TAN_C;
var
t1,N,NF,S,L_ZTAN_END,L_ZTAN: Integer;
Addr: TAddress;
L1,L2: Integer;
AddrRe1,AddrIm1: TAddress;
begin
 {N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 S:=Interp[NFunc].S;  }
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 t1:=Alg.ExFunc[N].Func[NF].TV[0];
 //  Read/Write  EXP(I*Z)

 LoadArg1;
 if t1 = T_Real then
 begin
    if GNode^.RRF = rf_INVERSE_REPLACE    then     //tan=1/cotan
    begin
       FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);
       FDIVR(TAddress(@S_C1),_Double);
    end
    else
    begin
       FPTAN; FSTP0;
    end;
 end
 else
 if t1 = T_Complex then
 begin

  if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE) then
   begin
     MOVAadr(Cardinal(@Z_TAN));
     CALLA;
     CheckStack(3);
     CheckStack(-3);
   end
   else
   begin
      if GNode^.RRF = rf_EXPZ1_REPLACE    then
      begin   //sin(z1)+tan(z1)
       FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);       // -> IM(exp)
       FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);     // -> RE(exp)

       {.377}
       //Z_TAN_OF_EXPIZ;
       Z_Z2M1__DIV__Z2P1;
       ZDIV_i;

       {
       ZSQR;
       ZPUSH;
       FLD1;
       FSUBP;
       FXCH2;
       FLD1;
       FADDP;
       FXCH2;
       ZDIV;
       ZDIV_i;
       }

      end
      else
      if GNode^.RRF = rf_INVERSE_REPLACE    then
      begin
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);       // -> IM(exp)
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);     // -> RE(exp)
        ZDIVR_C1;
      end
      else
      if GNode^.WRF_CS = rf_EXPZ1_REPLACE    then { (GNode^.RRF = rf_NO_REPLACE) }
      begin

         //tan(z1)= (exp(i*z)^2-1)/(exp(i*z)^2+1)/i
          //tan(z1)+sin(z1)

           {.377}
         AddrRe1:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);               //  RE(exp)    ->
         AddrIm1:=TAddress(@Func.RFStack[GNode^.MWF_CS]);                 //  IM(exp)    ->
         PUSHM(F_DataType);
         PUSHM(AddrIm1);
         PUSHM(AddrRe1);
         ZMUL_i;
         Z_EXPZ_Z2M1__DIV__Z2P1_SAVE;
         ZDIV_i;
         //ZZ_TANZ_EXPIZ_M;
         ADDESP(12);


          (*
          //tan(z)=-i*th(i*z)
          AddrRe1:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);               //  RE(exp)    ->
          AddrIm1:=TAddress(@Func.RFStack[GNode^.MWF_CS]);                 //  IM(exp)    ->
          ZMUL_i;
          ZEXP;
          Z_SAVE(AddrRe1,AddrIm1,F_DataType);
          ZSQR;
          ZPUSH;
          FLD1;
          FSUBP;
          FXCH2;
          FLD1;
          FADDP;
          FXCH2;
          ZDIV;
          FCHS;
          FXCH1;
          *)

         (*
          {.377}
         AddrRe1:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);               //  RE(exp)    ->
         AddrIm1:=TAddress(@Func.RFStack[GNode^.MWF_CS]);                 //  IM(exp)    ->
         ZZ_TANZ_EXPIZ;
         Z_PUSHOUT(AddrRe1,AddrIm1,F_DataType);
         *)

         (*
         {.335}
         if F_DataType = _Extended then
         begin
            L_ZTAN:=27;       //size of code
            L_ZTAN_END:=82;   //size of code
         end
         else
         if F_DataType = _Double then
         begin
            L_ZTAN:=23;       //size of code
            L_ZTAN_END:=78;   //size of code
         end;

         //If Z.IM = 0 then: ... else goto @@ztan
         FLDZ;
         FCOMIP2;
         JMPCI(L_ZTAN,_JNZ); //jnz @@ztan
         //L_ZTAN - size of:
               L1:=Length(IComp);
         FSINCOS;
           Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-1]);               //  RE(exp) ->
         FSTM(Addr,F_DataType);
         FXCH1;
           Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS]);               //  RE(exp^-1) ->
         FSTM(Addr,F_DataType);
         FDIVRP;
         //tan,0
         JMP(L_ZTAN_END);//jmp @@end
             L2:=Length(IComp);
             L2:=L2-L1;

             L1:=Length(IComp);
           {full complex z
            L_ZTAN_END - size of: }
          {@@ztan:}
          ZMUL_i;
          ZEXP;
             Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);       // -> RE(exp)
          FSTM(Addr,F_DataType);
          FXCH1;
             Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);        // -> IM(exp)
          FSTM(Addr,F_DataType);
          FXCH1;
          ZSQR;
          ZPUSH;
          FLD1;
          FSUBP;
          FXCH2;
          FLD1;
          FADDP;
          FXCH2;
          ZDIV;
          ZDIV_i;

             L2:=Length(IComp);
             L2:=L2-L1;
          *)

      end

   end;

 end;

end;



