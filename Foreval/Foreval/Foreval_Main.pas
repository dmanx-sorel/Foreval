// by value only for 'STDCALL' or 'CDECL'
procedure TForevalH.PUSHArgStackVal;
var
S,N,NF,i,j,Adr,vs,Arg,TM,TV,DS,CS,cn: Cardinal;
k: integer;


begin


{.304}
//transfer args. by values work only for stdcall & cdecl !!!

N:=GNode^.NFunc;
NF:=GNode^.NF;
S:=GNode^.S;
Arg:=GNode^.Arg;


DS:=0;
//DS - определение глубины стека для передаваемых аргументов:
 for k:=0 to  Arg-1 do
 begin
   CS:=0;
   TV:=Alg.ExFunc[N].Func[NF].TV[k];
   TM:=Alg.ExFunc[N].Func[NF].TM[k];

   if TV = T_Array then   CS:=4      {.197}
   else
   begin
     case TM of
     _Integer:     CS:=4;
     _Single:      CS:=4;
     _Pointer:     CS:=4;
     _Double:      CS:=8;
     _Extended:    CS:=12;  //12 -  (12 вместо 10) - так компилирует DELPHI
     end;
     case TV of
     T_Real:      CS:=CS;
     T_Complex:   CS:=CS*2;
     T_Pointer:   CS:=CS;
     end;
   end;



    DS:=DS+CS;
    if (TM = _Extended) and (TV = T_Complex) then DS:=DS+8; //16+16;выравнивание на 16

 end;

 if Alg.ExFunc[N].Func[NF].Set_Id = _YES then DS:=DS+4;

 {.304}
 //ID передается последним  при вызовах  'stdcall' & 'cdecl' !!! (в 'pascal' не работает)
if (Alg.ExFunc[N].Func[NF].Set_Id = _YES)  {and (Alg.ExFunc[N].Func[NF].ARROW = _BACK)} then
begin
  if Arg >= 1 then
  begin
     MOVCREG(R_EAX,Alg.ExFunc[N].Func[NF].Id_Func);
     MOVESPEAX(DS-4);
  end
  else
  if Arg = 0 then
     PUSHM(Alg.ExFunc[N].Func[NF].Id_Func);
end;




MOVAadr(Alg.ExFunc[N].Func[NF].Addr);
CALLA;
if Alg.ExFunc[N].Func[NF].CLST = _YES then ADDESP(DS);

end;




procedure TForevalH.ADD_C;
var
t1,t2,N,NF,S,st1,st2,Arg,nv1,nv2,xchT: Integer;
XchArg: Boolean;

  procedure ADD_DL;      //S1+S2 (F_SaveInFPU = True)
  begin
    if (t1 = T_Real) and (t2 = T_Real) then        //t2,t1
    begin
        if (st1 = _FPU) and (st2 = _FPU) then
        begin
           FADDP
        end
        else
        if (st1 = _FPU) and (st2 = _MEM) then
        begin
           FADD(GetStackAdr(S+1,_RE),F_DataType)
        end
        else
        if (st1 = _MEM) and (st2 = _FPU) then
        begin
           FADD(GetStackAdr(S,_RE),F_DataType)
        end
        else
        if (st1 = _MEM) and (st2 = _MEM) then
        begin
          FLD(GetStackAdr(S,_RE),F_DataType);
          FADD(GetStackAdr(S+1,_RE),F_DataType);
        end;
    end
    else
    if (t1 = T_Real) and (t2 = T_Complex) then            //x,y,r
    begin
       if (st1 = _FPU) and (st2 = _FPU) then
       begin
          FADDP2;
          FXCH1;
       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then
       begin
         FADD(GetStackAdr(S+1,_RE),F_DataType);
         FLD(GetStackAdr(S+1,_IM),F_DataType);
         FXCH1;
       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then
       begin
         FADD(GetStackAdr(S,_RE),F_DataType)
       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then
       begin
         FLD(GetStackAdr(S+1,_IM),F_DataType);
         FLD(GetStackAdr(S+1,_RE),F_DataType);
         FADD(GetStackAdr(S,_RE),F_DataType);
       end;
    end
    else
    if (t1 = T_Complex) and (t2 = T_Real) then
    begin
       if (st1 = _FPU) and (st2 = _FPU) then
       begin
         FADDP;
       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then
       begin
         FADD(GetStackAdr(S+1,_RE),F_DataType);
       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then
       begin
         FADD(GetStackAdr(S,_RE),F_DataType);
         FLD(GetStackAdr(S,_IM),F_DataType);
         FXCH1;
       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then
       begin
         FLD(GetStackAdr(S,_IM),F_DataType);
         FLD(GetStackAdr(S,_RE),F_DataType);
         FADD(GetStackAdr(S+1,_RE),F_DataType);
       end;
    end
    else
    if (t1 = T_Complex) and (t2 = T_Complex) then
    begin
       if (st1 = _FPU) and (st2 = _FPU) then
       begin
         FADDP2;
         FADDP2;
       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then
       begin
         FLD(GetStackAdr(S,_IM),F_DataType);
         FADD(GetStackAdr(S+1,_IM),F_DataType);
         FLD(GetStackAdr(S,_RE),F_DataType);
         FADD(GetStackAdr(S+1,_RE),F_DataType);
       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then
       begin
         FADD(GetStackAdr(S+1,_RE),F_DataType);
         FXCH1;
         FADD(GetStackAdr(S+1,_IM),F_DataType);
         FXCH1;
       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then
       begin
         FADD(GetStackAdr(S,_RE),F_DataType);
         FXCH1;
         FADD(GetStackAdr(S,_IM),F_DataType);
         FXCH1;
       end;
    end;
  end;

  procedure ADD_ST;       //S1+S2 (F_SaveInFPU = False)
  begin
   if (t1 = T_Real) and (t2 = T_Real) then
   begin
    FLD(GetStackAdr(S,_RE),F_DataType);
    FADD(GetStackAdr(S+1,_RE),F_DataType);
   end
   else
   if (t1 = T_Real) and (t2 = T_Complex) then
   begin
    FLD(GetStackAdr(S+1,_IM),F_DataType);
    FLD(GetStackAdr(S+1,_RE),F_DataType);
    FADD(GetStackAdr(S,_RE),F_DataType);
   end
   else
   if (t1 = T_Complex) and (t2 = T_Real) then
   begin
    FLD(GetStackAdr(S,_IM),F_DataType);
    FLD(GetStackAdr(S,_RE),F_DataType);
    FADD(GetStackAdr(S+1,_RE),F_DataType);
   end
   else
   if (t1 = T_Complex) and (t2 = T_Complex) then
   begin
    FLD(GetStackAdr(S,_IM),F_DataType);
    FADD(GetStackAdr(S+1,_IM),F_DataType);
    FLD(GetStackAdr(S,_RE),F_DataType);
    FADD(GetStackAdr(S+1,_RE),F_DataType);
   end;
  end;


  procedure ADD_VAR;                             //v1+v2
  var
    nv1,nv2,tv1,tv2,tm1,tm2,sh1,sh2: Integer;
    Adr1,Adr2,adr1RE,adr1IM,adr2RE,adr2IM: Cardinal;
  begin
   {nv1:=Interp[NFunc].nv1;
   nv2:=Interp[NFunc].nv2;  }
   nv1:=GNode^.NV1;
   nv2:=GNode^.NV2;

   {
   GetVar(nv1,adr1,tv1,tm1);
   GetVar(nv2,adr2,tv2,tm2);
   if (tm1 = _Extended) then sh1:=SH_E else sh1:=SH_D;
   if (tm2 = _Extended) then sh2:=SH_E else sh2:=SH_D;
   }

   GetVar2(nv1,adr1RE,adr1IM,tv1,tm1);   {.343}
   GetVar2(nv2,adr2RE,adr2IM,tv2,tm2);   {.343}
   Adr1:=Adr1RE; Adr2:=Adr2RE;           {.343}

   if (tv1 = T_Real) and (tv2 = T_Real) then
   begin
     FLD(Adr1,tm1);  //FLDV(nv1);
     FADD(Adr2,tm2); //FADDV(nv2,tv2);
   end
   else
   if (tv1 = T_Real) and (tv2 = IM_UNIT) then
   begin
     FLD1;
     FLD(Adr1,tm1);
   end
   else
   if (tv1 = T_Real) and (tv2 = T_Complex) then
   begin
     FLDV(nv2);
     FADD(Adr1,tm1); //FADDV(nv1);
   end
   else
   if (tv1 = IM_UNIT) and (tv2 = T_Real) then
   begin
     FLD1;
     FLD(Adr2,tm2); //FLDV(nv2);
   end
   else
   if (tv1 = T_Complex) and (tv2 = T_Real) then
   begin
     FLDV(nv1);
     FADD(Adr2,tm2);  //FADDV(nv2);
   end
   else
   if (tv1 = T_Complex) and (tv2 = T_Complex) then
   begin
     {.343}
     {FLD(Adr1+sh1,tm1); FADD(Adr2+sh2,tm2);
     FLD(Adr1,tm1);     FADD(Adr2,tm2); }
     FLD(Adr1IM,tm1);     FADD(Adr2IM,tm2);
     FLD(Adr1RE,tm1);     FADD(Adr2RE,tm2);
   end
   else
   if (tv1 = IM_UNIT) and (tv2 = T_Complex) then
   begin
     FLDV_IM(nv2); FLD1; FADDP;
     FLDV_RE(nv2);
   end
   else
   if (tv1 = T_Complex) and (tv2 = IM_UNIT) then
   begin
     FLDV_IM(nv1); FLD1; FADDP;
     FLDV_RE(nv1);
   end
   else
   if (tv1 = IM_UNIT) and (tv2 = IM_UNIT) then
   begin
     FLD1; FLD1; FADDP;
     FLDZ;
   end

  end;

 /////////////////////////////////MAIN//////////////////////////////////////////
begin
 {N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 S:=Interp[NFunc].S;
 Arg:=Interp[NFunc].N; }
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 Arg:=GNode^.N;

 t1:=Alg.ExFunc[N].Func[NF].TV[0]; t2:=Alg.ExFunc[N].Func[NF].TV[1];

 {
 st1:=Interp[NFunc].RData[0]; st2:=Interp[NFunc].RData[1];
 nv1:=Interp[NFunc].NV1;
 nv2:=Interp[NFunc].NV2;
 }
 st1:=GNode^.RData[0]; st2:=GNode^.RData[1];
 nv1:=GNode^.NV1;
 nv2:=GNode^.NV2;

 //if (Arg = 1) and (Interp[NFunc].TypeA <> 0) then  t1:=Interp[NFunc].TypeA;
 if (Arg = 1) and (GNode^.TypeA <> 0) then  t1:=GNode^.TypeA;

 XchArg:=GNode^.XchArg;
 if XchArg = True then
 begin
   xchT:=t1;
   t1:=t2;
   t2:=xchT;
 end;





 if F_SaveInFPU = False then
 begin
   if (Arg = 2) and (nv1 = -1) and (nv2 = -1) then         //S1+S2
   begin
    ADD_ST;
   end
   else
   if (Arg = 0) and (nv1 >= 0) and (nv2 >= 0) then         //v1+v2
   begin
      ADD_VAR;
   end
   else
   if (Arg = 1) and  (nv1 >= 0)     then                   //S+v1
   begin
    FLDS(0,_MEM);  FADDV(nv1,t1)
   end
   else
   if (Arg = 1) and  (nv1 = -1) and (nv2 = -1)  then       //S1+c
   begin
    FLDS(0,_MEM); FADD(WriteData(GNode{NFunc}),F_DataType);
   end
   else
   if (Arg = 0) and (nv2 = -1)    then                     //v+c
   begin
     FLD(WriteData(GNode{NFunc}),F_DataType);
     FADDV(nv1,T_Real);
   end
 end
 else
 if F_SaveInFPU = True then
 begin
   if (Arg = 2) and (nv1 = -1) and (nv2 = -1) then         //S1+S2
   begin
    ADD_DL;
   end
   else
   if (Arg = 0) and (nv1 >= 0) and (nv2 >= 0) then         //v1+v2
   begin
      ADD_VAR
   end
   else
   if (Arg = 1) and  (nv1 >= 0)     then                   //S+v1
   begin
    FLDS(0);  FADDV(nv1,t1)
   end
   else
   if (Arg = 1) and  (nv1 = -1) and (nv2 = -1)  then       //S1+c
   begin
    FLDS(0); FADD(WriteData(GNode{NFunc}),F_DataType);
   end
   else
   if (Arg = 0) and (nv2 = -1)    then                     //v+c
   begin
     FLD(WriteData(GNode{NFunc}),F_DataType);
     FADDV(nv1,T_Real);
   end;
 end;


end;




procedure TForevalH.FLDV(nv: Integer);
var
 Adr: Cardinal;
 tv,tm: Integer;
begin
 GetVar1(nv,Adr,tv,tm);
 if  tv = T_Real    then FLDV_RE(nv)//FLD(Adr,tm)
 else
 if tv = T_Complex  then
 begin
   FLDV_IM(nv);
   FLDV_RE(nv);
 end
 else
 if tv = IM_UNIT then
 begin
   FLD1;
   FLDZ;
 end;
end;





procedure TForevalH.LDSF_C(N: Integer);
var
NFunc,NF,CallT: Integer;
begin
   //Node^ = Interp[NFunc]

 if Alg.Obj[N].TypeF = T_Real then
 begin
  if (GNode^.TS = 0) or (GNode^.TS = _RE) then
     FLD(Alg.Obj[N].Addr,Alg.Obj[N].MType)
  else
  if GNode^.TS = _IM then
     FLDZ;
 end
 else
 if Alg.Obj[N].TypeF = T_Complex then
 begin
  if GNode^.TS = 0 then
  begin
    {if Alg.Obj[N].MType = _Double then
     FLD(Alg.Obj[N].Addr+sh_D,Alg.Obj[N].MType)        //Sh_D = 8
    else
    if Alg.Obj[N].MType = _Extended then
     FLD(Alg.Obj[N].Addr+sh_E,Alg.Obj[N].MType);     //Sh_E = 16

    FLD(Alg.Obj[N].Addr,Alg.Obj[N].MType);  }

    {.343}
    FLD(Alg.Obj[N].AddrIM,Alg.Obj[N].MType);
    FLD(Alg.Obj[N].Addr,Alg.Obj[N].MType);
  end
  else
  if GNode^.TS = _RE then
  begin
    FLD(Alg.Obj[N].Addr,Alg.Obj[N].MType);
  end
  else
  if GNode^.TS = _IM then
  begin
    {
    if Alg.Obj[N].MType = _Double then
     FLD(Alg.Obj[N].Addr+sh_D,Alg.Obj[N].MType)     //Sh_D = 8
    else
    if Alg.Obj[N].MType = _Extended then
     FLD(Alg.Obj[N].Addr+sh_E,Alg.Obj[N].MType);     //Sh_E = 16
     }
     {.343}
     FLD(Alg.Obj[N].AddrIM,Alg.Obj[N].MType);
  end
 end
 else
 //Pointer: Vector
 if Alg.Obj[N].TypeF = T_Array then
 begin   {arraycpu}
   //FILD(Alg.Obj[N].Addr);

   //PUSHF(Alg.Obj[N].Addr);     {.197}




  (*
  if (GNode^.ExtArg <> 0) then
  begin
      NFunc:=GNode^.Pr^.NFunc;
      NF:=GNode^.Pr^.NF;
      CallT:=Alg.ExFunc[NFunc].Func[NF].CallT;
  end;

   //загрузка адреса массива сразу в стек выражения   {.223}, кроме ф-ий  _STACK_VAL,...
  if  (CallT <> _STACK_VAL)  then
  begin
     if (F_SaveInFPU = True) and  ((CallT = _MEMORY_EAX) or (CallT = _MEMORY_ESP)) then     {.309}
     begin
       {}
     end
     else
     begin
       {
       PUSHF(Alg.Obj[N].Addr);
       POPF(GetStackAdr(GNode^.S,_RE));
       }
       //Addr:=Alg.Obj[GNode^.NObj].Addr;
       MOVMREG(R_EAX,Alg.Obj[N].Addr);
       MOVREGM(R_EAX,GetStackAdr(GNode^.S,_RE));
     end;
  end;
  *)

    //загрузка адреса массива  в EAX   {.353}
     MOVMREG(R_EAX,Alg.Obj[N].Addr);
     //MOVREGM(R_EAX,GetStackAdr(GNode^.S,_RE));
     GNode^.ExtArgPlace:=R_EAX;

 end
 (*
 else
 if Alg.Obj[N].TypeF = T_Pointer then
   begin   {arraycpu}
    //загрузка содержимого указателя  в EAX   {.353}
     MOVMREG(R_EAX,Alg.Obj[N].Addr);
 end;
 *)

end;





procedure TForevalH.LDSA_C;
var
NFunc,NF,CallT,N: Integer;
Addr: TAddress;

t1,S,nv,TM,TA,NM,NA,TMA,tva: Integer;
AdrM,AdrA,Num: Cardinal;
begin


   {arraycpu}
   //FILD(Alg.Obj[N].Addr);
   //PUSHF(Alg.Obj[N].Addr);     {.197}


   Addr:=GNode^.Addr1;

  (*
  if (GNode^.ExtArg <> 0) then
  begin
      NFunc:=GNode^.Pr^.NFunc;
      NF:=GNode^.Pr^.NF;
      CallT:=Alg.ExFunc[NFunc].Func[NF].CallT;
  end;
   //загрузка адреса массива сразу в стек выражения   {.223}, кроме ф-ий  _STACK_VAL,...
  if  (CallT <> _STACK_VAL)  then
  begin
     if (F_SaveInFPU = True) and  ((CallT = _MEMORY_EAX) or (CallT = _MEMORY_ESP)) then     {.309}
     begin
       {}
     end
     else
     begin
       {
       PUSHF(Alg.Obj[N].Addr);
       POPF(GetStackAdr(GNode^.S,_RE));
       }
       //Addr:=Alg.Obj[GNode^.NObj].Addr;
       MOVMREG(R_EAX,Addr);
       MOVREGM(R_EAX,GetStackAdr(GNode^.S,_RE));
     end;
  end;
 *)


  //загрузка указателя  в EAX   {.353}
   if (GNode^.AI = tc_AddrVar) then      //@var -> EAX
   begin
         MOVAadr(Addr);
         GNode^.ExtArgPlace:=R_EAX;
   end
   else
   if (GNode^.AI = tc_AddrFunc) then     //@Func -> EAX
   begin
         MOVAadr(Addr);
         GNode^.ExtArgPlace:=R_EAX;
   end
   else
   if (GNode^.AI = tc_AddrArray) then       //@vec -> EAX
   begin
        {
        MOVAadr(AddrObj);
        //MOVAA;   //вычисление и передача адреса нулевого элемента массива
        MOVESPEAX(SZ);
        }
        //
         //MOVMREG(R_EAX,Addr);
         MOVCREG(R_EAX,Addr);
         GNode^.ExtArgPlace:=R_EAX;
   end
   else
   if GNode^.AI = tc_PointerVar then
   begin   {arraycpu}
     //загрузка содержимого указателя  в EAX   {.353}
      N:=GNode^.NObj;
      MOVMREG(R_EAX,Alg.Obj[N].Addr);
      GNode^.ExtArgPlace:=R_EAX;
   end
   else
   if GNode^.AI = tc_PointerArray then           //Vec[indx]-> EAX (Vec = array of Pointer)
   begin   {arraycpu}
     //загрузка содержимого указателя  в EAX   {.353}

      //MOVMREG(R_EAX,Alg.Obj[N].Addr);


       N:=GNode^.NObj;
       AdrM:=Alg.Obj[N].Addr;
       //TM:=Alg.Obj[NM].MType;


       if GNode^.CI = 0 then     //Vec[Trunc(Stack)]
       begin
          LoadArg1;
          //TRUNCR(R_ECX);
          FISTPR(R_ECX); {.387}

         //trunc
         (*
          PUSHCW;    {.227}
          FLDCW(TAddress(@FCW1));
          MEM:=WriteDataA(0,_Integer);
          FISTP(MEM);
          POPCW;    {.227} //FLDCW(TAddress(@FCW2));
          MOVMC(MEM);
          *)
      end
      else
      if GNode^.CI = 2 then    //Vec[float_var]
      begin
         GetVar1(GNode^.NV1,AdrA,tva,TMA);
         if (TMA = _Double) or (TMA = _Extended) or (TMA = _Single) then
         begin
            FLDV(GNode^.NV1);
            //TRUNCR(R_ECX);
            FISTPR(R_ECX); {.387}

            (*
            PUSHCW;    {.227}
            FLDCW(TAddress(@FCW1));
            MEM:=WriteDataA(0,_Integer);
            FISTP(MEM);
            POPCW;    {.227} //FLDCW(TAddress(@FCW2));
            MOVMC(MEM);
            *)

         end
         else
         if TMA = _Integer then
         begin
           MOVMC(AdrA);
         end;
      end
      else
      if GNode^.CI = 1 then  //Vec[num]
      begin
          Num:=Trunc(GNode^.FD);
          MOVCadr(NUM); //Num>=0!!!
      end
      else
      if GNode^.CI = 3 then  //Vec[AIVP]  - vec[IntForm]
      begin
         //AIVP1;
          LineFormN(GNode^.AIVP1,Trunc(GNode^.FD));
          MOVREG(R_EAX,R_ECX);
      end
      else
      if GNode^.CI = 4 then  //Vec[VecInt[indx]]    {.357}
      begin
         LoadArrayElem(tc_LoadIntArrayElemEAX);//VecInt[indx]->EAX
         MOVREG(R_EAX,R_ECX);
      end;

      {
      MOVBadr(AdrM);
      //mov  ebx, [ebx]:
      AddByte2($8B,$1B);  //вычисление адреса массива: адрес адреса
      }
      MOVMREG(R_EBX,AdrM); //[AddrArray] -> EBX (= @Array[0])    {.369**}

      //mov  eax, [ebx+4*ecx]:
      AddByte3($8B,$04,$8B);
      SetReg(R_EAX);
      SetReg(R_EBX);
      SetReg(R_ECX);

      GNode^.ExtArgPlace:=R_EAX;



   end
   else
   if GNode^.AI = tc_AddrArrayElem then    //загрузка в EAX адреса элемента массива @vec[indx]-> EAX ; @vd[2*k+3*j-1]
   begin
      LoadArrayElem(tc_LoadArrayElemAddr);
      GNode^.ExtArgPlace:=R_EAX;
   end;



end;





procedure TForevalH.LoadArrayElem(Act: Integer);
var
t1,N,NF,S,nv,TM,TA,NM,NA,TMA,tva: Integer;
AdrM,AdrA,Num,AddrI: Cardinal;
begin


//Act =
// tc_LoadIntArrayElemEAX  - загрузка элемента целочисленного массива в EAX :  Intvec[indx] -> EAX
// tc_LoadArrayElemAddr    - загрузка адреса массива в EAX                  :  @vec[indx] -> EAX
// tc_LoadArrayElemFPU     - загрузка элемента массива в FPU                :  vec[indx] -> FPU






 //GNode^.NObj2 номер массива в NObj !!!
 //тип аргумента в DI !!!
 //GNode^.NV2 - целочисленная переменная vec[IntVar]
 //GNode^.FD - целочисленная константа vec[IntConst]

 NM:=GNode^.NObj2;
 AdrM:=Alg.Obj[NM].Addr;
 TM:=Alg.Obj[NM].MType;

 //вычисление индекса (аргумента массива) и загрузка его в ECX:
 if GNode^.DI = 0 then     //Vec[Trunc(Stack)]
 begin
   LoadArg1;
   //TRUNCR(R_ECX);
   FISTPR(R_ECX); {.387}

   //trunc
   (*
   PUSHCW;    {.227}
   FLDCW(TAddress(@FCW1));
   MEM:=WriteDataA(0,_Integer);
   FISTP(MEM);
   POPCW;    {.227} //FLDCW(TAddress(@FCW2));
   MOVMC(MEM);
   *)
 end
 else
 if GNode^.DI = 2 then    //Vec[IntVar]
 begin
   AddrI:=Alg.Obj[GNode^.NV2].Addr;
   MOVMC(AddrI);
  (*
  GetVar1({Interp[NFunc]}GNode^.NV1,AdrA,tva,TMA);
  if (TMA = _Double) or (TMA = _Extended) then
  begin
   FLDV(GNode^.NV1);
   PUSHCW;    {.227}
   FLDCW(TAddress(@FCW1));
   MEM:=WriteDataA(0,_Integer);
   FISTP(MEM);
   POPCW;    {.227} //FLDCW(TAddress(@FCW2));
   MOVMC(MEM);
  end
  else
  if TMA = _Integer then
  begin
    MOVMC(AdrA);
  end;
  *)
 end
 else
 if GNode^.DI = 1 then  //Vec[num]
 begin
   Num:=Trunc(GNode^.FD);
   MOVCadr(NUM); //Num>=0!!!
 end
 else
 if GNode^.DI = 3 then  //Vec[AIVP]  - vec[IntForm]
 begin
    //AIVP1;
    LineFormN(GNode^.AIVP1,Trunc(GNode^.FD));
    MOVREG(R_EAX,R_ECX);
 end;


 //AddrArray -> EBX; indxArray -> ECX
  {
  MOVBadr(AdrM);
  //mov  ebx, [ebx]:
  AddByte($8B); AddByte($1B);
  }
  MOVMREG(R_EBX,AdrM); //[AddrArray] -> EBX (= @Array[0])    {.369**}

 //загрузка элемента массива в FPU  или его адреса в EAX:
 if TM = _Double then
 begin

     if Act = tc_LoadArrayElemFPU then
     begin
       //fld  qword ptr [ebx+8*ecx]:
       //AddByte($DD); AddByte($04);AddByte($CB);
        LoadArrayCellFPU(R_EBX,R_ECX,TM);
     end
     else
     if Act = tc_LoadArrayElemAddr then
     begin
       //lea eax,ebx+8*ecx
       //AddByte3($8D,$04,$CB);
       LoadArrayAddrCell(R_EAX,R_EBX,R_ECX,TM);
     end;

 end
 else
 if TM = _Extended then
 begin

     if Act = tc_LoadArrayElemFPU then
     begin
     {
       //lea   ecx,[ecx+4*ecx]:
        AddByte($8D); AddByte($0C);AddByte($89);
       //fld   tbyte ptr [ebx+2*ecx]:
        AddByte($DB); AddByte($2C);AddByte($4B);
        }
         LoadArrayCellFPU(R_EBX,R_ECX,TM);
     end
     else
     if Act = tc_LoadArrayElemAddr then
     begin
       {
        //lea   ecx,[ecx+4*ecx]:
        AddByte($8D); AddByte($0C);AddByte($89);
        //lea eax,ebx+2*ecx
        AddByte3($8D,$04,$4B);
        }
         LoadArrayAddrCell(R_EAX,R_EBX,R_ECX,TM);
     end;


 end
 else
 if (TM = _Integer) or (TM = _Pointer) then
 begin

     if Act = tc_LoadArrayElemFPU then
     begin
        //fild  dword ptr [ebx+4*ecx]:
        //AddByte($DB); AddByte($04);AddByte($8B);
         LoadArrayCellFPU(R_EBX,R_ECX,_Integer);
     end
     else
     if Act = tc_LoadArrayElemAddr then
     begin
        //lea eax,ebx+4*ecx
       //AddByte3($8D,$04,$8B);
        LoadArrayAddrCell(R_EAX,R_EBX,R_ECX,_Integer);
     end
     else
      if Act = tc_LoadIntArrayElemEAX then
     begin
         //mov   eax,[ebx+4*ecx]:
         AddByte($8B); AddByte($04);AddByte($8B);
     end


 end
 else
 if (TM = _Single) then
 begin

     if Act = tc_LoadArrayElemFPU then
     begin
        //fld  dword ptr [ebx+4*ecx]:
        //AddByte($D9); AddByte($04);AddByte($8B);
        LoadArrayCellFPU(R_EBX,R_ECX,TM);
     end
     else
     if Act = tc_LoadArrayElemAddr then
     begin
        //lea eax,ebx+4*ecx
       //AddByte3($8D,$04,$8B);
        LoadArrayAddrCell(R_EAX,R_EBX,R_ECX,TM);
     end;


 end;

SetReg(R_EAX);
SetReg(R_EBX);
SetReg(R_ECX);

end;







procedure TForevalH.LoadArrayAddrCell(REG_load,REG_AddrArray,REG_indx,tm: Integer);
//in: @VEC -> REG_AddrArray; indx -> REG_indx;  out: REG_load <- @VEC[indx];
begin


 if tm = _Single then
 begin
    if  (REG_AddrArray = R_EBX) and  (REG_indx = R_EAX) then
    begin
       if REG_load = R_EDI  then
       begin
              //lea edi,ebx+4*eax
               AddByte3($8D,$3C,$83);
       end
       else
       if REG_load = R_EBX  then
       begin
              //lea ebx,ebx+4*eax
               AddByte3($8D,$1C,$83);
       end
       else
       if REG_load = R_ESI  then
       begin
              //lea esi,ebx+4*eax
               AddByte3($8D,$34,$83);
       end;
    end
    else
    if  (REG_AddrArray = R_EBX) and  (REG_indx = R_ECX) then
    begin
       if REG_load = R_EAX  then
       begin
            //lea eax,ebx+4*ecx
            AddByte3($8D,$04,$8B);
       end
    end;
 end
 else
 if tm = _Double then
 begin
    if  (REG_AddrArray = R_EBX) and  (REG_indx = R_EAX) then
    begin
       if REG_load = R_EDI  then
       begin
              //lea edi,ebx+8*eax
               AddByte3($8D,$3C,$C3);
       end
       else
       if REG_load = R_EBX  then
       begin
              //lea ebx,ebx+8*eax
               AddByte3($8D,$1C,$C3);
       end
       else
       if REG_load = R_ESI  then
       begin
              //lea esi,ebx+8*eax
               AddByte3($8D,$34,$C3);
       end;
    end
    else
    if  (REG_AddrArray = R_EBX) and  (REG_indx = R_ECX) then
    begin
       if REG_load = R_EAX  then
       begin
           //lea eax,ebx+8*ecx
           AddByte3($8D,$04,$CB);
       end
    end;

 end
 else
 if tm = _Extended   then
 begin
    if (REG_AddrArray = R_EBX) and  (REG_indx = R_EAX) then
    begin
       if REG_load = R_EDI then
       begin
            //lea   eax,[eax+4*eax]:
              AddByte3($8D,$04,$80);
              //add   eax,eax:
              AddByte2($01,$C0);
              //lea edi,ebx+eax
              AddByte3($8D,$3C,$18);
       end
       else
       if REG_load = R_EBX  then
       begin
             //lea   eax,[eax+4*eax]
              AddByte3($8D,$04,$80);
              //add   eax,eax
              AddByte2($01,$C0);
              //lea ebx,ebx+eax
              AddByte3($8D,$1C,$18);
       end
       else
       if REG_load = R_ESI  then
       begin
              //lea   eax,[eax+4*eax]
              AddByte3($8D,$04,$80);
              //add   eax,eax
              AddByte2($01,$C0);
              //lea esi,ebx+eax
              AddByte3($8D,$34,$18);
       end;
    end
    else
    if  (REG_AddrArray = R_EBX) and  (REG_indx = R_ECX) then
    begin
       if REG_load = R_EAX  then
       begin
           //lea   ecx,[ecx+4*ecx]:
           AddByte($8D); AddByte($0C);AddByte($89);
           //lea eax,ebx+2*ecx
           AddByte3($8D,$04,$4B);
       end
    end;
 end
 else
 if tm = _Integer   then
 begin
    if (REG_AddrArray = R_EBX) and  (REG_indx = R_EAX) then
    begin
       if REG_load = R_EDI then
       begin
           //lea edi,ebx+4*eax
           AddByte($8D); AddByte($3C);AddByte($83);
       end
       else
       if REG_load = R_EBX  then
       begin
           //lea ebx,[ebx+4*eax]
          AddByte($8D); AddByte($1C);AddByte($83);
       end
       else
       if REG_load = R_ESI  then
       begin
          //lea esi,ebx+4*eax
           AddByte($8D); AddByte($34);AddByte($83);
       end;
    end
    else
    if  (REG_AddrArray = R_EBX) and  (REG_indx = R_ECX) then
    begin
       if REG_load = R_EAX  then
       begin
          //lea eax,ebx+4*ecx
          AddByte3($8D,$04,$8B);
       end
    end;
 end;

end;


procedure TForevalH.LoadArrayCellFPU(Addr: TAddress; REG_indx, tm: Integer);
begin
//FLD  type ptr Array[indx]

//Addr - AddrArray or REG with AddrArray
//REG_indx- REG with indxArray
//tm - type of float array


if tm = _Integer then
begin
   if Addr = R_EBX then
   begin
      if REG_indx = R_ECX then
      begin
         //fild  dword ptr [ebx+4*ecx]:
        AddByte($DB); AddByte($04);AddByte($8B);
      end;
   end;
end
else
if tm = _Single then
begin
   if Addr = R_EBX then
   begin
      if REG_indx = R_ECX then
      begin
        //fld  dword ptr [ebx+4*ecx]:
        AddByte($D9); AddByte($04);AddByte($8B);
      end;
   end;
end
else
if tm = _Double then
begin
   if Addr = R_EBX then
   begin
      if REG_indx = R_ECX then
      begin
         //fld  qword ptr [ebx+8*ecx]:
         AddByte($DD); AddByte($04);AddByte($CB);
      end;
   end;
end
else
if tm = _Extended then
begin
   if Addr = R_EBX then
   begin
      if REG_indx = R_ECX then
      begin
         //lea   ecx,[ecx+4*ecx]:
         AddByte($8D); AddByte($0C);AddByte($89);
        //fld   tbyte ptr [ebx+2*ecx]:
         AddByte($DB); AddByte($2C);AddByte($4B);
      end;
   end;
end;




CheckStack(1);
end;





procedure TForevalH.LoadArrayElemLineForm(TypeArray,Place,Reg: Integer; AddrArray: TAddress);
var
t1,N,NF,S,nv,TM,TA,NM,NA,TMA,tva: Integer;
AdrM,AdrA,Num,AddrI: Cardinal;
begin

// TypeArray = _integer, _single, _double, _extended
// Reg = R_FPU, R_EAX, R_EBX, ...
// place = _First, _Second


// IntArray[LineForm]   ->  ST(0), EAX, EBX,...
// FloatArray[LineForm] ->  ST(0), EAX, EBX,...

 if TypeArray = _Integer then
 begin
     LoadLineFormEAX(Place);        // indx(LineForm) ->  EAX
     MOVMREG(R_EBX,AddrArray);       // AddrArray      ->  EBX
     case Reg   of
        R_EAX: MOV_EAX__EBX_4EAX;     // mov eax, [ebx+4*eax]
        R_ESI: MOV_ESI__EBX_4EAX;     // mov esi, [ebx+4*eax]
     end;
 end;

end;





