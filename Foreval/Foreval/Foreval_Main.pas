endp:
CheckForZeroNode:=bFZ;
end;



procedure TForevalH.ReplaceDiffTeplate(Tree: PNode; var DiffFunc: String);
label endp;
var
HTree: PNode;
NFunc,NArg,NFArg,i,NF: Integer;
FArg,DFArg: array of String;
Expr,TemplateDiffFunc,SFunc: String;
begin

if Tree = nil  then
begin
 {ERROR!!!}
 F_InternalError:=E_AccessViolation;;
 F_SyntaxErrorString:=Tree^.Expression;
 goto endp;
end;

NArg:=Tree^.Stack.N;            //число вытекающих узлов из вершины
NFunc:=Tree^.NFunc;

NF:=Tree^.NF;      {.301}
NFArg:=Alg.ExFunc[NFunc].Func[NF].NArg;   {.301}
//NFArg:=Alg.ExFunc[NFunc].NArg;  //число аргументов ф-ии NFunc   (должно быть равно NArg)

{.365} //закрыто из-за отлова ошибки с повторным заданием шаблона дифф-я: ошибка есть , но ловить не нужно :)
(*
if NFArg <> NArg then
begin
 F_InternalError:=9;
 F_SyntaxErrorString:=Tree^.Expression;
 {ERROR!!!}
 goto endp;
end;
*)

HTree:=Tree^.Ch;
//SFunc:=Tree^.SFunc;
SFunc:=Alg.ExFunc[NFunc].Name;                                    {.301}
//TemplateDiffFunc:=Alg.ExFunc[NFunc].TemplateDiffFunc;
TemplateDiffFunc:=Alg.ExFunc[NFunc].Func[NF].TemplateDiffFunc;    {.301}

SetLength(FArg,NArg);   SetLength(DFArg,NArg);

try
  for i := 0 to NArg - 1 do
  begin
   FArg[i]:=HTree^.Expression;
   DFArg[i]:=HTree^.SDiff;

   FindExternalBracketNegPS(@FArg[i]);      {.335}
   FindExternalBracketNegPS(@DFArg[i]);     {.335}

   HTree:=HTree^.Nb;
  end;
except
  F_InternalError:=E_AccessViolation;
  F_SyntaxErrorString:=Tree^.Expression;
  {INTERNAL ERROR !!!}
end;

if F_InternalError <> 0 then goto endp;


DiffFunc:=TemplateDiffFunc;
for i := 0 to Length(FArg) - 1 do
begin
  DiffFunc:=StringReplace( DiffFunc, DiffTmplNameArg+IntToStr(i+1), '('+FArg[i]+')',  [rfReplaceAll, rfIgnoreCase]);
end;

for i := 0 to Length(DFArg) - 1 do
begin
  DiffFunc:=StringReplace( DiffFunc, DiffTmplNameDiffArg+IntToStr(i+1), '('+DFArg[i]+')',  [rfReplaceAll, rfIgnoreCase]);
end;


{
SD1:=HTree^.SDiff;           FindExternalBracketN(SD1,SD1b,ng);
SD2:=HTree^.Nb^.SDiff;       FindExternalBracketN(SD2,SD2b,ng);
S1:=HTree^.Expression;       FindExternalBracketN(S1,S1b,ng);
S2:=HTree^.Nb^.Expression;   FindExternalBracketN(S2,S2b,ng2);
}
{F_InternalError:=9;
F_SyntaxErrorString:=Tree^.Expression;}

endp:
end;



