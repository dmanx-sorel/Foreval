procedure TForevalH.MOD_EAX_2(LoadFPU: Boolean);     //EAX mod 2 (-> EAX/ST(0))
begin
     //and eax,$80000001
     AddByte($25); AddByte($01); AddByte($00); AddByte($00); AddByte($80);
     //jns +5
     AddByte($79); AddByte($05);
     //dec eax
     AddByte($48);
     //or eax,-$02
     AddByte($83); AddByte($C8); AddByte($FE);
     //inc eax
     AddByte($40);

     if LoadFPU = True then
     begin
       MEM:=WriteDataA(0,_Integer);
       MOVAM(MEM);
       FILD(MEM);
     end;

     SetReg(1);
end;

procedure TForevalH.MOD_EAX_EBX(LoadFPU: Boolean);   //EAX mod EBX (-> EDX/ST(0))
begin
     CDQ;
     IDIVB;
     if LoadFPU = True then
     begin
       MEM:=WriteDataA(0,_Integer);
       MOVDM(MEM);
       FILD(MEM);
     end;
end;

procedure TForevalH.IDIV_EAX_2(LoadFPU: Boolean);     //EAX idiv 2 (-> EAX/ST(0))
begin

     //sar eax,1
     AddByte($D1); AddByte($F8);
     //jns +3
     AddByte($79); AddByte($03);
     //adc $00
     AddByte($83); AddByte($D0); AddByte($00);

     if LoadFPU = True then
     begin
       MEM:=WriteDataA(0,_Integer);
       MOVAM(MEM);
       FILD(MEM);
     end;

     SetReg(1);

end;

procedure TForevalH.IDIV_EAX_EBX(LoadFPU: Boolean);   //EAX div EBX (-> EAX/ST(0))
begin
     CDQ;
     IDIVB;
     if LoadFPU = True then
     begin
       MEM:=WriteDataA(0,_Integer);
       MOVREGM(R_EAX,MEM);
       FILD(MEM);
     end;
end;




procedure TForevalH.MOD_EAX_EBX(Arg2Type: Integer; IntConst: Integer; AddrIntVar: TAddress; NotRes: Boolean; LoadFPU: Boolean; PlacementArg: Integer);
// EAX mod EBX (-> EAX/ST(0))
var
Reg_Const,Reg_Res: Integer;
begin

     if Arg2Type = _IntVar then
     begin
        // Arg2->EAX;
        if PlacementArg = 20 then
        begin
           AddByte($93); // xchg eax,ebx
           MOVMREG(R_EAX,AddrIntVar);
        end
        else
        MOVMREG(R_EBX,AddrIntVar);


        CDQ;
        IDIVB;
        Reg_Res:=R_EDX;

     end
     else
     if Arg2Type = _IntConst then
     begin

        // Arg2->EAX;
        if PlacementArg = 20 then
        begin
           AddByte($93); // xchg eax,ebx
           Reg_Const:=R_EAX;
        end
        else
        Reg_Const:=R_EBX;



       if (IntConst = 2) and (Reg_Const = R_EBX) then       // mod(Arg1,2)
       begin
             //and eax,$80000001
             AddByte5($25,$01,$00,$00,$80);
             //jns +5
             AddByte2($79,$05);
             //dec eax
             AddByte($48);
            //or eax,-$02
             AddByte3($83,$C8,$FE);
            //inc eax
             AddByte($40);

             Reg_Res:=R_EAX;
       end
       else      {.393}
       if (IntConst = 4) and (Reg_Const = R_EBX) then       // mod(Arg1,4)
       begin
             //and eax,$80000003
             AddByte5($25,$03,$00,$00,$80);
             //jns +5
             AddByte2($79,$05);
             //dec eax
             AddByte($48);
            //or eax,-$04
             AddByte3($83,$C8,$FC);
            //inc eax
             AddByte($40);

             Reg_Res:=R_EAX;
       end
       else     {.393}
       if (IntConst = 8) and (Reg_Const = R_EBX) then       // mod(Arg1,8)
       begin
             //and eax,$80000007
             AddByte5($25,$07,$00,$00,$80);
             //jns +5
             AddByte2($79,$05);
             //dec eax
             AddByte($48);
            //or eax,-$08
             AddByte3($83,$C8,$F8);
            //inc eax
             AddByte($40);

             Reg_Res:=R_EAX;
       end
       else      {.393}
       if (IntConst = 16) and (Reg_Const = R_EBX) then       // mod(Arg1,16)
       begin
             //and eax,$8000000f
             AddByte5($25,$0F,$00,$00,$80);
             //jns +5
             AddByte2($79,$05);
             //dec eax
             AddByte($48);
            //or eax,-$10
             AddByte3($83,$C8,$F0);
            //inc eax
             AddByte($40);

             Reg_Res:=R_EAX;
       end
       else
       begin
           MOVCREG(Reg_Const,IntConst);
           CDQ;
           IDIVB;

           Reg_Res:=R_EDX;
       end;

     end
     else
     begin
        // Arg2->EAX; Agr1->EBX
        if PlacementArg = 21 then   AddByte($93); // xchg eax,ebx

        CDQ;
        IDIVB;

        Reg_Res:=R_EDX;
     end;


     if Reg_Res = R_EDX  then
          MOVREG(R_EDX,R_EAX); //EDX->EAX

      {
     if NotRes = True  then
          AddByte2($F7,$D0); // NOT eax
      }

     if LoadFPU = True then
     begin
       MEM:=WriteDataA(0,_Integer);
       MOVREGM(R_EAX,MEM);
       FILD(MEM);
     end;

end;




procedure TForevalH.IDIV_EAX_EBX(Arg2Type: Integer; IntConst: Integer; AddrIntVar: TAddress; NotRes: Boolean; LoadFPU: Boolean; PlacementArg: Integer);
// EAX idiv EBX (-> EAX/ST(0))
var
Reg_Const: Integer;
begin

     if Arg2Type = _IntVar then
     begin
        // Arg2->EAX;
        if PlacementArg = 20 then
        begin
           AddByte($93); // xchg eax,ebx
           MOVMREG(R_EAX,AddrIntVar);
        end
        else
        MOVMREG(R_EBX,AddrIntVar);


        CDQ;
        IDIVB;

     end
     else
     if Arg2Type = _IntConst then
     begin

        // Arg2->EAX;
        if PlacementArg = 20 then
        begin
           AddByte($93); // xchg eax,ebx
           Reg_Const:=R_EAX;
        end
        else
        Reg_Const:=R_EBX;



       if (IntConst = 2) and (Reg_Const = R_EBX) then       // idiv(Arg1,2)
       begin
           AddByte2($D1,$F8);    //sar eax,1
           AddByte2($79,$03);     //jns +3
           AddByte3($83,$D0,$00);   //adc $00
       end
       else   {.393}
       if (IntConst = 4) and (Reg_Const = R_EBX) then       // idiv(Arg1,4)
       begin
           AddByte2($85,$C0);    //test eax,eax
           AddByte2($79,$03);     //jns +3
           AddByte3($83,$C0,$03);  //add $03
           AddByte3($C1,$F8,$02);   //sar eax,2
       end
       else  {.393}
       if (IntConst = 8) and (Reg_Const = R_EBX) then       // idiv(Arg1,8)
       begin
           AddByte2($85,$C0);    //test eax,eax
           AddByte2($79,$03);     //jns +3
           AddByte3($83,$C0,$07);  //add $07
           AddByte3($C1,$F8,$03);   //sar eax,3
       end
       else   {.393}
       if (IntConst = 16) and (Reg_Const = R_EBX) then       // idiv(Arg1,16)
       begin
           AddByte2($85,$C0);    //test eax,eax
           AddByte2($79,$03);     //jns +3
           AddByte3($83,$C0,$0F);  //add $03
           AddByte3($C1,$F8,$04);   //sar eax,4
       end
       else
       begin
           MOVCREG(Reg_Const,IntConst);
           CDQ;
           IDIVB;
       end;

     end
     else
     begin
        // Arg2->EAX; Agr1->EBX
        if PlacementArg = 21 then   AddByte($93); // xchg eax,ebx

        CDQ;
        IDIVB;
     end;

     {
     if NotRes = True  then
          AddByte2($F7,$D0); // NOT eax
     }

     if LoadFPU = True then
     begin
       MEM:=WriteDataA(0,_Integer);
       MOVREGM(R_EAX,MEM);
       FILD(MEM);
     end;
end;




procedure TForevalH.AND_EAX_EBX(Arg2Type: Integer; IntConst: Integer; AddrIntVar: TAddress; NotRes: Boolean;  LoadFPU: Boolean);   //EAX and EBX/IntVar/IntConst (-> EAX/ST(0))
begin

     if Arg2Type = _IntVar then
     begin
       // AND eax, [IntVar]
       AddByte2($23,$05);
       AddAddress(AddrIntVar);
     end
     else
     if Arg2Type = _IntConst then
     begin
       // AND eax, IntConst
       AddByte($25);
       AddNum(IntConst);
     end
     else
     begin
        //  AND eax, ebx
          AddByte2($21,$D8);
     end;

     if NotRes = True  then
          AddByte2($F7,$D0); // NOT eax      //AND -> NAND


     if LoadFPU = True then
     begin
       MEM:=WriteDataA(0,_Integer);
       MOVREGM(R_EAX,MEM);
       FILD(MEM);
     end;
end;



procedure TForevalH.OR_EAX_EBX(Arg2Type: Integer; IntConst: Integer; AddrIntVar: TAddress; NotRes: Boolean;  LoadFPU: Boolean);   //EAX and EBX/IntVar/IntConst (-> EAX/ST(0))
begin

     if Arg2Type = _IntVar then
     begin
       // OR eax, [IntVar]
       AddByte2($0B,$05);
       AddAddress(AddrIntVar);
     end
     else
     if Arg2Type = _IntConst then
     begin
       // OR eax, IntConst
       AddByte($0D);
       AddNum(IntConst);
     end
     else
     begin
        //  OR eax, ebx
          AddByte2($09,$D8);
     end;

     if NotRes = True  then
          AddByte2($F7,$D0); // NOT eax    //OR -> NOR

     if LoadFPU = True then
     begin
       MEM:=WriteDataA(0,_Integer);
       MOVREGM(R_EAX,MEM);
       FILD(MEM);
     end;
end;



procedure TForevalH.XOR_EAX_EBX(Arg2Type: Integer; IntConst: Integer; AddrIntVar: TAddress; NotRes: Boolean;  LoadFPU: Boolean);   //EAX and EBX/IntVar/IntConst (-> EAX/ST(0))
begin

     if Arg2Type = _IntVar then
     begin
       // XOR eax, [IntVar]
       AddByte2($33,$05);
       AddAddress(AddrIntVar);
     end
     else
     if Arg2Type = _IntConst then
     begin
       // XOR eax, IntConst
       AddByte($35);
       AddNum(IntConst);
     end
     else
     begin
        //  XOR eax, ebx
          AddByte2($31,$D8);
     end;

     if NotRes = True  then
          AddByte2($F7,$D0); // NOT eax        XOR -> XNOR

     if LoadFPU = True then
     begin
       MEM:=WriteDataA(0,_Integer);
       MOVREGM(R_EAX,MEM);
       FILD(MEM);
     end;
end;


