procedure TForevalH.EvalFuncN(PNE: PNode; var Res: TComplex; var IsEval: Boolean);
label endc, endp;
var
Re1,Im1,Re2,Im2: Extended;
ResT1,ResT2,NFunc,NF,NS,NArg,TypeF,TV1,TV2,COP: Integer;
Answ: Boolean;
Arg1,Arg2: TComplex;
BeginNode,ChNd: PNode;
begin
if F_InternalError <> 0  then goto endp;  {.322}

try
//Answ:=False;
TryFPUMask; {.326}

IsEval:=False;

   NFunc:=PNE^.NFunc; NF:=PNE^.NF;
   NArg:=Alg.ExFunc[NFunc].Func[NF].NArg;
   TypeF:=Alg.ExFunc[NFunc].Func[NF].TypeF;

   NS:=PNE^.Stack.N;
   if Alg.ExFunc[NFunc].Func[NF].CallT = _STACK_INFINITE then NArg:=NS; {.322} //для inf ф-ий текущее число арг. в Stack.N



   ChNd:=PNE^.Ch;
   while ChNd <> nil do
   begin
     COP:=ChNd^.COP;
     if (COP = _LDSC) or  (COP = _LDSCX) or ((COP = _LDINTFORM) and (ChNd^.TA1 = _IntConst))  then
     begin
     end
     else
     begin
        IsEval:=False;
        goto endc;
     end;
     ChNd:=ChNd^.Nb;
   end;

   {
    компиляция func(arg1,arg2,...,argN); arg1,..,argN - константы
    число узлов для компиляции: NArg+1 - arg1,...,argN + функция
    первый узел - первый аргумент: PNE^.Ch, последний - функция
   }
   CompileNodes(PNE^.Ch,NArg+1);


  _EvalFunc(Func.PAddr,TypeF,Res);
  FreeExtFunc(@Func);
  IsEval:=True;

 (*
   if TypeF = T_Real then
   begin
       PNE^.FD:=Res.re;
       PNE^.COP := _LDSC;
       PNE^.TypeF:=T_Real;
   end
   else
   if TypeF = T_Complex then
   begin
       PNE^.FDC.re:=Res.re;
       PNE^.FDC.im:=Res.im;
       PNE^.COP := _LDSCX;
       PNE^.TypeF:=T_Complex;
   end;

  if PNE^.COP = _LDSCX then PNE^.TC := C_Complex;
  Answ:=True;

  *)


endc:
TryCatchFPUException;    {.326}
except {.322}
 on E: EZeroDivide      do F_InternalError:=E_ZeroDivide;
 on E: EInvalidOp       do F_InternalError:=E_InvalidOp;
 on E: EOverFlow        do F_InternalError:=E_OverFlow;
 on E: EUnderFlow       do F_InternalError:=E_UnderFlow;
 on E: EIntOverFlow     do F_InternalError:=E_IntOverFlow;
 on E: EAccessViolation do F_InternalError:=E_AccessViolation;
 on E: EOutOfMemory     do F_InternalError:=E_OutOfMemory;
 on E: EStackOverFlow   do F_InternalError:=E_StackOverFlow
end;


{.385}
if (IsEval = True) and (F_InternalError = 0)  then
begin
  if TypeF = T_Real then
  begin
     if IsNanOrInf(Res.re) = True then   F_InternalError:=E_InvalidOp;
  end
  else
  if TypeF = T_Complex then
  begin
    if (IsNanOrInf(Res.re) = True) or (IsNanOrInf(Res.im) = True) then   F_InternalError:=E_InvalidOp;
  end;
end;


if F_InternalError <> 0 then F_SyntaxErrorCode:=E_INTERNAL_ERROR_AT_CALCULATION;    {.326}

endp:
end;



function TForevalH.EvalConstFuncN(PNE: PNode): Boolean;
label endp;
var
Re1,Im1,Re2,Im2: Extended;
ResT1,ResT2,NFunc,NF,NArg,TypeF,TV1,TV2,COP: Integer;
Answ,IsEval: Boolean;
Arg1,Arg2,Res: TComplex;
BeginNode,ChNd: PNode;
begin
Answ:=False;
if  F_CalcConstExtFunc = False then goto endp;
//IsEval:=True;
  (*
   NFunc:=PNE^.NFunc; NF:=PNE^.NF;
   NArg:=Alg.ExFunc[NFunc].Func[NF].NArg;
   TypeF:=Alg.ExFunc[NFunc].Func[NF].TypeF;

   ChNd:=PNE^.Ch;
   while ChNd <> nil do
   begin
     COP:=ChNd^.COP;
     if (COP = _LDSC) or  (COP = _LDSCX) or ((COP = _LDINTFORM) and (ChNd^.TA1 = _IntConst))  then
     begin
     end
     else
     begin
        Answ:=False;
        goto endp;
     end;
     ChNd:=ChNd^.Nb;
   end;

   CompileNodes(PNE^.Ch,NArg+1);


  _EvalFunc(GFAddr,TypeF,Res);
  *)


   NFunc:=PNE^.NFunc; NF:=PNE^.NF;
   NArg:=Alg.ExFunc[NFunc].Func[NF].NArg;
   if (Alg.ExFunc[NFunc].Func[NF].IntF <> _External) or (Alg.ExFunc[NFunc].Func[NF].Addr = 0) then goto endp;

   TypeF:=Alg.ExFunc[NFunc].Func[NF].TypeF;

   EvalFuncN(PNE,Res,IsEval);

if IsEval = True then
begin

   if TypeF = T_Real then
   begin
       PNE^.FD:=Res.re;
       PNE^.COP := _LDSC;
       PNE^.TypeF:=T_Real;
   end
   else
   if TypeF = T_Complex then
   begin
       PNE^.FDC.re:=Res.re;
       PNE^.FDC.im:=Res.im;
       PNE^.COP := _LDSCX;
       PNE^.TypeF:=T_Complex;
   end;

  if PNE^.COP = _LDSCX then PNE^.TC := C_Complex;
  Answ:=True;

end;



endp:
EvalConstFuncN:=Answ;
end;



procedure TForevalH.CompileNodes(BeginNode: PNode; NNodes: Integer);
label recompile,2,endp;
var
i,j,N,alg,db,db1: Integer;
AH,AB: TArray4;
R: TFloat;
P: Pointer;
X: TFloat;
CS,LCode: Cardinal;
ANL: TArrayC;
S,S1: String;
AdrCmpl,AdrD,AdrS: Pointer;
AdrTst: TAddress;
Node: PNode;
CalcTypeF: Integer;
DataInArrayF: Boolean;
begin
if F_SyntaxErrorCode <> 0 then goto endp;
{
CalcTypeF:=F_CalcType;
F_CalcType:=T_None;
}
DataInArrayF:=F_DataInArray;

//каждый раз инициализация т.к. предыдущее выражение может сбросить F_SaveInFPU:
N_Stack:=0;
_MaxStack:=0;
//F_Opt:=False;
F_ExtFunc:=False;
ES_OverFlow:=False;
F_EnableCheckStack:=True;
F_Mode:=M_Compile;   {.197}



recompile:
new(FuncData); FuncData^.Next:=nil; BFuncData:=FuncData;
SetLength(ICOMP,0);
N_CurrentDataCell:=0;

F_IntermediateLastNode:=False; {.310}
F_DataInArray := False;        {.310}
SetLength(Func.Stack,BeginNode^.S+NNodes+1); {.310}    {.364}

SetLength(GotoLab,0);

CS:=0;
F_JMP:=1;
TE_ADDR:=0; TE_ADDR1:=0;

PUSHAD;

Node:=BeginNode;
//while Node <> nil do
for j := 1 to NNodes do
begin

   Node^.CS:=0;

   if Node^.COP <> _NOP then      //COP=_NOP: только для аргументов замещаемой комманды //for(j,0,1,t=(x^2+x)*(x^2+x) ); t
   begin
      {$IFDEF DEBUGS}
         S:=Node^.Expression;
         db1:=Node^.SData1;
         if db1 = _MEM then S1:='SaveRes:MEM'  else if db1 = _FPU then S1:='SaveRes:FPU';
         dbFPUBefore:=N_Stack; dbFPULoad:=0;
      {$ENDIF}

     S:=Node^.Expression;


      GNode:=Node;

      if j = NNodes then F_IntermediateLastNode:=True;

     // Node^.NC:=Length(ICOMP);

      AddCommand(Node);
     (*
      Node^.NCP:=Length(ICOMP);
      CS:=Length(ICOMP)-CS;
      Node^.CS:=CS+GetLevelsCS(Node{i});
      CS:=Length(ICOMP);
     *)

      {$IFDEF DEBUGS}
        dbMaxLoadCom:=dbFPUBefore+dbFPULoad;
        TestZ.Form1.MT.Lines.Add('"'+S+'"   '+S1+'    loadFPUafter:'+IntToStr(N_Stack)+ '    MaxLoadFPU:'+IntToStr(_MaxStack{dbMaxLoadCom}));
      {$ENDIF}
  end;

  Node:=Node^.Next;
end;

 (*
//расстановка адресов переходов jmp adr
F_JMP:=2;
Node:=BeginNode;
//while Node <> nil do
for j := 1 to NNodes do
begin
  GNode:=Node; //NFunc:=i;
  if Node^.NFunc = CM_JMP then JMP_C;//if Interp[i].NFunc = CM_JMP then JMP_C;
  Node:=Node^.Next;
end;
*)

POPAD;
RET;


//if  (F_SaveInFPU = True) and (_MaxStack > 8) and ({F_Opt = False}F_Mode=M_Compile) then
if  (F_SaveInFPU = True) and (ES_OverFlow = True) and (F_Mode = M_Compile) then    {.300}
begin
//может быть только в случае внутренней ошибки в DinamicLoadOptimizator: неверный расчет Load FPU => защита)
  N_Stack:=0;
  _MaxStack:=0;
  ES_OverFlow:=False;
  FreeData;
  //Db_OverFlow:=True;
  F_SaveInFPU:=False;
  Db_DinLoadOverFlow:=True;
  //S:=CurrentExpression;
  goto recompile;
end;


if F_UseVirtAlloc = False then
begin

  SetLength(Func.Code,Length(ICOMP));
  for i:=0 to High(ICOMP) do
  begin
   Func.Code[i]:=ICOMP[i];
  end;

  Func.Addr:=TAddress(@Func.Code[0]);
  Func.PAddr:=@Func.Code[0];
  Func.CodeSize:=Length(ICOMP);
  Func.AllocMem:=1;

end
else
{
  fzSet(fz_ENABLE, fz_USE_VIRTUAL_ALLOC);
  allows memory for the  code  is allocated  out  by  the system command  instead: command 'SetLength' in a dynamic array.
{
//F_VirtAlloc = True   {.193}
begin     //only for WinXP SP2+;  memory alloc. only for exe code. Use, only if is any errors with standard memory allocating   (SetLength)
  LCode:=Length(ICOMP);
  AdrD:=VirtualAlloc(Nil, LCode, MEM_COMMIT or MEM_RESERVE, PAGE_EXECUTE_READWRITE);
  AdrS:=@ICOMP[0];
  CopyMemory(AdrD,AdrS,LCode);
  Func.Addr:=TAddress(AdrD);
  Func.PAddr:=AdrD;
  Func.CodeSize:=LCode;
  Func.AllocMem:=2;
end;

ICOMP:=nil;
Func.Data:=BFuncData;



ICOMP:=nil;

F_DataInArray := DataInArrayF;
F_IntermediateLastNode:=False;
//F_CalcType:=CalcTypeF;

//PInteger(AdrCmpl)^:=Func.Addr;
{AdrTst:=Func.Addr;
asm
  push eax
  mov eax, AdrTst
  call eax

  pop  eax

end;  }

endp:
end;




function  TForevalH.EvalConstFunc(PNE: PNode): Boolean;
label endp;
var
ResT1,ResT2,ResT,TC1,TC2,COP1,COP2,NFunc,NF,NArg,NS: Integer;
PN1,PN2: PNode;
Re1,Im1,Re2,Im2,RE,IM: Extended;
Answ: Boolean;
begin
Answ:=False;
if F_InternalError <> 0  then goto endp;  {.322}


  NFunc:=PNE^.NFunc; NF:=PNE^.NF;
  NArg:=Alg.ExFunc[NFunc].Func[NF].NArg;
  NS:=PNE^.Stack.N;


  if NS = NArg then
  begin
     case NArg of
       0:    Answ:=EvalConstFunc0(PNE);
       1:    Answ:=EvalConstFunc1(PNE);
       2:    Answ:=EvalConstFunc2(PNE);
       //3:    Answ:=EvalConstFunc3(PNE);
       else  Answ:=EvalConstFuncN(PNE);
     end;

  end
  else  //вычисление ф-ий с переменным числом арг. sum(1,2,3), sum(1,2-4/5,3*2,4/(5-7/8),5)*x
  if (Alg.ExFunc[NFunc].Func[NF].CallT = _STACK_INFINITE) and  (NS > 0) then     {.322}
  begin
     Answ:=EvalConstFuncN(PNE);
  end;
  //else Internal ERROR !!!



endp:
 EvalConstFunc:=Answ;
end;






function TForevalH.CheckChildForZero(PNE: PNode; NumArg: Integer): Boolean;
label endp;
var
ResT1,ResT2,ResT,TC1,TC2,COP1,COP2: Integer;
PN1,PN2: PNode;
Re1,Im1,Re2,Im2,RE,IM: Extended;
ZeroArg: Boolean;
S1,S2: String;
begin
ZeroArg:=False;
if F_InternalError <> 0  then goto endp;  {.322}



 PN1:=PNE^.Ch; PN2:=PN1^.Nb;
 ResT1:=PN1^.TypeF;     ResT2:=PN2^.TypeF;
 TC1:=PN1^.TC;   TC2:=PN2^.TC;
 COP1:=PN1^.COP;  COP2:=PN2^.COP;

 S1:=PN1^.Expression;
 S2:=PN2^.Expression;

 Re1:=1.0; Im1:=1.0; Re2:=1.0; Im2:=1.0; //init for delete garbage

if (NumArg = _First) or  (NumArg = _Both) then
begin
 if (COP1 = _LDSC) then
 begin
   ResT1:=T_Real;
   Re1:=PN1^.FD; Im1:=0.0;
 end
 else
 if (COP1 = _LDSCX) then
 begin
    if TC1 = C_Complex then
    begin
       ResT1:=T_Complex;
       Re1:=PN1^.FDC.re; Im1:=PN1^.FDC.im;
    end
    else
    if TC1 = C_Image then
    begin
       ResT1:=T_Complex;
       Re1:=0.0; Im1:=PN1^.FDC.im;
    end
    else
    if TC1 = C_Real then
    begin
       ResT1:=T_Real;
       Re1:=PN1^.FDC.re; Im1:=0.0;
    end
 end ;
end;



if (NumArg = _Second) or  (NumArg = _Both) then
begin
 if (COP2 = _LDSC) then
 begin
   ResT2:=T_Real;
   Re2:=PN2^.FD; Im2:=0.0;
 end
 else
 if (COP2 = _LDSCX) then
 begin
    if TC2 = C_Complex then
    begin
       ResT2:=T_Complex;
       Re2:=PN2^.FDC.re; Im2:=PN2^.FDC.im;
    end
    else
    if TC2 = C_Image then
    begin
       ResT2:=T_Complex;
       Re2:=0.0; Im2:=PN2^.FDC.im;
    end
    else
    if TC2 = C_Real then
    begin
       ResT2:=T_Real;
       Re2:=PN2^.FDC.re; Im2:=0.0;
    end
 end ;
end;

 if ((Re1 = 0.0) and (Im1 = 0.0)) or ((Re2 = 0.0) and (Im2 = 0.0)) then
    ZEroArg:=True;

if ZeroArg = True then
begin
 PNE^.FDC.re:=0.0;
 PNE^.FDC.im:=0.0;
 PNE^.FD:=0.0;

 if (ResT1 = T_Complex) and (ResT2 = T_Complex) then
 begin
   PNE^.COP:=_LDSCX;
   PNE^.TypeF:=T_Complex;
 end
 else
 if (ResT1 = T_Real) and (ResT2 = T_Real) then
 begin
   PNE^.COP := _LDSC;
   PNE^.TypeF:=T_Real;
 end
 else
 if ((ResT1 = T_Complex) and (ResT2 = T_Real)) or ((ResT1 = T_Real) and (ResT2 = T_Complex)) then
 begin
   PNE^.COP:=_LDSCX;
   PNE^.TypeF:=T_Complex;
 end ;

 if PNE^.COP = _LDSCX then PNE^.TC := C_Complex;
end;


endp:
CheckChildForZero:=ZeroArg;
end;




procedure TForevalH.EvalCOP1(PNE: PNode; COP,tArg:Integer);
label endp;
var
ResT1,ResT,TC1,COP1,Inv: Integer;
PN1: PNode;
Re1,Im1,RE,IM: Extended;

begin
if F_InternalError <> 0  then goto endp;  {.322}

try
TryFPUMask; {.326}

  PN1:=PNE^.Ch;
  ResT1:=PN1^.TypeF;
  TC1:=PN1^.TC;
  COP1:=PN1^.COP;
  Inv:=PNE^.Inv;
  Re1:=0; Im1:=0;

  if (COP1 = _LDSC) then
  begin
   ResT1:=T_Real;
   Re1:=PN1^.FD; Im1:=0.0;
  end
  else
  if (COP1 = _LDSCX) then
  begin
    if TC1 = C_Complex then
    begin
       ResT1:=T_Complex;
       Re1:=PN1^.FDC.re; Im1:=PN1^.FDC.im;
    end
    else
    if TC1 = C_Image then
    begin
       ResT1:=T_Complex;
       Re1:=0.0; Im1:=PN1^.FDC.im;
    end
    else
    if TC1 = C_Real then
    begin
       ResT1:=T_Real;
       Re1:=PN1^.FDC.re; Im1:=0.0;
    end
  end ;



 if (ResT1 = T_Complex)  then
 begin
   case COP of

     CM_NEG:  begin
                 PNE^.FDC.re:=-Re1;//PN1^.FDC.re;
                 PNE^.FDC.im:=-Im1;//PN1^.FDC.im;
                 PNE^.COP := _LDSCX;
                 PNE^.TypeF:=T_Complex;
              end;

     CM_RE:   begin
                 PNE^.FD:=Re1;//-PN1^.FDC.re;
                 PNE^.COP := _LDSC;
                 PNE^.TypeF:=T_Real;
              end;

     CM_IM:   begin
                 PNE^.FD:=Im1;//-PN1^.FDC.im;
                 PNE^.COP := _LDSC;
                 PNE^.TypeF:=T_Real;
              end;

     CM_ADD:  begin
                  if tArg = IM_UNIT then   //constCX+i
                  begin
                    PNE^.FDC.re:=Re1;
                    PNE^.FDC.im:=Im1+1;
                    PNE^.COP := _LDSCX;
                    PNE^.TypeF:=T_Complex;
                  end
                  else
                  begin   //tArg = Any_Const       //constCX+const
                    PNE^.FDC.re:=Re1+PNE^.FD;
                    PNE^.FDC.im:=Im1;
                    PNE^.COP := _LDSCX;
                    PNE^.TypeF:=T_Complex;
                  end;
              end;

     CM_MUL:  begin
                 if tArg = IM_UNIT then    //constCX*i
                  begin
                    PNE^.FDC.re:=-Im1;
                    PNE^.FDC.im:=Re1;
                    PNE^.COP := _LDSCX;
                    PNE^.TypeF:=T_Complex;
                  end
                  else
                  begin   //tArg = Any_Const
                    {After MulDivOtimizator: i - recognize as const (not variable)}

                    if PNE^.TC = C_Real then
                    begin
                     PNE^.FDC.re:=Re1*PNE^.FD;
                     PNE^.FDC.im:=Im1*PNE^.FD;
                     PNE^.COP := _LDSCX;
                     PNE^.TypeF:=T_Complex;
                    end
                    else
                    if PNE^.TC = C_Complex then
                    begin
                      _ComplexMUL(PNE^.FDC.re,PNE^.FDC.im,Re1,Im1,RE,IM);
                     PNE^.FDC.re:=RE;
                     PNE^.FDC.im:=IM;
                     PNE^.COP := _LDSCX;
                     PNE^.TypeF:=T_Complex;
                    end

                  end;
              end;

     CM_SUB:  begin
                 if tArg = IM_UNIT then      //ConstCX-i
                 begin
                    if Inv = 1 then        //i-ConstCX
                    begin
                       PNE^.FDC.re:=-Re1;
                       PNE^.FDC.im:=1-Im1;
                    end
                    else                 //ConstCX-i
                    begin
                       PNE^.FDC.re:=Re1;
                       PNE^.FDC.im:=Im1-1;
                    end;
                    PNE^.COP := _LDSCX;
                    PNE^.TypeF:=T_Complex;
                 end
                 else
                 begin   //tArg = Any_Const
                    if Inv = 1 then
                    begin
                       PNE^.FDC.re:=PNE^.FD-Re1;
                       PNE^.FDC.im:=-Im1;
                    end
                    else
                    begin
                       PNE^.FDC.re:=Re1-PNE^.FD;
                       PNE^.FDC.im:=Im1;
                    end;
                    PNE^.COP := _LDSCX;
                    PNE^.TypeF:=T_Complex;
                  end;
              end;

     CM_DIV:  begin
                 if tArg = IM_UNIT then
                  begin
                     if Inv = 1 then      // i/ConstCX
                    begin
                       _ComplexDIV(0,1,Re1,Im1,RE,IM);
                       PNE^.FDC.re:=RE;
                       PNE^.FDC.im:=IM;
                    end
                    else                   //ConstCX/i
                    begin
                       PNE^.FDC.re:=Im1;
                       PNE^.FDC.im:=-Re1;
                    end;

                    PNE^.COP := _LDSCX;
                    PNE^.TypeF:=T_Complex;
                  end
                  else
                  begin   //tArg = Any_Const
                    if Inv = 1 then
                    begin
                         {After MulDivOtimizator: i - recognize as const (not variable)}

                        if PNE^.TC = C_Real then
                        begin
                          _ComplexDIV(PNE^.FD,0,Re1,Im1,RE,IM);
                          PNE^.FDC.re:=RE;
                          PNE^.FDC.im:=IM;
                        end
                        else
                        if PNE^.TC = C_Complex then
                        begin
                          _ComplexDIV(PNE^.FDC.re,PNE^.FDC.im,Re1,Im1,RE,IM);
                          PNE^.FDC.re:=RE;
                          PNE^.FDC.im:=IM;
                        end

                    end
                    else
                    begin
                       PNE^.FDC.re:=Re1/PNE^.FD;
                       PNE^.FDC.im:=Im1/PNE^.FD;
                    end;

                    PNE^.COP := _LDSCX;
                    PNE^.TypeF:=T_Complex;
                  end;
              end;
   end;
 end
 else

 if (ResT1 = T_Real)  then
 begin
   case COP of
      CM_NEG:  begin PNE^.FD:=-Re1;  PNE^.COP := _LDSC; PNE^.TypeF:=T_Real;  end;
      CM_RE:   begin PNE^.FD:=Re1;   PNE^.COP := _LDSC; PNE^.TypeF:=T_Real;  end;
      CM_IM:   begin PNE^.FD:=0.0;   PNE^.COP := _LDSC; PNE^.TypeF:=T_Real;  end;

      CM_ADD:  begin
                 if tArg = IM_UNIT then     //ConstRe+i
                  begin
                    PNE^.FDC.re:=Re1;
                    PNE^.FDC.im:=1.0;
                    PNE^.COP := _LDSCX;
                    PNE^.TypeF:=T_Complex;
                  end
                  else
                  begin   //tArg = Any_Const
                    PNE^.FD:=Re1+PNE^.FD;
                    PNE^.COP := _LDSC;
                    PNE^.TypeF:=T_Real;
                  end;
               end;
      CM_MUL:  begin
               if tArg = IM_UNIT then       //ConstRe*i
                  begin
                    PNE^.FDC.re:=0.0;
                    PNE^.FDC.im:=Re1;
                    PNE^.COP := _LDSCX;
                    PNE^.TypeF:=T_Complex;
                  end
                  else
                  begin   //tArg = Any_Const
                    {After MulDivOtimizator: i - recognize as const (not variable)}
                    if  (PNE^.TC = C_Real) then
                    begin
                      PNE^.FD:=Re1*PNE^.FD;
                      PNE^.COP := _LDSC;
                      PNE^.TypeF:=T_Real;
                    end
                    else
                    if  (PNE^.TC = C_Complex) then
                    begin
                      _ComplexMUL(PNE^.FDC.re,PNE^.FDC.im,Re1,Im1,RE,IM);
                      PNE^.FDC.re:=RE;
                      PNE^.FDC.im:=IM;
                      PNE^.COP := _LDSCX;
                      PNE^.TypeF:=T_Complex;
                    end
                  end;
               end;

      CM_SUB:  begin
                  if tArg = IM_UNIT then
                  begin
                    if Inv = 1 then         //i-ConstRe
                    begin
                       PNE^.FDC.re:=-Re1;
                       PNE^.FDC.im:=1.0;
                    end
                    else                   //ConstRe-i
                    begin
                       PNE^.FDC.re:=Re1;
                       PNE^.FDC.im:=-1.0;
                    end;
                    PNE^.COP := _LDSCX;
                    PNE^.TypeF:=T_Complex;
                  end
                  else
                  begin   //tArg = Any_Const
                    if Inv = 1 then PNE^.FD:=PNE^.FD-Re1 else PNE^.FD:=Re1-PNE^.FD;
                    PNE^.COP := _LDSC;
                    PNE^.TypeF:=T_Real;
                  end;
               end;

      CM_DIV:  begin
                 if tArg = IM_UNIT then
                  begin
                    if Inv = 1 then     // i/ConstRe
                    begin
                       PNE^.FDC.re:=0.0;
                       PNE^.FDC.im:=1.0/Re1;
                    end
                    else               // ConstRe/i
                    begin
                       PNE^.FDC.re:=0.0;
                       PNE^.FDC.im:=-Re1;
                    end;

                    PNE^.COP := _LDSCX;
                    PNE^.TypeF:=T_Complex;
                  end
                  else
                  begin   //tArg = Any_Const

                       if Inv = 1 then
                       begin
                         {After MulDivOtimizator: i - recognize as const (not variable)}

                         if PNE^.TC = C_Real then
                         begin
                           {_ComplexDIV(PNE^.FD,0,Re1,Im1,RE,IM);
                           PNE^.FDC.re:=RE;
                           PNE^.FDC.im:=IM;}
                           PNE^.FD:=PNE^.FD/Re1;
                           PNE^.COP := _LDSC;
                           PNE^.TypeF:=T_Real;
                         end
                         else
                         if PNE^.TC = C_Complex then
                         begin
                           _ComplexDIV(PNE^.FDC.re,PNE^.FDC.im,Re1,Im1,RE,IM);
                           PNE^.FDC.re:=RE;
                           PNE^.FDC.im:=IM;
                           PNE^.COP := _LDSCX;
                           PNE^.TypeF:=T_Complex;
                         end

                       end
                       else
                       begin
                         PNE^.FD:=Re1/PNE^.FD;
                         PNE^.COP := _LDSC;
                         PNE^.TypeF:=T_Real;
                       end;

                    {
                    if Inv = 1 then PNE^.FD:=PNE^.FD/Re1 else PNE^.FD:=Re1/PNE^.FD;
                    PNE^.COP := _LDSC;
                    PNE^.TypeF:=T_Real;  }
                  end;
               end;
   end;


 end ;

 if PNE^.COP = _LDSCX then PNE^.TC := C_Complex;


TryCatchFPUException;    {.326}
except          {.322}
 on E: EZeroDivide      do F_InternalError:=E_ZeroDivide;
 on E: EInvalidOp       do F_InternalError:=E_InvalidOp;
 on E: EOverFlow        do F_InternalError:=E_OverFlow;
 on E: EUnderFlow       do F_InternalError:=E_UnderFlow;
 on E: EIntOverFlow     do F_InternalError:=E_IntOverFlow;
 on E: EAccessViolation do F_InternalError:=E_AccessViolation;
 on E: EOutOfMemory     do F_InternalError:=E_OutOfMemory;
 on E: EStackOverFlow   do F_InternalError:=E_StackOverFlow
end;

if F_InternalError <> 0 then F_SyntaxErrorCode:=E_INTERNAL_ERROR_AT_CALCULATION;    {.326}

endp:
end;





procedure TForevalH.EvalCOP2(PNE: PNode; COP:Integer);
label endp;
var
ResT1,ResT2,ResT,TC1,TC2,COP1,COP2: Integer;
PN1,PN2: PNode;
Re1,Im1,Re2,Im2,RE,IM: Extended;
begin
if F_InternalError <> 0  then goto endp;  {.322}

try
TryFPUMask; {.326}


 PN1:=PNE^.Ch; PN2:=PN1^.Nb;
 ResT1:=PN1^.TypeF;     ResT2:=PN2^.TypeF;
 TC1:=PN1^.TC;   TC2:=PN2^.TC;
 COP1:=PN1^.COP;  COP2:=PN2^.COP;
 Re1:=0; Im1:=0;   Re2:=0; Im2:=0;

 if (COP1 = _LDSC) then
 begin
   ResT1:=T_Real;
   Re1:=PN1^.FD; Im1:=0.0;
 end
 else
 if (COP1 = _LDSCX) then
 begin
    if TC1 = C_Complex then
    begin
       ResT1:=T_Complex;
       Re1:=PN1^.FDC.re; Im1:=PN1^.FDC.im;
    end
    else
    if TC1 = C_Image then
    begin
       ResT1:=T_Complex;
       Re1:=0.0; Im1:=PN1^.FDC.im;
    end
    else
    if TC1 = C_Real then
    begin
       ResT1:=T_Real;
       Re1:=PN1^.FDC.re; Im1:=0.0;
    end
 end ;


 if (COP2 = _LDSC) then
 begin
   ResT2:=T_Real;
   Re2:=PN2^.FD; Im2:=0.0;
 end
 else
 if (COP2 = _LDSCX) then
 begin
    if TC2 = C_Complex then
    begin
       ResT2:=T_Complex;
       Re2:=PN2^.FDC.re; Im2:=PN2^.FDC.im;
    end
    else
    if TC2 = C_Image then
    begin
       ResT2:=T_Complex;
       Re2:=0.0; Im2:=PN2^.FDC.im;
    end
    else
    if TC2 = C_Real then
    begin
       ResT2:=T_Real;
       Re2:=PN2^.FDC.re; Im2:=0.0;
    end
 end ;



 if (ResT1 = T_Complex) and (ResT2 = T_Complex) then
 begin
   case COP of
     CM_ADD:  _ComplexADD(Re1,Im1,Re2,Im2,RE,IM);
     CM_SUB:  _ComplexSUB(Re1,Im1,Re2,Im2,RE,IM);
     CM_MUL:  _ComplexMUL(Re1,Im1,Re2,Im2,RE,IM);
     CM_DIV:  _ComplexDIV(Re1,Im1,Re2,Im2,RE,IM);
   end;
   PNE^.FDC.re:=RE;
   PNE^.FDC.im:=IM;
   PNE^.COP:=_LDSCX;
   PNE^.TypeF:=T_Complex;
 end
 else
 if (ResT1 = T_Real) and (ResT2 = T_Real) then
 begin
   case COP of
      CM_ADD:  PNE^.FD:=Re1+Re2;
      CM_SUB:  PNE^.FD:=Re1-Re2;
      CM_MUL:  PNE^.FD:=Re1*Re2;
      CM_DIV:  PNE^.FD:=Re1/Re2;
   end;

   PNE^.COP := _LDSC;
   PNE^.TypeF:=T_Real;
 end
 else
 if ((ResT1 = T_Complex) and (ResT2 = T_Real)) or ((ResT1 = T_Real) and (ResT2 = T_Complex)) then
 begin
   case COP of
     CM_ADD:  _ComplexADD(Re1,Im1,Re2,Im2,RE,IM);
     CM_SUB:  _ComplexSUB(Re1,Im1,Re2,Im2,RE,IM);
     CM_MUL:  _ComplexMUL(Re1,Im1,Re2,Im2,RE,IM);
     CM_DIV:  _ComplexDIV(Re1,Im1,Re2,Im2,RE,IM);
   end;
   PNE^.FDC.re:=RE;
   PNE^.FDC.im:=IM;
   PNE^.COP:=_LDSCX;
   PNE^.TypeF:=T_Complex;
 end ;

 if PNE^.COP = _LDSCX then PNE^.TC := C_Complex;

TryCatchFPUException;    {.326}
except   {.322}
 on E: EZeroDivide      do F_InternalError:=E_ZeroDivide;
 on E: EInvalidOp       do F_InternalError:=E_InvalidOp;
 on E: EOverFlow        do F_InternalError:=E_OverFlow;
 on E: EUnderFlow       do F_InternalError:=E_UnderFlow;
 on E: EIntOverFlow     do F_InternalError:=E_IntOverFlow;
 on E: EAccessViolation do F_InternalError:=E_AccessViolation;
 on E: EOutOfMemory     do F_InternalError:=E_OutOfMemory;
 on E: EStackOverFlow   do F_InternalError:=E_StackOverFlow
end;

if F_InternalError <> 0 then F_SyntaxErrorCode:=E_INTERNAL_ERROR_AT_CALCULATION;    {.326}

endp:
end;




procedure TForevalH.EvalConstCOP1(PNE: PNode; COP,tArg: Integer);
label endp;
var
Inv: Integer;
begin
if F_InternalError <> 0  then goto endp;  {.322}

try
TryFPUMask; {.326}

Inv:=PNE^.Inv;

if tArg = IM_UNIT then //FD COP i
begin
   case COP of

     CM_ADD: begin
                PNE^.FDC.re:=PNE^.FD;
                PNE^.FDC.im:=1.0;
             end;

     CM_SUB: begin
                    if Inv = 1 then         //i-FD
                    begin
                       PNE^.FDC.re:=-PNE^.FD;
                       PNE^.FDC.im:=1.0;
                    end
                    else                   //FD-i
                    begin
                       PNE^.FDC.re:=PNE^.FD;
                       PNE^.FDC.im:=-1.0;
                    end;
               end;

     CM_MUL: begin
                PNE^.FDC.re:=0.0;
                PNE^.FDC.im:=PNE^.FD;
             end;


     CM_DIV:  begin
                    if Inv = 1 then     // i/FD
                    begin
                       PNE^.FDC.re:=0.0;
                       PNE^.FDC.im:=-PNE^.FD;
                    end
                    else               // FD/i
                    begin
                       PNE^.FDC.re:=0.0;
                       PNE^.FDC.im:=1.0/PNE^.FD;
                    end;
              end;
   end;

   PNE^.COP:=_LDSCX;
   PNE^.TypeF:=T_Complex;

TryCatchFPUException;    {.326}
end;

 if PNE^.COP = _LDSCX then PNE^.TC := C_Complex;

except    {.322}
 on E: EZeroDivide      do F_InternalError:=E_ZeroDivide;
 on E: EInvalidOp       do F_InternalError:=E_InvalidOp;
 on E: EOverFlow        do F_InternalError:=E_OverFlow;
 on E: EUnderFlow       do F_InternalError:=E_UnderFlow;
 on E: EIntOverFlow     do F_InternalError:=E_IntOverFlow;
 on E: EAccessViolation do F_InternalError:=E_AccessViolation;
 on E: EOutOfMemory     do F_InternalError:=E_OutOfMemory;
 on E: EStackOverFlow   do F_InternalError:=E_StackOverFlow
end;

if F_InternalError <> 0 then F_SyntaxErrorCode:=E_INTERNAL_ERROR_AT_CALCULATION;    {.326}

endp:
end;




 {.322}
procedure TForevalH.EvalTreeConst;
label endp;

          function EvalNode(PNE: PNode): Boolean;
          label endp;
          var
           Answ: Boolean;
           PN1,PN2: PNode;
           N,COP,ResT1,ResT2,nv1,nv2,tv1,tv2,tm1,tm2,NFunc,NF: Integer;
           adr1,adr2: TAddress;
           S: String;
          begin

            S:=PNE^.Expression;
            //F_CurrentEvalSubExpr:=PNE^.Expression; {.322}
            F_SyntaxErrorString:=PNE^.Expression; {.326}
            Answ:=False;

            if F_CalcConstARG = True then
            begin

              if (PNE^.COP = _LDSC) or (PNE^.COP = _LDSCX) or ((PNE^.COP = _LDINTFORM) and (PNE^.TA1 = _IntConst)) then answ:=True
              else
              if (PNE^.NFunc = CM_NEG) or (PNE^.NFunc = CM_RE) or (PNE^.NFunc = CM_IM) then
              begin
                 PN1:=PNE^.Ch;
                 if PN1 <> nil then  {else Internal ERROR!!!}
                 begin
                     if ((PN1^.COP = _LDSC) or (PN1^.COP = _LDSCX))  then          //re(2+3i), -(3+5i),
                     begin
                        EvalCOP1(PNE,PNE^.NFunc,Any_Const);
                        FreeChildTree(PNE);
                        answ:=True;
                     end;
                 end;
              end
              else
              if PNE^.COP = _FUNC then
              begin
                COP:=PNE^.NFunc;

                if (COP = CM_ADD) or (COP = CM_SUB) or (COP = CM_MUL) or (COP = CM_DIV) then
                begin

                  N:=PNE^.Stack.N;
                  if N = 2 then      //const1(Stack) COP const2(Stack)             // (1+2)+(4+5),    (1+2i+3)*(4+5i+7)   ,  (2+3i+4)+5i
                  begin
                    PN2:=nil;
                    PN1:=PNE^.Ch; if PN1 <> nil then PN2:=PN1^.Nb;
                    if (PN1 <> nil) and (PN2 <> nil)  then  {else Internal ERROR!!!}
                    begin

                        if ((PN1^.COP = _LDSC) or (PN1^.COP = _LDSCX)) and ((PN2^.COP = _LDSC) or (PN2^.COP = _LDSCX)) then
                        begin
                            EvalCOP2(PNE,COP);
                            answ:=True;
                            FreeChildTree(PNE);
                        end
                        else
                        //удаление всех ветвей произведения, если среди сомножителей есть нулевой аргумент.
                        if (F_DeleteZeroBranch = True) and  (COP = CM_MUL) then  {.363}        // sin(x)*cos(x+1)*(a*c-a*(3*c-2*c))*sin(x+3)*cos(x+4)
                        //sin(x)*cos(x+1)*(sin(2*x)*(a*c-a*(3*c-2*c))*cos(3*x)+sin(4*x)*(b*c-b*(3*c-2*c))*cos(5*x))*sin(x+3)*cos(x+4)
                        begin
                           if (PN1^.COP = _LDSC) or (PN1^.COP = _LDSCX) or (PN2^.COP = _LDSC) or (PN2^.COP = _LDSCX) then
                           begin
                            if CheckChildForZero(PNE,_Both) = True then
                            begin
                              FreeChildTree(PNE);
                              answ:=True;
                            end;
                           end
                        end
                        else
                        if (F_DeleteZeroBranch = True) and (COP = CM_DIV) then  {.363}
                        begin      //   sin(x)/cos(x+1)*(a*c-a*(3*c-2*c))/sin(x+3)*cos(x+4)
                           if (PN1^.COP = _LDSC) or (PN1^.COP = _LDSCX) then
                           begin
                             if CheckChildForZero(PNE,_First) = True then
                             begin
                               FreeChildTree(PNE);
                               answ:=True;
                            end;
                           end;
                        end;

                    end;

                  end
                  else
                  if N = 1 then //const COP Stack(const)
                  begin

                     PN1:=PNE^.Ch;
                     if (PN1 <> nil)  then  {else Internal ERROR!!!}
                     begin
                         nv1:=PNE^.NV1; nv2:=PNE^.NV2;
                         if ((PN1^.COP = _LDSC) or (PN1^.COP = _LDSCX)) and (nv1 = _NOT_FOUND) and (nv2 = _NOT_FOUND)  then
                         begin
                           EvalCOP1(PNE,COP,Any_Const);            //1+(2+3i) , (2+3i+4)/i , i/(2+3i+4)  ,      5/(-3*2)
                           answ:=True;
                           FreeChildTree(PNE);
                         end
                         else
                         if ((PN1^.COP = _LDSC) or (PN1^.COP = _LDSCX)) and (nv1 >= 0)   then
                         begin
                           GetVar1(nv1,adr1,tv1,tm1);
                           if tv1 = IM_UNIT then
                           begin
                             EvalCOP1(PNE,COP,IM_UNIT);
                             answ:=True;
                             FreeChildTree(PNE);
                           end;
                         end
                     end;

                  end
                  else
                  if N = 0 then //const COP i
                  begin
                     nv1:=PNE^.NV1;   GetVar1(nv1,adr1,tv1,tm1);
                     nv2:=PNE^.NV2;   GetVar1(nv2,adr2,tv2,tm2);

                     if ((tv1 = IM_UNIT) and (nv2 = _ABSENT)) or ((tv2 = IM_UNIT) and (nv1 = _ABSENT)) then
                     begin
                       //FD COP i
                       EvalConstCOP1(PNE,COP,IM_UNIT);
                       answ:=True;
                     end;
                   {
                    nv1:=PNE^.NV1;
                    if nv1 >=0 then
                    begin
                     GetVar(nv1,adr1,tv1,tm1);
                     if tv1 = IM_UNIT then
                     begin
                       //FD COP i
                       EvalConstCOP1(PNE,COP,IM_UNIT);
                       answ:=True;
                     end;
                    end;
                    }
                  end;
                  if Answ = True then inc(db_CalcConstArg);
                end  //end of << if (COP = CM_ADD) or (COP = CM_SUB) or (COP = CM_MUL) or (COP = CM_DIV)  >>

              end   // end of <<if PNE^.COP = _FUNC>>
            end;    //end of  F_CalcConstARG



            if IsFunction(PNE) = False then    goto endp; //calc const only for functions:   {.329}

            if (F_CalcConstFUNC = True) and (F_InternalError = 0 ) and (Answ = False){не найдена в F_CalcConstARG}  then          {.322}
            begin
                   NFunc:=PNE^.NFunc;
                   NF:=PNE^.NF;
                   if (Alg.ExFunc[NFunc].Func[NF].CalcConst = _YES) and
                      (Alg.ExFunc[NFunc].Func[NF].TypeF <> T_None)  and
                      (Alg.ExFunc[NFunc].Func[NF].TypeF <> T_Void)
                   then  Answ:=EvalConstFunc(PNE);

                   if Answ = True then
                   begin
                    FreeChildTree(PNE);
                    inc(db_CalcConstFunc);
                   end;
            end;

          endp:
             EvalNode:=answ; {.395}
          end;

var
 Node: PNode;
 BEval: Boolean;
begin

BEval:=False;

if F_SyntaxErrorCode <> 0 then goto endp;
if F_InternalError <> 0  then goto endp;  {.322}


Node:=FirstNode;

while Node <> nil do
begin
  //EvalNode(Node);
  if EvalNode(Node) = True then BEval:=True;  {.385}

     if F_InternalError <> 0 then goto endp;  {.322}

  Node:=Node^.Next;
end;

endp:
FirstNode:=GetLowLeftNode(BeginTree);  //реинициализация


{.385}
// SetNL, RestoreStack -  нужно после ReduceArgOptimizator  и ,возможно, некоторых других.
if BEval = True then
begin
   SetNL;
   RestoreStack;

  //InitSequentList; // восстанавливает ссылки в линейном списке. Включить, если будут ошибки после выполнения EvalTreeConst

end;

//endp:
end;





