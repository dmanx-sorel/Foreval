       ZDIVR_C1;        // ->  RE(exp^-1),IM(exp^-1),RE(exp),IM(exp)
       FSUBP2;
       FXCH2;
       FSUBRP2;
       FMUL_C05;
       FXCH1;
       FMUL_C05;
       FXCH1;
   end
   else
   if (GNode^.RRF = rf_EXPZ1_REPLACE) and (GNode^.WRF_CS = rf_EXPZ2_REPLACE)    then
   begin            //  tanh(z1)+sinh(z1)+cosh(z1)

      FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);     // -> IM(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);
         FSTM(Addr,F_DataType);                                          //  IM(exp) ->
      FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);   // -> RE(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-3]);
         FSTM(Addr,F_DataType);                                          //  RE(exp) ->
      ZPUSH;
      ZDIVR_C1;        // ->  RE(exp^-1),IM(exp^-1),RE(exp),IM(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);
         FSTM(Addr,F_DataType);                                          //  RE(exp^-1) ->
      FSUBP2;
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);
         FSTM(Addr,F_DataType);                                          //  IM(exp^-1) ->
      FXCH2;
      FSUBRP2;
      FMUL_C05;
      FXCH1;
      FMUL_C05;
      FXCH1;
   end;


 end;
 end;

