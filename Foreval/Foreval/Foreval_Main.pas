procedure TForevalH.RestoreStack;
{
   пересчёт размера стека после перестановки и удаления ветвей
   и реинициализация сооветствующих полей
 }
label endp;
var
S,SSN: Integer;
SE: String;
begin
if F_SyntaxErrorCode <> 0 then goto endp;
Tree:=BeginTree;   //не обязательно, т.к. чтение дерева - циклически

S:=1;
while Tree^.Ch <> nil do
begin
  Tree:=Tree^.Ch;
  //SE:=Tree^.Expression;
  Tree^.Stack.S:=S;
  Tree^.S:=Tree^.Stack.S-1;
end;

SSN:=Tree^.Stack.S;    {.332}

while Tree^.Pr <> nil do
begin

 while Tree^.Nb <> nil  do
 begin
   S:=Tree^.Stack.S;
   Tree:=Tree^.Nb;
   //SE:=Tree^.Expression;
   Tree^.Stack.S:=S+1;
   Tree^.S:=Tree^.Stack.S-1;
   inc(S);
   while Tree^.Ch <> nil do
   begin
     Tree:=Tree^.Ch;
     //SE:=Tree^.Expression;
     Tree^.Stack.S:=S;
     Tree^.S:=Tree^.Stack.S-1;
   end;

   if Tree^.Stack.S > SSN then SSN:=Tree^.Stack.S;  {.332}

 end;

 Tree:=Tree^.Pr;

 if Tree^.Stack.S > SSN then SSN:=Tree^.Stack.S;       {.332}
end;

if SSN > StackSize  then  StackSize:=SSN;      {.332}

{.332} //SSN пересчёт размера стека после перестановки ветвей дерева.
       //В некоторых случаях он может увеличится (по неизвестной пока причине :))



endp:
end;





