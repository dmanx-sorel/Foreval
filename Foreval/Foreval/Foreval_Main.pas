        goto endp;
    end;

   end;



    callarray:
    //if (F_EnableUseIntegerPointer = True) and (F_EnableUsePointer = True) then
    begin

         //CALL(IntArray[indx])
         FindFuncBrPS(@Str1,'[',']',Sv,Sa,FH1);
         if FH1 = True then FindVarPS(@Sv,ni) else ni:=-1; {.333}

         if ni <> -1 then //ni - vector
         begin
           if (Alg.Obj[ni].TypeF = T_Array) and ( (Alg.Obj[ni].MType = _Pointer) or ( (Alg.Obj[ni].MType = _Integer) and (F_EnableUseIntegerPointer = True))) then
