procedure TForevalH.FLDV_RE(nv: Integer);
var
 Adr: Cardinal;
 tv,tm: Integer;
begin
 GetVar1(nv,adr,tv,tm);
 if  tv = T_Real    then  FLD(Adr,tm)
 else
 if  tv = T_Complex  then FLD(Adr,tm)
 else
 if  tv = IM_UNIT  then   FLDZ;
end;




procedure TForevalH.FLDV_IM(nv: Integer);
var
 AdrRE,AdrIM: Cardinal;
 tv,tm: Integer;
begin
 GetVar2(nv,adrRE,adrIM,tv,tm);
 if  tv = T_Real    then FLDZ  else
 if  tv = T_Complex  then
 begin
      FLD(AdrIM,tm); {.343}
     {
     if tm = _Double    then   FLD(Adr+Sh_D,tm) else
     if tm = _Extended  then   FLD(Adr+Sh_E,tm)
     }
 end
 else
 if  tv = IM_UNIT  then   FLD1;
end;



procedure TForevalH.FADDV(nv: Integer; st: Integer);
var
 Adr,AdrRE,AdrIM: Cardinal;                //st = T_Real,T_Complex
 tv,tm,sh: Integer;
begin
 //GetVar(nv,adr,tv,tm);
 GetVar2(nv,adrRE,adrIM,tv,tm);        {.343}
 adr:=adrRE;

 if (tm = _Extended) then sh:=SH_E else sh:=SH_D;

 if (tv = T_Real) and (st = T_Real)    then  FADD(adr,tm)
 else
 if (tv = T_Real) and (st = T_Complex) then  FADD(adr,tm)
 else
 if (tv = T_Complex) and (st = T_Real) then
 begin
   FADD(adr,tm);
   //FLD(adr+sh,tm);
   FLD(adrIM,tm);  {.343}
   FXCH1;
 end
 else
  if (tv = T_Complex) and (st = T_Complex) then
 begin
   FADD(adr,tm);
   FXCH1;
   //FADD(adr+sh,tm);
   FADD(adrIM,tm);   {.343}
   FXCH1;
 end
 else
 if (tv = IM_UNIT) and (st = T_Real) then
 begin
   FLD1;
   FXCH1;
 end
 else
 if (tv = IM_UNIT) and (st = T_Complex) then
 begin
   FLD1;
   FADDP2;
 end

end;




procedure TForevalH.FSUBV(nv: Integer; st: Integer; inv:Integer = 0);
var
 Adr,adrRE,adrIM: Cardinal;                //st = T_Real,T_Complex
 tv,tm,sh: Integer;
begin
 {                        //S-v (inv=0); v-S (inv=1);
 GetVar(nv,adr,tv,tm);
 if (tm = _Extended) then sh:=SH_E else sh:=SH_D;
 }

 GetVar2(nv,adrRE,adrIM,tv,tm);        {.343}
 adr:=adrRE;                           {.343}



 if (tv = T_Real) and (st = T_Real)    then
 begin
  if (inv = 0) then  FSUB(adr,tm) else if (inv = 1) then FSUBR(adr,tm);
 end
 else
 if (tv = T_Real) and (st = T_Complex) then
 begin
  if (inv = 0) then  FSUB(adr,tm) else if (inv = 1) then begin FXCH1; FCHS; FXCH1; FSUBR(adr,tm); end
 end
 else
 if (tv = T_Complex) and (st = T_Real) then
 begin
   if (inv = 0) then
   begin
     FSUB(adr,tm);
     //FLD(adr+sh,tm);
     FLD(adrIM,tm); {.343}
     FCHS; FXCH1;
   end
   else
   if (inv = 1) then
   begin
     FSUBR(adr,tm);
     //FLD(adr+sh,tm);
     FLD(adrIM,tm); {.343}
     FXCH1;
   end
 end
 else
  if (tv = T_Complex) and (st = T_Complex) then
 begin
   if (inv = 0) then
   begin
     FSUB(adr,tm); FXCH1;
     //FSUB(adr+sh,tm);
     FSUB(adrIM,tm);  {.343}
     FXCH1;
   end
   else
   if (inv = 1) then
   begin
     FSUBR(adr,tm); FXCH1;
     //FSUBR(adr+sh,tm);
     FSUBR(adrIM,tm);    {.343}
     FXCH1;
   end
 end
 else
 if (tv = IM_UNIT) and (st = T_Real) then
 begin
   if (inv = 0) then
   begin
    FLD1;
    FCHS;
    FXCH1;
   end
   else
   if (inv = 1) then
   begin
    FCHS;
    FLD1;
    FXCH1;
   end
 end
 else
 if (tv = IM_UNIT) and (st = T_Complex) then
 begin
   if (inv = 0) then
   begin
    FLD1;
    FSUBP2;
   end
   else
   if (inv = 1) then
   begin
    FCHS;
    FXCH1;
    FLD1;
    FSUBRP;
    FXCH1;
   end
 end

end;





procedure TForevalH.MUL_SC(TS,TC: Integer);
var
Re,Im: Extended;
CMul: Integer;
AdrC: Cardinal;
begin       {умножение  стека TS=T_Real: ST(0), TS=T_Complex: ST(0),ST(1) на константу TC = C_Real,C_Complex}

Re:=0; Im:=0;
if TC =  C_Real    then Re:=GNode^.FD else
if TC =  C_Complex then
begin
  Re:=GNode^.FDC.re;
  Im:=GNode^.FDC.im;
end;

CMul:=-1;
if (Re = 0)  and  (Im = 0)  then CMul:=0 else  // 0
if (Re = 1)  and  (Im = 0)  then CMul:=1 else  // 1
if (Re = -1) and  (Im = 0)  then CMul:=2 else  // -1
if (Re = 0)  and  (Im = 1)  then CMul:=3 else  // i
if (Re = 0)  and  (Im = -1) then CMul:=4 else  // -i
if (Re = 0)                 then CMul:=5;      // im*i


if TC = C_Real then
begin


          if TS = T_Real then
          begin
            if CMul = 1 then  begin              end else
            if CMul = 2 then  begin FCHS;        end else
            if CMul = 0 then  begin FSTP0; FLDZ; end else
                                    FMUL(WriteData(GNode),F_DataType)
          end
          else
          if TS = T_Complex then
          begin
             if CMul = 1  then  begin       end else
             if CMul = 2  then
             begin
                FCHS;
                FXCH1;
                FCHS;
                FXCH1;
             end
             else
             if CMul = 0 then
             begin
                FSTP0;
                FSTP0;
                FLDZ;
                FLDZ;
             end
             else
             begin
                AdrC:=WriteData(GNode);
                FMUL(AdrC,F_DataType);
                FXCH1;
                FMUL(AdrC,F_DataType);
                FXCH1;
             end;
          end;

end
else //.318    TC = C_Complex
begin

          if TS = T_Real then
          begin
             if CMul = 3 then   // St(0)*i
             begin
                FLDZ;
             end
             else
             if CMul = 4 then  // St(0)*(-i)
             begin
                FCHS;
                FLDZ;
             end
             else
             if CMul = 5 then  // St(0)*[0,im]
             begin
                FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                FLDZ;
             end
             else              //St(0)*[re,im]
             begin
                FLD0;
                FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                FXCH1;
                FMUL(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
             end;

          end
          else
          if TS = T_Complex then
          begin
              if CMul = 3 then   // [St(0),St(1)]*i
             begin
                FXCH1;
                FCHS;
             end
             else
             if CMul = 4 then  // [St(0),St(1)]*(-i)
             begin
                FCHS;
                FXCH1;
             end
             else
             if CMul = 5 then     // [St(0),St(1)]*[0,im]
             begin
                FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                FXCH1;
                FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                FCHS;
             end
             else             // [St(0),St(1)]*[re,im]
             begin
               FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
               FLD(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
               ZMULP;
             end;
          end;

end;

end;


procedure TForevalH.MUL_VC(nv: Integer; TC: Integer);
{умножение  переменной nv на константу  (TC = C_Real,C_Complex)}
var
 Adr,Adr_RE,Adr_IM,AdrC: Cardinal;                //st = T_Real,T_Complex
 tv,tm,sh,CMul: Integer;
 Re,Im: Extended;
begin

 {GetVar(nv,adr,tv,tm);
 if (tm = _Extended) then sh:=SH_E else sh:=SH_D;
 Adr_RE:=adr; Adr_IM:=adr+sh;
 }
 GetVar2(nv,adr_RE,adr_IM,tv,tm);       {.343}
 adr:=adr_RE;                            {.343}


Re:=0; Im:=0;
if TC =  C_Real    then Re:=GNode^.FD else
if TC =  C_Complex then
begin
  Re:=GNode^.FDC.re;
  Im:=GNode^.FDC.im;
end;

CMul:=-1;
if (Re = 0)  and  (Im = 0)  then CMul:=0 else  // 0
if (Re = 1)  and  (Im = 0)  then CMul:=1 else  // 1
if (Re = -1) and  (Im = 0)  then CMul:=2 else  // -1
if (Re = 0)  and  (Im = 1)  then CMul:=3 else  // i
if (Re = 0)  and  (Im = -1) then CMul:=4 else  // -i
if (Re = 0)                 then CMul:=5;      // im*i


if TC = C_Real then
begin

          if TV = T_Real then
          begin

            if CMul = 1 then
            begin
               FLD(adr_re,tm);
            end
            else
            if CMul = 2 then
            begin
               FLD(adr_re,tm);
               FCHS;
            end
            else
            if CMul = 0 then
            begin
               FLDZ;
            end
            else
            begin
               FLD(adr_re,tm); FMUL(WriteData(GNode),F_DataType)
            end

          end
          else
          if TV = T_Complex then
          begin

             if CMul = 1  then
             begin
                FLD(adr_im,tm);
                FLD(adr_re,tm);
             end
             else
             if CMul = 2  then
             begin
                FLD(adr_im,tm);
                FCHS;
                FLD(adr_re,tm);
                FCHS;
             end
             else
             if CMul = 0 then
             begin
                FLDZ;
                FLDZ;
             end
             else
             begin
                AdrC:=WriteData(GNode);
                FLD(adr_im,tm);
                FMUL(AdrC,F_DataType);
                FLD(adr_re,tm);
                FMUL(AdrC,F_DataType);
             end;
          end

         {
         FLD(WriteData(GNode),F_DataType);
         MUL_SV(nv,T_Real);
         }
          else
          {del ERROR:  MulDiv,CaclConstOnTree = off     2*i; i*a}
          if TV = IM_UNIT then    {.329}
          begin

              if CMul = 0 then
              begin
                FLDZ;
              end
              else
              if CMul = 1 then
              begin
                FLD1;
                FLDZ;
              end
              else
              if CMul = 2 then
              begin
                FLD1;
                 FCHS;
               FLDZ;
              end
              else
              begin
                FLD(WriteDataA(GNode^.FD,F_DataType),F_DataType);
                FLDZ;
              end

          end;



end
else  //.318 // TC = C_Complex
begin

          if TV = T_Real then
          begin

             if CMul = 3 then   // v(re)*i
             begin
                FLD(adr_re,tm);
                FLDZ;
             end
             else
             if CMul = 4 then  // v(re)*(-i)
             begin
                FLD(adr_re,tm);
                FCHS;
                FLDZ;
             end
             else
             if CMul = 5 then  // v(re)*[0,im]
             begin
                FLD(adr_re,tm);
                FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                FLDZ;
             end
             else              //v(re)*[re,im]
             begin
                FLD(adr_re,tm);
                FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                FLD(adr_re,tm);
                FMUL(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
             end;

          end
          else
          if TV = T_Complex then
          begin
             if CMul = 3 then   //v(re,im)*i
             begin
                FLD(adr_re,tm);
                FLD(adr_im,tm);
                FCHS;
             end
             else
             if CMul = 4 then  // v(re,im)*(-i)
             begin
                FLD(adr_re,tm);
                FCHS;
                FLD(adr_im,tm);
             end
             else
             if CMul = 5 then     // v(re,im)*[0,im]
             begin
                FLD(adr_re,tm);
                FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                FLD(adr_im,tm);
                FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                FCHS;
             end
             else             // v(re,im)*[re,im]
             begin
               FLD(adr_im,tm);
               FLD(adr_re,tm);
               FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
               FLD(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
               ZMULP;
             end;
          end
         {
         FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
         FLD(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
         MUL_SV(nv,T_Complex);
         }
          else
          if TV = IM_UNIT then    {.329}
          begin

              if CMul = 3 then
              begin
                FLD1;
                FCHS;
              end
              else
              if CMul = 4 then
              begin
                FLD1;
              end
              else
              if CMul = 5 then
              begin
                FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                FCHS;
                FLDZ;
              end
              else
              begin
                FLD(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
                FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                FCHS;
              end;

          end;




end



end;



procedure TForevalH.MUL_SV(nv: Integer; st: Integer);
{умножение  стека st=T_Real: ST(0), st=T_Complex: ST(0),ST(1) на переменную nv (tv = T_Real,T_Complex)}
var
 Adr,Adr_RE,Adr_IM: Cardinal;                //st = T_Real,T_Complex
 tv,tm,sh: Integer;
begin
 {GetVar(nv,adr,tv,tm);
 if (tm = _Extended) then sh:=SH_E else sh:=SH_D;
 Adr_RE:=adr; Adr_IM:=adr+sh; }

 GetVar2(nv,adr_RE,adr_IM,tv,tm);   {.343}
 adr:=adr_RE;                        {.343}



 if (tv = T_Real) and (st = T_Real)    then  FMUL(adr,tm)
 else
 if (tv = T_Real) and (st = T_Complex) then  begin FMUL(adr,tm); FXCH1; FMUL(adr,tm); FXCH1; end
 else
 if (tv = T_Complex) and (st = T_Real) then
 begin
   FLD0;
   FMUL(adr_im,tm); FXCH1; FMUL(adr_re,tm);
 end
 else
  if (tv = T_Complex) and (st = T_Complex) then
 begin
         FXCH1;
         FLD0;                                     //y1,y1,x1
         FMUL(adr_re,tm);                          //y1*x2,y1,x1
         FXCH2;                                    //x1,y1,y1*x2
         FLD0;                                     //x1,x1,y1,y1*x2
         FMUL(adr_im,tm);                          //x1*y2,x1,y1,y1*x2
         FADDP3;                                   //x1,y1,IM
         FMUL(adr_re,tm);                          //x1*x2,y1,IM
         FXCH1;                                    //y1,x1*x2,IM
         FMUL(adr_im,tm);                          //y1*y2,x1*x2,IM
         FSUBP;                                    //RE,IM
 end
 else
 if (tv = IM_UNIT) and (st = T_Real) then
 begin
   FLDZ;
 end
 else
 if (tv = IM_UNIT) and (st = T_Complex) then
 begin
   FXCH1;
   FCHS;
 end

end;






procedure TForevalH.DIV_SC(TS,TC: Integer);
{деление   стека TS=T_Real: ST(0), TS=T_Complex: ST(0),ST(1) на константу TC = C_Real,C_Complex;  и наоборот inv=0,1 }
var
 Adr,Adr_RE,Adr_IM,AdrC: Cardinal;                //st = T_Real,T_Complex
 tv,tm,sh,CMul,inv: Integer;
 Re,Im: Extended;
begin

 
 inv:=GNode^.Inv;

Re:=0; Im:=0;
if TC =  C_Real    then Re:=GNode^.FD else
if TC =  C_Complex then
begin
  Re:=GNode^.FDC.re;
  Im:=GNode^.FDC.im;
end;

CMul:=-1;
if (Re = 0)  and  (Im = 0)  then CMul:=0 else  // 0
if (Re = 1)  and  (Im = 0)  then CMul:=1 else  // 1
if (Re = -1) and  (Im = 0)  then CMul:=2 else  // -1
if (Re = 0)  and  (Im = 1)  then CMul:=3 else  // i
if (Re = 0)  and  (Im = -1) then CMul:=4 else  // -i
if (Re = 0)                 then CMul:=5;      // im*i


if TC = C_Real then    // S(r)/C(r), c(r)/S(r)
begin


          if TS = T_Real then      //  S(r)/c(r), c(r)/S(r)
          begin
             if (CMul = 0) and (inv = 0) then    // 0/C(r)
             begin
               FLDZ;
             end
             else
             if inv = 0 then FDIV(WriteData(GNode),F_DataType) else
               if inv = 1 then  FDIVR(WriteData(GNode),F_DataType);
          end
          else
          if TS = T_Complex then      //  S(z)/c(r), c(r)/S(z)
          begin

              if inv = 0 then               //xxx                 // (z1*z2+z1*(z1+z2))/50.123;   (DL=3)
              begin
                 if F_FAST_DIV = True then
                 begin
                    AdrC:=WriteData(GNode);
                    FLD(AdrC,F_DataType);
                    FDIVR(TAddress(@S_C1),_Double);
                    FMUL1;
                    FXCH2;
                    FMULP20;
                 end
                 else
                 begin
                    AdrC:=WriteData(GNode);
                    FDIV(AdrC,F_DataType);
                    FXCH1;
                    FDIV(AdrC,F_DataType);
                    FXCH1;
                 end;

              end
              else
              if inv = 1 then
              begin
                 if CMul = 1 then  // 1/S(z)  {.339}
                 begin
                   ZDIVR_C1;
                 end
                 else
                 begin
                   FLD(WriteData(GNode),F_DataType);
                   RZDIV;
                 end;
             end;
          end;

  {
  if inv = 0 then inv:=1 else inv:=0;
  if (CMul = 0) and (inv = 0) then    // 0/C(r)
  begin
    FLDZ;
  end
  else
  begin
   FLD(WriteData(GNode),F_DataType);
   FDIVV(nv,T_Real,inv);
  end;
  }

end
else  //.318 // TC = C_Complex       // v/c(z), c(z)/v
begin

          if TS = T_Real then    //S(r)
          begin

             if inv = 0 then   // S(r)/c(z)
             begin

                 if F_FAST_DIV = True then       //FAST DIV!!!
                 begin

                   FLD(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);  //x,r
                   FMUL0;                                    //x^2,r
                   FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);  //y,x^2,r
                   FMUL0;                                    //y^2,x^2,r
                   FADDP;
                   FLD1;
                   FDIVRP;                                   //B,r (B=1/(x^2+y^2))

                   FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);   //y,B,r
                   FMUL02;                                   //y*r,B,r
                   FMUL01;                                   //y*B*r,B,r
                   FCHS;                                     //IM,B,r
                   FXCH2;                                    //r,B,IM
                   FMULP;                                    //r*B,IM
                   FMUL(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType); //RE,IM

                 end
                 else
                 begin
                   {.335}
                   FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);     //y,r
                   FXCH1;                                                    //r,y
                   FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);     //x,r,y
                   FXCH1;                                                    //r,x,y
                   //MOVAadr(TAddress(@Z_RZDIV_acc));
                   MOVAadr(TAddress(RZDIV_ADDR)); {.345}
                   CheckStack(2);
                   CheckStack(-3);
                   CALLA;
                   {
                   FLD(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);                                //x,r
                   FMUL0;                                    //x^2,r
                   FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);                                //y,x^2,r
                   FMUL0;                                    //y^2,x^2,r
                   FADDP;                                    //B,r (B=(x^2+y^2))

                   FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);                                //y,B,r
                   FMUL02;                                   //y*r,B,r
                   FDIV01;                                   //y*r/B,B,r
                   FCHS;                                     //IM,B,r
                   FXCH2;                                    //r,B,IM
                   FDIVRP;                                    //r/B,IM
                   FMUL(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);                           //RE,IM
                   }
                 end;

             end

             else

             if inv = 1 then    // c(z)/S(r)
             begin

                if (CMul = 3)  then  // i/S(r)
                begin
                   FDIVR(TAddress(@S_C1),_Double);
                   FLDZ;
                end
                else
                if  (CMul = 4) then  //  -i/S(r)
                begin
                   FDIVR(TAddress(@S_C1n),_Double);
                   FLDZ;
                end
                else
                if  (CMul = 5) then  //  [0,im]/S(r)       2i/(x+y)
                begin
                   FDIVR(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                   FLDZ;
                end
                else    // c[re,im]/S(r)
                begin

                  if F_FAST_DIV = True then    //FAST DIV!!!
                   begin
                     FDIVR(TAddress(@S_C1),_Double);
                     FLD0;
                     FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                     FXCH1;
                     FMUL(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
                   end
                   else
                   begin
                     FLD0;
                     FDIVR(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                     FXCH1;
                     FDIVR(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
                   end;

                end;

             end; //inv = 1


          end
          else
          if TS = T_Complex then      //S(z)
          begin
             if inv = 0 then     // S(z)/c(z)
             begin

               //else
               begin
                 FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                 FXCH2;
                 FLD(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
                 FXCH2;

                 ZDIV;
               end;

             end
             else
             if inv = 1 then    // c(z)/S(z)
             begin

                if (CMul = 3) or (CMul = 4) then      // i/S(z) , -i/S(z)
                begin
                  if F_FAST_DIV = True then
                  begin
                    FLD0;
                    FMUL0;
                    FXCH2;
                    FLD0;
                    FMUL0;
                    FADDP30;
                    FLD1;
                    if (CMul = 4) then FCHS;
                    FDIVRP3;

                    FMUL02;
                    FXCH2;
                    FMULP;
                    FXCH1;
                  end
                  else
                  begin
                    FLD0;
                    FMUL0;
                    FXCH2;
                    FLD0;
                    FMUL0;
                    FADDP30;

                    FDIV02;
                    FXCH2;
                    FDIVP;
                    if (CMul = 4) then FCHS;
                    FXCH1;
                    if (CMul = 4) then FCHS;
                  end;

                end
                else
                if CMul = 5 then //[0,im]/S(z)
                begin

                   if F_FAST_DIV = True then
                   begin
                     FLD0;
                     FMUL0;
                     FXCH2;
                     FLD0;
                     FMUL0;
                     FADDP30;
                     FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                     FDIVRP3;

                     FMUL02;
                     FXCH2;
                     FMULP;
                     FXCH1;
                   end
                   else
                   begin
                     {.335}
                     FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);   //r(im),x,y
                     //MOVAadr(TAddress(@Z_RZDIV_acc));
                     MOVAadr(TAddress(RZDIV_ADDR));
                     CheckStack(2);
                     CheckStack(-3);
                     CALLA;
                     //res=res*i
                     FXCH1;
                     FCHS;

                     {
                     FLD0;
                     FMUL0;
                     FXCH2;
                     FLD0;
                     FMUL0;
                     FADDP30;

                     FDIV02;
                     FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                     FXCH2;
                     FDIVP;
                     FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                     FXCH1;
                     }
                 end;
             
                end
                else
                begin
                  FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                  FLD(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
                  ZDIV;
                end;
             end;


          end;

end



end;






procedure TForevalH.DIV_VC(nv: Integer; TC: Integer);
{деление  переменной nv на константу и наоборот inv=0,1 (TC = C_Real,C_Complex)}
var
 Adr,Adr_RE,Adr_IM,AdrC: Cardinal;                //st = T_Real,T_Complex
 tv,tm,sh,CMul,inv: Integer;
 Re,Im: Extended;
begin
 {
 GetVar(nv,adr,tv,tm);
 if (tm = _Extended) then sh:=SH_E else sh:=SH_D;
 Adr_RE:=adr; Adr_IM:=adr+sh;
 }
 GetVar2(nv,adr_RE,adr_IM,tv,tm);        {.343}
 adr:=adr_RE;                            {.343}


 inv:=GNode^.Inv;

Re:=0; Im:=0;
if TC =  C_Real    then Re:=GNode^.FD else
if TC =  C_Complex then
begin
  Re:=GNode^.FDC.re;
  Im:=GNode^.FDC.im;
end;

CMul:=-1;
if (Re = 0)  and  (Im = 0)  then CMul:=0 else  // 0
if (Re = 1)  and  (Im = 0)  then CMul:=1 else  // 1
if (Re = -1) and  (Im = 0)  then CMul:=2 else  // -1
if (Re = 0)  and  (Im = 1)  then CMul:=3 else  // i
if (Re = 0)  and  (Im = -1) then CMul:=4 else  // -i
if (Re = 0)                 then CMul:=5;      // im*i


if TC = C_Real then    // v/c(r), c(r)/v
begin
  if inv = 0 then inv:=1 else inv:=0;

  if (CMul = 0) and (inv = 0) then    // 0/v
  begin
    FLDZ;
  end
  else
  if (CMul = 1) and (inv = 0) and (tv = T_Complex) then // 1/v(complex)
  begin
    FLDV(nv);
    ZDIVR_C1;
  end
  else
  begin
   if Re = 1.0 then FLD1 else                {.385}
      FLD(WriteData(GNode),F_DataType);
   FDIVV(nv,T_Real,inv);
  end;

end
else  //.318 // TC = C_Complex       // v/c(z), c(z)/v
begin

   if inv = 0 then inv:=1 else inv:=0;

   if TV = T_Real then
   begin

        if CMul = 3 then
        begin
           if inv = 0 then     // i/v(re)
           begin
              FLD(adr,tm);
              FDIVR(TAddress(@S_C1),_Double);
              FLDZ;
           end
           else   //v(re)/i
           begin
              FLD(adr,tm);
              FCHS;
              FLDZ;
           end;
        end
        else
        if CMul = 4 then
        begin
           if inv = 0 then     // -i/v(re)
           begin
              FLD(adr,tm);
              FDIVR(TAddress(@S_C1n),_Double);
              FLDZ;
           end
           else   //v(re)/(-i)
           begin
              FLD(adr,tm);
              FLDZ;
           end;
        end
        else
        if CMul = 5 then
        begin
           if inv = 0 then     // [0,im]/v(re)
           begin
              FLD(adr,tm);
              FDIVR(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
              FLDZ;
           end
           else   //v(re)/[0,im]
           begin
              FLD(adr,tm);
              FDIV(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
              FLDZ;
           end;
        end
        else     // v(re)/[re,im] ;  [re,im]/v(re)
        begin
           FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
           FLD(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
           FDIVV(nv,T_Complex,inv);
        end;
   end

   else

   if TV = T_Complex then
   begin
       if (CMul = 3) or (CMul = 4) then
        begin

          if inv = 0 then     // i/v(re,im)
           begin
               if F_FAST_DIV = True then      //FAST DIV!!!
               begin
                 FLD(Adr_re,tm);
                 FMUL0;
                 FLD(Adr_im,tm);
                 FMUL0;
                 FADDP;
                 FLD1;
                 FDIVRP;

                 FLD0;
                 FMUL(Adr_RE,tm);
                 if CMul = 4 then  FCHS;      // -i/v(re,im)
                 FXCH1;
                 FMUL(Adr_IM,tm);
                 if CMul = 4 then  FCHS;      // -i/v(re,im)
               end
               else
               begin
                 FLD(Adr_re,tm);
                 FMUL0;
                 FLD(Adr_im,tm);
                 FMUL0;
                 FADDP;

                 FLD0;
                 FDIVR(Adr_RE,tm);
                 if CMul = 4 then  FCHS;       // -i/v(re,im)
                 FXCH1;
                 FDIVR(Adr_IM,tm);
                 if CMul = 4 then  FCHS;       // -i/v(re,im)
             end;
           end
           else   //v(re,im)/i
           begin
              if CMul = 3 then
              begin
                FLD(Adr_RE,tm);
                FCHS;
                FLD(Adr_IM,tm);
              end
              else   // CMul = 4  : v(re,im)/(-i)
              begin
                FLD(Adr_RE,tm);
                FLD(Adr_IM,tm);
                FCHS;
              end;
           end;

        end
        else
        if CMul = 5 then
        begin
           if inv = 0 then     // [0,im]/v(re,im)
           begin
               if F_FAST_DIV = True then      //FAST DIV!!!
               begin
                 FLD(Adr_re,tm);
                 FMUL0;
                 FLD(Adr_im,tm);
                 FMUL0;
                 FADDP;
                 FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                 FDIVRP;


                 FLD0;
                 FMUL(Adr_RE,tm);
                 FXCH1;
                 FMUL(Adr_IM,tm);
               end
               else
               begin
                 {.335}
                 FLD(Adr_im,tm);
                 FLD(Adr_re,tm);
                 FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                 //MOVAadr(TAddress(@Z_RZDIV_acc));
                 MOVAadr(TAddress(RZDIV_ADDR));     {.345}
                 CheckStack(2);
                 CheckStack(-3);
                 CALLA;
                 //res=res*i
                 FXCH1;
                 FCHS;
                 {
                 FLD(Adr_re,tm);
                 FMUL0;
                 FLD(Adr_im,tm);
                 FMUL0;
                 FADDP;

                 FLD0;
                 FDIVR(Adr_RE,tm);
                 FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                 FXCH1;
                 FDIVR(Adr_IM,tm);
                 FMUL(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                 }
             end;
           end
           else   //v(re,im)/[0,im]
           begin
               if F_FAST_DIV = True then      //FAST DIV!!!
               begin
                  FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                  FDIVR(TAddress(@S_C1),_Double);
                  FLD0;

                  FMUL(Adr_RE,tm);
                  FCHS;
                  FXCH1;
                  FMUL(Adr_IM,tm);
               end
               else
               begin
                  FLD(Adr_RE,tm);
                  FDIV(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
                  FCHS;
                  FLD(Adr_IM,tm);
                  FDIV(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
               end;
           end;
        end
        else           // v(re,im)/[re,im] ;  [re,im]/v(re,im)
        begin
          FLD(WriteDataA(GNode^.FDC.im,F_DataType),F_DataType);
          FLD(WriteDataA(GNode^.FDC.re,F_DataType),F_DataType);
          FDIVV(nv,T_Complex,inv);
        end;
   end;
end



end;





procedure TForevalH.FDIVV(nv: Integer; st: Integer; inv:Integer = 0);
var
 Adr,Adr_RE,Adr_IM: Cardinal;                //st = T_Real,T_Complex
 tv,tm,sh: Integer;
begin                          //S/v (inv=0); v/S (inv=1);
 {
 GetVar(nv,adr,tv,tm);
 if (tm = _Extended) then sh:=SH_E else sh:=SH_D;
 Adr_RE:=adr; Adr_IM:=adr+sh;
 }

 GetVar2(nv,adr_RE,adr_IM,tv,tm); {.343}
 adr:=adr_RE;                     {.343}

 if (tv = T_Real) and (st = T_Real)    then
 begin
  if (inv = 0) then  FDIV(adr,tm) else if (inv = 1) then FDIVR(adr,tm);
 end
 else
 if (tv = T_Real) and (st = T_Complex) then
 begin
  if (inv = 0) then   // S(z)/r           (z1+z2)/x
  begin

    if F_FAST_DIV = True then
    begin
       //FAST DIV!!!
      FLD(adr,tm);
      FDIVR(TAddress(@S_C1),_Double);
      FMUL20;
      FMULP;
    end
    else
    begin
      FDIV(adr,tm);
      FXCH1;
      FDIV(adr,tm);
      FXCH1;
    end;

  end
  else
  if (inv = 1) then    // r/S(z)          x/(z1+z2)
  begin  //FAST DIV!!!
         FLDV(nv);
         RZDIV;

  end
 end
 else
 if (tv = T_Complex) and (st = T_Real) then
 begin
   if (inv = 0) then   //S(r)(fpu)/z(mem)            // (x*y+x*y)/z1
   begin
       if F_FAST_DIV = True then
       begin
         //FAST DIV!!!
         FLDV_RE(nv);                               //x,r
         FMUL0;                                    //x^2,r
         FLDV_IM(nv);                               //y,x^2,r
         FMUL0;                                    //y^2,x^2,r
         FADDP;
         FLD1;
         FDIVRP;                                   //B,r (B=1/(x^2+y^2))

         FLDV_IM(nv);                               //y,B,r
         FMUL02;                                   //y*r,B,r
         FMUL01;                                   //y*B*r,B,r
         FCHS;                                     //IM,B,r
         FXCH2;                                    //r,B,IM
         FMULP;                                    //r*B,IM
         FMUL(Adr_RE,tm);                          //RE,IM
       end
       else
       begin
         {.335}
         FLDV_IM(nv);                              //y,r
         FXCH1;                                    //r,y
         FLDV_RE(nv);                              //x,r,y
         FXCH1;                                    //r,x,y
         //MOVAadr(TAddress(@Z_RZDIV_acc));
         MOVAadr(TAddress(RZDIV_ADDR));     {.345}
         CheckStack(2);
         CheckStack(-3);
         CALLA;
         {
         FLDV_RE(nv);                               //x,r
         FMUL0;                                    //x^2,r
         FLDV_IM(nv);                               //y,x^2,r
         FMUL0;                                    //y^2,x^2,r
         FADDP;                                    //B,r (B=(x^2+y^2))
        
         FLDV_IM(nv);                               //y,B,r
         FMUL02;                                   //y*r,B,r
         FDIV01;                                   //y*r/B,B,r
         FCHS;                                     //IM,B,r
         FXCH2;                                    //r,B,IM
         FDIVRP;                                    //r/B,IM
         FMUL(Adr_RE,tm);                          //RE,IM
         }
       end;
   end
   else
   if (inv = 1) then       //z(mem)/S(r)(fpu)        // z1/(x*y+x*y)
   begin

         if F_FAST_DIV = True then
         begin //FAST DIV !!!
            FDIVR(TAddress(@S_C1),_Double);
            FLD0;
            FMUL(adr_IM,tm);
            FXCH1;
            FMUL(adr_RE,tm);
         end
         else
         begin
            FLD0;
            FDIVR(adr_IM,tm);
            FXCH1;
            FDIVR(adr_RE,tm);
         end;
   end
 end
 else
  if (tv = T_Complex) and (st = T_Complex) then          // (z1+z2)/z1
 begin
   if (inv = 0) then                                //  S(z)(fpu)/z(mem)
   begin //FAST DIV!!!
         FLDV_IM(nv);
         FXCH2;
         FLDV_RE(nv);
         FXCH2;

         ZDIV;
   end
   else
   if (inv = 1) then                                  //  z(mem)/S(z)(fpu)
   begin //FAST DIV!!!                                   // z1/(z1+z2)
         FLDV_IM(nv);
         FLDV_RE(nv);

         ZDIV;
   end
 end
 else
 if (tv = IM_UNIT) and (st = T_Real) then
 begin
   if (inv = 1) then      // i/S(r)
   begin
    FLD1;
    FDIVRP;
    FLDZ;
   end
   else
   if (inv = 0) then     // S(r)/i
   begin
    FCHS;
    FLDZ;
   end
 end
 else
 if (tv = IM_UNIT) and (st = T_Complex) then
 begin
   if (inv = 1) then          //  i/S(z)         //  i/(z1+z2)
   begin

         if F_FAST_DIV = True then
         begin //FAST DIV !!!
           FLD0;
           FMUL0;                                  //x^2,x,y
           FXCH2;                                  //y,x,x^2
           FLD0;                                   //y,y,x,x^2
           FMUL0;                                  //y^2,y,x,x^2,
           FADDP3;                                 //y,x,y^2+x^2
           FXCH2;                                  //y^2+x^2,y,x
           FLD1;
           FDIVRP;                                 //B,y,x
           FMUL1;                                  //B,IM,x
           FMULP2;
           FXCH1;
         end
         else
         begin
           FLD0;
           FMUL0;                                  //x^2,x,y
           FXCH2;                                  //y,x,x^2
           FLD0;                                   //y,y,x,x^2
           FMUL0;                                  //y^2,y,x,x^2,
           FADDP3;                                 //y,x,y^2+x^2
           FXCH2;                                  //y^2+x^2,y,x
                                                    //B,y,x
           FDIV10;                                 //B,IM,x
           FDIVP2;
           FXCH1;
         end;
   end
   else
   if (inv = 0) then                //   S(z)/i
   begin
    FCHS;
    FXCH1;
   end
 end

end;






procedure TForevalH.FLDS(K: Integer; fm:Integer = _FPU);
var
S,st,t,N,NF: Integer;
begin                           //DL загрузка стека (K - номер аргумента = 0,1) !!!
 S:={Interp[NFunc]}GNode^.S;
 N:={Interp[NFunc]}GNode^.NFunc;
 NF:={Interp[NFunc]}GNode^.NF;

 if {Interp[NFunc]}GNode^.TypeA = 0 then  t:=Alg.ExFunc[N].Func[NF].TV[K] else  t:={Interp[NFunc]}GNode^.TypeA;

st:={Interp[NFunc]}GNode^.RData[K];
if fm = _MEM then st:=_MEM;


if st = _MEM then
begin
  if t = T_Real then   FLD(GetStackAdr(S,_RE),F_DataType)
  else
  if t = T_Complex then
  begin
     FLD(GetStackAdr(S,_IM),F_DataType);
     FLD(GetStackAdr(S,_RE),F_DataType);
  end;
end;
end;





procedure TForevalH.SUB_C;
var
t1,t2,N,NF,S,st1,st2,Arg,nv1,nv2,Inv,xchT: Integer;
XchArg: Boolean ;

  procedure SUB_ST;
  begin
   if (t1 = T_Real) and (t2 = T_Real) then
   begin
     if XchArg = False then
     begin
        FLD(GetStackAdr(S,_RE),F_DataType);
        FSUB(GetStackAdr(S+1,_RE),F_DataType);
     end
     else
     begin
        FLD(GetStackAdr(S,_RE),F_DataType);
        FSUBR(GetStackAdr(S+1,_RE),F_DataType);
     end;
   end
   else
   if (t1 = T_Real) and (t2 = T_Complex) then
   begin
     if XchArg = False then
     begin
        FLD(GetStackAdr(S+1,_IM),F_DataType);
        FCHS;
        FLD(GetStackAdr(S,_RE),F_DataType);
        FSUB(GetStackAdr(S+1,_RE),F_DataType);
     end
     else
     begin
        FLD(GetStackAdr(S+1,_IM),F_DataType);
        FLD(GetStackAdr(S,_RE),F_DataType);
        FSUBR(GetStackAdr(S+1,_RE),F_DataType);
     end;
   end
   else
   if (t1 = T_Complex) and (t2 = T_Real) then
   begin
     if XchArg = False then
     begin
        FLD(GetStackAdr(S,_IM),F_DataType);
        FLD(GetStackAdr(S,_RE),F_DataType);
        FSUB(GetStackAdr(S+1,_RE),F_DataType);
     end
     else
     begin
        FLD(GetStackAdr(S,_IM),F_DataType);
        FCHS;
        FLD(GetStackAdr(S,_RE),F_DataType);
        FSUBR(GetStackAdr(S+1,_RE),F_DataType);
     end;
   end
   else
   if (t1 = T_Complex) and (t2 = T_Complex) then
   begin
     if XchArg = False then
     begin
       FLD(GetStackAdr(S,_IM),F_DataType);
       FSUB(GetStackAdr(S+1,_IM),F_DataType);
       FLD(GetStackAdr(S,_RE),F_DataType);
       FSUB(GetStackAdr(S+1,_RE),F_DataType);
     end
     else
     begin
       FLD(GetStackAdr(S,_IM),F_DataType);
       FSUBR(GetStackAdr(S+1,_IM),F_DataType);
       FLD(GetStackAdr(S,_RE),F_DataType);
       FSUBR(GetStackAdr(S+1,_RE),F_DataType);
     end;

   end;
  end;


  procedure SUB_DL;
  begin
     if (t1 = T_Real) and (t2 = T_Real) then
     begin
        if (st1 = _FPU) and (st2 = _FPU) then
        begin
           if XchArg = False then FSUBP else FSUBRP;
        end
        else
        if (st1 = _FPU) and (st2 = _MEM) then
        begin
           if XchArg = False then FSUB(GetStackAdr(S+1,_RE),F_DataType) else FSUBR(GetStackAdr(S+1,_RE),F_DataType);
        end
        else
        if (st1 = _MEM) and (st2 = _FPU) then
        begin
            if XchArg = False then  FSUBR(GetStackAdr(S,_RE),F_DataType) else FSUB(GetStackAdr(S,_RE),F_DataType)  ;
        end
        else
        if (st1 = _MEM) and (st2 = _MEM) then
        begin
           if XchArg = False then
           begin
              FLD(GetStackAdr(S,_RE),F_DataType);
              FSUB(GetStackAdr(S+1,_RE),F_DataType);
           end
           else
           begin
              FLD(GetStackAdr(S,_RE),F_DataType);
              FSUBR(GetStackAdr(S+1,_RE),F_DataType);
           end;
        end;
     end
    else
    if (t1 = T_Real) and (t2 = T_Complex) then
    begin
       if (st1 = _FPU) and (st2 = _FPU) then
       begin
         if XchArg = False then
         begin
           FSUBP2;
           FCHS;
           FXCH1;
         end
         else
         begin
           FSUBRP2;
           FXCH1;
         end;
       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then
       begin
         if XchArg = False then
         begin
           FSUB(GetStackAdr(S+1,_RE),F_DataType);
           FLD(GetStackAdr(S+1,_IM),F_DataType);
           FXCH1;
         end
         else
         begin
           FSUBR(GetStackAdr(S+1,_RE),F_DataType);
           FLD(GetStackAdr(S+1,_IM),F_DataType);
           FXCH1;
         end;
       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then
       begin
         if XchArg = False then
         begin
           FXCH1;
           FCHS;
           FXCH1;
           FSUBR(GetStackAdr(S,_RE),F_DataType);
         end
         else
         begin
           FSUB(GetStackAdr(S,_RE),F_DataType);
         end;
       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then
       begin
         if XchArg = False then
         begin
           FLD(GetStackAdr(S+1,_IM),F_DataType);
           FCHS;
           FLD(GetStackAdr(S,_RE),F_DataType);
           FSUB(GetStackAdr(S+1,_RE),F_DataType);
         end
         else
         begin
           FLD(GetStackAdr(S+1,_IM),F_DataType);
           FLD(GetStackAdr(S,_RE),F_DataType);
           FSUBR(GetStackAdr(S+1,_RE),F_DataType);
         end;
       end;
    end
    else
    if (t1 = T_Complex) and (t2 = T_Real) then
    begin
       if (st1 = _FPU) and (st2 = _FPU) then
       begin
         if XchArg = False then
         begin
           FSUBP;
         end
         else
         begin
           FSUBRP;
           FXCH1;
           FCHS;
           FXCH1;
         end;
       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then
       begin
         if XchArg = False then
         begin
           FSUB(GetStackAdr(S+1,_RE),F_DataType);
         end
         else
         begin
           FSUBR(GetStackAdr(S+1,_RE),F_DataType);
           FXCH1;
           FCHS;
           FXCH1;
         end;
       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then
       begin
         if XchArg = False then
         begin
           FSUBR(GetStackAdr(S,_RE),F_DataType);
           FLD(GetStackAdr(S,_IM),F_DataType);
           FXCH1;
         end
         else
         begin
           FSUB(GetStackAdr(S,_RE),F_DataType);
           FLD(GetStackAdr(S,_IM),F_DataType);
           FCHS;
           FXCH1;
         end;
       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then
       begin
         if XchArg = False then
         begin
           FLD(GetStackAdr(S,_IM),F_DataType);
           FLD(GetStackAdr(S,_RE),F_DataType);
           FSUB(GetStackAdr(S+1,_RE),F_DataType);
         end
         else
         begin
           FLD(GetStackAdr(S,_IM),F_DataType);
           FCHS;
           FLD(GetStackAdr(S,_RE),F_DataType);
           FSUBR(GetStackAdr(S+1,_RE),F_DataType);
         end;
       end;
    end
    else
    if (t1 = T_Complex) and (t2 = T_Complex) then
    begin
       if (st1 = _FPU) and (st2 = _FPU) then
       begin
         if XchArg = False then
         begin
           FSUBP2;
           FSUBP2;
         end
         else
         begin
           FSUBRP2;
           FSUBRP2;
         end;
       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then
       begin
         if XchArg = False then
         begin
           FLD(GetStackAdr(S,_IM),F_DataType);
           FSUB(GetStackAdr(S+1,_IM),F_DataType);
           FLD(GetStackAdr(S,_RE),F_DataType);
           FSUB(GetStackAdr(S+1,_RE),F_DataType);
         end
         else
         begin
           FLD(GetStackAdr(S,_IM),F_DataType);
           FSUBR(GetStackAdr(S+1,_IM),F_DataType);
           FLD(GetStackAdr(S,_RE),F_DataType);
           FSUBR(GetStackAdr(S+1,_RE),F_DataType);
         end;
       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then
       begin
         if XchArg = False then
         begin
           FSUB(GetStackAdr(S+1,_RE),F_DataType);
           FXCH1;
           FSUB(GetStackAdr(S+1,_IM),F_DataType);
           FXCH1;
         end
         else
         begin
           FSUBR(GetStackAdr(S+1,_RE),F_DataType);
           FXCH1;
           FSUBR(GetStackAdr(S+1,_IM),F_DataType);
           FXCH1;
         end;
       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then
       begin
         if XchArg = False then
         begin
           FSUBR(GetStackAdr(S,_RE),F_DataType);
           FXCH1;
           FSUBR(GetStackAdr(S,_IM),F_DataType);
           FXCH1;
         end
         else
         begin
           FSUB(GetStackAdr(S,_RE),F_DataType);
           FXCH1;
           FSUB(GetStackAdr(S,_IM),F_DataType);
           FXCH1;
         end;

       end;
    end;
  end;



  procedure SUB_VAR;                             //v1-v2
  var
    nv1,nv2,tv1,tv2,tm1,tm2,sh1,sh2: Integer;
    Adr1,Adr2,V1_RE,V1_IM,V2_RE,V2_IM: Cardinal;
  begin
   {nv1:=Interp[NFunc].nv1;
   nv2:=Interp[NFunc].nv2;  }
   nv1:=GNode^.NV1;
   nv2:=GNode^.NV2;
   {
   GetVar(nv1,adr1,tv1,tm1);
   GetVar(nv2,adr2,tv2,tm2);
   if (tm1 = _Extended) then sh1:=SH_E else sh1:=SH_D;
   if (tm2 = _Extended) then sh2:=SH_E else sh2:=SH_D;
   V1_RE:=adr1;
   V1_IM:=adr1+sh1;
   V2_RE:=adr2;
   V2_IM:=adr2+sh2;
   }

   GetVar2(nv1,V1_RE,V1_IM,tv1,tm1);      {.343}
   GetVar2(nv2,V2_RE,V2_IM,tv2,tm2);       {.343}
   adr1:=V1_RE; adr2:=V2_RE;               {.343}

   if (tv1 = T_Real) and (tv2 = T_Real) then         //r1+r2
   begin
     FLD(Adr1,tm1);  //FLDV(nv1);
     FSUB(Adr2,tm2); //FADDV(nv2,tv2);
   end
   else
   if (tv1 = T_Real) and (tv2 = IM_UNIT) then       //r1-i
   begin
     FLD1;
     FCHS;
     FLD(Adr1,tm1);
   end
   else
   if (tv1 = T_Real) and (tv2 = T_Complex) then       //r1-z2
   begin
     FLDV_IM(nv2);
     FCHS;
     FLDV(nv1);
     FSUB(V2_RE,tm2);
   end
   else
   if (tv1 = IM_UNIT) and (tv2 = T_Real) then         //i-r2
   begin
     FLD1;
     FLD(Adr2,tm2);
     FCHS;
   end
   else
   if (tv1 = T_Complex) and (tv2 = T_Real) then      //z1-r1
   begin
     FLDV(nv1);
     FSUB(Adr2,tm2);
   end
   else
   if (tv1 = T_Complex) and (tv2 = T_Complex) then   //z1-z2
   begin
     FLD(V1_IM,tm1);
     FSUB(V2_IM,tm2);
     FLD(V1_RE,tm1);
     FSUB(V2_RE,tm2);
   end
   else
   if (tv1 = IM_UNIT) and (tv2 = T_Complex) then       //i-z1
   begin
     FLD1;
     FSUB(V2_IM,tm2);
     FLDV_RE(nv2);
     FCHS;
   end
   else
   if (tv1 = T_Complex) and (tv2 = IM_UNIT) then        //z1-i
   begin
     FLDV_IM(nv1);
     FLD1;
     FSUBP;
     FLDV_RE(nv1);
   end;

  end;


///////////////////////////////////////MAIN/////////////////////////////////////
begin
 {N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 S:=Interp[NFunc].S;
 Arg:=Interp[NFunc].N;
 inv:=Interp[NFunc].Inv;
 t1:=Alg.ExFunc[N].Func[NF].TV[0]; t2:=Alg.ExFunc[N].Func[NF].TV[1];
 st1:=Interp[NFunc].RData[0]; st2:=Interp[NFunc].RData[1];
 nv1:=Interp[NFunc].NV1;
 nv2:=Interp[NFunc].NV2;
 }

 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 Arg:=GNode^.N;
 inv:=GNode^.Inv;
 t1:=Alg.ExFunc[N].Func[NF].TV[0]; t2:=Alg.ExFunc[N].Func[NF].TV[1];
 st1:=GNode^.RData[0]; st2:=GNode^.RData[1];
 nv1:=GNode^.NV1;
 nv2:=GNode^.NV2;

 XchArg:=GNode^.XchArg;

 //if (Arg = 1) and (Interp[NFunc].TypeA <> 0) then  t1:=Interp[NFunc].TypeA;
 if (Arg = 1) and (GNode^.TypeA <> 0) then  t1:=GNode^.TypeA;

 if XchArg = True then
 begin
   xchT:=t1;
   t1:=t2;
   t2:=xchT;
 end;



 if F_SaveInFPU = False then
 begin
   if (Arg = 2) and (nv1 = -1) and (nv2 = -1) then         //S1-S2
   begin
    SUB_ST;
   end
   else
   if (Arg = 0) and (nv1 >= 0) and (nv2 >= 0) then         //v1-v2
   begin
      SUB_VAR;
   end
   else
   if (Arg = 1) and  (nv1 >= 0)     then                   //S-v1
   begin
      FLDS(0,_MEM);  FSUBV(nv1,t1,inv)
   end
   else
   if (Arg = 1) and  (nv1 = -1) and (nv2 = -1)  then       //S1-c
   begin
    FLDS(0,_MEM);
    if inv = 0 then FSUB(WriteData(GNode{NFunc}),F_DataType)
    else
    if inv = 1 then
    begin
     if t1 = T_Real then
      FSUBR(WriteData(GNode{NFunc}),F_DataType)
     else
     if t1 = T_Complex then
     begin
      FXCH1; FCHS; FXCH1; FSUBR(WriteData(GNode{NFunc}),F_DataType);
     end;
    end
   end
   else
   if (Arg = 0) and (nv2 = -1)    then                     //v-c
   begin
     FLD(WriteData(GNode{NFunc}),F_DataType);
     if inv = 0 then FSUBV(nv1,T_Real,1) else if inv = 1 then  FSUBV(nv1,T_Real,0);
   end
 end
 else
 if F_SaveInFPU = True then
 begin
   if (Arg = 2) and (nv1 = -1) and (nv2 = -1) then         //S1-S2
   begin
    SUB_DL;
   end
   else
   if (Arg = 0) and (nv1 >= 0) and (nv2 >= 0) then         //v1-v2
   begin
      SUB_VAR;
   end
   else
   if (Arg = 1) and  (nv1 >= 0)     then                   //S-v1
   begin
      FLDS(0);  FSUBV(nv1,t1,inv)
   end
   else
   if (Arg = 1) and  (nv1 = -1) and (nv2 = -1)  then       //S1-c
   begin
    FLDS(0);
    if inv = 0 then FSUB(WriteData(GNode{NFunc}),F_DataType)
    else
    if inv = 1 then
    begin
     if t1 = T_Real then
      FSUBR(WriteData(GNode{NFunc}),F_DataType)
     else
     if t1 = T_Complex then
     begin
      FXCH1; FCHS; FXCH1; FSUBR(WriteData(GNode{NFunc}),F_DataType);
     end;
    end
   end
   else
   if (Arg = 0) and (nv2 = -1)    then                     //v-c
   begin
     FLD(WriteData(GNode{NFunc}),F_DataType);
     if inv = 0 then FSUBV(nv1,T_Real,1) else if inv = 1 then  FSUBV(nv1,T_Real,0);

   end;
 end;

end;






procedure TForevalH.MUL_C;
var
t1,t2,N,NF,S,st1,st2,Arg,nv1,nv2,AdrC,xchT,TC,TS: Integer;
XchArg: Boolean;

  procedure MUL_ST;
  begin
    if (t1 = T_Real) and (t2 = T_Real) then
  begin
   FLD(GetStackAdr(S,_RE),F_DataType);
   FMUL(GetStackAdr(S+1,_RE),F_DataType);
  end
  else
  if (t1 = T_Real) and (t2 = T_Complex) then
  begin
   FLD(GetStackAdr(S+1,_IM),F_DataType);
   FMUL(GetStackAdr(S,_RE),F_DataType);
   FLD(GetStackAdr(S+1,_RE),F_DataType);
   FMUL(GetStackAdr(S,_RE),F_DataType);
  end
  else
  if (t1 = T_Complex) and (t2 = T_Real) then
  begin
   FLD(GetStackAdr(S,_IM),F_DataType);
   FMUL(GetStackAdr(S+1,_RE),F_DataType);
   FLD(GetStackAdr(S,_RE),F_DataType);
   FMUL(GetStackAdr(S+1,_RE),F_DataType);
  end
  else
  if (t1 = T_Complex) and (t2 = T_Complex) then
  begin
   FLD(GetStackAdr(S+1,_IM),F_DataType);
   FLD(GetStackAdr(S+1,_RE),F_DataType);
   FLD(GetStackAdr(S,_IM),F_DataType);
   FLD(GetStackAdr(S,_RE),F_DataType);
   ZMULP;
   {MOVA1(TAddress(@Z_MUL));
   CALLA;}
  end;
  end;


  procedure MUL_DL;
  begin
    if (t1 = T_Real) and (t2 = T_Real) then
  begin
        if (st1 = _FPU) and (st2 = _FPU) then
        begin
           FMULP;
        end
        else
        if (st1 = _FPU) and (st2 = _MEM) then
        begin
           FMUL(GetStackAdr(S+1,_RE),F_DataType)
        end
        else
        if (st1 = _MEM) and (st2 = _FPU) then
        begin
           FMUL(GetStackAdr(S,_RE),F_DataType)
        end
        else
        if (st1 = _MEM) and (st2 = _MEM) then
        begin
          FLD(GetStackAdr(S,_RE),F_DataType);
          FMUL(GetStackAdr(S+1,_RE),F_DataType);
        end;
  end
  else
  if (t1 = T_Real) and (t2 = T_Complex) then
  begin
       if (st1 = _FPU) and (st2 = _FPU) then
       begin
         FMUL02;
         FXCH1;
         FMULP2;
       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then
       begin
         FLD0;
         FMUL(GetStackAdr(S+1,_IM),F_DataType);
         FXCH1;
         FMUL(GetStackAdr(S+1,_RE),F_DataType);
       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then
       begin
         FMUL(GetStackAdr(S,_RE),F_DataType);
         FXCH1;
         FMUL(GetStackAdr(S,_RE),F_DataType);
         FXCH1;
       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then
       begin
         FLD(GetStackAdr(S+1,_IM),F_DataType);
         FMUL(GetStackAdr(S,_RE),F_DataType);
         FLD(GetStackAdr(S+1,_RE),F_DataType);
         FMUL(GetStackAdr(S,_RE),F_DataType);
       end;
  end
  else
  if (t1 = T_Complex) and (t2 = T_Real) then
  begin
       if (st1 = _FPU) and (st2 = _FPU) then
       begin
         FMUL1;
         FMULP2;
       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then
       begin
         FMUL(GetStackAdr(S+1,_RE),F_DataType);
         FXCH1;
         FMUL(GetStackAdr(S+1,_RE),F_DataType);
         FXCH1;
       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then
       begin
         FLD0;
         FMUL(GetStackAdr(S,_IM),F_DataType);
         FXCH1;
         FMUL(GetStackAdr(S,_RE),F_DataType);
       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then
       begin
         FLD(GetStackAdr(S,_IM),F_DataType);
         FMUL(GetStackAdr(S+1,_RE),F_DataType);
         FLD(GetStackAdr(S,_RE),F_DataType);
         FMUL(GetStackAdr(S+1,_RE),F_DataType);
       end;
  end
  else
  if (t1 = T_Complex) and (t2 = T_Complex) then
  begin
       if (st1 = _FPU) and (st2 = _FPU) then
       begin
         {MOVA1(TAddress(@Z_MUL));
         CALLA;
         CheckStack(1);
         CheckStack(-3);}
         ZMULP;

       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then      //RE:(x1*x2-y1*y2);IM(y1*x2+y2*x1)
       begin
         FLD(GetStackAdr(S,_IM),F_DataType);      //y1
         FMUL(GetStackAdr(S+1,_RE),F_DataType);   //y1*x2
         FLD(GetStackAdr(S+1,_IM),F_DataType);    //y2
         FMUL(GetStackAdr(S,_RE),F_DataType);     //y1*x1
         FADDP;                                   //IM
         FLD(GetStackAdr(S,_RE),F_DataType);      //x1
         FMUL(GetStackAdr(S+1,_RE),F_DataType);   //x1*x2
         FLD(GetStackAdr(S,_IM),F_DataType);      //y1
         FMUL(GetStackAdr(S+1,_IM),F_DataType);   //y1*y2
         FSUBP;                                   //RE
       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then
       begin
         FXCH1;
         FLD0;                                     //y1,y1,x1
         FMUL(GetStackAdr(S+1,_RE),F_DataType);    //y1*x2,y1,x1
         FXCH2;                                    //x1,y1,y1*x2
         FLD0;                                     //x1,x1,y1,y1*x2
         FMUL(GetStackAdr(S+1,_IM),F_DataType);    //x1*y2,x1,y1,y1*x2
         FADDP3;                                   //x1,y1,IM
         FMUL(GetStackAdr(S+1,_RE),F_DataType);    //x1*x2,y1,IM
         FXCH1;                                    //y1,x1*x2,IM
         FMUL(GetStackAdr(S+1,_IM),F_DataType);    //y1*y2,x1*x2,IM
         FSUBP;                                    //RE,IM
       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then
       begin
         FXCH1;
         FLD0;
         FMUL(GetStackAdr(S,_RE),F_DataType);
         FXCH2;
         FLD0;
         FMUL(GetStackAdr(S,_IM),F_DataType);
         FADDP3;
         FMUL(GetStackAdr(S,_RE),F_DataType);
         FXCH1;
         FMUL(GetStackAdr(S,_IM),F_DataType);
         FSUBP;
       end;
  end;

  end;



  procedure MUL_VAR;                             //v1*v2
  var
    nv1,nv2,tv1,tv2,tm1,tm2,sh1,sh2: Integer;
    Adr1,Adr2,V1_RE,V1_IM,V2_RE,V2_IM: Cardinal;
  begin
   {nv1:=Interp[NFunc].nv1;
   nv2:=Interp[NFunc].nv2; }
   nv1:=GNode^.NV1;
   nv2:=GNode^.NV2;
   {
   GetVar(nv1,adr1,tv1,tm1);
   GetVar(nv2,adr2,tv2,tm2);
   if (tm1 = _Extended) then sh1:=SH_E else sh1:=SH_D;
   if (tm2 = _Extended) then sh2:=SH_E else sh2:=SH_D;
   V1_RE:=adr1;
   V1_IM:=adr1+sh1;
   V2_RE:=adr2;
   V2_IM:=adr2+sh2;
   }

   GetVar2(nv1,V1_RE,V1_IM,tv1,tm1);             {.343}
   GetVar2(nv2,V2_RE,V2_IM,tv2,tm2);              {.343}
   adr1:=V1_RE;   adr2:=V2_RE;                     {.343}

   if (tv1 = T_Real) and (tv2 = T_Real) then
   begin
     FLD(Adr1,tm1);  //FLDV(nv1);
     FMUL(Adr2,tm2); //FADDV(nv2,tv2);
   end
   else
   if (tv1 = T_Real) and (tv2 = IM_UNIT) then
   begin
     FLD(Adr1,tm1);
     FLDZ;
   end
   else
   if (tv1 = T_Real) and (tv2 = T_Complex) then
   begin
     FLDV_IM(nv2); FMUL(V1_RE,tm1);
     FLDV_RE(nv2); FMUL(V1_RE,tm1);
   end
   else
   if (tv1 = IM_UNIT) and (tv2 = T_Real) then
   begin
     FLD(Adr2,tm2);
     FLDZ;
   end
   else
   if (tv1 = T_Complex) and (tv2 = T_Real) then
   begin
     FLDV_IM(nv1); FMUL(V2_RE,tm2);
     FLDV_RE(nv1); FMUL(V2_RE,tm2);
   end
   else
   if (tv1 = T_Complex) and (tv2 = T_Complex) then
   begin
     FLDV_IM(nv1);        //y1
     FMUL(V2_RE,tm2);    //y1*x2
     FLDV_IM(nv2);        //y2
     FMUL(V1_RE,tm1);    //y2*x1
     FADDP;              //IM
     FLDV_RE(nv1);        //x1
     FMUL(V2_RE,tm2);    //x1*x2
     FLDV_IM(nv1);        //y1
     FMUL(V2_IM,tm2);    //y1*y2
     FSUBP;              //RE
   end
   else
   if (tv1 = IM_UNIT) and (tv2 = T_Complex) then
   begin
     FLDV_RE(nv2);
     FLDV_IM(nv2);
     FCHS;
   end
   else
   if (tv1 = T_Complex) and (tv2 = IM_UNIT) then
   begin
     FLDV_RE(nv1);
     FLDV_IM(nv1);
     FCHS;
   end
   else    // del ERROR at CalcConstMulDiv = off  i*i   {.329}
   if (tv1 = IM_UNIT) and (tv2 = IM_UNIT) then
   begin
     FLDZ;     {.395}
     FLD1;
     FCHS;
   end

  end;

 {.318}
 procedure MUL_CONST(TypeP,TS,TC: Integer);
 var
   nv1: Integer;
   AdrC: Cardinal;
 begin

   nv1:=GNode^.NV1;

   if TypeP = _Stack then     //S*c
   begin
      if F_SaveInFPU = False then FLDS(0,_MEM)  else  FLDS(0,_FPU);
      MUL_SC(TS,TC);
   end

   else

   if TypeP = _Var then       //v*c
   begin
      MUL_VC(nv1,TC);
   end;



 end;

 /////////////////////////////////MAIN//////////////////////////////////////////
begin
 

 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 Arg:=GNode^.N;
 st1:=GNode^.RData[0];
 st2:=GNode^.RData[1];
 nv1:=GNode^.NV1;
 nv2:=GNode^.NV2;
 t1:=Alg.ExFunc[N].Func[NF].TV[0]; t2:=Alg.ExFunc[N].Func[NF].TV[1];
 TC:=GNode^.TC;   //constant type


 //if (Arg = 1) and (Interp[NFunc].TypeA <> 0) then  t1:=Interp[NFunc].TypeA;
 if (Arg = 1) and (GNode^.TypeA <> 0) then  t1:=GNode^.TypeA;

 XchArg:=GNode^.XchArg;
 if XchArg = True then
 begin
   xchT:=t1;
   t1:=t2;
   t2:=xchT;
 end;

 TS:=t1; //stack type for 1 arg

 if F_SaveInFPU = False then
 begin
   if (Arg = 2) and (nv1 = -1) and (nv2 = -1) then         //S1*S2
   begin
       MUL_ST;
   end
   else
   if (Arg = 0) and (nv1 >= 0) and (nv2 >= 0) then         //v1*v2
   begin
       MUL_VAR;
   end
   else
   if (Arg = 1) and  (nv1 >= 0)     then                   //S*v1
   begin
       FLDS(0,_MEM);  MUL_SV(nv1,t1)
   end
   else
   if (Arg = 1) and  (nv1 = -1) and (nv2 = -1)  then       //S1*c
   begin
        MUL_CONST(_Stack,TS,TC);    {.318}
   end
   else
   if (Arg = 0) and (nv2 = -1)    then                     //v*c
   begin
        MUL_CONST(_VAR,TS,TC);    {.318}
   end
 end
 else
 if F_SaveInFPU = True then
 begin
   if (Arg = 2) and (nv1 = -1) and (nv2 = -1) then         //S1*S2
   begin
       MUL_DL;
   end
   else
   if (Arg = 0) and (nv1 >= 0) and (nv2 >= 0) then         //v1*v2
   begin
      MUL_VAR;
   end
   else
   if (Arg = 1) and  (nv1 >= 0)     then                   //S*v1
   begin
       FLDS(0);  MUL_SV(nv1,t1);
   end
   else
   if (Arg = 1) and  (nv1 = -1) and (nv2 = -1)  then       //S1*c
   begin
      MUL_CONST(_Stack,TS,TC);    {.318}
   end
   else
   if (Arg = 0) and (nv2 = -1)    then                     //v*c
   begin
      MUL_CONST(_VAR,TS,TC);    {.318}
   end;
 end;


end;







procedure TForevalH.DIV_C;
var
t1,t2,N,NF,S,st1,st2,Arg,nv1,nv2,AdrC,inv,xchT,TS,TC: Integer;
XchArg: Boolean;

  procedure DIV_ST;            //without optimization  DL
  begin
    if (t1 = T_Real) and (t2 = T_Real) then
   begin
     if XchArg = False then
     begin
        FLD(GetStackAdr(S,_RE),F_DataType);
        FDIV(GetStackAdr(S+1,_RE),F_DataType);
     end
     else
     begin
        FLD(GetStackAdr(S,_RE),F_DataType);
        FDIVR(GetStackAdr(S+1,_RE),F_DataType);
     end;
   end
   else
   if (t1 = T_Real) and (t2 = T_Complex) then
   begin
      if XchArg = False then
      begin
        FLD(GetStackAdr(S+1,_IM),F_DataType);    // (x*y+x*y)/(z1*z2+z1*z2)
        FLD(GetStackAdr(S+1,_RE),F_DataType);
        FLD(GetStackAdr(S,_RE),F_DataType);

        RZDIV;
      end
      else
      begin
        //FLD(GetStackAdr(S+1,_IM),F_DataType);
        //FLD(GetStackAdr(S+1,_RE),F_DataType);

        if F_FAST_DIV = True then
        begin
          FLD(GetStackAdr(S,_RE),F_DataType);
          FDIVR(TAddress(@S_C1),_Double);
          FLD(GetStackAdr(S+1,_RE),F_DataType);
          FMUL01;
          FXCH1;
          FMUL(GetStackAdr(S+1,_IM),F_DataType);
          FXCH1;
        end
        else
        begin
          FLD(GetStackAdr(S+1,_IM),F_DataType);
          FDIV(GetStackAdr(S,_RE),F_DataType);
          FLD(GetStackAdr(S+1,_RE),F_DataType);
          FDIV(GetStackAdr(S,_RE),F_DataType);
        end;
      end;

   end
   else
   if (t1 = T_Complex) and (t2 = T_Real) then    //(z1*z2+z1*z2)/(x*y+x*y)
   begin
    if XchArg = False then
    begin
        if F_FAST_DIV = True then
        begin
          FLD(GetStackAdr(S+1,_RE),F_DataType);
          FDIVR(TAddress(@S_C1),_Double);
          FLD(GetStackAdr(S,_RE),F_DataType);
          FMUL01;
          FXCH1;
          FMUL(GetStackAdr(S,_IM),F_DataType);
          FXCH1;
        end
        else
        begin
          FLD(GetStackAdr(S,_IM),F_DataType);
          FDIV(GetStackAdr(S+1,_RE),F_DataType);     //(z1+z2)/(x+y)     z1/x
          FLD(GetStackAdr(S,_RE),F_DataType);
          FDIV(GetStackAdr(S+1,_RE),F_DataType);
        end;
    end
    else
    begin
           FLD(GetStackAdr(S,_IM),F_DataType);
           FLD(GetStackAdr(S,_RE),F_DataType);
           FLD(GetStackAdr(S+1,_RE),F_DataType);

           RZDIV;
    end;
   end
   else
   if (t1 = T_Complex) and (t2 = T_Complex) then
   begin
     if XchArg = False then
     begin
       FLD(GetStackAdr(S+1,_IM),F_DataType);
       FLD(GetStackAdr(S+1,_RE),F_DataType);
       FLD(GetStackAdr(S,_IM),F_DataType);
       FLD(GetStackAdr(S,_RE),F_DataType);
     end
     else
     begin
       FLD(GetStackAdr(S,_IM),F_DataType);
       FLD(GetStackAdr(S,_RE),F_DataType);
       FLD(GetStackAdr(S+1,_IM),F_DataType);
       FLD(GetStackAdr(S+1,_RE),F_DataType);
     end;

      ZDIV;

   end;
  end;



  procedure DIV_DL;
  begin
     if (t1 = T_Real) and (t2 = T_Real) then
  begin
        if (st1 = _FPU) and (st2 = _FPU) then
        begin
           if XchArg = False then FDIVP else  FDIVRP ;
        end
        else
        if (st1 = _FPU) and (st2 = _MEM) then
        begin
           if XchArg = False then FDIV(GetStackAdr(S+1,_RE),F_DataType)  else FDIVR(GetStackAdr(S+1,_RE),F_DataType)  ;
        end
        else
        if (st1 = _MEM) and (st2 = _FPU) then
        begin
           if XchArg = False then FDIVR(GetStackAdr(S,_RE),F_DataType)  else  FDIV(GetStackAdr(S,_RE),F_DataType) ;
        end
        else
        if (st1 = _MEM) and (st2 = _MEM) then
        begin
           if XchArg = False then
           begin
              FLD(GetStackAdr(S,_RE),F_DataType);
              FDIV(GetStackAdr(S+1,_RE),F_DataType);
           end
           else
           begin
              FLD(GetStackAdr(S,_RE),F_DataType);
              FDIVR(GetStackAdr(S+1,_RE),F_DataType);
           end;
        end;
  end
  else
  if (t1 = T_Real) and (t2 = T_Complex) then
  begin
       if (st1 = _FPU) and (st2 = _FPU) then
       begin
          if XchArg = False then
          begin
             FXCH1;
             FXCH2;

             RZDIV;

          end
          else
          begin
             if F_FAST_DIV = True then
             begin
                FXCH2;
                FDIVR(TAddress(@S_C1),_Double);
                FMUL20;
                FMULP;
                FXCH1;
             end
             else
             begin
                FXCH2;
                FDIV2;
                FDIVP;
                FXCH1;
             end;
          end;

       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then
       begin
         if XchArg = False then
         begin

            if F_FAST_DIV = True then
            begin
              FLD(GetStackAdr(S+1,_RE),F_DataType);     //x,r
              FMUL0;                                    //x^2,r
              FLD(GetStackAdr(S+1,_IM),F_DataType);     //y,x^2,r
              FMUL0;                                    //y^2,x^2,r
              FADDP;
              FLD1;
              FDIVRP;                                   //B,r (B=1/(x^2+y^2))

              FLD(GetStackAdr(S+1,_IM),F_DataType);     //y,B,r
              FMUL02;                                   //y*r,B,r
              FMUL01;                                   //y*B*r,B,r
              FCHS;                                     //IM,B,r
              FXCH2;                                    //r,B,IM
              FMULP;                                    //r*B,IM
              FMUL(GetStackAdr(S+1,_RE),F_DataType);    //RE,IM
            end
            else
            begin
              {.335}
              FLD(GetStackAdr(S+1,_IM),F_DataType);     //y,r
              FXCH1;                                    //r,y
              FLD(GetStackAdr(S+1,_RE),F_DataType);     //x,r,y
              FXCH1;                                    //r,x,y
              //MOVAadr(TAddress(@Z_RZDIV_acc));
              MOVAadr(TAddress(RZDIV_ADDR));     {.345}
              CheckStack(2);
              CheckStack(-3);
              CALLA;

              {
              FLD(GetStackAdr(S+1,_RE),F_DataType);     //x,r
              FMUL0;                                    //x^2,r
              FLD(GetStackAdr(S+1,_IM),F_DataType);     //y,x^2,r
              FMUL0;                                    //y^2,x^2,r
              FADDP;

              FLD(GetStackAdr(S+1,_IM),F_DataType);     //y,B,r
              FMUL02;                                   //y*r,B,r
              FDIV01;                                    //y*r/B,B,r
              FCHS;                                     //IM,B,r
              FXCH2;                                    //r,B,IM
              FDIVRP;                                   //r/B,IM
              FMUL(GetStackAdr(S+1,_RE),F_DataType);    //RE,IM
              }
            end;
         end
         else  //<Test
         begin
              if F_FAST_DIV = True then
              begin
                FDIVR(TAddress(@S_C1),_Double);
                FLD(GetStackAdr(S+1,_IM),F_DataType);
                FXCH1;
                FLD(GetStackAdr(S+1,_RE),F_DataType);
                FXCH1;
                FMUL1;
                FXCH2;
                FMULP20;
              end
              else
              begin
                FLD(GetStackAdr(S+1,_RE),F_DataType);
                FDIV01;
                FLD(GetStackAdr(S+1,_IM),F_DataType);
                FDIVRP2;
              end;
         end;

       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then
       begin
         if XchArg = False then
         begin
            FLD(GetStackAdr(S,_RE),F_DataType);
            RZDIV;
         end
         else
         begin
             if F_FAST_DIV = True then
             begin
                FLD(GetStackAdr(S,_RE),F_DataType);
                FDIVR(TAddress(@S_C1),_Double);
                FMUL1;
                FXCH2;
                FMULP20;
             end
             else
             begin
                FDIV(GetStackAdr(S,_RE),F_DataType);
                FXCH1;
                FDIV(GetStackAdr(S,_RE),F_DataType);
                FXCH1;
             end;
         end;

       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then
       begin

        if XchArg = False then
        begin
            if F_FAST_DIV = True then
            begin

               FLD(GetStackAdr(S+1,_RE),F_DataType);
               FMUL0;
               FLD(GetStackAdr(S+1,_IM),F_DataType);
               FMUL0;
               FADDP;
               FLD1;
               FDIVRP;   //B=1/x^2+y^2

               FLD(GetStackAdr(S+1,_RE),F_DataType);
               FMUL(GetStackAdr(S,_RE),F_DataType);
               FMUL01;   //RE,B

               FLD(GetStackAdr(S+1,_IM),F_DataType);
               FMUL(GetStackAdr(S,_RE),F_DataType);
               FCHS;
               FMULP2;
            end
            else
            begin
               {.335}
               FLD(GetStackAdr(S+1,_IM),F_DataType);
               FLD(GetStackAdr(S+1,_RE),F_DataType);
               FLD(GetStackAdr(S,_RE),F_DataType);

               //MOVAadr(TAddress(@Z_RZDIV_acc));
               MOVAadr(TAddress(RZDIV_ADDR));     {.345}
               CheckStack(2);
               CheckStack(-3);
               CALLA;

               {
               FLD(GetStackAdr(S+1,_RE),F_DataType);
               FMUL0;
               FLD(GetStackAdr(S+1,_IM),F_DataType);
               FMUL0;
               FADDP;

               FLD(GetStackAdr(S+1,_RE),F_DataType);
               FMUL(GetStackAdr(S,_RE),F_DataType);
               FDIV01;

               FLD(GetStackAdr(S+1,_IM),F_DataType);
               FMUL(GetStackAdr(S,_RE),F_DataType);
               FCHS;
               FDIVRP2;
               }
            end;
        end
        else
        begin

            if F_FAST_DIV = True then
            begin
              FLD(GetStackAdr(S,_RE),F_DataType);
              FDIVR(TAddress(@S_C1),_Double);
              FLD0;
              FMUL(GetStackAdr(S+1,_IM),F_DataType);
              FXCH1;
              FMUL(GetStackAdr(S+1,_RE),F_DataType);
           end
           else
           begin
              FLD(GetStackAdr(S+1,_IM),F_DataType);
              FDIV(GetStackAdr(S,_RE),F_DataType);
              FLD(GetStackAdr(S+1,_RE),F_DataType);
              FDIV(GetStackAdr(S,_RE),F_DataType);
           end;

        end;

       end;
  end
  else
  if (t1 = T_Complex) and (t2 = T_Real) then
  begin
       if (st1 = _FPU) and (st2 = _FPU) then    // (z1+z2)/(x+y)
       begin

          if XchArg = False then
          begin
             if F_FAST_DIV = True then
             begin
                FDIVR(TAddress(@S_C1),_Double);
                FMUL20;
                FMULP;
             end
             else
             begin
                FDIV2;
                FDIVP;
             end;
          end
          else
          begin

              RZDIV;
          end;

       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then        //sin(z1*sin(z1)/cos(x)*(sin(z1)/cos(x)))/(sin(z1)/cos(x))
       begin                                        //(z1*(z1)/(x)*((z1)/(x)))/((z1)/(x))
         //FAST DIV!!!                              //(z1)/(x)/(z1)/(x)
                                                   //(z1*z1)/sin(x*y+x*y*(x*y+x))/(z1*z2)/sin(x*y+x*y*(x*y+x))
                                                   //sin(z1)/sin(x)
         if XchArg = False then
         begin
            if F_FAST_DIV = True then
            begin
               FLD(GetStackAdr(S+1,_RE),F_DataType);
               FDIVR(TAddress(@S_C1),_Double);
               FMUL1;
               FXCH2;
               FMULP20;
            end
            else
            begin
               FDIV(GetStackAdr(S+1,_RE),F_DataType);
               FXCH1;
               FDIV(GetStackAdr(S+1,_RE),F_DataType);
               FXCH1;
            end;
         end
         else
         begin
            FLD(GetStackAdr(S+1,_RE),F_DataType);
            RZDIV;
         end;


       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then          //sin(z1)/sin(x)
       begin
         if XchArg = False then
         begin
             if F_FAST_DIV = True then
             begin
                 FDIVR(TAddress(@S_C1),_Double);
                 FLD0;
                 FMUL(GetStackAdr(S,_IM),F_DataType);
                 FXCH1;
                 FMUL(GetStackAdr(S,_RE),F_DataType);
             end
             else
             begin
                 FLD0;
                 FDIVR(GetStackAdr(S,_IM),F_DataType);
                 FXCH1;
                 FDIVR(GetStackAdr(S,_RE),F_DataType);
             end;
         end
         else
         begin
             FLD(GetStackAdr(S,_IM),F_DataType);
             FXCH1;
             FLD(GetStackAdr(S,_RE),F_DataType);
             FXCH1;

             RZDIV;

         end;
       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then         //sin(z1)/cos(x)
       begin

         if XchArg = False then
         begin
            if F_FAST_DIV = True then
            begin
               FLD(GetStackAdr(S+1,_RE),F_DataType);
               FDIVR(TAddress(@S_C1),_Double);
               FLD0;
               FMUL(GetStackAdr(S,_IM),F_DataType);
               FXCH1;
               FMUL(GetStackAdr(S,_RE),F_DataType);
            end
            else
            begin
               FLD(GetStackAdr(S,_IM),F_DataType);
               FDIV(GetStackAdr(S+1,_RE),F_DataType);
               FLD(GetStackAdr(S,_RE),F_DataType);
               FDIV(GetStackAdr(S+1,_RE),F_DataType);
            end;
         end
         else
         begin
             FLD(GetStackAdr(S,_IM),F_DataType);
             FLD(GetStackAdr(S,_RE),F_DataType);
             FLD(GetStackAdr(S+1,_RE),F_DataType);

             RZDIV;
         end;

       end;
  end
  else
  if (t1 = T_Complex) and (t2 = T_Complex) then        //Test
  begin

    if (st1 = _FPU) and (st2 = _FPU) then
    begin

        if XchArg = False then
        begin
              FXCH2;
              FXCH1;
              FXCH3;
              FXCH1;

              ZDIV;
        end
        else
        begin

              ZDIV;
         end;

       end
       else
       if (st1 = _MEM) and (st2 = _MEM) then
       begin

           if XchArg = False then
           begin
             FLD(GetStackAdr(S+1,_IM),F_DataType);
             FLD(GetStackAdr(S+1,_RE),F_DataType);
             FLD(GetStackAdr(S,_IM),F_DataType);
             FLD(GetStackAdr(S,_RE),F_DataType);

             ZDIV;
           end
           else
           begin
              FLD(GetStackAdr(S,_IM),F_DataType);
              FLD(GetStackAdr(S,_RE),F_DataType);
              FLD(GetStackAdr(S+1,_IM),F_DataType);
              FLD(GetStackAdr(S+1,_RE),F_DataType);

              ZDIV;
           end;

       end
       else
       if (st1 = _FPU) and (st2 = _MEM) then
       begin
         if XchArg = False then
         begin
            FLD(GetStackAdr(S+1,_IM),F_DataType);
            FXCH2;
            FLD(GetStackAdr(S+1,_RE),F_DataType);
            FXCH2;

            ZDIV;

         end
         else
         begin
            FLD(GetStackAdr(S+1,_IM),F_DataType);
            FLD(GetStackAdr(S+1,_RE),F_DataType);

            ZDIV;
         end;


       end
       else
       if (st1 = _MEM) and (st2 = _FPU) then
       begin
         if XchArg = False then
         begin
            FLD(GetStackAdr(S,_IM),F_DataType);
            FLD(GetStackAdr(S,_RE),F_DataType);

            ZDIV;
         end
         else
         begin
              FLD(GetStackAdr(S,_IM),F_DataType);
              FXCH2;
              FLD(GetStackAdr(S,_RE),F_DataType);
              FXCH2;

              ZDIV;
         end;
       end;
  end;
  end;





  procedure DIV_VAR;                             // v1/v2
  var
    nv1,nv2,tv1,tv2,tm1,tm2,sh1,sh2: Integer;
    Adr1,Adr2,V1_RE,V1_IM,V2_RE,V2_IM: Cardinal;
  begin
   {nv1:=Interp[NFunc].nv1;
   nv2:=Interp[NFunc].nv2; }
   nv1:=GNode^.NV1;
   nv2:=GNode^.NV2;
   {
   GetVar(nv1,adr1,tv1,tm1);
   GetVar(nv2,adr2,tv2,tm2);
   if (tm1 = _Extended) then sh1:=SH_E else sh1:=SH_D;
   if (tm2 = _Extended) then sh2:=SH_E else sh2:=SH_D;
   V1_RE:=adr1;
   V1_IM:=adr1+sh1;
   V2_RE:=adr2;
   V2_IM:=adr2+sh2;
    }
   GetVar2(nv1,V1_RE,V1_IM,tv1,tm1);             {.343}
   GetVar2(nv2,V2_RE,V2_IM,tv2,tm2);              {.343}
   adr1:=V1_RE;   adr2:=V2_RE;                     {.343}

   if (tv1 = T_Real) and (tv2 = T_Real) then
   begin
     FLD(Adr1,tm1);  //FLDV(nv1);
     FDIV(Adr2,tm2); //FADDV(nv2,tv2);
   end
   else
   if (tv1 = T_Real) and (tv2 = IM_UNIT) then
   begin
     FLD(Adr1,tm1);
     FCHS;
     FLDZ;
   end
   else
   if (tv1 = T_Real) and (tv2 = T_Complex) then
   begin
      if F_FAST_DIV = True then
      begin
         FLDV_RE(nv2);                           //FAST DIV!!!
         FMUL0;
         FLDV_IM(nv2);
         FMUL0;
         FADDP;
         FLD1;
         FDIVRP;   //B=1/x^2+y^2

         FLDV_RE(nv2);
         FMUL(V1_RE,tm1);
         FMUL01;   //RE,B

         FLDV_IM(nv2);
         FMUL(V1_RE,tm1);
         FCHS;
         FMULP2;
      end
      else
      begin
         {.335}
         FLDV_IM(nv2);
         FLDV_RE(nv2);
         FLD(V1_RE,tm1);// FLDV_RE(nv1);
         //MOVAadr(TAddress(@Z_RZDIV_acc));
         MOVAadr(TAddress(RZDIV_ADDR));     {.345}
         CheckStack(2);
         CheckStack(-3);
         CALLA;
         {
         FLDV_RE(nv2);
         FMUL0;
         FLDV_IM(nv2);
         FMUL0;
         FADDP;

         FLDV_RE(nv2);
         FMUL(V1_RE,tm1);
         FDIV01;   //RE,B

         FLDV_IM(nv2);
         FMUL(V1_RE,tm1);
         FCHS;
         FDIVRP2;
         }

      end;

   end
   else
   if (tv1 = IM_UNIT) and (tv2 = T_Real) then
   begin
     FLD(Adr2,tm2);
     FLD1;
     FDIVRP;
     FLDZ;
   end
   else
   if (tv1 = T_Complex) and (tv2 = T_Real) then
   begin
      //FAST DIV!!!
      if F_FAST_DIV = True then
      begin
         FLD(V2_RE,tm2);
         FDIVR(TAddress(@S_C1),_Double);
         FLD0;
         FMUL(V1_IM,tm1);
         FXCH1;
         FMUL(V1_RE,tm1);
       end
       else
       begin
         FLDV_IM(nv1); FDIV(V2_RE,tm2);
         FLDV_RE(nv1); FDIV(V2_RE,tm2);
       end;


   end
   else
   if (tv1 = T_Complex) and (tv2 = T_Complex) then
   begin

         FLDV(nv2);
         FLDV(nv1);

         ZDIV;
   end
   else
   if (tv1 = IM_UNIT) and (tv2 = T_Complex) then    //FAST DIV!!!
   begin
         if F_FAST_DIV = True then
         begin
           FLDV_RE(nv2);
           FMUL0;
           FLDV_IM(nv2);
           FMUL0;
           FADDP;
           FLD1;
           FDIVRP;   //B=1/x^2+y^2

           FLD0;
           FMUL(V2_RE,tm2);
           FXCH1;
           FMUL(V2_IM,tm2);
         end
         else
         begin
           FLDV_RE(nv2);
           FMUL0;
           FLDV_IM(nv2);
           FMUL0;
           FADDP;

           FLD0;
           FDIVR(V2_RE,tm2);
           FXCH1;
           FDIVR(V2_IM,tm2);
         end;

   end
   else
   if (tv1 = T_Complex) and (tv2 = IM_UNIT) then
   begin
     FLDV_RE(nv1);
     FCHS;
     FLDV_IM(nv1);
   end
   else    // del ERROR at CalcConstMulDiv = off  i/i   {.329}
   if (tv1 = IM_UNIT) and (tv2 = IM_UNIT) then
   begin
     FLDZ; {.395}
     FLD1;
   end

  end;

  {.318}

  {
    оптимизация отдельно для каждого случая:
    CF.re=0; CF.im = -1;
    CF.re = 0; CF.im = 1 !!!!!!
    CF.re=+-1; CF.im=0

  }
  procedure DIV_CONST(TypeP,TS,TC: Integer);
  var
   {TS,TC,}nv1,inv: Integer;
    AdrC: Cardinal;
  begin
    //TS:=Alg.ExFunc[N].Func[NF].TV[0];  //stack type
    //TC:=GNode^.TC;   //constant type

    inv:=GNode^.Inv;
    nv1:=GNode^.NV1;

    if TypeP = _Stack then     //  S/c, c/S
    begin

      if F_SaveInFPU = False then FLDS(0,_MEM)  else  FLDS(0,_FPU);

      DIV_SC(TS,TC);

    end

    else

    if TypeP = _Var then       // v/c, c/v
    begin

       DIV_VC(nv1,TC);
    end;



  end;

 /////////////////////////////////MAIN//////////////////////////////////////////
begin


 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 Arg:=GNode^.N;
 inv:=GNode^.Inv;
 t1:=Alg.ExFunc[N].Func[NF].TV[0]; t2:=Alg.ExFunc[N].Func[NF].TV[1];
 st1:=GNode^.RData[0]; st2:=GNode^.RData[1];
 nv1:=GNode^.NV1;
 nv2:=GNode^.NV2;
 TC:=GNode^.TC;
 XchArg:=GNode^.XchArg;

 if (Arg = 1) and (GNode^.TypeA <> 0) then  t1:=GNode^.TypeA;

 if XchArg = True then
 begin
   xchT:=t1;
   t1:=t2;
   t2:=xchT;
 end;

 TS:=t1;

 if F_SaveInFPU = False then
 begin
   if (Arg = 2) and (nv1 = -1) and (nv2 = -1) then         // S1/S2
   begin
    DIV_ST;
   end
   else
   if (Arg = 0) and (nv1 >= 0) and (nv2 >= 0) then         // v1/v2
   begin
    DIV_VAR;
   end
   else
   if (Arg = 1) and  (nv1 >= 0)     then                   // S/v1; v1/S
   begin
    FLDS(0,_MEM);  FDIVV(nv1,t1,inv)
   end
   else
   if (Arg = 1) and  (nv1 = -1) and (nv2 = -1)  then       // S1/c; c/S1
   begin
      DIV_CONST(_Stack,TS,TC);   {.318}
     {
     FLDS(0,_MEM);
     if t1 = T_Real then
     begin
      if inv = 0 then FDIV(WriteData(GNode),F_DataType) else
        if inv = 1 then  FDIVR(WriteData(GNode),F_DataType);
     end
     else
     if t1 = T_Complex then
     begin

      if inv = 0 then               //xxx                 // (z1*z2+z1*(z1+z2))/50.123;   (DL=3)
      begin
         if F_FAST_DIV = True then
         begin
           AdrC:=WriteData(GNode);
           FLD(AdrC,F_DataType);
           FDIVR(TAddress(@S_C1),_Double);
           FMUL1;
           FXCH2;
           FMULP20;
         end
         else
         begin
           AdrC:=WriteData(GNode);
           FDIV(AdrC,F_DataType);
           FXCH1;
           FDIV(AdrC,F_DataType);
           FXCH1;
         end;

      end
      else
      if inv = 1 then
      begin
         FLD(WriteData(GNode),F_DataType);

         if F_FAST_DIV = True then
             MOVAadr(TAddress(@Z_RZDIV_FAST))    //FAST DIV!!!
                               else
             MOVAadr(TAddress(@Z_RZDIV));
         CALLA;
         CheckStack(1);
         CheckStack(-2);
      end;
     end
     }

   end
   else
   if (Arg = 0) and (nv2 = -1)    then                     // v1/c; c/v1
   begin
      DIV_CONST(_VAR,TS,TC);   {.318}
     {
     if inv = 0 then inv:=1 else inv:=0;
     FLD(WriteData(GNode),F_DataType);
     FDIVV(nv1,T_Real,inv);
     }

   end
 end
 else
 if F_SaveInFPU = True then
 begin
   if (Arg = 2) and (nv1 = -1) and (nv2 = -1) then         // S1/S2
   begin
    DIV_DL;
   end
   else
   if (Arg = 0) and (nv1 >= 0) and (nv2 >= 0) then         // v1/v2
   begin
      DIV_VAR;
   end
   else
   if (Arg = 1) and  (nv1 >= 0)     then                   // S/v1;v1/S
   begin
    FLDS(0);  FDIVV(nv1,t1,inv);
   end
   else
   if (Arg = 1) and  (nv1 = -1) and (nv2 = -1)  then       // S1/c; c/S1
   begin
      DIV_CONST(_Stack,TS,TC);   {.318}
     {
     FLDS(0);
     if t1 = T_Real then
     begin
      if inv = 0 then FDIV(WriteData(GNode),F_DataType) else
        if inv = 1 then  FDIVR(WriteData(GNode),F_DataType);
     end
     else
     if t1 = T_Complex then
     begin
      if inv = 0 then
      begin
        if F_FAST_DIV = True then                           // (z1*z2+z1*(z1+z2))/50.123;
         begin
           //FAST DIV!!!
           AdrC:=WriteData(GNode);
           FLD(AdrC,F_DataType);
           FDIVR(TAddress(@S_C1),_Double);
           FMUL1;
           FXCH2;
           FMULP20;
         end
         else
         begin
           AdrC:=WriteData(GNode);
           FDIV(AdrC,F_DataType);
           FXCH1;
           FDIV(AdrC,F_DataType);
           FXCH1;
       end
      end
      else
      if inv = 1 then
      begin
         FLD(WriteData(GNode),F_DataType);
         if F_FAST_DIV = True then
             MOVAadr(TAddress(@Z_RZDIV_FAST))    //FAST DIV!!!
                               else
             MOVAadr(TAddress(@Z_RZDIV));
         CALLA;
         CheckStack(1);
         CheckStack(-2);
      end;
     end
     }

   end
   else
   if (Arg = 0) and (nv2 = -1)    then                     // v1/c; c/v1
   begin
     DIV_CONST(_VAR,TS,TC);    {.318}
     {
     if inv = 0 then inv:=1 else inv:=0;
     FLD(WriteData(GNode),F_DataType);
     FDIVV(nv1,T_Real,inv);
     }
   end;

 end;
end;





