procedure TForevalH.DelExternalBracketInArgsPS(ArgM: TArrayS; PSa:PString); {.335}
var
 i: Integer;
begin
   if Length(ArgM) = 1 then
   begin
      FindExternalBracketNegPS(PSa);
   end
   else
   if  Length(ArgM) > 1 then
   begin
      PSa^:='';
      for i := 0 to High(ArgM) do
      begin
        FindExternalBracketNegPS(@ArgM[i]);
        PSa^:=PSa^+ArgM[i]+',';
      end;
      Delete(PSa^,Length(PSa^),1);
   end;
end;



function TForevalH.CheckSaveForPointer(PS:PString): Boolean;

        function CheckForOutOfBracket(SFT: PString): Boolean;
        var
         Answ: Boolean;
         n,sbr: Integer;
         LS: Cardinal;
        begin

          Answ:=False;
          sbr:=0;
          LS:=Length(SFT^);
          for n := 1 to LS do
          begin
            if SFT^[n] in OpenBracket then inc(sbr)
            else
            if SFT^[n] in CloseBracket then dec(sbr)
          end;

          if sbr = 0 then Answ:=True;
          CheckForOutOfBracket:=Answ;

        end;


label extrf,endp;
var
  L,k,LPS :Integer;
  idf,Peq,Pbr: Cardinal;
  BH: Boolean;
  SF,SFN: String;
  //Answ: Boolean;
begin
  BH:=False;
  Peq:=Pos('=',PS^);
  SF:='';  LPS:=0;

  if Peq > 0 then
  begin

     LPS:=Length(PS^);
     SF:=Copy(PS^,1,Peq-1);
     Pbr:=Pos('(',SF);
     if Pbr = 0 then   goto endp;
     SFN:=Copy(SF,1,Pbr-1);

     if CheckForOutOfBracket(@SF) = False then goto endp;  //операция '=' д.б. вне скобок

     idf:=CM_PEXTENDED;
     L:=Length(Alg.ExFunc[idf].NameEx);

     if SFN =  Alg.ExFunc[idf].Name then begin  BH:=True; goto extrf; end
     else
     begin
       for k := 0 to L-1 do
       begin
         if SFN =  Alg.ExFunc[idf].NameEx[k] then  begin  BH:=True; goto extrf; end
       end;
     end;

     idf:=CM_PDOUBLE;
     L:=Length(Alg.ExFunc[idf].NameEx);

     if SFN =  Alg.ExFunc[idf].Name then begin  BH:=True; goto extrf; end
     else
     begin
       for k := 0 to L-1 do
       begin
         if SFN =  Alg.ExFunc[idf].NameEx[k] then  begin  BH:=True; goto extrf; end
       end;
     end;

     idf:=CM_PINTEGER;
     L:=Length(Alg.ExFunc[idf].NameEx);

     if SFN =  Alg.ExFunc[idf].Name then begin  BH:=True; goto extrf; end
     else
     begin
       for k := 0 to L-1 do
       begin
         if SFN =  Alg.ExFunc[idf].NameEx[k] then  begin  BH:=True; goto extrf; end
       end;
     end;


     idf:=CM_PSINGLE;
     L:=Length(Alg.ExFunc[idf].NameEx);

     if SFN =  Alg.ExFunc[idf].Name then begin  BH:=True; goto extrf; end
     else
     begin
       for k := 0 to L-1 do
       begin
         if SFN =  Alg.ExFunc[idf].NameEx[k] then  begin  BH:=True; goto extrf; end
       end;
     end;


     idf:=CM_PBYTE;
     L:=Length(Alg.ExFunc[idf].NameEx);

     if SFN =  Alg.ExFunc[idf].Name then begin  BH:=True; goto extrf; end
     else
     begin
       for k := 0 to L-1 do
       begin
         if SFN =  Alg.ExFunc[idf].NameEx[k] then  begin  BH:=True; goto extrf; end
       end;
     end;

     idf:=CM_PWORD;
     L:=Length(Alg.ExFunc[idf].NameEx);

     if SFN =  Alg.ExFunc[idf].Name then begin  BH:=True; goto extrf; end
     else
     begin
       for k := 0 to L-1 do
       begin
         if SFN =  Alg.ExFunc[idf].NameEx[k] then  begin  BH:=True; goto extrf; end
       end;
     end;


  end;

  extrf:
  if BH =  True then
  begin
     PS^:='save('+SF+','+Copy(PS^,Peq+1,LPS-Peq)+')';
  end;

  endp:
  CheckSaveForPointer:=BH;
end;



