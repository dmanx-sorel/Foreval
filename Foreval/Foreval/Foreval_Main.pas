procedure  TForevalH.IsNumPS(PS: PString; var fx: extended; var bnum: boolean);
var
 S3: String;
 Neg: Integer;
begin
bnum:=false;
fx:=0;
S3:=PS^;
FindExternalBracketNegPS(@S3);
Neg:=1;
SaveSW; {.229} {TryStrToFloat damage SW}

if Length(S3) > 2 then     //-(num) -> num
begin
 if (S3[1]='-') and (S3[2] ='(') and (S3[Length(S3)] = ')') then
 begin
   Delete(S3,1,2);
   Delete(S3,Length(S3),1);
