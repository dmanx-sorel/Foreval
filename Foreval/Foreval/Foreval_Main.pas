 {.395}
procedure TForevalH.FindFunctionOrArrayPS(PS: PString;  var ND: TDataNode; var LV: PLevel;  var BFuncArrayFind,EOFN: Boolean);
// Поиск функции или массива вида: func(), func(arg1,arg2,...) ,array[indx]
{
   Поиск главной функции - ND.NFunc  без учёта числа аргументов и их типов - ND.nf (выполняется в - LinkDataNode)
   Анализаторы выполняют конвертацию функций из внешних шаблонов в исполняемые функции +
     оптимизация внутренних функций в зависимости от типа аргументов. В этом случае определяется  ND.nf

}

label array_,endp,intf,endpp;
var
i,k,l,j,bb,pf,pr,b1,b2,nf,ni,ni1,TV,NArg: Integer;        //BFuncArrayFind - функция/массив найдена да/нет
S1,Sa,Sa1,Sf,Sf1,Sfn,Sv: String;                     //EOFN - (end of node)-достигнут конец узла: выражение нуждается в дальнейшем разборе да/нет
Neg,SB,TM,code,IC,NV: Integer;
FH,FH1,ExtFunc,BEF,BFuncFind,BArrayFind: Boolean;
C: Extended;
AIVP:  TArrayIntVarProd;
begin

BFuncFind:=False;
BArrayFind:=False;
EOFN:=False;
BEF:=False;


if F_SyntaxErrorCode <> 0 then goto endpp;
F_CurrentString:=PS^;
FH:=False;
FH1:=False;
ExtFunc:=False;


{.375B} //some speed up parse  for non func&array expr.
//if (PS^[Length(PS^)] <> ')') and  (PS^[Length(PS^)] <> ']') then  goto endp;
if not (PS^[Length(PS^)] in CloseBracket)  then  goto endp;       {.395}




//[-[x-1.5]-[-[x+5.7]]]-[t-[t-[t+7.5]-[t+1.8]]+t]

nf:=0;



//поск функции вида: func(arg1,...,argN)
begin

  //FindFuncBr(S,'(',')',Sf,Sa,FH);

  //поиск и конвертация в команду Save присвоения значения по указателю: PType(PointerArg)=value -> save(PType(PointerArg),value)
  //CheckSaveForPointer(PS);     {.367}

  //? func(Sarg) ->     общий код фукции (без идентефикации числа и типов аргументов) - nf, имя - Sf=func, аргумент - Sa=Sarg,   BFuncFind=True
  FindFuncBrInExprPS(PS, nf, Sf, Sa, BFuncFind);   {.369}


  if F_SyntaxErrorCode <> 0 then
  begin

     if (F_SyntaxErrorCode = E_UNKNOWN_FUNCTION) then
     begin
          // !abs(x)       {.385}
          if (F_WrongPlacedOperation = True) then  F_SyntaxErrorCode := E_WRONG_PLACEMENT_OPERATOR;

          {.393}            // sss(cos(x))
          {if     Tree^.Pr <> nil then  F_SyntaxErrorString:= '  "'+F_SyntaxErrorString + '"'+#13#10+ '   in:' +#13#10+'"'+Tree^.Pr^.Expression+'"    '
          else   F_SyntaxErrorString:='"  '+ Sf+'  "'+#13#10+'  in expression:  '+#13#10+'"'+F_SyntaxErrorString+'"    '; }
          F_SyntaxErrorString:='"  '+ Sf+'  "'+#13#10+'  in expression:  '+#13#10+'"'+F_SyntaxErrorString+'"    ';

     end;

     goto endp; {.375C}
  end;




  if BFuncFind = False then goto array_;    //функция не найдена => искать массив


end;



 if nf <> -1 then          // имя функции найдено (без идентефикации числа и типов аргументов)
 begin
    //SFunc:=Alg.ExFunc[nf].Name; {.301}


    FindManyArgPS(@Sa,ArgM);{.314}      //поиск числа аргументов
    NArg:=Length(ArgM);
    DelExternalBracketInArgsPS(ArgM,@Sa); {.335}  //очистка от лишних скобок

    {общие записи  для  функций всех типов:}

    {
        запись аргументов найденной функции в поля
        вытекающих узлов:             LV[].Expression       - строковые аргументы
        текущего узла найденной ф-ии: ND.N, ND.COP, ND.Func - параметры функции
    }

    ND.ExpressionArg:=Sa; {.193}   //used in compare at replace func optimization

    ND.NFunc:=nf;    // общий код функции  (без идентефикации числа и типов аргументов)
    ND.N:=NArg;      // число аргументов
    ND.COP:=_Func;     // только для внутренних функций  ???

    SetLength(LV,ND.N);
    for i:= 0 to High(LV)do
    begin
        LV[i].Expression:=Copy(ArgM[i],1,Length(ArgM[i]));
          {LV[i].NL:=i+1;     LV[i].IdL:=F_IdN;}
    end;



      // 395x
       {
       power(x1,x2,x3: real)=x1+x2+x3
       power(x1: real; vd1: array of double)= len(vd1)*x1

       power(x,y,t)
       power(x,vd)

       Проверить все остальные ф-ии
             CALLAnalizator(LV,ND,LV,ND,EOFN);

             AddrAnalizator(LV,ND,LV,ND,EOFN);


             PTYPEAnalizator(LV,ND,LV,ND,EOFN,BEF);
       }



     {
         если внутренняя функция может быть переопределена (overload), то нужно через соответствующий анализатор возвращать
         переменную BEF = True, если внутренняя функция распознана и BEF = False , если нет
     }


     // BEF = True если ф-ия - внутренняя и/или оптимизирована в соответствующем анализаторе

          if NArg = 0 then
          begin
              // F_CurrentFunction:=Sf;
               ZeroArgFuncAnalizator(LV,ND,LV,ND,BEF,EOFN);
               if BEF = True then goto endp;
               if F_SyntaxErrorCode =  E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS then
               begin
                  F_SyntaxErrorString:='"  '+ Sf+'  "'+#13#10+'  in expression:  '+#13#10+'"'+F_SyntaxErrorString+'"    ';
                  goto endp;
               end;
          end;


           {.301}
          if M_ParseMode = M_ParseDiffExpr then
          begin
            if ND.NFunc = CM_IFin then
            begin
              IFAnalizator(LV,ND,LV,ND);
              BFuncFind:=True;
              EOFN:=False;
            end;
            goto endp;
          end;




          // SUM,MAX,MIN, PROD,DEV,DEVS,AVR,SUMQ, GCD,LCM,  LEN,HIGH:
          if  (nf = CM_SUM)  or (nf = CM_MAX) or (nf = CM_MIN)  or (nf = CM_PROD)   or
              (nf = CM_AVR)  or (nf = CM_DEV) or (nf = CM_DEVS) or (nf = CM_SUMQ)   or
              (nf = CM_NORM) or (nf = CM_GCD) or (nf = CM_LCM)  or (nf = CM_LENGTH) or (nf = CM_HIGH)
          then
          begin

                 //Func(Array)     только внутренние ф-ии c одним явным аргументом - Array. Для внешних Array заносится в стек
                 Array1FuncAnalizator(LV,ND,LV,ND,BEF,EOFN);      // м.б. переопределены (overload)
                 if BEF = True then
                 begin
                    goto endp;
                 end
                 else   // infinite; оптимизация для NArg = 2,3  ; max(x,y),  max(x,y,t) -> max23(x,y),  max23(x,y,t)
                 if (ND.NFunc = CM_MAX) or (ND.NFunc = CM_MIN)  or (ND.NFunc = CM_NORM) or (ND.NFunc = CM_AVR) then
                 begin
                    DataFuncAnalizator(LV,ND,LV,ND,BEF,EOFN);
                  end
          end
          else
          if ((ND.NFunc =  CM_RE) or (ND.NFunc = CM_IM)) and (F_OperationOptimizatorA1 = True) then
          begin
             ReImAnalizator(LV, ND, LV, ND, BEF,EOFN);
          end
          else
          if ND.NFunc = CM_JMP then
          begin
             GOTOAnalizator(LV,ND,LV,ND);
             EOFN:=True;   BEF:=True;
          end
          else
          if ND.NFunc = CM_GOSUB then
          begin
             GOSUBAnalizator(LV,ND,LV,ND);
             EOFN:=True;  BEF:=True;
          end
          else
          if (ND.NFunc = CM_INC) or (ND.NFunc = CM_DEC) then
          begin
              IDAMAnalizator(LV,ND,LV,ND,BEF,EOFN);
          end
          else
          if (ND.NFunc = CM_CALLR) or (ND.NFunc = CM_CALLCX) or (ND.NFunc = CM_CALL) then       {.347}
          begin
              CALLAnalizator(LV,ND,LV,ND,EOFN);
              BEF:=True;
          end
          else
          if (ND.NFunc = CM_ADDR) or (ND.NFunc = CM_ADDR_ARRAY) or
             (ND.NFunc = CM_ADDR_FUNC) or (ND.NFunc = CM_ADDR_VAR) then
          begin
             AddrAnalizator(LV,ND,LV,ND,EOFN);
             BEF:=True;
         end
         else
         if (ND.NFunc = CM_PEXTENDED) or (ND.NFunc = CM_PDOUBLE) or  (ND.NFunc = CM_PSINGLE) or
            (ND.NFunc = CM_PINTEGER)  or  (ND.NFunc = CM_PBYTE)or  (ND.NFunc = CM_PWORD) then       {.367} {.381}
         begin
             PTYPEAnalizator(LV,ND,LV,ND,BEF,EOFN);            // м.б. переопределены (overload)
             //ExtFunc:=BEF;
         end
         else
         if ND.NFunc = CM_SWAPIFin then
         begin
            SwapIfAnalizator(LV,ND,LV,ND,EOFN);
            BEF:=True;
         end
         else
        if (ND.NFunc = CM_POWER) and (F_OperationOptimizatorA2 = True) then
        begin
            PowerAnalizator(LV,ND,LV,ND,BEF,EOFN);          // м.б. переопределена (overload)
        end
        else
        if (ND.NFunc = CM_LOG) and (F_OperationOptimizatorA2 = True) then
        begin
