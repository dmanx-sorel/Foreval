var
ni: integer;
TV: Integer;
SU: String;
Answ: Boolean;
begin

Sgn:=_POSITIVE;
Answ:=False;
SU:='';

//i
if (PSI^ = S_IM_UNIT) and (F_RecoverImUnit = False) then
begin
  FindVarPS(@S_IM_UNIT,ni);
  if ni <> -1 then
  begin
     Answ:=True;
     goto endp;
  end;
end;

//(i), (-i)
if (PSI^[1] = '(') and (PSI^[Length(PSI^)] = ')') then
begin

  if PSI^[2]='-' then    // (-i)
  begin
    Sgn:=_NEGATIVE;
    SU:=Copy(PSI^,3,Length(PSI^)-3);
  end
  else                //(i)
    SU:=Copy(PSI^,2,Length(PSI^)-2);
end;



if (SU = S_IM_UNIT) and  (F_RecoverImUnit = False) then
begin
  FindVarPS(@S_IM_UNIT,ni);
  if ni <> -1 then
  begin
     Answ:=True;
  end;
end;



endp:
CheckImUnit:=Answ;
end;


