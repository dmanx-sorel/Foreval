      //if TryStrToFloat(LV[0].Expression,f1,G_FMT) = true  then    //poly(1.123,x)  poly(1.123,x/y)  poly(x,1.123) poly(x/y,1.123)
      if TC = T_Real then     {.347}
      begin{
      SetLength(LV1,0);
      ND1.EI:=2;
      ND1.N:=0;
      SetLength(ND1.VFP,1);
      ND1.VFP[0]:=f1;
      EOFN:=True;
      goto endp;
      }
         ND1.TC:=C_Real;
         ND1.FDC.re:=Re;
         ND1.FDC.im:=0;
         ND1.FD:=Re;
         ND1.COP:=_LDSC;
         ND1.N:=0;
         SetLength(LV1,0);
         EOFN:=True;
         goto endp;
      end
      else
      if TC = T_Complex then {.347}
      begin
         ND1.TC:=C_Complex;
         ND1.FDC.re:=Re;
         ND1.FDC.im:=Im;
         ND1.COP:=_LDSCX;
         ND1.N:=0;
         SetLength(LV1,0);
         EOFN:=True;
         goto endp;
      end
      (*
      //if TryStrToFloat(LV[1].Expression,f1,G_FMT) = true  then
      if  SubstParamACXPSF(@LV[1].Expression, Re,Im) = T_Real then {.347}
      begin
         ND1.TC:=C_Real;
         ND1.FDC.re:=Re;
         ND1.FDC.im:=0;
         ND1.FD:=Re;
         ND1.COP:=_LDSC;
         ND1.N:=0;
         SetLength(LV1,0);
         EOFN:=True;
         goto endp;
      end
      *)

      else
      {
      begin
        F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT;
        F_SyntaxErrorString:=F_CurrentString;
        SetLength(LV1,0);
        SetLength(ND1.VFP,0);
        goto endp;
      end;
      }
      begin                            //poly(Expr,Var)
          ND1.NFunc:=CM_POLYU;
          SetLength(ND1.VFP,1);
          InitVFP(@ND1);
          ND1.N:=1;
          ND1.VFP[0].Re:=0;
          ND1.VFP[0].Im:=0;
          ND1.VFP[0].indx:=_ABSENT;
          SetLength(LV1,1);
          LV1[0].Expression:=Copy(LV[0].Expression,1,Length(LV[0].Expression));
          EOFN:=False;
      end;
   end;


end
else
if Len > 2 then
begin

  //poly(3,5,7,9,11,15,17,19,x)-(3*x^7+5*x^6+7*x^5+9*x^4+11*x^3+15*x^2+17*x+19)

   //SaveSW; {.229} {TryStrToFloat damage SW}
   //if TryStrToFloat(LV[0].Expression,f1,G_FMT) = true then


