procedure TForevalH.FreeBranch(BranchPrnt: PNode);
label endp;
var
H,PrevH,NextH,LastCh,LastFreeNode: PNode;
S: String;
NNode: Integer;
begin


if BranchPrnt = nil then goto endp;
if BranchPrnt^.Ch = nil then goto endp;

LastCh:=GetLastChld(BranchPrnt);


if {BranchPrnt^.Ch^.Nb = nil}BranchPrnt^.Ch = LastCh then    {только один исходящий узел}
begin
   {ClearNode(BranchPrnt^.Ch);
   dispose(BranchPrnt^.Ch);  }
   FreeNode(BranchPrnt^.Ch);
   goto endp;
end;


Tree:=BranchPrnt;

while Tree^.Ch <> nil do
begin
  Tree:=Tree^.Ch;
end;
 //z1/(x+z2)+z1/(x+z2)
 //(z1*(z3+z1)+z2/(z1-z3))/(x*(x-y)+z2*(x+y))+(z1*(z3+z1)+z2/(z1-z3))/(x*(x-y)+z2*(x+y))
// (z1*(z3+z1)+z2/(z1-z3))+(z1*(z3+z1)+z2/(z1-z3))

//S:=Tree^.Expression;



LastFreeNode:=Tree;
while LastFreeNode <> LastCh do
begin

  { if Tree = nil then
       S:= Tree^.Expression;    }


 while Tree^.Nb {Tree} <> nil  do
 begin

    H:=Tree; LastFreeNode:=Tree;
    Tree:=Tree^.Nb;
    FreeNode(H);

   while Tree^.Ch <> nil do
   begin
     Tree:=Tree^.Ch;
   end;


 end;



  H:=Tree;   LastFreeNode:=Tree;

  Tree:=Tree^.Pr;
  FreeNode(H);

end;

endp:
end;



