procedure TForevalH.DelVoidSaveCF;
label nxts;

  (*******************************************
    function ConditionForDel(NodeS: PNode): Boolean;
    label endp;
    var
      Answer: Boolean;
      NodeD: PNode;
    begin
         Answer:=False;

         NodeD:=NodeS;
         NodeD:=GetLowLeftNode(NodeD);

         if (NodeD^.RRF <>  rf_NO_REPLACE) and
         (
          ((NodeS^.MRF = NodeD^.MRF)       and (NodeS^.MRF >=0))     or
          ((NodeS^.MRF = NodeD^.MRF_CS)    and (NodeS^.MRF >= 0))    or
          ((NodeS^.MRF_CS = NodeD^.MRF_CS) and (NodeS^.MRF_CS >= 0)) or
          ((NodeS^.MRF_CS = NodeD^.MRF)    and (NodeS^.MRF_CS >= 0))
         )  then
         begin
           Answer:=True; goto endp;
         end;

         while NodeS^.Pr <> nil do
         begin
            NodeS:=GetNextNode(NodeS);

            if (NodeD^.RRF <>  rf_NO_REPLACE) and
           (
           ((NodeS^.MRF = NodeD^.MRF)       and (NodeS^.MRF >=0))     or
           ((NodeS^.MRF = NodeD^.MRF_CS)    and (NodeS^.MRF >= 0))    or
           ((NodeS^.MRF_CS = NodeD^.MRF_CS) and (NodeS^.MRF_CS >= 0)) or
           ((NodeS^.MRF_CS = NodeD^.MRF)    and (NodeS^.MRF_CS >= 0))
           )  then
           begin
             Answer:=True; goto endp;
           end;

         end;

         endp:
         ConditionForDel:=Answer;
    end;

    ***********************************************)
var
 BRF: Boolean;
 NRF,NS,ND,NV: Cardinal;

 NodeS,NodeD,NodeF: PNode;
begin

//NS->ND



(*******************************************

   NV:=0;

   NodeS:=BeginTree; //не обязательно, т.к. чтение дерева - циклически
   NodeS:=GetLowLeftNode(NodeS);

   if (NodeS^.NFunc <> CM_NOP) and ((NodeS^.WRF <> rf_NO_REPLACE) or (NodeS^.WRF_CS <> rf_NO_REPLACE)) then
   begin
     if  ConditionForDel(NodeS) = True then
     begin
       NodeS^.WRF:=rf_NO_REPLACE;
       NodeS^.NRF:=0;
       inc(NV);
     end;
   end;


   while NodeS^.Pr <> nil do
   begin
      NodeS:=GetNextNode(NodeS);

      if (NodeS^.NFunc <> CM_NOP) and ((NodeS^.WRF <> rf_NO_REPLACE) or (NodeS^.WRF_CS <> rf_NO_REPLACE)) then
      begin
        if  ConditionForDel(NodeS) = True then
        begin
          NodeS^.WRF:=rf_NO_REPLACE;
          NodeS^.NRF:=0;
          inc(NV);
        end;
      end;
   end;

 ***********************************************)



//NS->ND
NV:=0;
NodeS:=FirstNode;
while NodeS <> nil do
begin
  BRF:=False;

  if (NodeS^.NFunc <> CM_NOP) and ((NodeS^.WRF <> rf_NO_REPLACE) or (NodeS^.WRF_CS <> rf_NO_REPLACE)) then
  begin

    NodeD:=NodeS^.Next;
    while NodeD <> nil do
    begin

      if (NodeD^.RRF <>  rf_NO_REPLACE) and
        (
          ((NodeS^.MRF = NodeD^.MRF)       and (NodeS^.MRF >=0))     or
          ((NodeS^.MRF = NodeD^.MRF_CS)    and (NodeS^.MRF >= 0))    or
          ((NodeS^.MRF_CS = NodeD^.MRF_CS) and (NodeS^.MRF_CS >= 0)) or
          ((NodeS^.MRF_CS = NodeD^.MRF)    and (NodeS^.MRF_CS >= 0))
        )  then
      begin
       BRF:=True;
       goto nxts; {.233}
      end;


      {.331}  //исключения для :  cossin -> sin,cos,sec,cosec     несовпадение по  номерам ячеек (полное сохранение и чтение, но для sin читает из +shift(=1))
     if (NodeS^.NFunc = CM_COSSIN) then
     begin
       if (NodeD^.NFunc = CM_COS) or (NodeD^.NFunc = CM_SIN) or (NodeD^.NFunc = CM_SEC) or (NodeD^.NFunc = CM_COSEC) then    //<- необязательно
       begin
         if (NodeS^.WRF = rf_FULL_REPLACE) and (NodeD^.RRF = rf_FULL_REPLACE)  then        //полная замена cossin(x)+cos(x)
         begin
           if (NodeS^.MRF = NodeD^.MRF+TableRF[NodeS^.NFunc,NodeD^.NFunc].SHFT_R) then
           begin
             BRF := True;
             goto nxts;
           end
         end
         else
         if (NodeS^.WRF = rf_FULL_REPLACE) and (NodeD^.RRF <> rf_NO_REPLACE)  then       //частичные замены       cossin(x)+sec(x)
         begin
           if (NodeS^.MRF = NodeD^.MRF_CS+TableRF[NodeS^.NFunc,NodeD^.NFunc].SHFT_R) then
           begin
             BRF := True;
             goto nxts;
           end
         end;
       end;
     end;




      NodeD:=NodeD^.Next;
    end;

  end;


  //удаляются только полные (уже ненужные) сохранения. Частичные остаются(WRF_CS).
  if BRF = False then
  begin
    NodeS^.WRF:=rf_NO_REPLACE;
    NodeS^.NRF:=0;
    inc(NV);
  end;

  nxts:
  NodeS:=NodeS^.Next;
end;



end;





