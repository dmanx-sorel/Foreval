                            if Interp[NM].TypeF = T_Real then CheckStack(-1) else
                            if Interp[NM].TypeF = T_Complex then CheckStack(-2); //else T_None
                          end;
                        end;
                        }
                         *)
                      end;
                   end;
label endp;
var
P: ^Integer{Cardinal};
NC,CC,N1,N2,SZ,S,NCP,L,NCP1,NM,NM1,NM2: Cardinal;
NL,NB,CS,Adr1,Adr2,AdrM1,AdrM2,CS1,N: Cardinal;
ANL: TArrayC;
NN,CI,ta1,ta2,tva,tma: Integer;
Node,NodeCh1,NodeCh2,NodeJmp: PNode;
AddrI1,AddrI2: TAddress;

begin
 //AI = 1       2      3       4      5      6     7       8
 //   #JMP, #JMPE, #JMPEL, #JMPEB, #JMPB, #JMPL, #JMPNE, JMP(goto)

Node:=GNode;//N:=NFunc;

   (*
if F_Mode = M_XchBranch{C_Compile} then    {.302}
begin
//режим: DinamicLoad
 if (Node^.AI >= 2) and (Node.AI <= 7) then CheckStack(-2); //FCOMPP      {.new}  {!!!}
 //else CheckStack(-1); //JMP
 //CorrectStackIF(N);  {.235}

 goto endp;
end;
   *)

 //Node^ = Interp[N]

//первый проход
if F_JMP = 1 then
begin
  if (Node^.AI = 1) or (Node^.AI = 8) then     //JMP ,goto
  begin
   SetLength(ICOMP,Length(ICOMP)+5);
   ICOMP[High(ICOMP)-4]:=$E9;         //jmp
   CorrectStackIF(Node);  {.211}
  end
  else    //CJMP
  begin

    // Node^.Pr  <- pointer to IF

    if Node^.Pr^.BI = _IntArg then
    begin
       ta1:=Node^.Pr^.TA1;
       ta2:=Node^.Pr^.TA2;
       if (ta1 = _IntForm) and (ta2 = _IntForm) then
       begin
          LineFormN(Node^.Pr^.AIVP2,Node^.Pr^.IC2);
          PUSHR(R_EAX);
          LineFormN(Node^.Pr^.AIVP1,Node^.Pr^.IC1);
          POPR(R_EBX);
          CMPR(R_EAX,R_EBX);
       end
       else
       if (ta1 = _IntVar) and (ta2 = _IntVar) then      //ok
       begin
          GetVar1(Node^.Pr^.NV1,AddrI1,tva,TMA);
          GetVar1(Node^.Pr^.NV2,AddrI2,tva,TMA);

          MOVMREG(R_EAX,AddrI1);
          CMPRM(R_EAX,R_MEM,AddrI2);
       end
       else
       if (ta1 = _IntVar) and (ta2 = _IntConst) then      //ok
       begin
          GetVar1(Node^.Pr^.NV1,AddrI1,tva,TMA);
          MOVCREG(R_EAX,Node^.Pr^.IC2);
          CMPRM(R_MEM,R_EAX,AddrI1);
       end
       else
       if (ta1 = _IntVar) and (ta2 =  _IntForm) then   //ok
       begin
          LineFormN(Node^.Pr^.AIVP2,Node^.Pr^.IC2);
          //PUSHR(R_EAX);
          GetVar1(Node^.Pr^.NV1,AddrI1,tva,TMA);
          //MOVCREG(R_EAX,Node^.Pr^.IC2);
          CMPRM(R_MEM,R_EAX,AddrI1);
       end
       else
       if (ta1 = _IntForm) and (ta2 = _IntConst) then
       begin
          LineFormN(Node^.Pr^.AIVP1,Node^.Pr^.IC1);
          MOVCREG(R_EBX,Node^.Pr^.IC2);
          CMPR(R_EAX,R_EBX);
       end
       else
       if (ta1 = _IntForm) and (ta2 = _IntVar) then
       begin
          LineFormN(Node^.Pr^.AIVP1,Node^.Pr^.IC1);
          GetVar1(Node^.Pr^.NV2,AddrI2,tva,TMA);
          CMPRM(R_EAX,R_MEM,AddrI2);
       end
       else
       if (ta1 = _IntConst) and (ta2 = _IntVar) then
       begin
          GetVar1(Node^.Pr^.NV2,AddrI2,tva,TMA);
          MOVCREG(R_EAX,Node^.Pr^.IC1);
          CMPRM(R_EAX,R_MEM,AddrI2);
       end
       else
       if (ta1 = _IntConst) and (ta2 = _IntForm) then
       begin
          LineFormN(Node^.Pr^.AIVP2,Node^.Pr^.IC2);
          MOVCREG(R_EBX,Node^.Pr^.IC1);
          CMPR(R_EBX,R_EAX);
       end
       else
       if (ta1 = _IntConst) and (ta2 = _IntConst) then   {.322}
       begin
          MOVCREG(R_EAX,Node^.Pr^.IC1);
          MOVCREG(R_EBX,Node^.Pr^.IC2);
          CMPR(R_EAX,R_EBX);
       end
       else
       begin
          F_SyntaxErrorCode:=E_INTERNAL_ERROR;
          F_SyntaxErrorString:='IF_ERROR';
       end;


       JMPCI(0,Node^.AI);
       goto out1;
    end;
    {

    сравнение IntArray1[] vs  IntArray2[]
    else

    if Node^.Pr^.BI = _IntArray then
    begin

       //if(vi2[j]>vi1[k],1,0)

       ta1:=Node^.Pr^.TA1;
       ta2:=Node^.Pr^.TA2;


       NM1:=GNode^.Pr^.NObj;
       NM2:=GNode^.Pr^.NObj2;
       AdrM1:=Alg.Obj[NM1].Addr;
       AdrM2:=Alg.Obj[NM2].Addr;

       //indx2->EAX
       if ta2 = _IntVar then
       begin
         GetVar1(Node^.Pr^.NV2,AddrI2,tva,TMA);
         MOVMREG(R_EAX,AddrI2);
       end
       else
       if (ta2 = _IntConst) then
       begin
          MOVCREG(R_EAX,Node^.Pr^.IC2);
       end
       else
       if ta2 = _IntForm then
       begin
          LineFormN(Node^.Pr^.AIVP2,Node^.Pr^.IC2);
       end;

       MOVMREG(R_EBX,AdrM2);           // AddrArray2 -> EBX (= @Array[0])
       //mov   eax,[ebx+4*eax]:
       AddByte($8B); AddByte($04);AddByte($83); //IntArray2[indx2]->EAX

       PUSHR(R_EAX);

       //indx1->EAX
       if ta1 = _IntVar then
       begin
         GetVar1(Node^.Pr^.NV1,AddrI1,tva,TMA);
         MOVMREG(R_EAX,AddrI1);
       end
       else
       if (ta1 = _IntConst) then
       begin
          MOVCREG(R_EAX,Node^.Pr^.IC1);
       end
       else
       if ta1 = _IntForm then
       begin
          LineFormN(Node^.Pr^.AIVP1,Node^.Pr^.IC1);
       end;

       MOVMREG(R_EBX,AdrM1);           // AddrArray1 -> EBX (= @Array[0])
        //mov   eax,[ebx+4*eax]:
       AddByte($8B); AddByte($04);AddByte($83); //IntArray1[indx1]->EAX





       POPR(R_EBX);
       CMPR(R_EAX,R_EBX);


       JMPCI(0,Node^.AI);
       goto out1;
    end;
    }


    //A1,A2 - float arg
   //если A1,A2 в памяти
   {FindNumberLevelA(Interp[N].NM,ANL);      //NM - узел: комманда IFNOP
   N1:=ANL[0];    N2:=ANL[1];  }

   NodeCh1:=Node^.Pr^.Ch;
   NodeCh2:=NodeCh1^.Nb;
   if (NodeCh1 = nil) or (NodeCh2 = nil) then begin {InternalError} end;

   S:=Node^.Pr^.S;  //S:=Interp[Interp[N].NM].S;

   Adr1:=GetStackAdr(S,_RE);
   Adr2:=GetStackAdr(S+1,_RE);


   //if (Interp[N1].SData1 = _MEM) and (Interp[N2].SData1 = _MEM) then
   if (NodeCh1^.SData1 = _MEM) and (NodeCh2^.SData1 = _MEM) then
   begin

     //fld A1,fld A2
      FLD(Adr1,F_DataType);
      FLD(Adr2,F_DataType);

   end
   else
   //if (Interp[N1].SData1 = _MEM) and (Interp[N2].SData1 = _FPU) then
   if (NodeCh1^.SData1 = _MEM) and (NodeCh2^.SData1 = _FPU) then
   begin
     //fld A1
     FLD(Adr1,F_DataType);
     FXCH1;

   end
   else
   //if (Interp[N1].SData1 = _FPU) and (Interp[N2].SData1 = _MEM) then
   if (NodeCh1^.SData1 = _FPU) and (NodeCh2^.SData1 = _MEM) then
   begin
     // fld A2
     FLD(Adr2,F_DataType);

   end
   else
   //if (Interp[N1].SData1 = _FPU) and (Interp[N2].SData1 = _FPU) then
   if (NodeCh1^.SData1 = _FPU) and (NodeCh2^.SData1 = _FPU) then
   begin

   end;

   { P:=@ICOMP[0];
   asm
     call  P
   end;
   }

   {.217}
   {
   FCOMPP;
   FSTSW_AX;
   SAHF;
   JMPC(0,Interp[N].AI);
   }
   FCOMIP;
   FSTP0;
   JMPC(0,Node^.AI);


   out1:
  end;

end
else  //расстановка смещений в JMP
if F_JMP =2 then
begin
  if (Node^.AI = 8) {and (Length(GotoLab)>0)} then  //GOTO
  begin
    NCP:=Node^.NCP;
    P:=@ICOMP[NCP-4];
    NN:=Node^.CI-2;
    if (NN = -1) or(Length(GotoLab) = 0) then
    begin
         {Если возникает исключение при  OverFlowChecks,RangeChecks -On - это не ошибка ! }
         {If there is an exception at OverFlowChecks,RangeChecks -On - it is no error !}

      //{$RangeChecks Off}
      //{$OverFlowChecks Off}
      P^:=-NCP;
      //{$RangeChecks On}
      //{$OverFlowChecks On}

    end
    else
    begin
     {L:=GotoLab[NN];
     NCP1:=Interp[L].NCP; }
     NodeJmp:=GotoLab[NN];
     NCP1:=NodeJmp^.NCP;

       //{$RangeChecks Off}
       //{$OverFlowChecks Off}
     P^:=NCP1-NCP;
       //{$RangeChecks On}
       //{$OverFlowChecks On}

    end;
    goto endp;
  end;

  NN:=Node^.Pr^.N; //NN:=Interp[interp[N].NM].N;
  NL:=Node^.NL;    //NL:=Interp[N].NL;      //текущий эл-т на уровне: отсчёт с '1'
  CI:=Node^.Pr^.CI; //CI:=Interp[interp[N].NM].CI;  //CI=2: if(arg1,goto())
  {
  FindNumberLevelA(Interp[N].NM,ANL);      //NM - узел: комманда IFNOP
  NB:=ANL[NL];           //ANL:  отсчёт с '0': ANL[NL] содержит следующий эл-т уровня
  }

  CS:=Node^.Nb^.CS;  //CS:=Interp[NB].CS;     //размер кода следующего эл-та
  NC:=Node^.NC;      //NC:=Interp[N].NC;    //номер начальной ячейки в ICOMP текущей комманды
  CS1:=Node^.CS;     //CS1:=Interp[N].CS;   //размер кода текущей комманды
  //if Interp[N].AI = 1 then  //JMP
  if Node^.AI = 1 then  //JMP
  begin
    //ICOMP[NC]:=$E9;
    P:=@ICOMP[NC{+1}+CS1-4];
    P^:=CS;
  end
  else  //CJMP
  begin
    P:=@ICOMP[NC+CS1-4];
    if NN = 6 then P^:=CS+5 else  //5 - размерность операнда JMP: A1,A2,CJMP,A3,JMP,A4 переход на A4: NL и NB указывают на JMP
       if NN = 4 then P^:=5;      //if(arg,goto())     A1,A2,CJMP,JMP
                            //P^:=CS+5;  //5 - размерность операнда JMP: A1,A2,CJMP,A3,JMP,A4 переход на A4: NL и NB указывают на JMP

  end;

  //CheckStack(-1);            {.211}
end;

endp:
