procedure TForevalH.MOVCREG(Reg,N: Integer); //Const(32)->Reg
begin
 if Reg = R_EAX then   MOVAnum(N) else
 if Reg = R_EBX then   MOVBnum(N) else
 if Reg = R_ECX then   MOVCnum(N) else
 if Reg = R_EDX then   MOVDnum(N) else
 if Reg = R_ESI then   MOVSInum(N) else
 if Reg = R_EDI then   MOVDInum(N) ;


 SetReg(Reg);
end;


// mov reg, [mem]
procedure TForevalH.MOVMREG(Reg: Integer; MEM: TAddress); //MEM(32)->Reg
begin
 if Reg = R_EAX then   MOVMA(MEM) else
 if Reg = R_EBX then   MOVMB(MEM) else
 if Reg = R_ECX then   MOVMC(MEM) else
 if Reg = R_EDX then   MOVMD(MEM) else
 if Reg = R_ESI then   MOVMSI(MEM) else
 if Reg = R_EDI then   MOVMDI(MEM);

 SetReg(Reg);
end;



//mov [mem],reg
procedure TForevalH.MOVREGM(Reg: Integer; MEM: TAddress); //Reg->MEM(32)
begin
 if Reg = R_EAX then   begin AddWord($89,$05); AddAddress(MEM); end else
 if Reg = R_EBX then   begin AddWord($89,$1D); AddAddress(MEM); end else
 if Reg = R_ECX then   begin AddWord($89,$0D); AddAddress(MEM); end else
 if Reg = R_EDX then   begin AddWord($89,$15); AddAddress(MEM); end ;//else

 SetReg(Reg);
end;



procedure TForevalH.NEGREG(Reg: Integer); //-Reg
begin
 if Reg = R_EAX then   AddWord($F7,$D8) else
 if Reg = R_EBX then   AddWord($F7,$DB) else
 if Reg = R_ECX then   AddWord($F7,$D9) else
 if Reg = R_EDX then   AddWord($F7,$DA);// else

 SetReg(Reg);
end;




procedure TForevalH.NEGMEM(MEM: Integer); //MEM=-MEM
begin
  AddWord($F7,$1D);
  AddAddress(MEM);
end;


procedure TForevalH.ADDREG(Reg1,Reg2: Integer); //Reg1=Reg1+Reg2
begin
 if (Reg1 = R_EAX) and (Reg2 = R_EAX) then   AddWord($01,$C1) else
 if (Reg1 = R_EAX) and (Reg2 = R_EBX) then   AddWord($01,$D8) else
 if (Reg1 = R_EAX) and (Reg2 = R_ECX) then   AddWord($01,$C8) else
 if (Reg1 = R_EBX) and (Reg2 = R_EBX) then   AddWord($01,$DB) else
 if (Reg1 = R_EBX) and (Reg2 = R_ECX) then   AddWord($01,$CB) else
 if (Reg1 = R_ECX) and (Reg2 = R_ECX) then   AddWord($01,$C9) else
 if (Reg1 = R_ECX) and (Reg2 = R_EDX) then   AddWord($01,$D1) else
 if (Reg1 = R_EDX) and (Reg2 = R_EDX) then   AddWord($01,$D3);// else

 SetReg(Reg1);
 SetReg(Reg2);
end;


procedure TForevalH.ADDMREG(Reg: Integer; MEM: TAddress); //Reg=Reg+[MEM(32)]
begin
 if Reg = R_EAX then    begin AddWord($03,$05); AddAddress(MEM); end  else
 if Reg = R_EBX then    begin AddWord($03,$1D); AddAddress(MEM); end else
 if Reg = R_ECX then    begin AddWord($03,$0D); AddAddress(MEM); end else
 if Reg = R_EDX then    begin AddWord($03,$15); AddAddress(MEM); end;// else

 SetReg(Reg);
end;



procedure TForevalH.SUBMREG(Reg: Integer; MEM: TAddress); //Reg=Reg-[MEM(32)]
begin
 if Reg = R_EAX then    begin AddWord($2B,$05); AddAddress(MEM); end else
 if Reg = R_EBX then    begin AddWord($2B,$1D); AddAddress(MEM); end else
 if Reg = R_ECX then    begin AddWord($2B,$0D); AddAddress(MEM); end else
 if Reg = R_EDX then    begin AddWord($2B,$15); AddAddress(MEM); end;// else

 SetReg(Reg);
end;


procedure TForevalH.ADDCREG(Reg: Integer; IC: Integer); //Reg=Reg+Const(32)
begin
 if Reg = R_EAX then    begin AddByte($05); AddNum(IC); end  else

 SetReg(Reg);
end;



procedure TForevalH.SUBCREG(Reg: Integer; IC: Integer); //Reg=Reg-Const(32)
begin
 if Reg = R_EAX then    begin AddByte($2D); AddNum(IC); end else

 SetReg(Reg);
end;



procedure TForevalH.SUBREG(Reg1,Reg2: Integer); //Reg1=Reg1-Reg2
begin
 if (Reg1 = R_EAX) and (Reg2 = R_EAX) then   AddWord($29,$C1) else
 if (Reg1 = R_EAX) and (Reg2 = R_EBX) then   AddWord($29,$D8) else
 if (Reg1 = R_EAX) and (Reg2 = R_ECX) then   AddWord($29,$C8) else
 if (Reg1 = R_EBX) and (Reg2 = R_EBX) then   AddWord($29,$DB) else
 if (Reg1 = R_EBX) and (Reg2 = R_ECX) then   AddWord($29,$CB) else
 if (Reg1 = R_ECX) and (Reg2 = R_ECX) then   AddWord($29,$C9) else
 if (Reg1 = R_ECX) and (Reg2 = R_EDX) then   AddWord($29,$D1) else
 if (Reg1 = R_EDX) and (Reg2 = R_EDX) then   AddWord($29,$D3);// else

 SetReg(Reg1);
 SetReg(Reg2);
end;



procedure TForevalH.MOVREG(Reg1,Reg2: Integer); //Reg1=>Reg2
begin
 if (Reg1 = R_EAX) and (Reg2 = R_ECX) then   AddWord($89,$C1) else
 if (Reg1 = R_EAX) and (Reg2 = R_EBX) then   AddWord($89,$C3) else
 if (Reg1 = R_EAX) and (Reg2 = R_EDX) then   AddWord($89,$C2) else
 if (Reg1 = R_EAX) and (Reg2 = R_ESI) then   AddWord($89,$C6) else

 if (Reg1 = R_EBX) and (Reg2 = R_ECX) then   AddWord($89,$D9) else

 if (Reg1 = R_ECX) and (Reg2 = R_EDX) then   AddWord($89,$CA) else

 if (Reg1 = R_EDX) and (Reg2 = R_EAX) then   AddWord($89,$D0) else
 if (Reg1 = R_EDX) and (Reg2 = R_EBX) then   AddWord($89,$D3) else
 if (Reg1 = R_EDX) and (Reg2 = R_ESI) then   AddWord($89,$D6) else

 if (Reg1 = R_ESI) and (Reg2 = R_EBX) then   AddWord($89,$F3) else
 if (Reg1 = R_ESI) and (Reg2 = R_EAX) then   AddWord($89,$F0) else
 if (Reg1 = R_ESI) and (Reg2 = R_ECX) then   AddWord($89,$F1);// else



 SetReg(Reg1);
 SetReg(Reg2);
end;


// mov [ebx],eax      eax->addr(ebx)
procedure TForevalH.MOV_ADDREBX_EAX;
begin
   AddWord($89,$03);
   SetReg(R_EBX); SetReg(R_EAX);
end;



procedure TForevalH.ADDMEMCONST(MEM: TAddress; IC: Integer); //MEM=MEM+IC
begin
   AddWord($81,$05);
   AddAddress(MEM);
   AddNum(IC);
end;


procedure TForevalH.IMULCREG(Reg: Integer; C: Integer); //Reg=Reg*C(32)
begin

if C = -1 then NEGREG(Reg)
else

if C <> 1 then
begin

 //if (C > 1) and (C <= 10) then IMULREG_CONST(Reg,C) else
 if IMULREG_CONST(Reg,C) = False then
 begin


 if Reg = R_EAX then
 begin
   begin
     AddWord($69,$C0);  AddNum(C);
   end;
 end
 else
 if Reg = R_EBX then
 begin

   begin
     AddWord($69,$DB);  AddNum(C);
   end;
 end
 else
 if Reg = R_ECX then
 begin

   begin
     AddWord($69,$C9);  AddNum(C);
   end;
 end
 else
 if Reg = R_EDX then
 begin

   begin
     AddWord($69,$D2);  AddNum(C);
   end;
 end;



 end;


end;

SetReg(Reg);

end;



function TForevalH.IMULREG_CONST(Reg,C: Integer): Boolean;

  {.357}
  procedure _NegReg;
  begin
   if C < 0  then NEGREG(Reg);
  end ;

var
 Answ,BNeg: Boolean;

begin
 Answ:=False;

 case abs(C)  of
  2:  begin IMULCREG2(Reg); _NegReg; Answ:=True; end;
  3:  begin IMULCREG3(Reg); _NegReg; Answ:=True; end;
  4:  begin IMULCREG4(Reg); _NegReg; Answ:=True; end;
  5:  begin IMULCREG5(Reg); _NegReg; Answ:=True; end;
  6:  begin IMULCREG6(Reg); _NegReg; Answ:=True; end;
  7:  begin IMULCREG7(Reg); _NegReg; Answ:=True; end;
  8:  begin IMULCREG8(Reg); _NegReg; Answ:=True; end;
  9:  begin IMULCREG9(Reg); _NegReg; Answ:=True; end;
  10: begin IMULCREG10(Reg);_NegReg; Answ:=True; end;
  12: begin IMULCREG12(Reg);_NegReg; Answ:=True; end;
  16: begin IMULCREG16(Reg);_NegReg; Answ:=True; end;
 end;

 IMULREG_CONST:=Answ;
end;




procedure TForevalH.IMULMREG(Reg: Integer; MEM: TAddress); //Reg=Reg*MEM(32)
begin

 if Reg = R_EAX then
 begin
     AddWord($0F,$AF); AddByte($05);  AddAddress(MEM);
 end
 else
 if Reg = R_EBX then
 begin
     AddWord($0F,$AF); AddByte($1D);  AddAddress(MEM);
 end
 else
 if Reg = R_ECX then
 begin
     AddWord($0F,$AF); AddByte($0D);  AddAddress(MEM);
 end
 else
 if Reg = R_EDX then
 begin
     AddWord($0F,$AF); AddByte($15);  AddAddress(MEM);
 end;


 SetReg(Reg);
end;





procedure TForevalH.IMULCREG2(Reg: Integer); //Reg=2*Reg
begin
 SHLREG(Reg,1);
 SetReg(Reg);
end;



procedure TForevalH.IMULCREG3(Reg: Integer); //Reg=3*Reg
begin
  LEAREG(Reg,2);
  SetReg(Reg);
end;


procedure TForevalH.IMULCREG4(Reg: Integer); //Reg=4*Reg
begin
  SHLREG(Reg,2);
  SetReg(Reg);
end;


procedure TForevalH.IMULCREG5(Reg: Integer); //Reg=5*Reg
begin
  LEAREG(Reg,4);
  SetReg(Reg);
end;





procedure TForevalH.IMULCREG6(Reg: Integer); //Reg=6*Reg
begin
  LEAREG(Reg,2);
  SHLREG(Reg,1);
  SetReg(Reg);
end;



procedure TForevalH.IMULCREG7(Reg: Integer); //Reg=7*Reg
begin
  MOVREG(Reg,Reg+1);
  SHLREG(Reg,3);
  SUBREG(Reg,Reg+1);

  SetReg(Reg);
  SetReg(Reg+1);
end;


procedure TForevalH.IMULCREG8(Reg: Integer); //Reg=8*Reg
begin
  SHLREG(Reg,3);
  SetReg(Reg);
end;



procedure TForevalH.IMULCREG9(Reg: Integer); //Reg=9*Reg
begin
  LEAREG(Reg,8);
  SetReg(Reg);
end;



procedure TForevalH.IMULCREG10(Reg: Integer); //Reg=10*Reg
begin
  LEAREG(Reg,4);
  SHLREG(Reg,1);
  SetReg(Reg);
end;


procedure TForevalH.IMULCREG16(Reg: Integer); //Reg=16*Reg
begin
  SHLREG(Reg,4);
  SetReg(Reg);
end;


procedure TForevalH.IMULCREG12(Reg: Integer); //Reg=12*Reg
begin
  LEAREG(Reg,2);
  SHLREG(Reg,2);
  SetReg(Reg);
end;


procedure TForevalH.SHLREG(Reg,Sh: Integer); //shl reg,Sh
begin
  if Sh = 1 then
  begin
       if Reg = R_EAX then AddWord($D1,$E0) else
       if Reg = R_EBX then AddWord($D1,$E3) else
       if Reg = R_ECX then AddWord($D1,$E1) else
       if Reg = R_EDX then AddWord($D1,$E2);

  end
  else
   if Sh = 2 then
  begin
       if Reg = R_EAX then begin AddWord($C1,$E0); AddByte($02); end else
       if Reg = R_EBX then begin AddWord($C1,$E3); AddByte($02); end else
       if Reg = R_ECX then begin AddWord($C1,$E1); AddByte($02); end else
       if Reg = R_EDX then begin AddWord($C1,$E2); AddByte($02); end
  end
  else
   if Sh = 3 then
  begin
       if Reg = R_EAX then begin AddWord($C1,$E0); AddByte($03); end else
       if Reg = R_EBX then begin AddWord($C1,$E3); AddByte($03); end else
       if Reg = R_ECX then begin AddWord($C1,$E1); AddByte($03); end else
       if Reg = R_EDX then begin AddWord($C1,$E2); AddByte($03); end
  end
  else
   if Sh = 4 then
  begin
       if Reg = R_EAX then begin AddWord($C1,$E0); AddByte($04); end else
       if Reg = R_EBX then begin AddWord($C1,$E3); AddByte($04); end else
       if Reg = R_ECX then begin AddWord($C1,$E1); AddByte($04); end else
       if Reg = R_EDX then begin AddWord($C1,$E2); AddByte($04); end
  end;

  SetReg(Reg);
end;



procedure TForevalH.LEAREG(Reg,Sh: Integer); // lea reg,[reg+reg*sh]
begin
  if Sh = 2 then
  begin
       if Reg = R_EAX then begin AddWord($8D,$04); AddByte($40); end else
       if Reg = R_EBX then begin AddWord($8D,$1C); AddByte($5B); end else
       if Reg = R_ECX then begin AddWord($8D,$0C); AddByte($49); end else
       if Reg = R_EDX then begin AddWord($8D,$14); AddByte($52); end

  end
  else
  if Sh = 4 then
  begin
       if Reg = R_EAX then begin AddWord($8D,$04); AddByte($80); end else
       if Reg = R_EBX then begin AddWord($8D,$1C); AddByte($9B); end else
       if Reg = R_ECX then begin AddWord($8D,$0C); AddByte($89); end else
       if Reg = R_EDX then begin AddWord($8D,$14); AddByte($92); end
  end
  else
  if Sh = 8 then
  begin
       if Reg = R_EAX then begin AddWord($8D,$04); AddByte($C0); end else
       if Reg = R_EBX then begin AddWord($8D,$1C); AddByte($DB); end else
       if Reg = R_ECX then begin AddWord($8D,$0C); AddByte($C9); end else
       if Reg = R_EDX then begin AddWord($8D,$14); AddByte($D2); end
  end;

end;


// lea eax,eax+CM*ebx
procedure TForevalH.LEA_EAX_EBX(CM: Cardinal);
begin
  if CM = 1 then begin AddWord($8D,$04); AddByte($03); end else
  if CM = 2 then begin AddWord($8D,$04); AddByte($58); end

end;


// lea eax,eax+CM*ebx+CA
procedure TForevalH.LEA_EAX_EBX_CONST(CM,CA: Cardinal);
begin
if CA <= $7F then
begin
    if CM = 1 then begin AddWord($8D,$44); AddByte($03); end else
    if CM = 2 then begin AddWord($8D,$44); AddByte($58)  end else
    if CM = 4 then begin AddWord($8D,$44); AddByte($98)  end else
    if CM = 8 then begin AddWord($8D,$44); AddByte($D8)  end ;

     AddByte(CA);
end
else
begin
  if CM = 1 then begin AddWord($8D,$84); AddByte($03); end else
  if CM = 2 then begin AddWord($8D,$84); AddByte($58)  end else
  if CM = 4 then begin AddWord($8D,$84); AddByte($98)  end else
  if CM = 8 then begin AddWord($8D,$84); AddByte($D8)  end ;

  AddNum(CA);
end;


end;



// lea eax,ebx+CM*eax
procedure TForevalH.LEA_EAX__EAX_EBX(CM: Cardinal);
begin
  if CM = 4 then AddByte3($8D,$04,$83); //end else
end;




procedure TForevalH.PUSHR(Reg: Integer);
//push Reg
begin

       if Reg = R_EAX then begin AddByte($50); end else
       if Reg = R_EBX then begin AddByte($53); end else
       if Reg = R_ECX then begin AddByte($51); end else
       if Reg = R_EDX then begin AddByte($52); end;

       SetReg(Reg);
end;


procedure TForevalH.POPR(Reg: Integer);
//pop Reg
begin

       if Reg = R_EAX then begin AddByte($58); end else
       if Reg = R_EBX then begin AddByte($5b); end else
       if Reg = R_ECX then begin AddByte($59); end else
       if Reg = R_EDX then begin AddByte($5a); end  ;
      SetReg(Reg);
end;


procedure TForevalH.POPRM(Reg: Integer);
//pop [Reg]
begin

       if Reg = R_EAX then begin AddWord($8F,$00); end;
       SetReg(Reg);
end;


procedure TForevalH.CMPR(Reg1,Reg2: Integer);
begin
  if (Reg1 = R_EAX) and (Reg2 = R_EBX) then begin AddWord($39,$D8); end else
  if (Reg1 = R_EBX) and (Reg2 = R_EAX) then begin AddWord($39,$C3); end else
  if (Reg1 = R_EAX) and (Reg2 = R_ESP) then begin AddWord($39,$E0); end else
  if (Reg1 = R_ESP) and (Reg2 = R_EAX) then begin AddWord($39,$C4); end else
  if (Reg1 = R_EAX) and (Reg2 = R_ECX) then begin AddWord($39,$C8); end else
  if (Reg1 = R_ECX) and (Reg2 = R_EAX) then begin AddWord($39,$C1); end else
  if (Reg1 = R_EAX) and (Reg2 = R_EDX) then begin AddWord($39,$D0); end else
  if (Reg1 = R_EAX) and (Reg2 = R_ESI) then begin AddWord($39,$F0); end else
  if (Reg1 = R_EAX) and (Reg2 = R_EDI) then begin AddWord($39,$F8); end;// else

  SetReg(Reg1); SetReg(Reg2);
end;


procedure TForevalH.CMPRM(Arg1,Arg2: Integer; Addr: TAddress);
begin
  if (Arg1 = R_EAX) and (Arg2 = R_MEM) then begin AddWord($3B,$05); AddAddress(Addr); SetReg(Arg1); end else
  if (Arg1 = R_MEM) and (Arg2 = R_EAX) then begin AddWord($39,$05); AddAddress(Addr); SetReg(Arg2); end else
  if (Arg1 = R_EBX) and (Arg2 = R_MEM) then begin AddWord($3B,$1D); AddAddress(Addr); SetReg(Arg1); end else
  if (Arg1 = R_MEM) and (Arg2 = R_EBX) then begin AddWord($39,$1D); AddAddress(Addr); SetReg(Arg2); end //else
end;


 // mov eax, [ebx+4*eax]
procedure TForevalH.MOV_EAX__EBX_4EAX;
begin
  AddByte3($8B,$04,$83);
  SetReg(R_EAX); SetReg(R_EBX);
end;



 // mov esi, [ebx+4*eax]
procedure TForevalH.MOV_ESI__EBX_4EAX;
begin
  AddByte3($8B,$34,$83);
  SetReg(R_EAX); SetReg(R_EBX);  SetReg(R_ESI);
end;



 // mov [ebx+4*eax], esi
procedure TForevalH.MOV_EAX_4EBX__ESI;
begin
  AddByte3($89,$34,$83);
  SetReg(R_EAX); SetReg(R_EBX);  SetReg(R_ESI);
end;


