begin

 {.375B}
 if (ND.NFunc >= 0) and (ND.NFunc <= High(Alg.ExFunc)) then   //должно быть!
 begin
   //если в ND.IsReplExpr уже прописано значение _No, то это поле инициализировано выше при разборе!!
   //по умолчанию - ND.IsReplExpr = _Yes
