     EOFN:=True;
    end
    else
    if ND.NFunc = CM_SETLENin then
    begin
     SetLenAnalizator(LV,ND,LV,ND,EOFN);
     BH:=True;
     //EOFN:=False;
    end
    else
    if ND.NFunc = CM_SWAPin then
