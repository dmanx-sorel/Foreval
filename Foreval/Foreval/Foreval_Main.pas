procedure TForevalH.SetReplaceType_ARCTAN_ARCCOTAN(ReplaceTypeSTD: Boolean);
begin
{.377}

if ReplaceTypeSTD = True then
{  =
   True:
        arcotan(Z)=pi/2-aratan(Z);
        arctan(Z)=pi/2-aratan(Z);

   False:
      Z.Re > 0
        arccotan(Z).Re=-arctan(Z).Re+Pi/2
        arccotan(Z).Im=-arctan(Z).Im

        arctan(Z).Re=-arccotan(Z).Re+Pi/2
        arctan(Z).Im=-arccotan(Z).Im

      Z.Re < 0
        arccotan(Z).Re=-arctan(Z).Re-Pi/2
        arccotan(Z).Im=-arctan(Z).Im

        arctan(Z).Re=-arccotan(Z).Re-Pi/2
        arctan(Z).Im=-arccotan(Z).Im

}
begin

  //Real:
  TableRF[CM_ARCTAN,CM_ARCCOTAN].WRF_R:=rf_FULL_REPLACE;
  TableRF[CM_ARCTAN,CM_ARCCOTAN].RRF_R:=rf_ARCTANR_REPLACE;
  TableRF[CM_ARCTAN,CM_ARCCOTAN].NMEM_R:=1;

  TableRF[CM_ARCCOTAN,CM_ARCTAN].WRF_R:=rf_FULL_REPLACE;
  TableRF[CM_ARCCOTAN,CM_ARCTAN].RRF_R:=rf_ARCCOTANR_REPLACE;
  TableRF[CM_ARCCOTAN,CM_ARCTAN].NMEM_R:=1;



  //Complex:
  TableRF[CM_ARCTAN,CM_ARCCOTAN].WRF_Z:=rf_FULL_REPLACE;
  TableRF[CM_ARCTAN,CM_ARCCOTAN].RRF_Z:=rf_ARCTANZ_REPLACE;
  TableRF[CM_ARCTAN,CM_ARCCOTAN].NMEM_Z:=2;

  TableRF[CM_ARCCOTAN,CM_ARCTAN].WRF_Z:=rf_FULL_REPLACE;
  TableRF[CM_ARCCOTAN,CM_ARCTAN].RRF_Z:=rf_ARCCOTANZ_REPLACE;
  TableRF[CM_ARCCOTAN,CM_ARCTAN].NMEM_Z:=2;

end
else
begin
  //сохраняют полностью функцию + Re(Arg)

  //Real:
  TableRF[CM_ARCTAN,CM_ARCCOTAN].WRF_R:=rf_FULL_XR_REPLACE;
  TableRF[CM_ARCTAN,CM_ARCCOTAN].RRF_R:=rf_ARCTANR_XR_REPLACE;
  TableRF[CM_ARCTAN,CM_ARCCOTAN].NMEM_R:=2;    //+1 для X

  TableRF[CM_ARCCOTAN,CM_ARCTAN].WRF_R:=rf_FULL_XR_REPLACE;
  TableRF[CM_ARCCOTAN,CM_ARCTAN].RRF_R:=rf_ARCCOTANR_XR_REPLACE;
  TableRF[CM_ARCCOTAN,CM_ARCTAN].NMEM_R:=2;   //+1 для X



  //Complex:
  TableRF[CM_ARCTAN,CM_ARCCOTAN].WRF_Z:=rf_FULL_ZRE_REPLACE;
  TableRF[CM_ARCTAN,CM_ARCCOTAN].RRF_Z:=rf_ARCTANZ_ZRE_REPLACE;
  TableRF[CM_ARCTAN,CM_ARCCOTAN].NMEM_Z:=3;       //+1 для Z.RE

  TableRF[CM_ARCCOTAN,CM_ARCTAN].WRF_Z:=rf_FULL_ZRE_REPLACE;
  TableRF[CM_ARCCOTAN,CM_ARCTAN].RRF_Z:=rf_ARCCOTANZ_ZRE_REPLACE;
  TableRF[CM_ARCCOTAN,CM_ARCTAN].NMEM_Z:=3;       //+1 для Z.RE


end;
end;



procedure TForevalH.SaveSW;
var
SSW: integer;
begin
 //если есть исключение: сохранить SW, но маски не сбрасывать
SSW:=0;

// {.365} Устранение странной ошибки, возникающей в некоторых случаях в CodeBlock16 (В остальных CodeBlock, MSVC ошибки нет)
if F_UseSaveSW = True then    {.365}
begin

if F_SaveSW = False then
begin
 asm
    push eax
    xor  eax,eax
    fnstsw ax
    sahf
    test ax, 001Fh

    jz @@Z

    push ax
    fnstsw ax
    mov word ptr [SWMEM],ax
    pop  ax
    mov SSW,1

    @@Z:
    pop eax

 end;

  if SSW = 1 then F_SaveSW:=True;
end;

end;

end;





procedure TForevalH.ClearFPUException;    {.229}
begin
 asm
    fnclex
 end;
end;


procedure TForevalH.MaskFPUException(CWAddr: PCardinal);  stdcall;  {.229}
begin
 asm
    push eax
    mov eax,CWAddr
    fnstcw word ptr [eax];       //->store
    pop eax
    sub esp,4
    fnstcw [esp];
    or word ptr [esp], 003Fh;
    fldcw [esp];
    add esp, 4
 end;
end;


 {.229}
function TForevalH.IsFPUException(CWAddr: PCardinal): integer;  stdcall;
begin
 asm
    push eax
    push ecx
    xor  eax,eax
    fnstsw ax
    sahf
    test ax, 001Fh
    mov  ecx,0
    //push $00000000
    jz @@Z
    mov  ecx,1
    //mov [esp],$00000001
    @@Z:
    mov dword ptr Result,ecx
    //pop dword ptr Result //[IsFPUException]
    fnclex
    mov eax,CWAddr
    fldcw  word ptr [eax]   //<-load
    pop ecx
    pop eax
 end;
end;



 {.229}
function TForevalH.IsFPUExceptionSW(CWAddr: PCardinal): integer;  stdcall;
begin
 asm
    push eax
    push ecx
    xor  eax,eax
    //fnstsw ax
    mov ax,word ptr [SWMEM]
    sahf
    test ax, 001Fh
    mov  ecx,0
    //push $00000000
    jz @@Z
    mov  ecx,1
    //mov [esp],$00000001
    @@Z:
    mov dword ptr Result,ecx
    //pop dword ptr Result //[IsFPUException]
    fnclex
    mov eax,CWAddr
