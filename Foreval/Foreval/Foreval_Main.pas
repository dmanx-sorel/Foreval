//ChangeToSetChar
//NOT USED
{.358}
procedure  TForevalH.FindFuncInExprPS(k: Integer; PSexpr: PString; var BH: Boolean);
label endp;
var
FName: set of  Char;
Sfn: String;
i,P,L,LF: integer;
begin
FName:=['(','{','[','|','*','/','>','<','=','+','^','-',',',';','$'];

BH:=False;

//if F_ExtNameFunction = True then LF:= Length(Alg.ExFunc[k].NameEx)-1 else LF:=1;

if F_ExtNameFunction = True then LF:=High(Alg.ExFunc[k].NameEx)  else
begin
   if Length(Alg.ExFunc[k].NameEx) <> 0 then  LF:=0 else LF:=-1;
end;


  for i:=0 to LF do
     begin
         Sfn:=Alg.ExFunc[k].NameEx[i];

         P:=Pos(Sfn,PSExpr^);
         if P > 0 then
         begin
           L:=Length(Sfn);

           if (PSExpr^[L+P] = '(') then
           begin
               if (P = 1)  then
               begin
                 BH:=True;
                 goto endp;
               end
               else
               begin
                  if PSExpr^[P-1] in FName = True then
                  begin
                    BH:=True;
                    goto endp;
                  end
               end;
           end
           else
           if PSExpr^[P-1] = '@' then     {.358}     //call(@func); AnyCall(..,@func,..) ; AnyCall(..,@func)
           begin
              if (Length(PSExpr^) = L+1) or       //anycall(@func)
                   (PSExpr^[L+P] = ',')    or       //anycall(...,@func,...)  ; anycall(@func,...)
                     (Length(PSExpr^) = L+P-1) then    //anycall(...,@func)
              begin
                 BH:=True;
                 goto endp;
              end;
           end;
         end;
     end;

endp:
end;







