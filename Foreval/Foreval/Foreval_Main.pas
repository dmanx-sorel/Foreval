         NNode:  Cardinal;    //порядковый номер узла в линейном (последовательном) списке.  Создаётся в InitSequentList; Используется только для отладки.
         //IdN:    Cardinal;    //В версии 9+ не используется
         //IdL:    Cardinal;    //В версии 9+ не используется
         NL:     Cardinal;    //порядковый (последовательный) номер команды на уровне (составляющая уровня); отсчет с 1 ; Главный узел: NL=0. Создаётся в SetNL.
         NCOP:   Cardinal;           //операция (номер массива) (составляющая узла);
         NFunc:  Cardinal;           //ф-ия (номер массива ф-ий; same names)
         NF:     Cardinal;           //ф-ия (номер массива в массиве ф-ий (same names) (for overload: different arguments))
         NObj:   Cardinal;           //номер массива переменной (исп-ся для массивов)
         NObj2:  Cardinal;           //номер массива переменной (исп-ся для массивов)
         COP:    Integer;            //COP: = 1(ф-ия) в Func номер массива ф-ий;
                                     //2(операция) в NCOP номер массива;
                                     //3(загрузка переменной) в NObj - номер массива;
                                     //4(загрузка константы) в FD - константа;
         FD:     TFloat;             //константа
         FD1:     TFloat;             //константа
         FD2:     TFloat;             //константа
         IC1:    Integer;             //константа
         IC2:    Integer;             //константа
         Expression:    String;//AnsiString;//String;
         ExpressionArg: String;//AnsiString;//String;
         SDiff:  String; {.301}
         TypeF: Integer;       //тип возвращаемого результата команды  текущего узла: T_Real, T_Complex,T_None, T_Array  {.353}
         TypeM: Integer;       //возвращаемый математический тип:  (_Extended,_Double,_Integer,_Single,_Pointer) {.353}
                                    // Используется для TypeF = T_Array. Для остальных по умолчанию - _Extended
         TypeA:  Cardinal;       //тип аргумента :исп-ся при оптимизации в арифметич. ком-ах с одним аргументом т.к в них возвращаемый тип определяется кроме типа аргумента также и типом константного аргумента, встроенного в команду
         Inv: Integer;               //инверсная (обратная) операция:  (исп-ся при оптимизации в арифметич. ком-ах CM_SUB, CM_DIV, )
         XchArg: Boolean;
         NV:     Integer;//TVar;
         NV1:    Integer;//TVar;       (исп-ся для переменных)
         NV2:    Integer;//TVar;       (исп-ся для переменных)
         NV3:    Integer;//TVar;       (исп-ся для переменных){.379}
         TA1:    Integer;             //тип аргумента {исп-ся с целочисленными арг.}
         TA2:    Integer;             //тип аргумента {исп-ся с целочисленными арг.}
         AI:     Integer; //control
         BI:     Integer; //control
         CI:     Integer; //control
         DI:     Integer; //control
         EI:     Integer; //control
         TS: Integer;    //_RE,_IM,0
         TS1:    Integer;     //_RE,_IM,0
         TS2:    Integer;      //_RE,_IM,0
         SData:  Integer;      //нахождение(сохранение) операнда (данного узла) в  MEM/FPU  в режиме DinamicLoad
         SData1:  Integer;     //нахождение операнда в MEM/FPU  в любом режиме
         RData: TArrayI;       //нахождение(чтение) аргументов (вытекающих узлов)  в MEM/FPU  в режиме DinamicLoad
         NM: Cardinal;       //В версии 9+ не используется
         FDC:    TComplex;
         TC:     Integer; //C_None,C_Real,C_Image,C_Complex   - constant type C_Real:FD;  C_Complex,C_Image: FDC.re,FDC.im
         TPM:    Integer; //мат. тип указателя в  командах PExtended, PDouble, PInteger, PSingle
         VFP:    TArrayCP; {.347}//TArrayF;   //коэфф. полинома {.207}
         Arg:  Cardinal;               //числу переменных (для infinite)
         ArgTypes:  TArrayI;                 //типы переменных для функций с TIntFunc.N=-2(_STACK_INFINITE_A)   _INTERNAL_INFINITE_ANY
         NC:   Cardinal;   //номер  ICOMP[NC] начала комманды
         NCP:   Cardinal;  //размер кода в байтах данного узла
         CS:   Cardinal;  //размер кода в байтах данного узла + размер кода всех вытекающих узлов
         RRF:    Integer;    //замещена и должна считывать рез-т    (ранг чтения)                 {.193}
         WRF:    Integer;    // сохраняет рез-т для замещения других ф-ий  (ранг сохранения)            {.193}
         NRF:    Integer;    //=числу функций, считывающих рез-т (если сохраняет рез-т)    {.193}
         MRF:    Integer;    //=номер ячейки в RFStack  с рез-ом (полная замена)                           {.193}
         WRF_CS:   Integer;    //= rf_: сохраняет рез-т для замещения других ф-ий  (ранг)            {.217}
         MRF_CS:   Integer;    //=номер ячейки в RFStack  с рез-ом (частичная замена) (чтение)                          {.217}
         MWF_CS:   Integer;    //=номер ячейки в RFStack  с рез-ом (частичная замена)  (сохранение)                         {.217}

         Addr1:  TAddress; {.347} //call(Addr1)

         ExtArg:  Integer;   //если команда является аргументом внешней ф-ии, то ExtArg = выталкиваемому типу этого аргумента  (либо нет = 0); исп-ся при компиляции
         ExtFunc: Integer;   {.309}// = NFunc, если является аргументом внешней ф-ии(NFunc) или _NOT_FOUND ; исп-ся для оптимизации IntForm ( FindExtFuncIntArg  )
         ExtArgPlace: Integer; //место положения аргумента для внешней функции : R_FPU, R_EAX,...  {.369}
         IsReplExpr:       Integer;  //=_No,_Yes; выражение(ф-ия) может? оптимизироваться Replace
         IsReplExprInArg:  Integer;  //=_No,_Yes; аргументы, вытекающие из выражения(ф-ия) могут? оптимизироваться Replace
         AlwaysEval: Integer; {.395if}  //  для аргументов if(A1 op A2, A3, A4)  A1,A2 - вычисляются всегда = _YES;  для A3,A4 = _NO ; используется при замене Replace
         EndIf     : Integer; {.395if}  //  для аргументов if(A1 op A2, A3, A4) для  последнего аргумента A4 = _YES Маркер конца IF ; используется при замене Replace

         cif:    Integer;       {.301}
         tif:    Integer;       {.301}
         AIVP1:  TArrayIntVarProd; {.303}
         AIVP2:  TArrayIntVarProd; {.303}

         Ch:   PNode;   //child                   ссылка от родителя. Всегда только на первого потомка (нижний левый): Tree^.Ch
         Nb:   PNode;   //neighbor (NextBrother)  ссылка на соседа (брата - Tree^.Ch^.Nb) от первого потомка  из общего родительского узла. Потомки  находятся на одном уровне - вытекают из общего узла. Последний брат указывает  nil
         Pr:   PNode;   //parent      ccылка на родительский узел; у всех потомков вышестоящего родительского узла  она есть.
                        {ссылка на   брата (второго) из родительского узла(если есть) - Tree^.Ch^.Nb ,на третьего - Tree^.Ch^.Nb^.Nb
                          Tree^.Ch^.Pr = Tree^.Ch^.Nb^.Pr = Tree^.Ch^.Nb^.Nb^.Pr = Tree - ссылка всех братьев (потомков общего родителя - Tree) на родителя
                        }
         Next: PNode;   //следующий  элемент  в последовательном линейном списке  дерева (создаётся в InitSequentList)
         Prev: PNode;   //предыдущий элемент  в последовательном линейном списке  дерева (создаётся в InitSequentList)
       end;             //последовательный линейный спискок  дерева начинается с нижнего левого узла и до вершины дерева.

