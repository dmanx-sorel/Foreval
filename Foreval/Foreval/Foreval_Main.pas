//NOT USED
Function TForevalH.GotoNextNodeROP(Node: PNode):Boolean;
label endp;
var
 Answ: Boolean;
 NFunc,NF,ReplF: Integer;

begin

  Answ:=False;


  if Node^.COP <> _FUNC          then       goto endp;
  if Node^.RRF = rf_FULL_REPLACE then     goto endp;     //если полностью замещена

  NFunc:=Node^.NFunc;
  NF:=Node^.NF;

  if (NFunc <> CM_DIV) and (NFunc <> CM_MUL) and (NFunc <> CM_SUB) and (NFunc <> CM_ADD) then goto endp;    //только для операций:


   ReplF:=Alg.ExFunc[NFunc].ReplFunc;
   if (ReplF = _No)  then goto endp;    //не подлежит оптимизации замещения

   //ResT1:=Node^.TypeF;


  Answ:=True;

endp:
end;


//NOT USED
procedure TForevalH.FindNodeForReplaceROP(Node1: PNode);
var
Node2: PNode;
begin

   Node2:=GetNextNode(Node1);

   if  GotoNextNodeROP(Node2) = False then
   begin
     CompareAndReplace(Node1,Node2);
   end;

   while Node2^.Pr <> nil do
   begin

      Node2:=GetNextNode(Node2);
      if  GotoNextNodeROP(Node2) = False then
      begin
        CompareAndReplace(Node1,Node2);
      end;

   end;
end;




