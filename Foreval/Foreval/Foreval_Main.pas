procedure TForevalH.FreeTree;
label endp;
var
H: PNode;
begin
if Tree = nil then goto endp;


      //L:int=len(vd);L
      //L=len(vd);L

//освобождение дерева через последовательное чтение списка
if F_SequentList = True then
begin
 Tree:=FirstNode;
 //Tree:=GetLowLeftNode(Tree);
 while Tree <> nil do
 begin
   H:=Tree^.Next;
   FreeNode(Tree);
   Tree:=H;
 end;
 FirstNode:=nil;
 F_SequentList:=False;
 goto endp;
end;



{
освобождение дерева обычным способом: через обход ссылок на Ch,Pr
исп-ся после дифф-я т.к. в нём удаляются промежуточные ветви дерева и
ссыли последовательного списока в дереве не действительны
}

Tree:=BeginTree;

while Tree^.Ch <> nil do
begin
Tree:=Tree^.Ch;
end;
//COP=NOP

while Tree^.Pr <> nil do
begin
 while Tree^.Nb <> nil  do
 begin
  H:=Tree; Tree:=Tree^.Nb;  H^.Nb:=nil;
  {ClearNode(H);//H^.RData:=nil;H^.Expression:='';   H^.ExpressionArg:='';
  dispose(H); }
  FreeNode(H);
  while Tree^.Ch <> nil do
  begin
  Tree:=Tree^.Ch;
  end;
 //COP=NOP
 end;

//COP<>NOP
 H:=Tree; Tree:=Tree^.Pr; H^.Pr:=nil;
 FreeNode(H);
 {ClearNode(H); //H^.RData:=nil;H^.Expression:='';   H^.ExpressionArg:='';
 dispose(H); }
end;
{.193}
FreeNode(Tree);
{ClearNode(Tree); //Tree^.RData:=nil;Tree^.Expression:='';   Tree^.ExpressionArg:='';
dispose(Tree);}



endp:
Tree:=nil;
BeginTree:=nil;
end;






        //sin(x)^cos(x)
procedure TForevalH.FreeChld(PrntNode: PNode);
label endp;
var
H: PNode;
Tree: PNode;
begin
//if F_SyntaxErrorCode <> 0 then goto endp;
if PrntNode = nil  then goto endp;

Tree:=PrntNode^.Ch;

repeat
   H:=Tree;
   Tree:=Tree^.Nb;
   H^.RData:=nil;
   H^.Expression:='';
   H^.ExpressionArg:='';
   H^.SDiff:='';
   //H^.SFunc:='';
   H^.Ch:=nil;
   dispose(H);
until Tree = nil ;


PrntNode^.Ch:=nil;

endp:
end;


procedure TForevalH.FreeChldNode(Prnt: PNode; NChld: Integer);
var
Ch1,Ch2,LLCh,PrevNode,NextNode: PNode;
begin
{
    Освобождает вытекающий узел (аргумент-константа) с номером NChld (и все из него)
    Ограничение:  Определена  только для двуаргументной функции Prnt^.N =2 !!! и
       NChld = 1 (первый аргумент константа)
       NChld = 2 (второй аргумент константа)


}
if Prnt^.N > 1 then
begin

  //  sin(x)*((1+2/3)^((1+2/30)^x))
  // ((sin(a/b)^2+cos(b/a)^2)^(x/y))/((sin(ai/bi)-cos(bi/ai))^(x/z1))
  //    (ln(sin(ai/bi)-cos(bi/ai)))*((1/(z1))*((sin(ai/bi)-cos(bi/ai))^(x/z1)*(1/(z1))*ln(sin(ai/bi)-cos(bi/ai))))

 { LLCh:=GetLowLeftNode(Prnt);
  PrevNode:=LLCh^.Prev; }


  if NChld = 1 then                      //   log(sin(c/b)+cos(b/a)+4,x+y)
  begin
     Ch1:=Prnt^.Ch;
     Ch2:=Ch1^.Nb;

     PrevNode:=Ch1^.Prev;



     NextNode:=Ch1^.Next;
     NextNode^.Prev:=PrevNode;
     if PrevNode <> nil then PrevNode^.Next:=NextNode;


     FreeNode(Ch1);
     Prnt^.Ch:=Ch2;
     Prnt^.Prev:=Ch2;

     Prnt^.N:=1;

     {.385}
     Ch2^.NL:=1;  // второй аргумент после вычисления в константу первого аргумента становится первым и единственным !!
     // восстановление стека (для второго аргумента)
     Ch2^.Stack.S:=Prnt^.Stack.S; // т.к. команда теперь одноаргументная
     Ch2^.S:=Ch2^.Stack.S-1;

     //  SetNL,  RestoreStack - дополнительно восстанавливают эти аргументы в конце оптимизации EvalTreeConst

  end
  else
  if NChld = 2 then          {.395}         // log(x+y,sin(c/b)+cos(b/a)+4)
  begin

     Ch1:=Prnt^.Ch;
     Ch2:=Ch1^.Nb;

     PrevNode:=Ch2^.Prev;

     NextNode:=Ch2^.Next;
     NextNode^.Prev:=PrevNode;
     if PrevNode <> nil then PrevNode^.Next:=NextNode;


     FreeNode(Ch2);
     Prnt^.Ch:=Ch1;
     Prnt^.Prev:=Ch1;

     Prnt^.N:=1;

     Ch1.Nb:=nil;

     Ch1^.NL:=1;

     Ch1^.Stack.S:=Prnt^.Stack.S;
     Ch1^.S:=Ch1^.Stack.S-1;



  end;

end;



end;




