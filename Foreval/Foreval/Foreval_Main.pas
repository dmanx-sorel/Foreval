procedure TForevalH.SaveArgStackVal(Node: PNode{i: Cardinal});      {.197} {.304}
var
S,N,NM,CallT,NF,dt,sh,Adr,tf,NL,TV,TM,Arg: Cardinal;
DS,SZ,Ar: Integer;
SAdr,AddrM,AddrObj: TAddress;

    function  GetCPUStackDeep(Arg1,Arg2: Integer): Integer;     //DS - определение глубины стека для передаваемых аргументов:
    var
      DS,k,CS: Integer;
    begin
     DS:=0;

     for k:=Arg1-1 to  Arg2-1 do
     begin
         CS:=0;
         TV:=Alg.ExFunc[N].Func[NF].TV[k];
         TM:=Alg.ExFunc[N].Func[NF].TM[k];

         if TV = T_Array then   CS:=4
         else
         begin
           case TM of
           _Single:      CS:=4;
           _Integer:     CS:=4;
           _Pointer:     CS:=4;
           _Double:      CS:=8;
           _Extended:    CS:=12;  //12 -  (12 вместо 10) - так компилирует DELPHI
           end;
          case TV of
           T_Real:       CS:=CS;
           T_Complex:    CS:=CS*2;
           end;
         end;



        DS:=DS+CS;
        if (TM = _Extended) and (TV = T_Complex) then DS:=DS+8; //16+16;выравнивание на 16

     end;

     //if Alg.ExFunc[N].Func[NF].Set_Id = _YES then DS:=DS+4;

     GetCPUStackDeep:=DS;
    end;





begin

   {S:=Interp[I].S;
   NM:=Interp[I].NM;
   NL:=Interp[I].NL;
   N:=Interp[NM].NFunc;
   NF:=Interp[NM].NF; }

   S:=Node^.S;
   NL:=Node^.NL;        //порядковый номер аргумента (номер на уровне)
   N:=Node^.Pr^.NFunc;
   NF:=Node^.Pr^.NF;
   Arg:=Alg.ExFunc[N].Func[NF].NArg;
  

   if NL = 1 then
   begin
    DS:=GetCPUStackDeep(1,Arg);   //полная глубина стека для ф-ии (без учета ID)
    if Alg.ExFunc[N].Func[NF].Set_Id = _YES then DS:=DS+4;
    SUBESP(DS);                 //резервирование стека
   end;


   //if _BACK then SZ:=GetCPUStackDeep(NL+1,Arg); //размер последующих аргументов в стеке    (обратный порядок)
   SZ:=GetCPUStackDeep(1,NL-1);   //размер предыдущих аргументов   (прямой порядок)

   case Node^.ExtArg of
      S_Real:          dt:=_Single;
      D_Real:          dt:=_Double;
      D_Complex:       dt:=_Double;
      E_Real:          dt:=_Extended;
      E_Complex:       dt:=_Extended;
      S_Complex:       dt:=_Single;
      D_Array_Real:    dt:=_Pointer;
      S_Array_Real:    dt:=_Pointer;
      E_Array_Real:    dt:=_Pointer;
      I_Array_Real:    dt:=_Pointer;
      I_Real:          dt:=_Integer;
      I_Pointer:       dt:=_Pointer;
   end;


   {
   if Alg.ExFunc[N].Func[NF].Arrow = _RIGHT then Ar:=-1 else
   if Alg.ExFunc[N].Func[NF].Arrow = _BACK then  Ar:=1;
    }

    //IntForm (EAX) -> Push(esp)
   if (Node^.TypeF = T_Real) and (Node^.COP = _LDINTFORM) then {.309}
   begin
      MOVESPEAX(SZ);
   end
   else    //IntArray[indx]: EAX -> Push(esp)
   if (Node^.TypeF = T_Real) and (Node^.ExtArg =  I_Real) and (Node^.NFunc = CM_LDSVX) and  (Node^.ExtArgPlace =  R_EAX) then {.369}
   begin
      MOVESPEAX(SZ);
   end
   else
   (*
   if Node^.COP = _LDSA then       {.347}
   begin  //передача адреса объекта

      {
      AddrObj:=Node^.Addr1;

      if (Node^.AI = _AddrVar) then
      begin
         MOVAadr(AddrObj);
         MOVESPEAX(SZ);
      end
      else
      if (Node^.AI = _AddrFunc) then
      begin
         MOVAadr(AddrObj);
         MOVESPEAX(SZ);
      end
      else
      if (Node^.AI = _AddrArray) then
      begin

        //MOVAadr(AddrObj);
        //MOVAA;   //вычисление и передача адреса нулевого элемента массива
        //MOVESPEAX(SZ);


         //MOVMREG(R_EAX,AddrObj);
         MOVCREG(R_EAX,AddrObj);
         MOVESPEAX(SZ);
      end;
      }

      {.353}   //выгрузка указателя из EAX в стек  CPU:
      MOVESPEAX(SZ);
   end
   else
   *)
   if Node^.TypeF = T_Real then
   begin
     FSTPESP(dt,SZ);
   end
   else
   if Node^.TypeF = T_Complex then
   begin       //RE-ST(0); IM-ST(1)
      FSTPESP(dt,SZ);    //re
      case dt  of
        _Single:     SZ:=SZ+Sh_S; //+4
        _Double:     SZ:=SZ+Sh_D; //+8
        _Extended:   SZ:=SZ+Sh_E; //+16
       end;
      FSTPESP(dt,SZ);    //im
   end
   else
   if Node^.TypeF = T_Array then      //_LDSF
   begin    {arraycpu}
     {AddrM:=Alg.Obj[GNode^.NObj].Addr;
     MOVMREG(R_EAX,AddrM);
     MOVESPEAX(SZ);  }

     {.353}   //выгрузка адреса массива из EAX в стек  CPU:
     MOVESPEAX(SZ);
   end
   else
   if Node^.TypeF = T_Pointer then      //_LDSA
   begin    {arraycpu}
     {.353}   //выгрузка указателя из EAX в стек  CPU:
     MOVESPEAX(SZ);
   end;



   (*
   S:=Node^.S;
   NL:=Node^.NL;
   N:=Node^.Pr^.NFunc;
   NF:=Node^.Pr^.NF;

   CallT:=Alg.ExFunc[N].Func[NF].CallT;

  case Node^.ExtArg of
      D_Real:     dt:=_Double;
      D_Complex:  dt:=_Double;
      E_Real:     dt:=_Extended;
      E_Complex:  dt:=_Extended;
      D_Array_Real:   dt:=_Pointer;
      E_Array_Real:   dt:=_Pointer;
      I_Array_Real:    dt:=_Pointer;
       _Integer:       dt:=_Integer;
     end;
     if Node^.TypeF = T_Real then
     begin
      FSTPM(GetStackAdr(S,_RE),dt);
     end
     else
     if Node^.TypeF = T_Complex then
     begin       //RE-ST(0); IM-ST(1)
      FSTPM(GetStackAdr(S,_RE),dt);
      FSTPM(GetStackAdr(S,_IM),dt);
     end
     else
     if Node^.TypeF = T_Array then
     begin    {arraycpu}
      //FSTPM(GetStackAdr(S,_RE),_Pointer);      {.197}

      //POPF(GetStackAdr(S,_RE));       {.223}
     end;

     *)
end;


procedure TForevalH.SaveArgStackAdr(Node: PNode{i: Cardinal});      {.197}
var
S,N,NM,CallT,NF,dt,sh,Adr,tf,NL,TV,TM: Cardinal;
SAdr: TAddress;

begin

   {S:=Interp[I].S;
   NM:=Interp[I].NM;
   NL:=Interp[I].NL;
   N:=Interp[NM].NFunc;
   NF:=Interp[NM].NF; }

   S:=Node^.S;
   NL:=Node^.NL;
   N:=Node^.Pr^.NFunc;
   NF:=Node^.Pr^.NF;
   CallT:=Alg.ExFunc[N].Func[NF].CallT;
   dt:=0; sh:=0;

   case Node^.ExtArg of
      D_Real:         dt:=_Double;
      D_Complex:      dt:=_Double;
      E_Real:         dt:=_Extended;
      E_Complex:      dt:=_Extended;
      S_Real:         dt:=_Single;
      S_Complex:      dt:=_Single;
      D_Array_Real:   dt:=_Pointer;
      E_Array_Real:   dt:=_Pointer;
      I_Array_Real:   dt:=_Pointer;
      S_Array_Real:   dt:=_Pointer;
      I_Real:         dt:=_Integer;
      I_Pointer:      dt:=_Pointer;
   end;


     if (Node^.TypeF = T_Real) and (Node^.COP = _LDINTFORM) then {.309}  //EAX -> MEM
     begin
      MOVREGM(R_EAX,GetStackAdr(S,_RE));
     end
     else    //IntArray[indx]: EAX->MEM
     if (Node^.TypeF = T_Real) and (Node^.ExtArg =  I_Real) and (Node^.NFunc = CM_LDSVX) and  (Node^.ExtArgPlace =  R_EAX) then {.369}
     begin
      MOVREGM(R_EAX,GetStackAdr(S,_RE));
     end
     else
     if Node^.TypeF = T_Real then
     begin
      FSTPM(GetStackAdr(S,_RE),dt);
     end
     else
     if (Node^.TypeF = T_Complex)  then
     begin
      Adr:=GetStackAdr(S,_RE);
      if  dt = _Double    then  sh:=sh_D else
      if  dt = _Extended  then  sh:=sh_E;
      FSTPM(Adr,dt);
      FSTPM(Adr+sh,dt);
     end
     else
     if Node^.TypeF = T_Array then
     begin    {arraycpu}
      //FSTPM(GetStackAdr(S,_RE),_Pointer);    {.197}

      //POPF(GetStackAdr(S,_RE));           {.223}

      {.353}   //выгрузка адреса массива из EAX в стек выражения:
       MOVREGM(R_EAX,GetStackAdr(GNode^.S,_RE));
     end
     else
     if Node^.TypeF = T_Pointer then
     begin    {arraycpu}
      {.353}   //выгрузка указателя из EAX в стек выражения:
       MOVREGM(R_EAX,GetStackAdr(GNode^.S,_RE));
     end;
end;




function TForevalH.SetExtArgInNode(Tree: PNode): Boolean;
var          //NOT USED !!
 i,NM,NL,N,NF,TV,TM,CallT: Integer;
 begin

          N:=Tree^.Pr^.NFunc;
          NF:=Tree^.Pr^.NF;
          TV:=0; TM:=0;
          NL:=0;{!!!}

          CallT:=Alg.ExFunc[N].Func[NF].CallT;

         if  CallT = 0 then
          //Interp[i].ExtArg:=0
           Tree^.ExtArg:=0
         else
         begin

           if (CallT = _STACK_ADDR) or (CallT = _MEMORY_EAX) or (CallT = _MEMORY_ESP) or (CallT = _STACK_VAL) or (CallT = _COMPILED) then
           begin
            TV:=Alg.ExFunc[N].Func[NF].TV[NL-1];     // NL-1 -> NL
            TM:=Alg.ExFunc[N].Func[NF].TM[NL-1];     // NL-1 -> NL
           end
           else
           if  CallT = _STACK_INFINITE then
           begin
            TV:=Alg.ExFunc[N].Func[NF].TV[0];
            TM:=Alg.ExFunc[N].Func[NF].TM[0];
           end
           else
           if  CallT = _INTERNAL_INFINITE_ANY then
           begin
            //TV:=Interp[i].TypeF;
            TV:=Tree^.TypeF;
            TM:=Alg.ExFunc[N].Func[NF].TM[0];
           end;

           if (TV = T_Real) and (TM = _Double) then Tree^.ExtArg:=D_Real else
           if (TV = T_Real) and (TM = _Extended) then Tree^.ExtArg:=E_Real else
           if (TV = T_Real) and (TM = _Single) then Tree^.ExtArg:=S_Real else
           if (TV = T_Complex) and (TM = _Double) then Tree^.ExtArg:=D_Complex else
           if (TV = T_Complex) and (TM = _Extended) then Tree^.ExtArg:=E_Complex else
           if (TV = T_Complex) and (TM = _Single) then Tree^.ExtArg:=S_Complex else
           if (TV = T_Array) and (TM = _Double) then Tree^.ExtArg:=D_Array_Real else
           if (TV = T_Array) and (TM = _Extended) then Tree^.ExtArg:=E_Array_Real else
           if (TV = T_Array) and (TM = _Integer)  then Tree^.ExtArg:=I_Array_Real else
           if (TV = T_Array) and (TM = _Pointer)  then Tree^.ExtArg:=I_Array_Real else
           if (TV = T_Array) and (TM = _Single) then Tree^.ExtArg:=S_Array_Real else
           if (TV = T_Real) and (TM = _Integer) then Tree^.ExtArg:=I_Real else
           if (TV = T_Pointer) and (TM = _Pointer) then Tree^.ExtArg:=I_Pointer;

   end;
 SetExtArgInNode:=False;
end;



procedure TForevalH.SetExtArg;
label endp;
var
PF: TProcTree;
PFObj: TProcTreeObj;
NL,NM,N,NF: Cardinal;
CallT,TV,TM: Integer;
Node: PNode;
begin
if F_SyntaxErrorCode <> 0 then goto endp;

(*
// PFObj:=ForevalH.SetExtArgInNode;

 ReadTree(SetExtArgInNode);
 //ReadTree(@TForevalH.SetExtArgInNode);
 //ReadTree(TProcTree(TForevalH.SetExtArgInNode));
 Tree^.ExtArg:=0;
*)

TV:=0; TM:=0; NL:=0;
Node:=FirstNode;
//Node^.ExtArg:=0;

//if Node^.NM = 0 then goto endp;

while Node^.Pr <> nil do
begin

    N:=Node^.Pr^.NFunc;
    NF:=Node^.Pr^.NF;
    NL:=Node^.NL;


    CallT:=Alg.ExFunc[N].Func[NF].CallT;

    if  CallT = 0 then
       Node^.ExtArg:=0
    else
    begin
      if (CallT = _STACK_ADDR) or (CallT = _MEMORY_EAX) or (CallT = _MEMORY_ESP) or (CallT = _STACK_VAL) or (CallT = _COMPILED) then
      begin
       TV:=Alg.ExFunc[N].Func[NF].TV[NL-1];
       TM:=Alg.ExFunc[N].Func[NF].TM[NL-1];
      end
      else
      if  CallT = _STACK_INFINITE then
      begin
       TV:=Alg.ExFunc[N].Func[NF].TV[0];
       TM:=Alg.ExFunc[N].Func[NF].TM[0];
      end
      else
      if  CallT = _INTERNAL_INFINITE_ANY then
      begin
       TV:=Node^.TypeF;
       TM:=Alg.ExFunc[N].Func[NF].TM[0];
      end;

       if (TV = T_Real) and (TM = _Double) then Node^.ExtArg:=D_Real else
       if (TV = T_Real) and (TM = _Extended) then Node^.ExtArg:=E_Real else
       if (TV = T_Real) and (TM = _Single) then Node^.ExtArg:=S_Real else
       if (TV = T_Complex) and (TM = _Double) then Node^.ExtArg:=D_Complex else
       if (TV = T_Complex) and (TM = _Extended) then Node^.ExtArg:=E_Complex else
       if (TV = T_Complex) and (TM = _Single) then Node^.ExtArg:=S_Complex else
       if (TV = T_Array) and (TM = _Double) then Node^.ExtArg:=D_Array_Real else
       if (TV = T_Array) and (TM = _Extended) then Node^.ExtArg:=E_Array_Real else
       if (TV = T_Array) and (TM = _Integer)  then Node^.ExtArg:=I_Array_Real else
       if (TV = T_Array) and (TM = _Pointer)  then Node^.ExtArg:=I_Array_Real else
       if (TV = T_Array) and (TM = _Single) then Node^.ExtArg:=S_Array_Real else
       if (TV = T_Real) and (TM = _Integer) then Node^.ExtArg:=I_Real else
       if (TV = T_Pointer) and (TM = _Pointer) then Node^.ExtArg:=I_Pointer;
    end;

    Node:=Node^.Next;
end;

  Node^.ExtArg:=0;     //top of tree: last node

 endp:
end;






