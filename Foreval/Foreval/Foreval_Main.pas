              AddByte2($01,$C0);
              //lea esi,ebx+eax
              AddByte3($8D,$34,$18);  // @VecFloat1[ArgForm1] -> ESI
           end;
           *)
           LoadArrayAddrCell(R_ESI,R_EBX,R_EAX,tm1);   // @VecFloat1[ArgForm1] -> ESI

           //load
           {if tm1 = _Double   then     AddByte2($DD,$06) else    //fld qword ptr [esi]
           if tm1 = _Extended then     AddByte2($DB,$2E);        //fld tbyte ptr [esi]

           if tm2 = _Double   then     AddByte2($DD,$07) else    //fld qword ptr [edi]
           if tm2 = _Extended then     AddByte2($DB,$2F);        //fld tbyte ptr [edi]


           //save
           if tm1 = _Double   then     AddByte2($DD,$1E) else    //fstp qword ptr [esi]
           if tm1 = _Extended then     AddByte2($DB,$3E);        //fstp tbyte ptr [esi]

           if tm2 = _Double   then     AddByte2($DD,$1F) else    //fstp qword ptr [edi]
           if tm2 = _Extended then     AddByte2($DB,$3F);        //fstp tbyte ptr [edi]

           CheckStack(2);
           CheckStack(-2);}

            //load

           FLDREG(R_ESI,tm1);
           FLDREG(R_EDI,tm2);

           FCOMI;
           JMPC(9,tif);

           //save
           FSTPREG(R_ESI,tm1);
           FSTPREG(R_EDI,tm2);

           JMP(4);
           FSTP0;
           FSTP0;

           CheckStack(2); //коррекция на излишние fstp


           SetReg(R_ESI);
           SetReg(R_EDI);
           SetReg(R_EAX);
           SetReg(R_EBX);


     end;


 end  // of swap(FloatArray,FloatArray)
 else
 //SWAPIF(FloatArray[] <=> FloatVar)
 if GNode^.AI = 21 then            //swap(FloatArray,FloatVar)   swap(FloatVar,FloatArray)
 begin
                                                       //FloatArray[] <=> FloatVar
     AddrA1:=Alg.Obj[GNode^.NObj].Addr;
     ArgForm1:=GNode^.TA1;
     tm1:=Alg.Obj[GNode^.NObj].MType;
     Adr2:=Alg.Obj[GNode^.NV2].Addr;
     tm2:=Alg.Obj[GNode^.NV2].MType;
     ts2:=GNode^.TS2;
     if ts2 = _IM then Adr2:=Alg.Obj[NV2].AddrIM;


     if (ArgForm1 = _IntConst) or (ArgForm1 = _IntVar) or (ArgForm1 = _IntForm) then
     begin                                                                     //x=1; vd[k]=10; swapif(vd[k]<x); x
                                                                               //swap(vd2[k],x); x
                                                                               //swap(ve2[2*k+3*j-1],y); y
                                                                               //swap(vd2[k],z1.re); z1.re
                                                                               //swap(ve2[2*k+3*j-1],z1.im); z1.im

           LoadLineFormEAX(_First);     //ArgForm1 -> EAX
           MOVMREG(R_EBX,AddrA1);       //Addr1    -> EBX
           LoadArrayAddrCell(R_EBX,R_EBX,R_EAX,tm1);   // @VecFloat1[ArgForm1] -> EBX
           {
           if tm1 = _Double   then
           begin
               //lea ebx,ebx+8*eax
               AddByte3($8D,$1C,$C3);       // @VecFloat1[ArgForm1] -> EBX
           end
           else
           if tm1 = _Extended   then
           begin
              //lea   eax,[eax+4*eax]
              AddByte3($8D,$04,$80);
              //add   eax,eax
              AddByte2($01,$C0);
              //lea ebx,ebx+eax
              AddByte3($8D,$1C,$18);  // @VecFloat1[ArgForm1] -> EBX
           end;
           }
            //load

            //_FloatArray
           FLDREG(R_EBX,tm1);
           //_FloatVar
           FLD(Adr2,tm2);

           //swap использует один вид: swap(vec[],var) для swap(vec[],var) и swap(var,vec[])
           //поэтому во 2-м случае нужно перевернуть условие сравнения:
           if GNode.DI = _FloatVar then
           begin
             if tif = _JNB  then  tif:=_JBE else
             if tif = _JBE  then  tif:=_JNB;
           end;

           FCOMI;
           JMPC(13,tif);


           //save

            //_FloatArray
           FSTPREG(R_EBX,tm1);
              //_FloatVar
           FSTPM(Adr2,tm2);


           JMP(4);
           FSTP0;
           FSTP0;

           CheckStack(2); //коррекция на излишние fstp

           SetReg(R_ECX);
           SetReg(R_EAX);
           SetReg(R_EBX);
     end
     else
     if  (ArgForm1 = _NOT_FOUND) then      //FloatArray1[Expr1]<->FloatVar2
     begin                                                                   //x=1; vd[k*(k+1)]=10; swapif(vd[k*(k+1)]>x); x
                                                                              //swap(vd2[k*y],x); x
                                                                              //swap(ve2[k*x+3*j-1],y); y
                                                                              //swap(vd2[x],z1.re); z1.re
                                                                              //swap(ve2[2*x+3*j-1],z1.im); z1.im
           LoadArg1;
           (*
           PUSHCW;   {.227}
           FLDCW(TAddress(@FCW1));
           MEM:=WriteDataA(0,_Integer);
           FISTP(MEM);
           POPCW;      {.227}   //FLDCW(TAddress(@FCW2));
           MOVMA(MEM);                 // Expr1->EAX
           *)

           //TRUNCR(R_EAX);            // indx->EAX
           FISTPR(R_EAX); {.387}      // indx->EAX

           MOVMREG(R_EBX,AddrA1);       //Addr1->EBX
           LoadArrayAddrCell(R_EBX,R_EBX,R_EAX,tm1);   // @VecFloat1[ArgForm1] -> EBX
           {
           if tm1 = _Double   then
           begin
               //lea ebx,ebx+8*eax
               AddByte3($8D,$1C,$C3);       // @VecFloat1[ArgForm1] -> EBX
           end
           else
           if tm1 = _Extended   then
           begin
              //lea   eax,[eax+4*eax]
              AddByte3($8D,$04,$80);
              //add   eax,eax
              AddByte2($01,$C0);
              //lea ebx,ebx+eax
              AddByte3($8D,$1C,$18);  // @VecFloat1[ArgForm1] -> EBX
           end;
           }
           //load
            //_FloatArray
            FLDREG(R_EBX,tm1);

            //_FloatVar
           FLD(Adr2,tm2);

            //swap использует один вид: swap(vec[],var) для swap(vec[],var) и swap(var,vec[])
           //поэтому во 2-м случае нужно перевернуть условие сравнения:
           if GNode.DI = _FloatVar then
           begin
             if tif = _JNB  then  tif:=_JBE else
             if tif = _JBE  then  tif:=_JNB;
           end;

           FCOMI;
           JMPC(13,tif);

           //save
           FSTPREG(R_EBX,tm1);
           //_FloatVar
           FSTPM(Adr2,tm2);

           JMP(4);
           FSTP0;
           FSTP0;

           CheckStack(2); //коррекция на излишние fstp


           SetReg(R_ECX);
           SetReg(R_EAX);
           SetReg(R_EBX);

     end;

 end;




end;









procedure TForevalH.FindNumberLevelA(num: Integer; var ANL: TArrayC);
var
j,IdN: Integer;
begin
 {
IdN:=Interp[num].IdN;
for j:=1 to LFunc-1 do
begin
   if IdN = Interp[j].IdL then
   begin
    SetLength(ANL,Length(ANL)+1);
    ANL[High(ANL)]:=j;
   end;
end;
 }
end;






{.213}
procedure TForevalH.JMP_C;
label out1;
                   procedure CorrectStackIF(Node: PNode{N: Integer});
                   begin
                     {.211}
                      //'выталкивание' из стека первого аргумента (перед вторым) в команде IF для корректного определения загрузки стека N_Stack
                      //команда #JMP (AI=1) всегда является аргументом IF
                      if Node^.AI = 1 then
                      begin
                        //по типу предыдущего аргумента
                        if Node^.Prev^.TypeF = T_Real then CheckStack(-1)       //if(x<y), if(x<y,x,y)
                         else
                        if Node^.Prev^.TypeF = T_Complex then CheckStack(-2);   //if(x<y,z1,z2)
                        // else T_None                                          //if(x<y,goto())  if(x<y,goto(),goto())


                          //тоже самое, только через главную команду IF:
                       { if Node^.Pr <> nil then
                        begin
                          if Node^.Pr^.NFunc = CM_IF then
                          begin
                            if Node^.Pr^.TypeF = T_Real then CheckStack(-1) else
                            if Node^.Pr^.TypeF = T_Complex then CheckStack(-2); //else T_None
                          end;
                        end;  }

                        (*
                        //по типу предыдущего аргумента
                        if Interp[N-1].TypeF = T_Real then CheckStack(-1)       //if(x<y), if(x<y,x,y)
                         else
                        if Interp[N-1].TypeF = T_Complex then CheckStack(-2);   //if(x<y,z1,z2)
                        // else T_None


                        {
                        NM:=Interp[N].NM;  //Interp[Interp[N].NM].NFunc = CM_IF !!! всегда
                        if NM > 0 then
                        begin
                          if Interp[NM].NFunc = CM_IF then
