procedure TForevalH.Array1FuncAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var BEF,EOFN: Boolean);
 label endp;
  var
   i,nf,ni: Integer;
   TV,TM: Cardinal;

begin

 if F_SyntaxErrorCode <> 0 then goto endp;


 LV1:=LV;
 ND1:=ND;
 EOFN:=False;
 BEF:=False;
 nf:=ND.NFunc;


     FindVarPS(@LV[0].Expression,ni);


     if ni <> -1 then
     begin

       TV:=Alg.Obj[ni].TypeF;
       TM:=Alg.Obj[ni].MType;
       if TV = T_Array then
       begin

         for i := 0 to High(Alg.ExFunc[nf].Func) do
         begin

           if (Alg.ExFunc[nf].Func[i].NArg = 1) and (Alg.ExFunc[nf].Func[i].TV[0] = T_Array) and (Alg.ExFunc[nf].Func[i].TM[0] = TM) then
           begin
             if (Alg.ExFunc[nf].Func[i].IntF = _Internal) and (Alg.ExFunc[nf].Func[i].TypeF = T_Real)  then    //internal+ return Real {.378}
             begin


                     ND1.N:=0; ND1.COP:=_Func; ND1.NFunc:=nf;  ND1.NF:=i; ND1.NV1:=ni;  SetLength(LV1,0); BEF:=True; EOFN:=True;
                     //ND.AI:=1;
                     goto endp;

               (*
                {.395}    //чтобы можно было переопределить эти ф-ии (SUM,MAX,MIN, PROD,DEV,DEVS,AVR,SUMQ, GCD,LCM ) для других аргументов
                if (nf = CM_SUM) or (nf = CM_MAX) or (nf = CM_MIN) then
                begin
                     ND1.N:=0; ND1.COP:=_Func; ND1.NFunc:=nf;  ND1.NF:=i; ND1.NV1:=ni;  SetLength(LV1,0); BEF:=True; EOFN:=True;
                     //ND.AI:=1;
                     goto endp;
                end
                else
                if (TM <> _Integer) then
                begin
                     ND1.N:=0; ND1.COP:=_Func; ND1.NFunc:=nf;  ND1.NF:=i; ND1.NV1:=ni;  SetLength(LV1,0);   BEF:=True; EOFN:=True;
                     //ND.AI:=1;
                     goto endp;
                end;
               *)


             end;
           end;



         end;
       end;
     end;

  endp:
end;




