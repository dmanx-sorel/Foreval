begin
 Tree:=Tree^.Ch;
end;


2:
if Tree^.Nb = nil then goto 3
else
begin
 Tree:=Tree^.Nb;
 goto 1;
end;

3:
if Tree^.Pr = nil then  goto endp
else
begin
 //для добавл. ф-ий с FType < 0 аргументы не переставлять {XchArg=_Yes}  {.205}
