procedure  TForevalH.MUL_ST(tc,ts: Integer);
{                               //Stack before               //Stack after:
  tc=T_Real; ts=T_Real;         ST(0)*[ST(1)]                -> ST(0);       ST(1)
  tc=T_Real; ts=T_Complex;      ST(0)*[ST(1),ST(2)]          -> ST(0),ST(1); ST(2),ST(3)
  tc=T_Complex; ts=T_Real;      (ST(0),ST(1))*[ST(2)]        -> ST(0),ST(1); ST(2);
  tc=T_Complex; ts=T_Complex;   (ST(0),ST(1))*[ST(2),ST(3)]  -> ST(0),ST(1); ST(2),ST(3);

}
begin

  if (tc = T_Real) and  (ts = T_Real)  then
  begin
     FMUL01;
  end
  else
  if (tc = T_Real) and  (ts = T_Complex)  then
  begin
     FLD0;
     FMUL03;
     FXCH1;
     FMUL02;
  end
  else
  if (tc = T_Complex) and  (ts = T_Real)  then
  begin
     FMUL02;
     FXCH1;
     FMUL02;
     FXCH1;
  end
  else
  if (tc = T_Complex) and  (ts = T_Complex)  then
  begin
     ZMUL;
  end;

end;


procedure  TForevalH.MULP_ST(tc,ts: Integer);
{                               //Stack before               //Stack after:
  tc=T_Real; ts=T_Real;         ST(0)*ST(1)                  -> ST(0);
  tc=T_Real; ts=T_Complex;      ST(0)*(ST(1),ST(2))          -> ST(0),ST(1);
  tc=T_Complex; ts=T_Real;      (ST(0),ST(1))*ST(2)          -> ST(0),ST(1);
  tc=T_Complex; ts=T_Complex;   (ST(0),ST(1))*(ST(2),ST(3))  -> ST(0),ST(1);

}
begin

  if (tc = T_Real) and  (ts = T_Real)  then
  begin
    FMULP;
  end
  else
  if (tc = T_Real) and  (ts = T_Complex)  then
  begin
    FMUL20;
    FMULP;
  end
  else
  if (tc = T_Complex) and  (ts = T_Real)  then
  begin
    FMUL02;
    FXCH1;
    FMULP2;
  end
  else
  if (tc = T_Complex) and  (ts = T_Complex)  then
  begin
    ZMULP;
  end;

end;

procedure  TForevalH.ADDP_ST(tc,ts: Integer);
{                               //Stack before               //Stack after:
  tc=T_Real; ts=T_Real;         ST(0)+ST(1)                  -> ST(0);
  tc=T_Real; ts=T_Complex;      ST(0)+(ST(1),ST(2))          -> ST(0),ST(1);
  tc=T_Complex; ts=T_Real;      (ST(0),ST(1))+ST(2)          -> ST(0),ST(1);
  tc=T_Complex; ts=T_Complex;   (ST(0),ST(1))+(ST(2),ST(3))  -> ST(0),ST(1);

}
begin

  if (tc = T_Real) and  (ts = T_Real)  then
  begin
    FADDP;
  end
  else
  if (tc = T_Real) and  (ts = T_Complex)  then
  begin
    FADDP;
  end
  else
  if (tc = T_Complex) and  (ts = T_Real)  then
  begin
    FADDP2;
    FXCH1;
  end
  else
  if (tc = T_Complex) and  (ts = T_Complex)  then
  begin
    FADDP2;
    FADDP2;
  end;

end;



