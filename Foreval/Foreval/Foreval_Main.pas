       begin
           S:='(-laguerrep('+S1+'-1,'+S2+'+1,'+S3+'))*('+SD3+')';
       end;
       *)

     end

     else

     if SFunc = 'polygamma' then    {.344}
     begin
        // d/dx polygamma(n,F(x)) -> polygamma(n+1,F(x))*d/dx(F(x))

        S1:=HTree^.Expression;
        S2:=HTree^.Nb^.Expression;
        SD1:=HTree^.SDiff;
        SD2:=HTree^.Nb^.SDiff;
        if SD2 = '0'  then S:='0' else
        if SD1 <> '0' then goto   extf    //{.356} polygamma(F1(x),F2(x)) Must be error! so that polygamma(const, var)
        else
        begin

           S1P:=S1;
           FindAddSubNumInArgPS(@S1P,fx,answ);
           if answ = _none then
           begin
               S:='polygamma('+S1+'+1,'+S2+')*('+SD2+')';
           end
           else
           if answ = _const then
           begin
               S:='polygamma('+FloatToStr(Trunc(fx+1))+','+S2+')*('+SD2+')';
           end
           else
           if answ = _num then
           begin
              AddNumToStrPS(@S1P,Trunc(fx+1),S1A);
              S:='polygamma('+S1A+','+S2+')*('+SD2+')';
           end;

        end;
     end

     else

     if (SFunc = 'gammaincl') or (SFunc = 'gammaincu') then    {.356}
     begin

        {
        d/dx gammaincl(a,F(x))= exp(-F(x))*power(F(x),a-1)*d/dx(F(x))
        d/dx gammaincu(a,F(x))= -exp(-F(x))*power(F(x),a-1)*d/dx(F(x))
        }

        S1:=HTree^.Expression;
        S2:=HTree^.Nb^.Expression;
        SD1:=HTree^.SDiff;
        SD2:=HTree^.Nb^.SDiff;

        if SD2 = '0'  then S:='0' else
        if SD1 <> '0' then goto   extf    //{.356} gammaincu(F1(x),F2(x))   gammaincl(F1(x),F2(x))
        else
        begin

          if SFunc = 'gammaincu' then
            S:='-exp(-('+S2+'))*power('+S2+','+S1+'-1)*'+SD2
          else
          if SFunc = 'gammaincl' then
            S:='exp(-('+S2+'))*power('+S2+','+S1+'-1)*'+SD2

        end;

     end

     else

     if (SFunc = 'gammaincln') or (SFunc = 'gammaincun') then    {.356}
     begin

        {
        d/dx gammaincln(a,F(x))= exp(-F(x))*power(F(x),a-1)/gamma(a)*d/dx(F(x))
        d/dx gammaincun(a,F(x))= -exp(-F(x))*power(F(x),a-1)/gamma(a)*d/dx(F(x))
        }

        S1:=HTree^.Expression;
        S2:=HTree^.Nb^.Expression;
        SD1:=HTree^.SDiff;
        SD2:=HTree^.Nb^.SDiff;

        if SD2 = '0'  then S:='0' else
        if SD1 <> '0' then goto   extf    //{.356} gammaincun(F1(x),F2(x))   gammaincln(F1(x),F2(x))
        else
        begin

          if SFunc = 'gammaincun' then
            S:='-exp(-('+S2+'))*power('+S2+','+S1+'-1)/gamma('+S1+')*'+SD2
          else
          if SFunc = 'gammaincln' then
            S:='exp(-('+S2+'))*power('+S2+','+S1+'-1)/gamma('+S1+')*'+SD2

        end;

     end

     else

     if (SFunc = 'gammaincinvln') or (SFunc = 'gammaincinvun') then    {.356}
     begin
        //d/dx gammainv(a,F(x))=Gamma(a)*(exp(gammainv(a,F(x))))*power(gammainv(a,F(x)),1-a)*dF(x)/dx

        {
        d/dx gammaincinvun(a,F(x))= -Gamma(a)*(exp(gammaincinvun(a,F(x))))*power(gammaincinvun(a,F(x)),1-a)*dF(x)/dx
        d/dx gammaincinvln(a,F(x))= Gamma(a)*(exp(gammaincinvln(a,F(x))))*power(gammaincinvln(a,F(x)),1-a)*dF(x)/dx
        }


        S1:=HTree^.Expression;
        S2:=HTree^.Nb^.Expression;
        SD1:=HTree^.SDiff;
        SD2:=HTree^.Nb^.SDiff;

        if SD2 = '0'  then S:='0' else
        if SD1 <> '0' then goto   extf    //{.356} gammaincinvln(F1(x),F2(x))   gammaincinvun(F1(x),F2(x))
        else
        begin

          if SFunc = 'gammaincinvun' then
            S:='-exp('+DiffFunc+')*power('+DiffFunc+',1-'+S1+')*gamma('+S1+')*'+SD2
          else
          if SFunc = 'gammaincinvln' then
            S:='exp('+DiffFunc+')*power('+DiffFunc+',1-'+S1+')*gamma('+S1+')*'+SD2

        end;

     end

     else


     if SFunc = 'polynom' then             //poly(vd,x); poly(vd,sin(x)/x)
     begin
        {
        S1:=HTree^.Expression;
        S2:=HTree^.Nb^.Expression;
        if S2 <> DiffVar then goto extf;   //poly(vd,y); poly(vd,f(x))
        S:='polynomdiff('+S1+','+S2+','+'1)'
        }
         {.213}
          {
           S1:=HTree^.Expression;
           S2:=HTree^.Nb^.Expression;
           SD2:=HTree^.Nb^.SDiff;
           //if S2 <> DiffVar then goto extf;   //poly(vd,y); poly(vd,f(x))
           if SD2 = '0' then S:='0' else
           begin
             if SD2 = '1' then
               S:='polynomdiff('+S1+','+S2+','+'1)'
             else
               S:='polynomdiff('+S1+','+S2+','+'1)*('+SD2+')';
           end;
         }
         {.223}
          S1:=HTree^.Expression;
          S2:=HTree^.Nb^.Expression;
          bl1:=IsArray(S1);
          bl2:=IsArray(S2);

          if (NArg = 2) and ((bl1=true) or (bl2 = true)) then
          begin
             if bl1 = true then
             begin
                SD2:=HTree^.Nb^.SDiff;
                //if S2 <> DiffVar then goto extf;   //poly(vd,x); poly(vd,f(x))
                if SD2 = '0' then S:='0' else
                begin
                  if SD2 = '1' then
                    S:='polynomdiff('+S1+','+S2+','+'1)'
                  else
                    S:='polynomdiff('+S1+','+S2+','+'1)*('+SD2+')';
                end;
             end
             else           //poly(x,vd); poly(f(x),vd)
             begin
                SD2:=HTree^.SDiff;
                //if S2 <> DiffVar then goto extf;   //poly(vd,x); poly(vd,f(x))
                if SD2 = '0' then S:='0' else
                begin
                  if SD2 = '1' then
                    S:='polynomdiff('+S2+','+S1+','+'1)'
                  else
                    S:='polynomdiff('+S2+','+S1+','+'1)*('+SD2+')';
                end;
             end;

          end
          else     //poly(1,2,3,4,5,6,7,x)     poly(x,1,2,3,4,5,6,7)  poly(1,2,3,4,5,6,7,f(x))  poly(f(x),1,2,3,4,5,6,7)
          begin
            if (NArg = 2) then S:='0' else
            begin
              PolyDiff(HTree,S);
            end;
          end;


     end
     else
      if SFunc = 'polynomdiff' then               //poly(vd,-sin(x)/x)/poly(ad,cos(x)/x)
     begin
        {
        S1:=HTree^.Expression;
        S2:=HTree^.Nb^.Expression;
        S3:=HTree^.Nb^.Nb^.Expression;
        if S2 <> DiffVar then goto extf;
        S3:=IntToStr(StrToInt(S3)+1);
        S:='polynomdiff('+S1+','+S2+','+S3+')';
        }
        {.213}
        S1:=HTree^.Expression;
        S2:=HTree^.Nb^.Expression;
        S3:=HTree^.Nb^.Nb^.Expression;
        SD2:=HTree^.Nb^.SDiff;
        //if S2 <> DiffVar then goto extf;
        if SD2 = '0' then S:='0' else
        begin
          S3:=IntToStr(StrToInt(S3)+1);
          if SD2 = '1' then
           S:='polynomdiff('+S1+','+S2+','+S3+')'
           else
           S:='polynomdiff('+S1+','+S2+','+S3+')*('+SD2+')';
        end;
     end
     else
     if {SFunc = 'root'}NFunc = CM_ROOT then
     begin
       S1:=HTree^.Expression;
       S2:=HTree^.Nb^.Expression;
       SD1:=HTree^.SDiff;
       SD2:=HTree^.Nb^.SDiff;
       FindExternalBracketNegPS(@SD2);

       if (SD2 = '0') and (SD1 = '0') then
       begin
        S:='0';
       end
       else
       if SD2 = '0' then     //root(func,number)
       begin
        //S:='('+S1+')^(1/('+S2+')-1)'+'*('+SD1+')/('+S2+')'

          FindExternalBracketNegPS(@S2);
          blx:=false;

          IsNumPS(@S2,fx,blx);
          {.203}
           (*
          if TryStrToFloat(S2,fx,G_FMT) = true then
          begin
            //fx:=StrToFloat(Sx,G_FMT);
            if ng = 1 then fx:=-fx;
          end
          else
          blx:=true;
          *)

          if blx = false then      //root(func,argi)
          begin
            //S:='('+SD1+')*'+'root(power('+S1+',1-('+S2+')),'+S2+')'+'/('+S2+')';
            //S:='('+SD1+')/(('+S2+')*root(power('+S1+','+S2+'-1),'+S2+'))';
            S:='('+SD1+')/(('+S1+')*('+S2+'))*root('+S1+','+S2+')';            {.209}
          end
          else                    //root(func,num)
          begin
            Sx:=FloatToStr(fx,G_FMT);
            //Sx:=FloatToStrF(fx, ffExponent, 20, 4, G_FMT);
            Sx1:=FloatToStr(fx-1,G_FMT);
            //Sx1:=FloatToStrF(fx-1, ffExponent, 20, 4, G_FMT);
            if fx-1 = 1 then   S:='('+SD1+')/(('+Sx+')*root('+S1+','+Sx+'))'
            else
            //S:='('+SD1+')/(('+Sx+')*root(power('+S1+','+Sx1+'),'+Sx+'))';
            S:='('+SD1+')/(('+S1+')*('+Sx+'))*root('+S1+','+Sx+')';            {.209}


            {Sx1:=FloatToStr(1-fx,G_FMT);
            S:='('+SD1+')*root(power('+S1+','+Sx1+'),'+Sx+')/('+Sx+')'; }
          end;

       end
       else
       if SD1 = '0' then
       begin
         //S:='-(('+S1+')^(1/('+S2+'))*('+SD2+')*'+'ln('+S1+')/sqr('+S2+'))'
         S:='-root('+S1+','+S2+')*('+SD2+')*'+'ln('+S1+')/sqr('+S2+')' ;
       end
       else  //(root(S1,S2)*SD1)/(S1*S2)-root(S1,S2)*SD2*ln(S1)/sqr(S2)
       //S:='('+S1+')^(1/('+S2+')-1)'+'*('+SD1+')/('+S2+')-('+S1+')^(1/('+S2+'))*('+SD2+')*'+'ln('+S1+')/sqr('+S2+')';
       //S:='root(power('+S1+',1-('+S2+')),'+S2+')*('+SD1+')/('+S2+')-root('+S1+','+S2+')*('+SD2+')*ln('+S1+')/sqr('+S2+')';
       S:='(root('+S1+','+S2+'))*(('+SD1+')*('+S2+')-('+S1+')*('+SD2+')*ln('+S1+'))/(('+S1+')*sqr('+S2+'))';  {.209}

       //S:=.....
     end  //sin(x)^((1-cos(x))/cos(x))-root(sin(x),cos(x))/sin(x)
          //root(sin(x),(1-cos(x))/cos(x))-power(sin(x),cos(x)/(1-cos(x)))

     else

     if (NFunc = CM_SUM) or (NFunc = CM_AVR) {or (NFunc = CM_MAX) or  (NFunc = CM_MIN)} then
     begin                                   // max и min закрыты т.к.  d/dx max (F1,F2,F3,...Fn) <> max(d/dx F1, d/dx F2, d/dx F3,...,d/dx Fn)
                                             // пример: max(cos(2*x),sin(x)) . Сравнение с численным дифференцированием
                                             // перенесено отдельно ниже,  через "if"
        if Tree^.Stack.N <= 1  then
        begin
          SD:=SD1;
        end
        else
        begin
         H1Tree:=HTree;
         SD:=H1Tree^.SDiff;
         H1Tree:=H1Tree^.Nb;
         while H1Tree <> nil do
         begin
          SD:=SD+','+H1Tree^.SDiff;
          H1Tree:=H1Tree^.Nb;
         end;
        end;


         S:=SFunc+'('+SD+')';
     end

     else

     if (NFunc = CM_MAX) or (NFunc = CM_MIN)  then              {.395}
     begin

        if Tree^.Stack.N <= 1  then
        begin
          S:=SD1;
        end
        else
        if Tree^.Stack.N = 2  then
        begin

          S1:=HTree^.Expression;
          S2:=HTree^.Nb^.Expression;

          SD1:=HTree^.SDiff;
          SD2:=HTree^.Nb^.SDiff;
          //SD:=SD1+','+SD2;


          if (NFunc = CM_MAX) then  Sc:='>'
          else
          if (NFunc = CM_MIN) then  Sc:='<';


          S:='if('+S1+Sc+S2+','+SD1+','+SD2+')'

        end
        else
        if Tree^.Stack.N = 3  then
        begin
            S1:=HTree^.Expression;
            S2:=HTree^.Nb^.Expression;
            S3:=HTree^.Nb^.Nb^.Expression;

            SD1:=HTree^.SDiff;
            SD2:=HTree^.Nb^.SDiff;
            SD3:=HTree^.Nb^.Nb^.SDiff;

            if (NFunc = CM_MAX) then  Sc:='>'
            else
            if (NFunc = CM_MIN) then  Sc:='<';


            S:='if('+S1+Sc+S2+','+'if('+S1+Sc+S3+','+SD1+','+SD3+')'+','+'if('+S2+Sc+S3+','+SD2+','+SD3+'))';
            //  if(x1 > x2, if(x1 > x3, dx1,dx3) ,if(x2 > x3 ,dx2,dx3))

        end
        else
        if Tree^.Stack.N = 4  then
        begin
            S1:=HTree^.Expression;
            S2:=HTree^.Nb^.Expression;
            S3:=HTree^.Nb^.Nb^.Expression;
            S4:=HTree^.Nb^.Nb^.Nb^.Expression;

            SD1:=HTree^.SDiff;
            SD2:=HTree^.Nb^.SDiff;
            SD3:=HTree^.Nb^.Nb^.SDiff;
            SD4:=HTree^.Nb^.Nb^.Nb^.SDiff;

            if (NFunc = CM_MAX) then  Sc:='>'
            else
            if (NFunc = CM_MIN) then  Sc:='<';


            S:='if('+S1+Sc+S2+','+'if('+S1+Sc+S3+',if('+S1+Sc+S4+','+SD1+','+SD4+'),if('+S3+Sc+S4+','+SD3+','+SD4+')),if('+S2+Sc+S3+',if('+S2+Sc+S4+','+SD2+','+SD4+'),if('+S3+Sc+S4+','+SD3+','+SD4+')))';
            // if(x1 > x2, if(x1 > x3, if(x1 > x4, dx1,dx4),if(x3 > x4, dx3,dx4)), if(x2 > x3, if(x2 > x4, dx2,dx4), if(x3 > x4, dx3, dx4)))

        end

     end

     else

     if (NFunc = CM_NORM)  then              {.395}
     begin
            if Tree^.Stack.N <= 1  then
            begin
                //S:='2*('+S1+')*'+SD1+'/('+DiffFunc+')';          //DiffFunc
                S:=SD1;
            end
            else
            if Tree^.Stack.N = 2  then
            begin

               S1:=HTree^.Expression;
               S2:=HTree^.Nb^.Expression;

               SD1:=HTree^.SDiff;
               SD2:=HTree^.Nb^.SDiff;

               S:='('+S1+'*('+SD1+')+('+S2+')*('+SD2+'))/('+DiffFunc+')';

            end
            else
            if Tree^.Stack.N = 3  then
            begin

               S1:=HTree^.Expression;
               S2:=HTree^.Nb^.Expression;
               S3:=HTree^.Nb^.Nb^.Expression;


               SD1:=HTree^.SDiff;
               SD2:=HTree^.Nb^.SDiff;
               SD3:=HTree^.Nb^.Nb^.SDiff;


               S:='('+S1+'*('+SD1+')+('+S2+')*('+SD2+')+('+S3+')*('+SD3+'))/('+DiffFunc+')';

            end
            else
            if Tree^.Stack.N = 4  then
            begin

               S1:=HTree^.Expression;
               S2:=HTree^.Nb^.Expression;
               S3:=HTree^.Nb^.Nb^.Expression;
               S4:=HTree^.Nb^.Nb^.Nb^.Expression;

               SD1:=HTree^.SDiff;
               SD2:=HTree^.Nb^.SDiff;
               SD3:=HTree^.Nb^.Nb^.SDiff;
               SD4:=HTree^.Nb^.Nb^.Nb^.SDiff;

                S:='('+S1+'*('+SD1+')+('+S2+')*('+SD2+')+('+S3+')*('+SD3+')+('+S4+')*('+SD4+'))/('+DiffFunc+')';
            end;

     end

     else

     if {SFunc = 'if'}NFunc = CM_IF then                 //ifnop->if {.243}
     begin
      case Tree^.tif of
       7: Sc:='=';
       6: Sc:='>=';
       5: Sc:='=<';
       4: Sc:='<';
       3: Sc:='>';
       2: Sc:='<>';
      end;

       if Tree^.cif = 0 then  S:='0' else
       if Tree^.cif = 1 then
       begin
         S1:=HTree^.Expression;
         S2:=HTree^.Nb^.Expression;
         SD1:=HTree^.Nb^.Nb^.Nb^.SDiff;
         S:='if('+S1+Sc+S2+','+SD1+')';
       end
       else
       if Tree^.cif = 2 then
       begin
         S1:=HTree^.Expression;
         S2:=HTree^.Nb^.Expression;
         SD1:=HTree^.Nb^.Nb^.Nb^.SDiff;
         SD2:=HTree^.Nb^.Nb^.Nb^.Nb^.Nb^.SDiff;
         S:='if('+S1+Sc+S2+','+SD1+','+SD2+')';
       end;
     end
     else
     {if SFunc = '@@external' then  goto extfwd
     else }
     begin

     extf:       //external functions:

         //if all derivatives of arguments = 0, then derivative of function = 0:
         {.211}
         if CheckForZeroNode(HTree) = True then
         begin
           S:='0';
           goto endf;
         end;

         {.211}
         //with diff template:
         //ограничение версии 9.0-9.1.1+; шаблон дифференцирования задаётся ОДИН на все overload ф-ии и прописывается в первую ф-ию:  {.327}
         if  Alg.ExFunc[NFunc].Func[0].DFTmpl = _YES {Alg.ExFunc[NFunc].Func[NF].DFTmpl = _YES} then
         begin
          //NArg:=Tree^.Stack.N;
          ReplaceDiffTeplate(Tree,S);
          goto endf;
         end;
         {
         if  Alg.ExFunc[Tree^.NFunc].DFTmpl = _YES then
         begin
          //NArg:=Tree^.Stack.N;
          ReplaceDiffTeplate(Tree,S);
          goto endf;
         end;
         }


        //with derivatives as external func(x):
       {
        SE:=Tree^.Expression;
        FindExternalBracket(SE,SE);
        }
        Sexpr:=Tree^.Expression;
        DelExternalBracketAP(@Sexpr);

        ExtDiffFunc(SExpr,SXD,Bl);     //find derivatives

        if Bl = true  then
        begin

          FindExternalBracketNeg(SD1,SD1b,ngd1);

          if SD1b = '0'  then  S:='0' else
           if (SD1b = '1') and (ngd1 = 0) then S:=SXD+'('+HTree^.Expression+')'
            else
             if (SD1b = '1') and (ngd1 = 1) then S:='(-('+SXD+'('+HTree^.Expression+')))'
              else S:=SXD+'('+HTree^.Expression+')*('+SD1+')';


        end
        else


        begin  //without derivatives. All other  functions with unknown names: (numiric diff. only on one var.)
         extfwd:  //@@external:

           {
           SE1:=Copy(SE,1,5);
           if SE1 = '@diff' then
           begin
             S:=HTree^.Expression;
             nn:=StrToInt(HTree^.Nb^.Expression);
             inc(nn);
             S:='@diff('+S+','+IntToStr(nn)+','+DiffVar+')';
           end
           else
           S:='@diff('+Tree^.Expression+',1,'+DiffVar+')';
           }

           {.215}      //make possible numeric diff.of many var.
          { Sexpr:=Tree^.Expression;
           DelExternalBracketAP(@Sexpr);
           SE1:=Copy(Sexpr,1,5);
            }

            {.345}
           (*
           SE1:=Copy(Sexpr,1,5);
           if SE1 = '@diff' then
           begin
             S1:=HTree^.Expression;
             S2:=HTree^.Nb^.Expression;
             S3:=HTree^.Nb^.Nb^.Expression;
             nn:=StrToInt(HTree^.Nb^.Expression);
             inc(nn);
             if S3 = DiffVar then S:='@diff('+S1+','+IntToStr(nn)+','+DiffVar+')'
             else
             begin
                S:='@diff('+Sexpr{Tree^.Expression}+',1,'+DiffVar+')';
             end;
           end
           else
           S:='@diff('+Sexpr{Tree^.Expression}+',1,'+DiffVar+')';
           *)

           //***
           {.347}
           Len:=Length(DiffNumFunc);
           SE1:=Copy(Sexpr,1,Len+1);    // #diff(
           if SE1 = DiffNumFunc+'(' then
           begin
             S1:=HTree^.Expression;
             S2:=HTree^.Nb^.Expression;
             S3:=HTree^.Nb^.Nb^.Expression;
             nn:=StrToInt(HTree^.Nb^.Expression);
             inc(nn);
             if S3 = DiffVar then S:=DiffNumFunc+'('+S1+','+IntToStr(nn)+','+DiffVar+')'
             else
             begin
                S:=DiffNumFunc+'('+Sexpr+',1,'+DiffVar+')';
             end;
           end
           else
           S:=DiffNumFunc+'('+Sexpr+',1,'+DiffVar+')';



        end;

        F_ExtFuncD:=True;


      end;



   end;
 end;



endf:

   HTree:=HTree^.Nb;
   while HTree <> nil do
   begin
    HTree:=HTree^.Nb;
   end;





 //Tree^.SDiff:=S;


 //NC:=Tree^.NCOP;

 //if NC = 5 then S:='-('+S+')';  {.301} //off
 //S:='('+S+')';

 //DelExternalBracketAP(@S);     {.301}

 Tree^.SDiff:=S;


 //освобождает память,занимаемую вытекающими узлами (более не нужными)для уменьшения захвата памяти
 FreeChld(Prnt);


end;


S:=Tree^.SDiff;
S_DiffString:=S;


endp:
end;






procedure TForevalH.DiffExpressionN(Expr: String; N: Integer; var SDiff: String);
label endp;
var
NS: Cardinal;
S,SD: String;
i: integer;
begin

S:=Expr;

PrevTreat(S,S);

if F_SyntaxErrorCode = 0 then
begin

  for i := 0 to N-1 do
  begin
   if F_SyntaxErrorCode = 0 then
   begin
    if F_DiffType = _Symbolic then
       DiffExtExpression(S,S)
    else
       DiffExtWholeNumeric(S,S); // F_DiffType = _Numeric
   end
   else goto endp;
  end;

end;


SDiff:=S;
endp:
end;


