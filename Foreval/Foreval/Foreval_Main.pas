procedure TForevalH.LinkDataNode(Node: PNode);
{
 Поиск и связывание найденных команд (при синтаксическом разборе) с типом их  аргументов:
 Определение возвращаемого типа команд - .TypeF
 Отлов синтаксических ошибок, вызванных неверным типом аргумента.
}

label endp;
var
fa,i,L,j,N,N1: Cardinal;
S,Sa: String;
nf,TypeF,TypeA,NF1: Integer;
ANL: TArrayC;
NCHLD: TArrayPN ;
begin
if F_SyntaxErrorCode <> 0 then goto endp;
//goto endp;

S:=Node^.Expression;
Sa:=Node^.ExpressionArg;
//Interp[LFunc].Expression:=Node^.Expression;   //for syntax error

if Node^.COP = _LDSC then
begin
 Node^.TypeF:=T_Real;
end
else
if Node^.COP = _LDSCX then
begin
 if Node^.TC = C_Real then Node^.TypeF:=T_Real else Node^.TypeF:=T_Complex;
end
else
if Node^.COP = _LDSF then
begin
  if Node^.TS <> 0 then  Node^.TypeF:=T_Real else  Node^.TypeF:=Alg.Obj[Node^.NObj].TypeF;
  Node^.TypeM:=Alg.Obj[Node^.NObj].MType;  {.353}
end
else
if Node^.COP = _FLD then
begin
 Node^.TypeF:=T_Real;
end
else
if Node^.COP = _LDINTFORM then
begin
  Node^.TypeF:=T_Real;
end
else
if (Node^.COP = _FUNC) or (Node^.COP = _COP) then
begin
  N:=Node^.Stack.N;
 //определение возвращаемого типа комманды:
 if (F_SaveInFPU = True) and (Node^.COP = _COP) then
 begin
   if (N = 0) or (N = 1) then        //в случае оптимизации арифметических комманд  (N - число аргументов)
   begin
     FindCallFunctionA(Node,TypeF,nf,TypeA);

     Node^.TypeF:=TypeF;
     Node^.TypeM:=_Extended;   {внутренние арифм. ф-ии всегда возвращают float var}
     Node^.TypeA:=TypeA;
   end
   else
   begin      //S1 op S2
     FindCallFunction(Node,nf);
     if nf >=0 then    {.197}
     begin
       Node^.TypeF:=Alg.ExFunc[Node^.NFunc].Func[nf].TypeF;
       Node^.TypeM:=Alg.ExFunc[Node^.NFunc].Func[nf].TypeM;
       Node^.TypeA:=0;
     end;
   end;

 end
 else
 if (F_SaveInFPU = False) and (Node^.COP = _COP)   then
 begin
   FindCallFunction(Node,nf);


   Node^.TypeF:=Alg.ExFunc[Node^.NFunc].Func[nf].TypeF;
   Node^.TypeM:=Alg.ExFunc[Node^.NFunc].Func[nf].TypeM;
   Node^.TypeA:=0;
 end
 else
 if (Node^.COP = _FUNC) and (N >= 1)   then
 begin
   FindCallFunction(Node,nf);
   if nf >=0 then    {.197}
   begin
     Node^.TypeF:=Alg.ExFunc[Node^.NFunc].Func[nf].TypeF;
     Node^.TypeM:=Alg.ExFunc[Node^.NFunc].Func[nf].TypeM;
     Node^.TypeA:=0;
   end;

   //для 'nop' тип результата = типу последнего аргумента
        //if Alg.ExFunc[Node^.NFunc].Name = 'nop'     then Interp[LFunc].TypeF:=Interp[LFunc].ArgTypes[high(Interp[LFunc].ArgTypes)];
   //if Node^.NFunc = CM_NOP     then Interp[LFunc].TypeF:=Interp[LFunc].ArgTypes[high(Interp[LFunc].ArgTypes)];    {.197}
   if Node^.NFunc = CM_NOP     then Node^.TypeF:=Node^.ArgTypes[high(Node^.ArgTypes)];
   if Node^.NFunc = CM_PROG    then Node^.TypeF:=Node^.ArgTypes[high(Node^.ArgTypes)];    {.316}
   //if Node^.NFunc = CM_POLYU   then Node^.TypeF:=GetReturnedFuncType(Node); {.347}
 end
 else
 if (Node^.COP = _FUNC) and (N = 0)   then
 {аргумент ф-ии (nf) определён на стадии разбора: func(v) (v-заданная переменная/переменные)
                                      либо ф-ия без аргументов типа _STACK_INFINITE  }
 { Если у ф-ии нет аргумента или он не прописан в   Alg.ExFunc, то её возвращаемый тип определяется на стадии разбора и передаётся через ND.TypeF}
 begin    // fint1()    ad[n]

   nf:=Node^.NF;
      { FindCallFunction(Node,nf);
       if nf = -1 then nf:=Node^.NF;  }


   Node^.TypeF:=Alg.ExFunc[Node^.NFunc].Func[nf].TypeF;
   Node^.TypeM:=Alg.ExFunc[Node^.NFunc].Func[nf].TypeM;

   //для 'nop' без аргументов  тип результата = T_None
   if Node^.NFunc = CM_NOP then Node^.TypeF:=T_None;    {.197}
   if Node^.NFunc = CM_PROG then Node^.TypeF:=T_None; {.316}

 end;


 if nf = _NOT_FOUND then
 begin {Error: нет ф-ии}
   TranslErrMsg(Node);
 end;


 Node^.COP:=_FUNC;
 Node^.Arg:=Node^.Stack.N;
 Node^.NF:=nf;


 //if in current expression present function similar 'rand' - disable calc const

 N1:=Node^.NFunc;
 NF1:=Node^.NF;
 if Alg.ExFunc[N1].Func[NF1].CalcConst = _NO then  F_EnableCalcConstExpression:=False;

end;





//{.347}

//x+proc1(...)
{
if (Node^.TypeF = T_None) then
begin
  if Node^.Pr <> nil then
  begin
    if (Node^.NFunc = CM_JMP) and (Node^.Pr^.NFunc = CM_IF) then
    begin

    end
    else
    if Node^.Pr^.NFunc <> CM_PROG then
    begin
      F_SyntaxErrorCode:=E_NO_FUNCTION;
      F_SyntaxErrorString:=Node^.Expression;
    end;
  end;
end;
}


//if Node^.NFunc = CM_PROG then Node^.COP:=_NOP;{.316}

{
 GetReturnedFuncType - определение возвращаемого типа для остальных, нестандартных команд
 нестандартные  те, у которых тип результата зависит от внутренних постоянных аргументов,
 тип которых определяется в ходе разбора,т.е.
 func(const, var) -> func(var), тип которой зависит от const и var
}
if Node^.NFunc = CM_POLYU    then Node^.TypeF:=GetReturnedFuncType(Node); {.347}
if Node^.NFunc = CM_POLY     then Node^.TypeF:=GetReturnedFuncType(Node); {.347}
if Node^.NFunc = CM_CZPWR    then Node^.TypeF:=GetReturnedFuncType(Node); {.361}
if Node^.NFunc = CM_CRZLOG   then Node^.TypeF:=GetReturnedFuncType(Node); {.377}
if Node^.NFunc = CM_CR2ZLOG  then Node^.TypeF:=GetReturnedFuncType(Node); {.377}
if Node^.NFunc = CM_IPWRSGN  then Node^.TypeF:=GetReturnedFuncType(Node); {.361}
if Node^.NFunc = CM_CRZIROOT then Node^.TypeF:=GetReturnedFuncType(Node); {.395}


Node^.S:=Node^.Stack.S-1;  //начинается с '0'
Node^.N:=Node^.Stack.N;
Node^.CS:=0;
Node^.RRF:=rf_NO_REPLACE;
Node^.WRF:=rf_NO_REPLACE;
Node^.NRF:=0;
Node^.MRF:=-1;
Node^.WRF_CS:=rf_NO_REPLACE; {.217}
Node^.MRF_CS:=-1; {.217}




{
N:=Length(Interp[LFunc].RData);
if N < 2 then N:=2;
//инициализация RData: чтобы не возникала ошибка Access Violation при чтении RData в коммандах с числом арг. < 2
SetLength(Interp[LFunc].RData,N);
Interp[LFunc].RData[0]:=_FPU;  Interp[LFunc].RData[1]:=_FPU;
}

//To Tree
(*
if Length(Node^.RData) <> 0 then
begin
 SetLength(Interp[LFunc].RData,Length(Node^.RData));
 for i:=0 to High(Node^.RData) do
 begin
  Interp[LFunc].RData[i]:=Node^.RData[i];
 end;
end;
*)

N:=Length(Node^.RData);
if N < 2 then
begin
 N:=2;
 //инициализация RData: чтобы не возникала ошибка Access Violation при чтении RData в коммандах с числом арг. < 2
 SetLength(Node^.RData,N);
 Node^.RData[0]:=_FPU;  Node^.RData[1]:=_FPU;
end;

// Проверка стека FPU после выполнения команды , являющейся аргументом в PROG
// Стек FPU перед ними и после должен быть пуст, за исключением последней команды,
if Node^.NFunc = CM_PROG    then  IsInvalidFPULoad(Node);      {.387}



endp:

end;



procedure TForevalH.FindCallFunction(Node:PNode; var nf: Integer);
label 1,2,3,endp;
var
Fnc: TIntFuncA;
i,N,T,j,S: Integer;
//ANL: TArrayC;
NCHLD: TArrayPN;
//HTree: PNode;
begin
nf:=-1;
N:=Node^.Stack.N;
S:=Node^.Stack.S;
Fnc:=Alg.ExFunc[Node^.NFunc].Func;


//FindNumberLevel(ANL);  //число аргументов
GetAllChilds(Node,NCHLD);
//HTree:=Tree;

//вначале искать среди внутренних
for i:=0 to High(Fnc) do
begin
  if Fnc[i].ExeF = _YES then   //если все правильно, должно работать и без этого
  begin

    if N = Fnc[i].NArg then //проверить совпадение типов:
    begin

     for j:=0 to N-1 do
     begin
      //if Interp[ANL[j]].TypeF <> Fnc[i].TV[j] then goto 1;

         {.353}
         if (NCHLD[j]^.TypeF = T_Pointer) and  (Fnc[i].TV[j] = T_Real) and (Fnc[i].TM[j] = _Integer) then
         begin
            if F_EnableUseIntegerPointer = False then  goto 1;   //разрешать передавать в  Integer аргументы - тип Pointer
         end
         else
         if (NCHLD[j]^.TypeF = T_Real) and  (Fnc[i].TV[j] = T_Pointer) and (Fnc[i].TM[j] = _Pointer) then
         begin
            //если тип текущего аргумента  внешний ф-ии - Pointer, а текущий аргумент имеет форму IntForm, то разрешать передавать
            if NCHLD[j]^.COP = _LDINTFORM then begin end    {.367}
            else
            //разрешать передавать в  Pointer аргументы - тип T_Real (Integer)
            if F_EnableUseIntegerPointer = False then  goto 1;
         end
         else   //для остальных аргументов: при несовпадении типов переданных аргументов и заданных типов аргументов текущей ф-ии перейти к следующей функции с таким же именем
         if NCHLD[j]^.TypeF <> Fnc[i].TV[j] then goto 1;

         if NCHLD[j]^.TypeF = T_Array then            {.302}
         begin

            {.353}
            if (NCHLD[j]^.TypeM  = _Pointer) and (Fnc[i].TM[j] = _Integer) then
            begin
               if F_EnableUseIntegerPointer = False then  goto 1;
            end
            else
            if NCHLD[j]^.TypeM <> Fnc[i].TM[j]  then goto 1;    //проверить совпадение математических типов , если аргумент -  массив или возвращаемый тип - массив

            {
            if (Alg.Obj[NCHLD[j]^.NObj].MType  = _Pointer) and (Fnc[i].TM[j] = _Integer) then
            begin
               if F_EnableUseIntegerPointer = False then  goto 1;
            end
            else
            if Alg.Obj[NCHLD[j]^.NObj].MType <> Fnc[i].TM[j]  then goto 1;    //проверить совпадение математических типов , если аргумент -  массив
            }
         end;

     end;

     nf:=i;
     goto endp;
    end;

  end;
1:
end;




 for i:=0 to High(Fnc) do
 begin

   if Fnc[i].ExeF = _YES then   //если все правильно, должно работать и без этого
   begin

     if  Fnc[i].CallT = _STACK_INFINITE then //проверить совпадение типов:
     begin

      for j:=0 to High(NCHLD) do
      begin
       //if Interp[ANL[j]].TypeF <> Fnc[i].TV[0] then goto 2;
       if NCHLD[j]^.TypeF <> Fnc[i].TV[0] then goto 2;
      end;

      nf:=i;
      goto endp;
     end;

   end;

 2:
 end;




for i:=0 to High(Fnc) do
 begin
   if Fnc[i].ExeF = _YES then   //если все правильно, должно работать и без этого
   begin

     if  Fnc[i].CallT = _INTERNAL_INFINITE_ANY then
     begin
      //SetLength(Interp[LFunc].ArgTypes,Length(ANL));
      SetLength(Node^.ArgTypes,Length(NCHLD));
      for j:=0 to High(NCHLD) {High(ANL)} do
      begin
       //if (Interp[ANL[j]].TypeF =  T_Integer) or (Interp[ANL[j]].TypeF =  T_Array) then goto 3;
        if (NCHLD[j]^.TypeF =  T_Integer) or (NCHLD[j]^.TypeF =  T_Array) then goto 3;
        //Interp[LFunc].ArgTypes[j]:=Interp[ANL[j]].TypeF;

        //Tree^.ArgTypes[j]:=NCHLD[j]^.TypeF;   {.345}
          Node^.ArgTypes[j]:=NCHLD[j]^.TypeF;   {.346}
      end;

      nf:=i;
      goto endp;
     end;

   end;
 3:
 end;



endp:
end;






procedure TForevalH.FindCallFunctionA(Node:PNode; var TypeF: Integer; var nf: Integer; var TypeA: Integer);
label endp;
var
Fnc: TIntFuncA;
i,N,T,j,S: Integer;
ANL: TArrayC;
NCHLD: TArrayPN;
TypeF1,TypeF2: Integer;
adr: Cardinal;
nv1,nv2,tv1,tv2,tm1,tm2: Integer;
begin

{
 поправка оптимизации для случаев (N=0,1) (N - число аргументов в стеке) арифметической операции
  (напр.: x+sin(x); x+y; x+1; sin(x)+1; mod(Real,IntForm); mod(IntForm1,IntForm2); IntForm1^IntForm2;  )

 Арифм. команды с 2-мя аргументами в некоторых случаях оптимизируются до такой же команды, но с одним аргументом или без аргументов.
 Данные о них скрыты внутри самой команды и не передаются в стек.

 В связи с этим нужно обработать всевозможные типы аргументов команд для каждой.

}


nf:=-1;
TypeA:=0;       //тип аргумента
TypeF2:=0;      //тип аргумента
tv1:=0;
tv2:=0;

N:=Node^.Stack.N;
S:=Node^.Stack.S;
Fnc:=Alg.ExFunc[Node^.NFunc].Func;

//скрытые переменные в командах
nv1:=Node^.NV1; nv2:=Node^.NV2;
if nv1 <> -1 then GetVar1(nv1,adr,tv1,tm1);
if nv2 <> -1 then GetVar1(nv2,adr,tv2,tm2);



//типы скрытых переменных в командах
if (tv1 = T_Complex) or (tv2 = T_Complex) then TypeF1:=T_Complex
 else
 if (tv1 = IM_UNIT) or (tv2 = IM_UNIT) then TypeF1:=T_Complex
  else TypeF1:=T_Real;

  {.395} // отменено !!!
// if ((Node^.NFunc = CM_MUL) or (Node^.NFunc = CM_DIV)) and (tv1 = IM_UNIT) and (tv2 = IM_UNIT) then  TypeF1:=T_Real; //i*i,i/i


//FindNumberLevel(ANL);  //число аргументов
GetAllChilds(Node,NCHLD);
//if N = 1 then begin TypeF2:=Interp[ANL[0]].TypeF; TypeA:=TypeF2; end;
if N = 1 then begin TypeF2:=NCHLD[0]^.TypeF; TypeA:=TypeF2; end;       // тип аргумента в стеке в случае одного
if (TypeF1 = T_Complex) or (TypeF2 = T_Complex) then TypeF:=T_Complex else TypeF:=T_Real;

{.346}
if (TypeF2 = T_None) {or (TypeF2 = T_Void)} then
begin
  nf:=_NOT_FOUND;
  goto endp;
end;


{
  Отлов ошибок неверного типа переменных для встроеных внутренних функций с 2 аргументами.
  Т.к. для них выполняется оптмизация, в некоторых случаях, сводящаяся к одному внешнему аргументу.
}

{.353}   //для отлова ошибок: арифм. команды выполняются только для  T_Real T_Complex
if (N > 0) and ((Node^.NFunc = CM_ADD) or (Node^.NFunc = CM_SUB)  or (Node^.NFunc = CM_MUL) or (Node^.NFunc = CM_DIV) or
                (Node^.NFunc = CM_MOD) or (Node^.NFunc = CM_IDIV) or (Node^.NFunc = CM_AND) or (Node^.NFunc = CM_OR) or (Node^.NFunc = CM_XOR) or
                (Node^.NFunc = CM_NAND) or (Node^.NFunc = CM_NOR) or (Node^.NFunc = CM_XNOR))  then
begin
  if (TypeF2 <> T_Real) and (TypeF2 <> T_Complex) then
  begin
     nf:=_NOT_FOUND;
     goto endp;
  end;

  {.357}
  if (TypeF2 <> T_Real) and
     ( (Node^.NFunc = CM_MOD) or (Node^.NFunc = CM_IDIV) or (Node^.NFunc = CM_AND) or (Node^.NFunc = CM_OR) or (Node^.NFunc = CM_XOR) or
       (Node^.NFunc = CM_NAND) or (Node^.NFunc = CM_NOR) or (Node^.NFunc = CM_XNOR)) then
  begin
     nf:=_NOT_FOUND;
     goto endp;
  end;
end;


{.318}
//если есть комплексная константа:
if ((Node^.NFunc = CM_MUL) or (Node^.NFunc = CM_DIV)) and (Node^.TC = C_Complex) then TypeF:=T_Complex; //MulDivAnalizator, 2i*3*(3i-1)*x; (2i-1)/(3i-2)/sin(x)

{
При одном аргументе в арифметических командах, тип аргумента определяется по  TypeA
}

//!!! nf не соответствует реальному (не сущ-ет подобной арифм. комманды  с одним аргументом)
begin
  case Node^.NFunc of
   CM_ADD:  nf:=0;
   CM_SUB:  nf:=0;
   CM_MUL:  nf:=0;
   CM_DIV:  nf:=0;
   CM_MOD:  nf:=0;
   CM_IDIV: nf:=0;
   CM_AND:  nf:=0;
   CM_OR:   nf:=0;
   CM_XOR:  nf:=0;
   CM_NAND: nf:=0;
   CM_NOR:  nf:=0;
   CM_XNOR: nf:=0;
  end;
goto endp;
end;





endp:
end;





