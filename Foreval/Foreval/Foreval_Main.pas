if Len <> 3 then
begin
 F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
 F_SyntaxErrorString:=F_CurrentString;
 goto endp;
end;



if Len = 3 then
begin

    //sumps(vec,expr,argi)

    Str3:=LV[2].Expression;
    Str1:=LV[0].Expression;
    Str2:=LV[1].Expression;

    DeleteExternalBracketPS(@Str1);
    DeleteExternalBracketPS(@Str3);


    FindVarPS(@Str1,ni);
    if ni <> -1 then
    begin
       TV:=Alg.Obj[ni].TypeF;
       if TV = T_Array then
       begin
          ND1.NV1:=ni;
       end
       else
       begin
          F_SyntaxErrorCode:= E_WRONG_TYPE;
          F_SyntaxErrorString:=F_CurrentString;
          goto endp;
       end;
    end
    else
    begin
         {F_SyntaxErrorCode:= E_WRONG_EXPRESSION;
          F_SyntaxErrorString:=F_CurrentString;}
          goto endp;
    end;

    WriteFindExtArgInt1PS(@Str3, _Second,  ND1, IntegerVarForm, ND1, BAnsw);


    if Bansw = True then       //SUMPS(vec,Expr,[_IntConst,_IntVar,_IntForm])
    begin
         ND1.AI:=1;
         ND1.N:=1;
         ND1.NFunc:=CM_SUMPS;
         SetLength(LV1,ND1.N);
         LV1[0].Expression:=Copy(Str2,1,Length(Str2));
         EOFN:=False;
    end
    else                     //SUMPS(vec,Expr,PwrExpr)
    begin
         ND1.AI:=0;
         ND1.N:=2;
         ND1.NFunc:=CM_SUMPS;
         SetLength(LV1,ND1.N);
         LV1[0].Expression:=Copy(Str2,1,Length(Str2));
         LV1[1].Expression:=Copy(Str3,1,Length(Str3));
         EOFN:=False;
    end;




end;



endp:
