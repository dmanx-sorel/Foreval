{.369}
if GNode^.AI = 3 then        // (-1)^IntArray[]
begin
{
    LoadArrayElem(tc_LoadIntArrayElemEAX);

    //fld1
    AddWord($D9,$E8);
   //and eax,1
    AddByte($83);AddByte($E0);AddByte($01);
    //jz +$2
    AddWord($74,$02);
    //fchs
    AddWord($D9,$E0);

    CheckStack(1);
 }
end;


end;


