      JMP(L_ZSEC_END);//jmp @@L_ZSEC_END
         L2:=Length(IComp);
         L2:=L2-L1;

        {full complex z
         L_ZSEC_END - size of: }

              L1:=Length(IComp);
       {@@L_ZSEC:}
       ZMUL_i;
       FEXP;
       FLD0;
       FDIVR_C1;
