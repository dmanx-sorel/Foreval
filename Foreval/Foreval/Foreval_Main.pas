   begin
      FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);     //Re(ArcCotan)
      FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);   //Im(ArcCotan)
