            while CrNode <> Node2 do
            begin
              // S:=CrNode^.Expression;
              CrNode^.AlwaysEval:=EvalMode;
              CrNode:=CrNode^.Next;
            end;

            CrNode^.AlwaysEval:=EvalMode;
          end;

     end;


var
 Node1: PNode;
 S: String;
 db: integer;
begin


     db:=0;
