//возвращается целая часть. дробная часть отбрасывается
procedure TForevalH.TRUNCR(Reg: Integer);
begin           //Trunc(ST(0)) -> Reg
   PUSHCW;
   FLDCW(TAddress(@FCW1));
   MEM:=WriteDataA(0,_Integer);
   FISTP(MEM);
   POPCW;    {.227} //FLDCW(TAddress(@FCW2));

   if Reg =  R_EAX then    MOVMA(MEM) else
   if Reg =  R_EBX then    MOVMB(MEM) else
   if Reg =  R_ECX then    MOVMC(MEM) else
   if Reg =  R_EDX then    MOVMD(MEM);

end;


