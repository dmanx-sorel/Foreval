procedure TForevalH.COPYARRAY_C;
var
Ns,Nd,TM,TMs,TMd: Integer;
AdrS,AdrD: Cardinal;
begin
     Ns:=GNode^.NObj2;
     Nd:=GNode^.NObj;
     AdrS:=Alg.Obj[Ns].Addr;
     AdrD:=Alg.Obj[Nd].Addr;
     TM:=Alg.Obj[Ns].MType;
     TMs:=Alg.Obj[Ns].MType;
     TMd:=Alg.Obj[Nd].MType;



     if TMs = TMd then
     begin
        PUSHM(AdrS);
        PUSHM(AdrD);

        if TM = _Double   then MOVAadr(TAddress(@_CopyArrayDbl))  else
        if TM = _Extended then MOVAadr(TAddress(@_CopyArrayExt))  else
        if TM = _Single   then MOVAadr(TAddress(@_CopyArraySng))  else
        if TM = _Integer  then MOVAadr(TAddress(@_CopyArrayInt))  else
        if TM = _Pointer  then MOVAadr(TAddress(@_CopyArrayInt))  ;

        CALLA;
     end
     else
     begin

       MOVMA(AdrS);
       MOVMD(AdrD);

       if TMs = _Integer then
       begin
          if TMd = _Double     then MOVCadr(TAddress(@_CopyArrayIntToDbl))  else
          if TMd = _Extended   then MOVCadr(TAddress(@_CopyArrayIntToExt))
       end
       else
       if TMs = _Single then
       begin
          if TMd = _Double     then MOVCadr(TAddress(@_CopyArraySngToDbl))  else
          if TMd = _Extended   then MOVCadr(TAddress(@_CopyArraySngToExt))
       end
       else
       if TMs = _Double then
       begin
          if TMd = _Extended   then MOVCadr(TAddress(@_CopyArrayDblToExt))
       end;

       CALLC;
     end;



     {
     PUSHM(TM);
     PUSHM(AdrS);
     PUSHM(AdrD);
     MOVAadr(TAddress(@_CopyArrayAny));
     CALLA;
     }
end;



procedure TForevalH.SWAP_C;
var
N,nv1,nv2,NF,tf,tv1,ts1,tv2,ts2,sh1,sh2,TM1,TM2,tva,ArgForm1,ArgForm2: Integer;
Adr1,Adr2,Adr1IM,Adr2IM, AddrA1, AddrA2: TAddress;
Com,tif: Integer;
begin

//используется сразу для 2 команд: SWAP и SWAPIF

 TM2:=0; Adr2:=0; TM1:=0; Adr1:=0; Adr1IM:=0; Adr2IM:=0;

 nv1:=GNode^.NV1;
 nv2:=GNode^.NV2;

 ts1:=GNode^.TS1;
 ts2:=GNode^.TS2;

 Com:=GNode^.NFunc;
 tif:=GNode.tif;

 if (GNode^.AI >= 1) and  (GNode^.AI <= 6) then
 begin
    Adr1:=Alg.Obj[nv1].Addr;
    Adr1IM:=Alg.Obj[nv1].AddrIM;      {.343}
    tv1:=Alg.Obj[nv1].TypeF;
    tm1:=Alg.Obj[nv1].MType;
    sh1:=GetSizeSh(tm1);
    //if tm1 = _Double then sh1:=sh_D else   if Alg.Obj[nv1].MType = _Extended  then sh1:=sh_E;

    Adr2:=Alg.Obj[nv2].Addr;
    Adr2IM:=Alg.Obj[nv2].AddrIM;       {.343}
    tv2:=Alg.Obj[nv2].TypeF;
    tm2:=Alg.Obj[nv2].MType;
    sh2:=GetSizeSh(tm2);
    //if tm2 = _Double then sh2:=sh_D else   if Alg.Obj[nv2].MType = _Extended  then sh2:=sh_E;
 end;


 if (GNode^.AI = 1) {or (GNode^.AI = 2)} then         //SWAP, SWAPIF
 begin
 {
    x=1; y=11; swap(x,y);   x-y;
    x=1; y=11; swapif(x<y); x-y;
 }
 (*
   FLD(Adr1,tm1);
   FLD(Adr2,tm2);
   FSTPM(Adr1,tm1);
   FSTPM(Adr2,tm2);
   //CheckStack(2);
   //CheckStack(-2);
   *)

      FLD(Adr1,tm1);
      FLD(Adr2,tm2);

      if Com = CM_SWAPIF then
      begin
        FCOMI;
        JMPC(17,tif);
      end;

      FSTPM(Adr1,tm1);
      FSTPM(Adr2,tm2);

      if Com = CM_SWAPIF then
      begin
         JMP(4);
         FSTP0;
         FSTP0;
         CheckStack(2);     //коррекция на излишние fstp в swapif
      end;
 end
 else
 if  (GNode^.AI = 2) then      //SWAP, SWAPIF
 begin
 {
    n=1; k=11; swap(n,k);   n-k;
    n=1; k=11; swapif(n<k); n-k;
 }

  (*
   MOVMREG(R_EAX,Adr1);
   MOVMREG(R_EBX,Adr2);
   MOVREGM(R_EAX,Adr2);
   MOVREGM(R_EBX,Adr1);
   *)

    MOVMREG(R_EAX,Adr1);
    MOVMREG(R_EBX,Adr2);

    if Com = CM_SWAPIF then
    begin
       CMPR(R_EBX,R_EAX);
       JMPC(12,tif);
    end;

    MOVREGM(R_EAX,Adr2);
    MOVREGM(R_EBX,Adr1);

 end
 else
 if (GNode^.AI = 3) then          //SWAP
 begin
  {
    z1=1+1i; z2=11+11i; swap(z1,z2);   z1-z2;
  }

   FLD(Adr1,tm1);
   //FLD(Adr1+sh1,tm1);
   FLD(Adr1IM,tm1);        {.343}
   FLD(Adr2,tm2);
   //FLD(Adr2+sh2,tm2);
   FLD(Adr2IM,tm2);       {.343}

   //FSTPM(Adr1+sh1,tm1);
   FSTPM(Adr1IM,tm1);       {.343}
   FSTPM(Adr1,tm1);
   //FSTPM(Adr2+sh2,tm2);
   FSTPM(Adr2IM,tm2);     {.343}
   FSTPM(Adr2,tm2);
   //CheckStack(4);
   //CheckStack(-4);
 end
 else
 if (GNode^.AI = 6) then          //SWAP, SWAPIF
 begin
  {
    z1=1+11i; z2=111+1111i; swap(z1.re,z2.im);     z1.re-z2.im;
    z1=1+11i; z2=111+1111i; swapif(z1.re<z2.im);   z1.re-z2.im;
  }

   (*
   if ts1 = _RE then FLD(Adr1,tm1) else  if ts1 = _IM then FLD(Adr1IM,tm1);//FLD(Adr1+sh1,tm1);   {.343}
   if ts2 = _RE then FLD(Adr2,tm2) else  if ts2 = _IM then FLD(Adr2IM,tm2);//FLD(Adr2+sh2,tm2);   {.343}

   if ts1 = _RE then FSTPM(Adr1,tm1) else  if ts1 = _IM then FSTPM(Adr1IM,tm1);//FSTPM(Adr1+sh1,tm1);  {.343}
   if ts2 = _RE then FSTPM(Adr2,tm2) else  if ts2 = _IM then FSTPM(Adr2IM,tm2);//FSTPM(Adr2+sh2,tm2);   {.343}
   *)

   //load
   if ts1 = _RE then FLD(Adr1,tm1) else  if ts1 = _IM then FLD(Adr1IM,tm1);
   if ts2 = _RE then FLD(Adr2,tm2) else  if ts2 = _IM then FLD(Adr2IM,tm2);

   if Com = CM_SWAPIF then    // z1.re=2; z2.im=12;  swapif(z2.im>z1.re) ; z2.im-z1.re
   begin
      FCOMI;
      JMPC(17,tif);
   end;

   //save
   if ts1 = _RE then FSTPM(Adr1,tm1) else  if ts1 = _IM then FSTPM(Adr1IM,tm1);//FSTPM(Adr1+sh1,tm1);  {.343}
   if ts2 = _RE then FSTPM(Adr2,tm2) else  if ts2 = _IM then FSTPM(Adr2IM,tm2);//FSTPM(Adr2+sh2,tm2);   {.343}

   if Com = CM_SWAPIF then
   begin
      JMP(4);
      FSTP0;
      FSTP0;
      CheckStack(2);     //коррекция на излишние fstp в swapif
   end;

   //CheckStack(2);
   //CheckStack(-2);
 end
 else
 if (GNode^.AI = 4) then          //SWAP, SWAPIF
 begin
  {
    x=1;  z2=11+111i; swap(x,z2.im);     x-z2.im;
    x=1;  z2=11+111i; swapif(x<z2.im);   x-z2.im;
  }

   (*
   FLD(Adr1,tm1);
   if ts2 = _RE then FLD(Adr2,tm2) else  if ts2 = _IM then FLD(Adr2IM,tm2);//FLD(Adr2+sh2,tm2);       {.343}

   FSTPM(Adr1,tm1);
   if ts2 = _RE then FSTPM(Adr2,tm2) else  if ts2 = _IM then FSTPM(Adr2IM,tm2);//FSTPM(Adr2+sh2,tm2);    {.343}
   *)

    //load
   FLD(Adr1,tm1);
   if ts2 = _RE then FLD(Adr2,tm2) else  if ts2 = _IM then FLD(Adr2IM,tm2);

   if Com = CM_SWAPIF then              //x=2; z2.im=12;  swapif(x<z2.im); z2.im-x
   begin
      FCOMI;
      JMPC(17,tif);
   end;

   //save
   FSTPM(Adr1,tm1);
   if ts2 = _RE then FSTPM(Adr2,tm2) else  if ts2 = _IM then FSTPM(Adr2IM,tm2);

   if Com = CM_SWAPIF then
   begin
      JMP(4);
      FSTP0;
      FSTP0;
      CheckStack(2);     //коррекция на излишние fstp  в swapif
   end;


   //CheckStack(-2);

 end
 else
 if GNode^.AI = 5 then    //SWAP, SWAPIF
 begin
  {
    x=1;  z2=11+111i; swap(z2.im,x);     x-z2.im;
    x=1;  z2=11+111i; swapif(z2.im>x);   x-z2.im;
  }
   (*
   FLD(Adr2,tm2);
   if ts1 = _RE then FLD(Adr1,tm1) else  if ts1 = _IM then FLD(Adr1IM,tm1);//FLD(Adr1+sh1,tm1);        {.343}

   FSTPM(Adr2,tm2);
   if ts1 = _RE then FSTPM(Adr1,tm1) else  if ts1 = _IM then FSTPM(Adr1IM,tm1);//FSTPM(Adr1+sh1,tm1);   {.343}

   *)

    //load
   if ts1 = _RE then FLD(Adr1,tm1) else  if ts1 = _IM then FLD(Adr1IM,tm1);//FLD(Adr1+sh1,tm1);        {.343}
   FLD(Adr2,tm2);

   if Com = CM_SWAPIF then         //x=2; z2.im=12;  swapif(z2.im>x); z2.im-x
   begin
      FCOMI;
      JMPC(17,tif);
   end;

   //save
   if ts1 = _RE then FSTPM(Adr1,tm1) else  if ts1 = _IM then FSTPM(Adr1IM,tm1);//FSTPM(Adr1+sh1,tm1);   {.343}
   FSTPM(Adr2,tm2);

   if Com = CM_SWAPIF then
   begin
      JMP(4);
      FSTP0;
      FSTP0;
      CheckStack(2);     //коррекция на излишние fstp  в swapif
   end;

 end
 else
 if GNode^.AI = 10 then    //SWAP, SWAPIF         // IntArray[]<->IntArray[]
 begin
     AddrA1:=Alg.Obj[GNode^.NObj].Addr;
     AddrA2:=Alg.Obj[GNode^.NObj2].Addr;
     ArgForm1:=GNode^.TA1;
     ArgForm2:=GNode^.TA2;

     //swap(IntArray,IntArray)
     if  ((ArgForm1 = _IntConst) or (ArgForm1 = _IntVar) or (ArgForm1 = _IntForm)) and ((ArgForm2 = _IntConst) or (ArgForm2 = _IntVar) or (ArgForm2 = _IntForm)) then
     begin                                //swap(vi1[2*k+4],vi2[j*n+2]); vi1[2*k+4]
     {
       vi1[10]=1; vi2[20]=11; swap(vi1[10],vi2[20]);   vi1[10]-vi2[20]
       vi1[10]=1; vi2[20]=11; swapif(vi1[10]<vi2[20]); vi1[10]-vi2[20]

       vi1[k]=1; vi2[j]=11; swap(vi1[k],vi2[j]);   vi1[k]-vi2[j]
       vi1[k]=1; vi2[j]=11; swapif(vi1[k]<vi2[j]); vi1[k]-vi2[j]

       vi1[2*k+4]=1; vi2[3*j*k-5]=11; swap(vi1[2*k+4],vi2[3*j*k-5]);   vi1[2*k+4]-vi2[3*j*k-5]
       vi1[2*k+4]=1; vi2[3*j*k-5]=11; swapif(vi1[2*k+4]<vi2[3*j*k-5]); vi1[2*k+4]-vi2[3*j*k-5]
     }

           LoadLineFormEAX(_First);     //ArgForm1
           MOVMREG(R_EBX,AddrA1);       //Addr1->EBX

           //lea esi,ebx+4*eax
           AddByte($8D); AddByte($34);AddByte($83);      // @VecInt1[ArgForm1] -> ESI

           LoadLineFormEAX(_Second);    //ArgForm2
           MOVMREG(R_EBX,AddrA2);       //Addr2->EBX

           //lea edi,ebx+4*eax
           AddByte($8D); AddByte($3C);AddByte($83);      // @VecInt2[ArgForm2] -> EDI

           //load
           //mov eax,[esi]
           AddByte($8B); AddByte($06);     // VecInt1[ArgForm1] -> EAX
           //mov ebx,[edi]
           AddByte($8B); AddByte($1F);     // VecInt2[ArgForm2] -> EBX

           if Com = CM_SWAPIF then
           begin
             CMPR(R_EBX,R_EAX);
             JMPC(4,tif);
           end;

           //save
           //mov [edi],eax
           AddByte($89); AddByte($07);     // EAX -> VecInt2[ArgForm2]
           //mov [esi],ebx
           AddByte($89); AddByte($1E);     // EBX -> VecInt1[ArgForm1]

           SetReg(R_ESI);
           SetReg(R_EDI);
           SetReg(R_EAX);
           SetReg(R_EBX);

     end
     else
     if ((ArgForm1 = _IntConst) or (ArgForm1 = _IntVar) or (ArgForm1 = _IntForm)) and (ArgForm2 = _NOT_FOUND) then
     begin
                          //vi1[2*k+4]=2; vi2[j*(n+2)]=12; swap(vi1[2*k+4],vi2[j*(n+2)]); vi2[j*(n+2)]-vi1[2*k+4]
      {
       vi1[10]=1; vi2[j*(n+2)]=11; swap(vi1[10],vi2[j*(n+2)]);   vi1[10]-vi2[j*(n+2)]
       vi1[10]=1; vi2[j*(n+2)]=11; swapif(vi1[10]<vi2[j*(n+2)]); vi1[10]-vi2[j*(n+2)]

       vi1[k]=1; vi2[j*(n+2)]=11; swap(vi1[k],vi2[j*(n+2)]);   vi1[k]-vi2[j*(n+2)]
       vi1[k]=1; vi2[j*(n+2)]=11; swapif(vi1[k]<vi2[j*(n+2)]); vi1[k]-vi2[j*(n+2)]

       vi1[2*k+4]=1; vi2[j*(n+2)]=11; swap(vi1[2*k+4],vi2[j*(n+2)]);   vi1[2*k+4]-vi2[j*(n+2)]
       vi1[2*k+4]=1; vi2[j*(n+2)]=11; swapif(vi1[2*k+4]<vi2[j*(n+2)]); vi1[2*k+4]-vi2[j*(n+2)]
     }

           LoadArg1;

           LoadLineFormEAX(_First);     //ArgForm1
           MOVMREG(R_EBX,AddrA1);       //Addr1->EBX
           //lea esi,ebx+4*eax
           AddByte($8D); AddByte($34);AddByte($83);      // @VecInt1[ArgForm1] -> ESI


