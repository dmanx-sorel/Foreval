     // перебрать все вытекающие аргументы из Node2
     procedure   SetForAllArg(Node2: PNode; EvalMode: Integer);
     var
       FirstNode,LastNode,CrNode: PNode;
       S: String;
     begin

          if Node2^.Ch <> nil then
          begin

            FirstNode:=GetLowLeftNode(Node2);
