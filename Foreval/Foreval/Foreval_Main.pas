       Alg.Obj[i].SrcDef:=SrcDef;
       goto endp;
     end;

      //перезаписать новую  на место удалённой
      if Name1 = SChidden then   //удаленная переменная
      begin
       Alg.Obj[i].Addr:=AddrRE;
       Alg.Obj[i].AddrIM:=AddrIM;
       Alg.Obj[i].TypeF:=IdType;
       Alg.Obj[i].MType:=MType;
       Alg.Obj[i].IsUsed:=_NO;
       Alg.Obj[i].SrcDef:=SrcDef;
       Alg.Obj[i].Name:=Copy(Name,1,Length(Name));
       goto endp;
      end;
   end;

 SetLength(Alg.Obj,Length(Alg.Obj)+1);
 Alg.Obj[High(Alg.Obj)].TypeF:=IdType;
 Alg.Obj[High(Alg.Obj)].MType:=MType;
 Alg.Obj[High(Alg.Obj)].Addr:=AddrRE;
 Alg.Obj[High(Alg.Obj)].AddrIM:=AddrIM;
 Alg.Obj[High(Alg.Obj)].IsUsed:=_NO;
 Alg.Obj[High(Alg.Obj)].SrcDef:=SrcDef;
 Alg.Obj[High(Alg.Obj)].Name:=Copy(Name,1,Length(Name));

 //в AlgVec  записывать все:
endp:
 {.353}
 if idType = T_Array then
 begin
   SetLength(AlgVec,Length(AlgVec)+1);
   //AlgVec[High(AlgVec)].TypeF:=IdType;
   AlgVec[High(AlgVec)].MType:=MType;
   AlgVec[High(AlgVec)].Addr:=AddrRE;
   //AlgVec[High(AlgVec)].AddrIM:=AddrIM;
   //AlgV.Obj[High(AlgV.Obj)].IsUsed:=_NO;
   //AlgV.Obj[High(AlgV.Obj)].Name:=Copy(Name,1,Length(Name));
 end
 else
 if idType = T_Real then
 begin
 //отключена _PRealU
  {
   SetLength(AlgVarR,Length(AlgVarR)+1);

   AlgVarR[High(AlgVarR)].MType:=MType;
   AlgVarR[High(AlgVarR)].Addr:=AddrRE;

   }
 end;


 //endp:
end;




