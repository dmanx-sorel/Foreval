end;



procedure TForevalH.DiffTreeP;
label endp,extf,extfwd,endf;
var
N,NCOP,nn,tr,ng,ng1,ng2,ngd1,ngd2,NP,NArg,NF,NFunc,Op,DF1,DF2,Len: Integer;
HTree,H1Tree,Chld,Prnt: PNode;
S,SD,SD1,SD2,SD3,SD4,S1,S2,S3,S4,Sc,SE,SE1,SD1b,SD2b,S1b,S2b,SFunc,SX,SXD,Sx1,Sexpr,S1A,S2A,SB1,SB2,S1P,S2P: String;
DiffFunc: String;
fx,fx1,fx2: extended;
bnum,bnum1,bnum2,Bl,blx,bl1,bl2: boolean;
Tmp1,Tmp2: Cardinal;
answ,answ1,answ2: Integer;
begin
F_ExtFuncD:=False;


if F_SyntaxErrorCode <> 0 then goto endp;
N:=0;

Tree:=BeginTree; //не обязательно, т.к. чтение дерева - циклически


while Tree^.Ch <> nil do
begin
Tree:=Tree^.Ch;
end;
//COP=NOP:

while Tree^.Pr <> nil do
begin
 while Tree^.Nb <> nil  do
 begin
 Tree:=Tree^.Nb;
  while Tree^.Ch <> nil do
  begin
  Tree:=Tree^.Ch;
  end;
 //COP=NOP:
 inc(N);
end;

//COP<>NOP:
 //S:=Tree^.Expression;
 Tree:=Tree^.Pr;
 //Sexpr:=Tree^.Expression;
 S:='0';
 N:=1;
 NCOP:=Tree^.NCOP;
 CurrentDiffSubExpression:=Tree^.Expression;
 DiffFunc:=Tree^.Expression;

 HTree:=Tree^.Ch;



 Prnt:=Tree;
 NArg:=Tree^.Stack.N;
 NF:=Tree^.NF;
 NFunc:=Tree^.NFunc;

 {.327}
 //приведение в соответствие COP -> NFunc для дифф-я операций (+ - * / ^)
 //т.к. связывание типов LinkTreeData при дифф.  не выполняется
 if (Tree^.COP = _COP) then
 begin
   NCOP:=Tree^.NCOP;
   Tree.NFunc:=Alg.Opr[NCOP].NFunc;
   Tree.COP:=_Func;
   NFunc:=Tree^.NFunc;
 end;

  if F_FAST_STD_FUNC = False then   {.335} // перекодировка NFunc  _acc функций в NFunc обычных (быстрых) для оптимального дифференцирования в режиме AccFunc
  begin
    NFunc:=XchNFuncFastAcc(NFunc);
  end;

 //SFunc:=Tree^.SFunc;
 //SFunc:=Alg.ExFunc[Alg.Opr[NCOP].NFunc].Name;
 SFunc:=Alg.ExFunc[NFunc].Name;

 (*
 {.325}
 if (Tree^.COP = _LDSC) or (Tree^.COP = _LDSCX) or (Tree^.COP = _LDSF) then
 begin
     //константы и переменные продифференцированы при разборе в TreeBuilder
 end
 else {.319}
 *)
 if Tree^.COP = _Func then
 begin
      {
        S1   - первый аргумент
        S2   - второй аргумент
        SD1  - производная первого аргумента
        SD2  - производная второго аргумента

        Все аргументы текущего узла - HTree (его потомки, вытекающие из него) содержатся в
           HTree^.Expression, HTree^.Nb^.Expression, HTree^.Nb^.Nb^.Expression, HTree^.Nb^.Nb^.Nb^.Expression,... до HTree^.Nb^.....Nb^.Nb = nil;

        Все производные этих аргументов содержатся в
           HTree^.SDiff, HTree^.Nb^.SDiff, HTree^.Nb^.Nb^.SDiff, HTree^.Nb^.Nb^.Nb^.SDiff,... до HTree^.Nb^.....Nb^.Nb = nil;
      }

      //двуаргументные операции
      if (NFunc =  CM_ADD) or (NFunc =  CM_SUB) or (NFunc =  CM_MUL) or (NFunc = CM_DIV) or (NFunc =  CM_POWER) then
      begin

        SD1:=HTree^.SDiff;           FindExternalBracketNegPS(@SD1);//FindExternalBracketN(SD1,SD1b,ngd1);
        SD2:=HTree^.Nb^.SDiff;       FindExternalBracketNegPS(@SD2);//FindExternalBracketN(SD2,SD2b,ngd2);
        S1:=HTree^.Expression;       FindExternalBracketNegPS(@S1);//FindExternalBracketN(S1,S1b,ng1);
        S2:=HTree^.Nb^.Expression;   FindExternalBracketNegPS(@S2);//FindExternalBracketN(S2,S2b,ng2);


        if (NFunc =  CM_ADD) then
        begin
           if (SD1 = '0')  and  (SD2 = '0') then  S:='0' else
           if (SD1 <> '0') and  (SD2 <> '0') then   S:=SD1+'+'+'('+SD2+')' else
           if  SD2 = '0'    then  S:=SD1 else
           if  SD1 = '0'    then  S:=SD2;
        end

        else

        if (NFunc =  CM_SUB) then
        begin
           if (SD1 = '0') and (SD2 = '0') then  S:='0' else
           if (SD1 <> '0') and (SD2 <> '0') then  S:=SD1+'-'+'('+SD2+')' else
           if SD2 = '0' then   S:=SD1 else
           if SD1 = '0' then   S:='-('+SD2+')';
        end

        else

        if (NFunc =  CM_MUL) then       //S:=S1*SD2+S2*SD1
        begin

           if (SD1 = '0') and (SD2 = '0') then  S:='0'
           else
           if SD1 = '0'  then      //S:=S1*SD2; SD1=0
           begin

             if (S1 = '0') or (SD2 = '0') then
               S:='0'
             else
             if (S1 = '1')  then
               S:='('+SD2+')'
             else
             if (S1 = '-1')  then
               S:='(-('+SD2+'))'
             else
             if (SD2 = '1')  then
              S:='('+S1+')'
             else
             if (SD2 = '-1')  then
              S:='(-('+S1+'))'
             else
             if (S1 = '1') and (SD2 = '1')  then
              S:='1'
             else
             if (S1 = '1') and (SD2 = '-1')  then
              S:='-1'
             else
             if (S1 = '-1') and (SD2 = '1')  then
              S:='-1'
             else
             if (S1 = '-1') and (SD2 = '-1')  then
              S:='1'
             else
              S:= '('+S1+')*('+SD2+')'

           end   //SD1=0
           else
           if SD2 = '0'  then              //S:=S2*SD1; SD2=0
           begin

             if (S2 = '0') or (SD1 = '0') then
              S:='0'
             else
             if (S2 = '1')  then
              S:='('+SD1+')'
             else
             if (S2 = '-1')  then
              S:='(-('+SD1+'))'
             else
             if (SD1 = '1')  then
              S:='('+S2+')'
             else
             if (SD1 = '-1')  then
              S:='(-('+S2+'))'
             else
             if (S2 = '1') and (SD1 = '1')  then
              S:='1'
             else
             if (S2 = '1') and (SD1 = '-1')  then
              S:='-1'
             else
             if (S2 = '-1') and (SD1 = '1')  then
              S:='-1'
             else
             if (S2 = '-1') and (SD1 = '-1')  then
              S:='1'
             else
              S:= '('+S2+')*('+SD1+')'

           end // SD2=0
           else      //S:=S1*SD2+S2*SD1
           begin

             if (SD1 = '1') and (SD2 = '1')  then
              S:='('+S1+')'+'+('+S2+')'
             else
             if (SD1 = '-1') and (SD2 = '1')  then
              S:='('+S1+')'+'-('+S2+')'
             else
             if (SD1 = '1') and (SD2 = '-1')  then
              S:='('+S2+')'+'-('+S1+')'
             else
             if (SD1 = '-1') and (SD2 = '-1')  then
              S:='(-('+S1+'))'+'+(-('+S2+'))'
             else
             if (SD1 = '1')  then
              S:='('+S1+')'+'*'+'('+SD2+')'+'+('+S2+')'
             else
             if (SD1 = '-1')  then
              S:='('+S1+')'+'*'+'('+SD2+')'+'-('+S2+')'
             else
             if (SD2 = '1')   then
              S:='('+S1+')'+'+('+S2+')'+'*'+'('+SD1+')'
             else
             if (SD2 = '-1')   then
              S:='('+S2+')'+'*'+'('+SD1+')'+'-('+S1+')'
             else
              S:='('+S1+')'+'*'+'('+SD2+')'+'+('+S2+')'+'*'+'('+SD1+')';

           end   //S:=S1*SD2+S2*SD1

        end

        else

        if (NFunc =  CM_DIV) then        //S:='(('+SD1+')*('+S2+')-('+SD2+')*('+S1+'))/sqr('+S2+')';
        begin

           if (SD1 = '0') and (SD2 = '0') then  S:='0'
           else
           if SD1 = '0'  then
           begin

              if (S1 = '0') or (SD2 = '0') then S:='0'
              else  //S:='-('+SD2+')*('+S1+')/sqr('+S2+')'
              begin
                 IsNumPS(@S1,fx1,bnum1);
                 IsNumPS(@SD2,fx2,bnum2);

                 if (bnum1 = true) and (bnum2 = true) then
                 begin
                    fx1:=-fx1*fx2;
                    Sx:=FloatToStr(fx1,G_FMT);
                    //Sx:=FloatToStrF(fx1, ffExponent, 20, 4, G_FMT);
                    S:='('+Sx+')/sqr('+S2+')';
                 end
                 else
                 begin
                   if (bnum2 = true) and (fx2 = 1.0) then
                      S:='-('+S1+')/sqr('+S2+')' //{.347}
                   else
                      S:='-('+SD2+')*('+S1+')/sqr('+S2+')';
                 end;
              end

           end   //SD1=0
           else
           if SD2 = '0'  then
           begin
               if (S2 = '0') or (SD1 = '0') then S:='0'
               else  //S:='('+SD1+')*('+S2+')/sqr('+S2+')'
               begin
                  IsNumPS(@SD1,fx1,bnum1);
                  IsNumPS(@S2,fx2,bnum2);

                if (bnum1 = true) and (bnum2 = true) then
                begin
                  fx1:=fx1*fx2;
                  Sx:=FloatToStr(fx1,G_FMT);
                  //Sx:=FloatToStrF(fx1, ffExponent, 20, 4, G_FMT);
                  S:='('+Sx+')/sqr('+S2+')';
                end
                else
                begin
                  if S1 = DiffVar then   S:='(1/'+'('+S2+'))'         // x/y -> 1/y  //{.209
                  else
                   S:='('+SD1+')*('+S2+')/sqr('+S2+')';
                end;
               end
           end  //SD2=0
           else
           begin
              if (SD1 = '1') then       //{.347}
              begin
                  if (SD2 = '1') then      //{.347}
                  S:='(('+S2+')-('+S1+'))/sqr('+S2+')'
                  else
                  S:='(('+S2+')-('+SD2+')*('+S1+'))/sqr('+S2+')'
              end
              else
              if (SD2 = '1') then                  //{.347}
              begin
                  S:='(('+SD1+')*('+S2+')-('+S1+'))/sqr('+S2+')';
              end
              else
              S:='(('+SD1+')*('+S2+')-('+SD2+')*('+S1+'))/sqr('+S2+')';

           end;

        end //CM_DIV
        else

        if (NFunc =  CM_POWER) then
        begin

           if SD1 = '1' then DF1:=1 else DF1:=0;
           if SD2 = '1' then DF2:=1 else DF2:=0;

           if SD2 = '0' then
           begin

             if (S2 = '0') or (SD1 = '0')  then  S:='0' else
             begin
                IsNumPS(@S2,fx,bnum);
                if bnum = true then
                begin
                   fx:=fx-1;
                   if fx = 0 then S:='('+S2+')*('+SD1+')'
                   else
                   begin
                       IsNumPS(@S2,fx1,bnum1);
                       IsNumPS(@SD1,fx2,bnum2);
                       if fx = 1  then SX:='' else SX:='^('+{FloatToStrF(fx, ffExponent, 20, 4, G_FMT)}FloatToStr(fx,G_FMT)+')';

                       if (bnum1 = true) and (bnum2 = true) then
