           if (Alg.ExFunc[nf].Func[i].CallT = _STACK_INFINITE) or (Alg.ExFunc[nf].Func[i].CallT = _INTERNAL_INFINITE_ANY) then
           begin
              ND1.N:=0; ND1.COP:=_Func; ND1.NFunc:=nf;  ND1.NF:=i;  BEF:=True; EOFN:=True; SetLength(LV1,0);
