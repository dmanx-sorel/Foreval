procedure TForevalH.POLYU_C;
label endp;
var
 NArg,NS,NF,S,nv,TM,tf,tv,LP,k,ts,tc: Integer;
 Addr: Cardinal;
 An,Ai,A0: Extended;
 CAn,CAi,CA0: TComplex;
 i,cs: Integer;
 //B_LoadST:Boolean;

    procedure _ADD_Cn(k: Integer);
    var
      B_LoadST:Boolean;

    begin
       B_LoadST:=False;

        if GNode^.VFP[k].indx >= 0 then
        begin
           CAn.re:=GNode^.VFP[k].Re;
           CAn.im:=GNode^.VFP[k].Im;
           tc:=GNode^.VFP[k].tc;

           if (CAn.re <> 0) or (CAn.im <> 0)  then
           begin

             if tc = T_Complex then
                FLD(WriteDataA(CAn.im,F_DataType),F_DataType);

             FLD(WriteDataA(CAn.re,F_DataType),F_DataType);

             B_LoadST:=True;
           end;

        end
        else
        begin
           tc:=GNode^.ArgTypes[cs];

           if tc = T_Complex then
              FLD(GetStackAdr(S+cs,_IM),F_DataType);

           FLD(GetStackAdr(S+cs,_RE),F_DataType);

           inc(cs);

           B_LoadST:=True;
        end;

        if   B_LoadST = True then ADDP_ST(tc,ts);

        if   tc = T_Complex then ts := T_Complex;
    end;

begin
//poly(2*a,3*a,4*a,x)+1

 //poly(2*a,3*a,4*a,x)
 //poly(2,3*a,4,5*a,6,7*a,x)
 //poly(2*a,3*y,4*a,5*y,6*a,7*y,x)
 //poly(a,3*y,a,5*y,a,7*y,x)
 //poly(2,3*a,4,5*a,6,7*a,x)-(2*x^5+3*a*x^4+4*x^3+5*a*x^2+6*x+7*a)
 //polynom(5*(z1+y),0,3*(2+3),4,5*(2+3+i),x)


 tf:=GNode^.TypeF;                             //возвращаемый тип полинома
 tv:= GNode^.ArgTypes[High(GNode^.ArgTypes)];  //тип выражения переменной
 S:=GNode^.S;
 NArg:=Length(GNode^.VFP)+1; //полное число аргументов, включая ExprArg
 NS:=GNode^.N; //число аргументов, сохранённых в памяти (аргументы-выражения) Все остальные аргументы - числа, содержатся в массиве VFP
 cs:=0; //указатель текущего аргумента  в памяти: cs = 0,..,NS;
 LP:=NArg-2;
 CAn.re:=0; CAn.im:=0;

 //poly(ExprAn, ExprAn-1, ExprAn-2,...,ExprA0, VarExpr)
 if tf = T_Real then
 begin
    if NArg-1 = 1 then  //poly(2*a,x) = 2*a    poly(2*a,z1)=2*a
    begin
       FLD(GetStackAdr(S,_RE),F_DataType);
       goto endp;
    end;

                  //NS-1: отсчёт стека с '0'
    FLD(GetStackAdr(S+(NS-1),_RE),F_DataType); //загрузка VarExpr

    if LP + 1 > 2 then FLD0;  //x,x


    if GNode^.VFP[0].indx >= 0 then
    begin
      //if F_Mode = M_Compile then An:=GNode^.VFP[0].Re else An:=1.234;   //1.234 <> +-1 !!!!
      An:=GNode^.VFP[0].Re;
      if An = -1 then
         FCHS    else
      if An <> 1 then
         FMUL(WriteDataA(An,F_DataType),F_DataType);    //An*x,x
    end
    else
    begin
      FMUL(GetStackAdr(S,_RE),F_DataType);    //ExprAn*x,x
      inc(cs);
    end;


    for i := 1 to LP-1 do
    begin

        if GNode^.VFP[i].indx >= 0 then
        begin
           //if F_Mode = M_Compile then Ai:=GNode^.VFP[i].Re else Ai:=1.0;     //1.0 <> 0!!!
           Ai:=GNode^.VFP[i].Re;
           if Ai <> 0 then    FADD(WriteDataA(Ai,F_DataType),F_DataType);
        end
        else
        begin
           FADD(GetStackAdr(S+cs,_RE),F_DataType);
           inc(cs);
        end;

        if i < LP-1 then FMUL01 else FMULP1;

    end;//for

    if GNode^.VFP[LP].indx >= 0 then
    begin
      //if F_Mode = M_Compile then An:=GNode^.VFP[LP].Re else A0:=1.0;   //1.0 <> 0!!!
      A0:=GNode^.VFP[LP].Re;
      if A0 <> 0  then FADD(WriteDataA(A0,F_DataType),F_DataType);   //+A0
    end
    else
    begin
      FADD(GetStackAdr(S+cs,_RE),F_DataType);    //+ExprA0
    end;


 end
 else
 if tf = T_Complex then
 begin
    // poly(ai+bi,x)=ai+bi   poly(ai*2,z1)=2*ai
    if NArg-1 = 1 then
    begin
       FLD(GetStackAdr(S,_IM),F_DataType);
       FLD(GetStackAdr(S,_RE),F_DataType);
       goto endp;
    end;



    // тип и значение An:
    if GNode^.VFP[0].indx >= 0 then
    begin
      {
        if F_Mode = M_Compile then
        begin
          CAn.re:=GNode^.VFP[0].Re;
          CAn.im:=GNode^.VFP[0].Im;
        end
        else
        begin
          CAn.re:=1.234;   //1.234 <> +-1 !!!!
          CAn.im:=1.234;   //1.234 <> +-1 !!!!
        end;
        }

        CAn.re:=GNode^.VFP[0].Re;
        CAn.im:=GNode^.VFP[0].Im;
        tc:=GNode^.VFP[0].tc;
    end
    else
    begin
        tc:=GNode^.ArgTypes[0];
    end;

    //загрузка VarExpr
    if tv = T_Real then
    begin
                      //NS-1: отсчёт стека с '0'
         FLD(GetStackAdr(S+(NS-1),_RE),F_DataType); //загрузка VarExpr
         if LP + 1 > 2 then FLD0;  //x,x
    end
    else
    if tv = T_Complex then
    begin                //NS-1: отсчёт стека с '0'
        FLD(GetStackAdr(S+(NS-1),_IM),F_DataType); //загрузка VarExpr.IM
        FLD(GetStackAdr(S+(NS-1),_RE),F_DataType); //загрузка VarExpr.RE
        if LP + 1 > 2 then ZPUSH;  //z,z
    end;


    //An*VarExpr:
    if tv = T_Real then      //VarExpr=real
    begin
       if GNode^.VFP[0].indx >= 0 then
       begin

          if tc = T_Real then       //An.Re*x         poly(a,bi,x)
          begin
             //
              if CAn.re = -1    then   FCHS          //poly(p2,bi,x)
              else
              if CAn.re <> 1    then   FMUL(WriteDataA(CAn.re,F_DataType),F_DataType);    //An*x,x     //poly(a,bi,x)
          end
          else
          if tc = T_Complex then          //CAn*x
          begin

             FLD0;

             if CAn.im = -1 then  FCHS                 //poly(p3i,a,x)      poly(p3i,ai,x)     poly(p5i,a,x)
             else
             if CAn.im <> 1 then  FMUL(WriteDataA(CAn.im,F_DataType),F_DataType);

             FXCH1;

             if CAn.re = -1 then  FCHS
             else
             if CAn.re <> 1 then  FMUL(WriteDataA(CAn.re,F_DataType),F_DataType);       //poly(ai,a,x) poly(ai,bi,x)

          end

       end
       else   //An in stack
       begin

          if tc = T_Real then                        //poly(a+b,bi,x)      poly(a+b,bi+ci,x)  poly(ai+bi,b+c,x)
          begin
             FMUL(GetStackAdr(S,_RE),F_DataType);    //ExprAn*x,x
             inc(cs);
          end
          else
          if tc = T_Complex then                       // poly(ai+bi,bi,x)    poly(ai+bi,bi+ci,x)    poly(ai+bi,b+c,x)
          begin
             FLD0;
             FMUL(GetStackAdr(S,_IM),F_DataType);
             FXCH1;
             FMUL(GetStackAdr(S,_RE),F_DataType);

             inc(cs);
          end

       end;

    end
    else
    if tv = T_Complex then    //VarExpr=complex
    begin

       if GNode^.VFP[0].indx >= 0 then
       begin

          if tc = T_Real then       //An.Re*z
          begin

              if CAn.re = -1    then             // poly(p2,bi,z1)
              begin
                 FCHS;
                 FXCH1;
                 FCHS;
                 FXCH1;
              end
              else
              if CAn.re <> 1    then             //     poly(a,bi,z1)
              begin
                 FLD(WriteDataA(CAn.re,F_DataType),F_DataType);
                 FMUL20;
                 FMULP;
              end;

          end
          else
          if tc = T_Complex then          //CAn(VFP)*z
          begin

             if CAn.re = 0 then
             begin
               if CAn.im = 1 then                     //poly(p4i,b,z1) poly(p4i,bi,z1)
               begin
                  FXCH1;
                  FCHS;
               end
               else
               if CAn.im = - 1 then                  //poly(p5i,b,z1) poly(p5i,bi,z1)
               begin
                 FCHS;
                 FXCH1;
               end
               else    //Ci*z
               begin
                 FMUL(WriteDataA(CAn.im,F_DataType),F_DataType);    //poly(p6i,b,z1)    poly(p6i,bi,z1)
                 FXCH1;
                 FMUL(WriteDataA(CAn.im,F_DataType),F_DataType);
                 FCHS;
               end;
             end
             else      //CAn(VFP)*z
             begin                                                //poly(ai,bi,z1)
               FLD(WriteDataA(CAn.im,F_DataType),F_DataType);
               FLD(WriteDataA(CAn.re,F_DataType),F_DataType);
               ZMULP;
             end;

          end

       end
       else   //An in stack
       begin

          if tc = T_Real then     //An*z                      //poly(a+b,c+d,z1)  poly(a+b,ci+di,z1)
          begin
             FMUL(GetStackAdr(S,_RE),F_DataType);
             FXCH1;
             FMUL(GetStackAdr(S,_RE),F_DataType);
             FXCH1;
             inc(cs);
          end
          else
          if tc = T_Complex then     //CAn(Mem)*z          // poly(ai+bi,ci+di,z1)   poly(ai+bi,c+d,z1)
          begin
             FLD(GetStackAdr(S,_IM),F_DataType);
             FLD(GetStackAdr(S,_RE),F_DataType);
             ZMULP;
             inc(cs);
          end

       end;

    end ;


    if (tc = T_Complex) or (tv = T_Complex) then ts := T_Complex else ts:=T_Real; //текущий тип выражения (в стеке)

    //главный цикл вычисления полинома:

   //********************************
   for i :=1 to LP-1 do
    begin
        {
        B_LoadST:=False;

        if GNode^.VFP[i].indx >= 0 then
        begin
           CAn.re:=GNode^.VFP[i].Re;
           CAn.im:=GNode^.VFP[i].Im;
           tc:=GNode^.VFP[i].tc;

           if (CAn.re <> 0) or (CAn.im <> 0)  then
           begin

             if tc = T_Complex then
                FLD(WriteDataA(CAn.im,F_DataType),F_DataType);

             FLD(WriteDataA(CAn.re,F_DataType),F_DataType);

             B_LoadST:=True;
           end;

        end
        else
        begin
           tc:=GNode^.ArgTypes[S+cs];

           if tc = T_Complex then
              FLD(GetStackAdr(S+cs,_IM),F_DataType);

           FLD(GetStackAdr(S+cs,_RE),F_DataType);

           inc(cs);

           B_LoadST:=True;
        end;

        if   B_LoadST = True then ADD_ST(tc,ts);
        }

        _ADD_Cn(i);

        if i < LP-1 then
           MUL_ST(ts,tv)
        else
           MULP_ST(ts,tv);



        if tc = T_Complex then   ts := T_Complex;
       

    end;//for

    {
      //+A0
    B_LoadST:=False;
    if GNode^.VFP[LP].indx >= 0 then
    begin
      CAn.re:=GNode^.VFP[LP].Re;
      CAn.im:=GNode^.VFP[LP].Im;
      tc:=GNode^.VFP[LP].tc;

      if (CAn.re <> 0) or (CAn.im <> 0)  then
      begin

             if tc = T_Complex then
                FLD(WriteDataA(CAn.im,F_DataType),F_DataType);

             FLD(WriteDataA(CAn.re,F_DataType),F_DataType);

             B_LoadST:=True;
      end

    end
    else
    begin
           tc:=GNode^.ArgTypes[S+cs];

           if tc = T_Complex then
              FLD(GetStackAdr(S+cs,_IM),F_DataType);

           FLD(GetStackAdr(S+cs,_RE),F_DataType);

           inc(cs);

           B_LoadST:=True;
    end;

    if   B_LoadST = True then ADD_ST(tc,ts);
    }

    _ADD_Cn(LP);

 end;

 (*
 {
 poly(9,-8,7,-6,5,-4,3,-2,1,-12.34,z1)
 9*z1^9-8*z1^8+7*z1^7-6*z1^6+5*z1^5-4*z1^4+3*z1^3-2*z1^2+z1-12.34
 (((((((((9*z1-8)*z1+7)*z1-6)*z1+5)*z1-4)*z1+3)*z1-2)*z1+1)*z1)-12.34
 }
 if t1 = T_Complex  then      //poly(<exprCX>,An,..,A0)   poly(An,..,A0,<exprCX>)
 begin
    LP:=Length({Interp[NFunc]}GNode^.VFP)-1;

   if F_Mode = M_Compile then F1:={Interp[NFunc]}GNode^.VFP[0].Re else  F1:=1.5;



     if LP + 1 > 2 then ZPUSH;

     Adr:=WriteDataA(F1,F_DataType);      // An*Zn
     if F1 = -1 then
     begin
       FCHS;
       FXCH1;
       FCHS;
       FXCH1;
     end
     else
     if F1 <> 1 then
     begin
       FMUL(Adr,F_DataType);
       FXCH1;
       FMUL(Adr,F_DataType);
       FXCH1;
     end;


     for k := 1 to LP-1 do
     begin
       if F_Mode = M_Compile then F1:={Interp[NFunc]}GNode^.VFP[k].Re else  F1:=1;

       if F1 <> 0 then FADD(WriteDataA(F1,F_DataType),F_DataType);

       if k < LP-1 then
       begin
         ZMUL;
       end
       else
       begin
         ZMULP;
       end;
     end;

    if F_Mode = M_Compile then  F1:={Interp[NFunc]}GNode^.VFP[LP].Re else  F1:=1;

    if F1 <> 0 then FADD(WriteDataA(F1,F_DataType),F_DataType);   //+A0
 end;

end;

