function  TForevalH.WriteData(Node: PNode): TAddress;
var
FD1: PFuncData;
Pm: Pointer;
Data: extended;
begin


if F_Mode=M_Compile then
begin

     if F_DataInArray = True then
     begin
       Pm:=Pointer(@Func.RFStack[N_CurrentDataCell+N_ReplFuncLen]);
       inc(N_CurrentDataCell);

          {DB}
          if N_CurrentDataCell+N_ReplFuncLen > High(Func.RFStack) then
          begin
              Db_WriteDataOverFlow:=True;
          end;

      end
     else
     begin
       new(FD1); FD1^.Next:=nil;
       FuncData^.Next:=FD1;
       FuncData:=FD1;
       Pm:=Pointer(@FD1^.FData);
     end;

    Data:=Node^.FD;

    case  F_DataType of
       _Integer:   Integer(Pm^):=Trunc(Data);
       //_Single:    Single(Pm^):=Data;
       _Double:    Double(Pm^):=Data;
       _Extended:  Extended(Pm^):=Data;
    end;

    WriteData:=TAddress(Pm);

 end
else
begin
 WriteData:=TAddress(nil);
 inc(N_DataCellNum);
end;

end;





 //выделяет память для сохранения промежуточных результатов вычислений - возвращвает адрес ячейки
 //Data - инициализирующее значение
 //DataType - тип данных для сохранения
function  TForevalH.WriteDataA(Data: extended; DataType: Integer): TAddress;
var
FD1: PFuncData;
Pm: Pointer;
begin


if F_Mode=M_Compile then
begin
   //выделение в массиве (размер рассчитывается заранее в EvalDataCellNum) =
   // = число  промежуточных результатов + число замещаемых выражений в оптимизациях Replace
   if F_DataInArray = True then
   begin
     Pm:=Pointer(@Func.RFStack[N_CurrentDataCell+N_ReplFuncLen]);
     inc(N_CurrentDataCell);

        {DB}
         if N_CurrentDataCell+N_ReplFuncLen > High(Func.RFStack) then
         begin
             Db_WriteDataOverFlow:=True;
         end;

   end
   else
   begin

     new(FD1); FD1^.Next:=nil;
     FuncData^.Next:=FD1;
     FuncData:=FD1;
     Pm:=Pointer(@FD1^.FData);

   end;

   case  DataType of
    _Integer:   Integer(Pm^):=Trunc(Data);
    //_Single:    Single(Pm^):=Data;
    _Double:    Double(Pm^):=Data;
    _Extended:  Extended(Pm^):=Data;
    end;

    WriteDataA:=TAddress(Pm);


end
else
begin
  WriteDataA:=TAddress(nil);
  inc(N_DataCellNum);
end;

end;



