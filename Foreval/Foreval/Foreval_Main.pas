procedure TForevalH.CopyArrayAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);
label endp;
var
  nf1,nf2,tv1,tv2,tm1,tm2,LenV: Integer;
  Addr1,Addr2: TAddress;
  Str1,Str2: String;
  EnblCopyArr: Boolean;
begin

EOFN:=False;
ND1.AI:=0;


if F_SyntaxErrorCode <> 0 then goto endp;

LenV:=Length(LV);

LV1:=LV;
ND1:=ND;

if (LenV <> 2)  then
begin
      F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
      F_SyntaxErrorString:=F_CurrentString;
      goto endp;
end;


Str1:=LV[0].Expression;
Str2:=LV[1].Expression;

FindVarAPS(@Str1,nf1,Addr1,tv1,tm1);
FindVarAPS(@Str2,nf2,Addr2,tv2,tm2);

EnblCopyArr:=False;   // vec2 = vec1
if (tv1 = T_Array) and (tv2 = T_Array)  then
begin
   if  (tm1 = tm2) or
       ( (tm2 = _Integer) and ((tm1 = _Double) or (tm1 = _Extended)) ) or
       ( (tm2 = _Single)  and ((tm1 = _Double) or (tm1 = _Extended)) ) or
       ( (tm2 = _Double)  and  (tm1 = _Extended) ) then
       EnblCopyArr:=True;
end;


if EnblCopyArr = True then
begin
     ND1.NObj:=nf1;
     ND1.NObj2:=nf2;
     SetLength(LV1,0);
     ND1.N:=0;
     ND1.COP:=_FUNC;
     ND1.NFunc:=CM_COPYARRAY;
     EOFN:=True;
end
else
begin
    F_SyntaxErrorCode:=E_WRONG_TYPE;// else F_SyntaxErrorCode:=1;
    F_SyntaxErrorString:=F_CurrentString;
end;



 endp:
end;







