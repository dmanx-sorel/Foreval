procedure TForevalH.POLYAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);

             procedure InitVFP(ND: PDataNode);
             var
                k,L: Integer;
             begin

                for k := 0 to Length(ND^.VFP)-1 do
                begin
                    ND^.VFP[k].indx:=_ABSENT;
                    ND^.VFP[k].tc:=T_Real;
                    ND^.VFP[k].Re:=0;
                    ND^.VFP[k].Im:=0;
                end;

             end;



label endp,endpp;
var
C: TFloat;
VC1,VC2: Integer;                              //poly(array,arg)->poly(arg) ; array: ND1.NV1=nv1
S,NA: Integer;
i,nf,ni,tv: Integer;
nv1,nv2,tv1,tv2,tm1,tm2,Len,TC: Integer;
