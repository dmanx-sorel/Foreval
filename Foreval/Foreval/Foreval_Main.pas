      CM_PINTEGER:  PTYPE_C;     {.367}
      CM_PSINGLE:   PTYPE_C;     {.367}
      CM_PBYTE:     PTYPE_C;     {.381}
      CM_PWORD:     PTYPE_C;     {.381}
      CM_COPYARRAY: COPYARRAY_C;  {.369}
      CM_GOSUB:     GOSUB_C;
      CM_RETURN:    RETURN_C;
      CM_SETMASKFPUEXC:     SETMASKFPUEXC_C;
      CM_RESETMASKFPUEXC:   RESETMASKFPUEXC_C;
      CM_READEXCEPTIONFPU:  READEXCEPTIONFPU_C;
      CM_INITFPU:   INITFPU_C;
      CM_ISNAN:     ISNAN_C;
      CM_AND:       AND_C;
      CM_OR:        OR_C;
      CM_XOR:       XOR_C;
      CM_NOT:       NOT_C;
      CM_NAND:      NAND_C;
      CM_NOR:       NOR_C;
      CM_XNOR:      XNOR_C;
      CM_RUNIROOT:  RUNIROOT_C;
      CM_ImUIROOT:  ImUIROOT_C;
      CM_IROOT3:    IROOT3_C;



 else
 //external functions
 begin
extf:
  if Alg.ExFunc[N].Func[NF].CallT = _STACK_ADDR then
  begin

     PushArgStackAdr;
     MOVAadr(Alg.ExFunc[N].Func[NF].Addr);
     CALLA;

     if Alg.ExFunc[N].Func[NF].Set_Id = 1 then CLS:=4 else CLS:=0;
     CLS:=CLS+Node^.Arg*4;
     if Alg.ExFunc[N].Func[NF].CLST = _YES then ADDESP(CLS);
  end
  else
  if Alg.ExFunc[N].Func[NF].CallT = _STACK_VAL then
  begin
     PushArgStackVal;
  end
  else
  if Alg.ExFunc[N].Func[NF].CallT = _MEMORY_ESP then
  begin

     LoadArgMem;

     if (Alg.ExFunc[N].Func[NF].Set_Id = _YES) and (Alg.ExFunc[N].Func[NF].ARROW = _RIGHT)
     then PUSHM(Alg.ExFunc[N].Func[NF].Id_Func);   {.302}

     PUSHM(GetStackAdr(S,_RE));

     if (Alg.ExFunc[N].Func[NF].Set_Id = _YES) and (Alg.ExFunc[N].Func[NF].ARROW = _BACK)
     then PUSHM(Alg.ExFunc[N].Func[NF].Id_Func);   {.302}

     MOVAadr(Alg.ExFunc[N].Func[NF].Addr);
     CALLA;
     if Alg.ExFunc[N].Func[NF].Set_Id = 1 then CLS:=4 else CLS:=0;
     CLS:=CLS+4;
     if Alg.ExFunc[N].Func[NF].CLST = _YES then ADDESP(CLS);   {.197}

  end
  else
  if Alg.ExFunc[N].Func[NF].CallT = _MEMORY_EAX then
  begin

     LoadArgMem;
     if (Alg.ExFunc[N].Func[NF].Set_Id = _YES) then PUSHM(Alg.ExFunc[N].Func[NF].Id_Func);   {.302}
     MOVAadr(GetStackAdr(S,_RE));
     MOVBadr(Alg.ExFunc[N].Func[NF].Addr);
     CALLB;
     if (Alg.ExFunc[N].Func[NF].Set_Id = _YES) then ADDESP(4);

  end
  else
  if Alg.ExFunc[N].Func[NF].CallT = _COMPILED then
    begin
     LoadArgPC;
     if (Alg.ExFunc[N].Func[NF].IsInline = _YES) and (F_EnableInline = True) then
        InsertInlineCode(Alg.ExFunc[N].Func[NF].Addr,Alg.ExFunc[N].Func[NF].CodeSize)
     else
     begin
        MOVAadr(Alg.ExFunc[N].Func[NF].Addr);
        CALLA;
     end;

    end

  else

  if Alg.ExFunc[N].Func[NF].CallT = _STACK_INFINITE then     //FUNC(ADR,LEN)
  begin

    LoadArgMemInf;
    if Alg.ExFunc[N].Func[NF].Arrow = _BACK then
    begin
      PUSHM(GetStackAdr(S,_RE));
      PUSHM(GNode^.Arg);
      if (Alg.ExFunc[N].Func[NF].Set_Id = _YES) then PUSHM(Alg.ExFunc[N].Func[NF].Id_Func);   {.302}
    end
    else
     if Alg.ExFunc[N].Func[NF].Arrow = _RIGHT then
    begin
      if (Alg.ExFunc[N].Func[NF].Set_Id = _YES) then PUSHM(Alg.ExFunc[N].Func[NF].Id_Func);   {.302}
      PUSHM(GNode^.Arg);
      PUSHM(GetStackAdr(S,_RE));
    end;
    MOVAadr(Alg.ExFunc[N].Func[NF].Addr);
    CALLA;
    if Alg.ExFunc[N].Func[NF].Set_Id = 1 then CLS:=4 else CLS:=0;
    CLS:=CLS+8;
    if Alg.ExFunc[N].Func[NF].CLST = _YES then ADDESP(CLS);

  end;
  {.316}//off
  (*
  else
  if (Alg.ExFunc[N].Func[NF].CallT = _STACK_INFINITE_A)  then     //FUNC(ADR,LEN,ADRT)
  begin

   if  {( Alg.ExFunc[N].Name <> 'nop')}(N <> CM_NOP) and (N <> CM_VOID) and (N <> CM_PROG) then       {.197}
   begin
     LoadArgMemInfA;
     if Alg.ExFunc[N].Func[NF].Arrow = _BACK then
     begin
       PUSHM(GetStackAdr(S,_RE));
       PUSHM({Interp[NFunc]}GNode^.Arg);
       //PUSHM(Cardinal(@Interp[I].ArgTypes[0]));  {.233}  //изменить !!!!!!!!!!!!!!!
     end
     else
     if Alg.ExFunc[N].Func[NF].Arrow = _RIGHT then
     begin
       //PUSHM(Cardinal(@Interp[I].ArgTypes[0]));  {.233}    //изменить !!!!!!!!!!!!!!!
       PUSHM({Interp[NFunc]}GNode^.Arg);
       PUSHM(GetStackAdr(S,_RE));
     end;
     MOVAadr(Alg.ExFunc[N].Func[NF].Addr);
     CALLA;
     if Alg.ExFunc[N].Func[NF].CLST = 1 then ADDESP(12);
   end;
  end;*)


   SDeep:=Alg.ExFunc[N].Func[NF].SDeep;
   SaveRegF;

   //fz_UNKNOWN
   if  SDeep = -1 then F_SaveInFPU:=False
   else
   begin
    R:=0;
    if Alg.ExFunc[N].Func[NF].TypeF = T_Real then R:=1 else
    if Alg.ExFunc[N].Func[NF].TypeF = T_Complex then R:=2 else
    if Alg.ExFunc[N].Func[NF].TypeF = T_None then R:=0 else
    if Alg.ExFunc[N].Func[NF].TypeF = T_Array then R:=0 else
    if Alg.ExFunc[N].Func[NF].TypeF = T_Pointer then R:=0;


     //исключение для PROG т.к. TypeF меняется при разборе (<>T_None):
     if Node^.NFunc = CM_NOP then R:=0;
     if Node^.NFunc = CM_PROG then R:=0;  {.316}
     //исключение для IF т.к. загрузка стека учитывается в аргументах и команде #JMP :
     if Node^.NFunc = CM_IF then R:=0;   {.211}

    if R > SDeep then SDeep:=R;
    CheckStack(SDeep);

    if (Alg.ExFunc[N].Func[NF].TypeF = T_Real) and (SDeep > 1) then CheckStack(-(SDeep-1)) else
    if (Alg.ExFunc[N].Func[NF].TypeF = T_Complex) and (SDeep > 2) then CheckStack(-(SDeep-2));
    if Alg.ExFunc[N].Func[NF].TypeF = T_None then CheckStack(-SDeep); //для процедур: нет результата (+SDeep,-SDeep) {.211}

    //F_ExtFunc:=True;
     //SetReg(1); SetReg(2); SetReg(3); SetReg(4);
   end;
    F_ExtFunc:=True;





 end;

 end; //of case

  WriteReplFunc(Node);
end;


endp:
SaveResult(Node);
end;




procedure TForevalH.SaveResult(Node:PNode{I: Cardinal});


   function IsSaveResultInFPU: Boolean;
   var
   Answ: Boolean;
   begin
        Answ:=False;

           //аргументы с плавающей точкой этих комманд не выталкиваются в стек: сохраняютс в FPU:
           //возвращаемый результат комманды IFNOP остаётся в стеке FPU (иначе IFNOP возвратит NAN)
        if CheckIfRet(Node)    then begin Answ:=True; end else
        if CheckNopRet(Node)   then begin Answ:=True; end else
            //{.353}аргументы T_Pointer, T_Array для SAVE сохраняются в стеке выражения (float vars остаются в FPU, не выталкиваются в память):
        if (CheckSaveRet(Node) = True) and ((Node^.TypeF = T_Real) or (Node^.TypeF = T_Complex))  then begin Answ:=True; end else
            //используется при промежуточной оптимизации:
        if F_IntermediateLastNode = True then begin Answ:=True; end else  {.310}
            //эти команды не возвращают результат: (T_None)    {.197}
        if Node^.TypeF = T_None then begin Answ:=True; end;

        IsSaveResultInFPU:=Answ;
   end;

    (*

   function IsInvalidFPULoad: Boolean;
   {
     Проверка стека FPU после выполнения команды , являющейся аргументом в PROG
     Стек FPU перед ними и после должен быть пуст, за исключением последней команды, если она возвращает число в FPU
     Если стек FPU в таких случаях не пуст,  команда  загружает его и не освобождает
   }
   var
    Answ: Boolean;
   begin
        Answ:=False;

        if (Node^.Pr <> nil) {and (F_Mode = M_Compile )} then
        begin
             // если команда является аргументом PROG
             if Node^.Pr^.NFunc = CM_PROG then
             begin
               // если команда - не последняя исполняемая
               if Node^.Nb <> nil {Node^.Next^.NFunc <> CM_PROG} then // (Node^.Nb <> nil) тоже самое  (Node^.Next^.NFunc <> CM_PROG)
               begin
                  // если есть загрузка стека FPU после выполнения команды
                  if N_Stack > 0 then
                  begin
                     // x=1; y+1; x=2; x               // y+1 - загружает стек без возврата/очистки

                     //
                      {
                        pfunc1(x1:ext):none  =   x=2*x1
                        pfunc1(x,y:ext):real =   x+y

                        x=1; y=2; pfunc1(x); x+y            // ошибки нет, pfunc1 - процедура
                        x=1; y=2; pfunc1(x,y); x+y          // ошибка, pfunc1 - функция

                      }

                     Answ:=True;
                     F_SyntaxErrorString:=Node^.Expression;
                     F_SyntaxErrorCode:=E_INVALID_FPU_LOADING;

                  end;

                end;

             end;
        end;

       IsInvalidFPULoad:=Answ;
   end;

    *)

label endp;
var
S,N,NM,CallT,NF,dt,sh,Adr,tf,NL: Cardinal;
REA,IMA: TAddress;
NodePrnt: PNode;
begin

F_SData:=_FPU;

{.387} // перенесено в  LinkDataNode !
// проверка стека FPU после выполнения команды, являющейся аргументом PROG. Стек должен быть пуст, за исключением последней
// if F_Mode = M_Compile then if IsInvalidFPULoad = True then goto endp;



{.367}
//нужно ли выталкивать результат текущей команды в память (из FPU)
if IsSaveResultInFPU = True then goto endp;
(*
//аргументы с плавающей точкой этих комманд не выталкиваются в стек: сохраняютс в FPU:
//возвращаемый результат комманды IFNOP остаётся в стеке FPU (иначе IFNOP возвратит NAN)

if CheckIfRet(Node)    then goto endp;
if CheckNopRet(Node)   then goto endp;
//if CheckSaveRet(Node)  then goto endp;

 //{.353}аргументы T_Pointer, T_Array для SAVE сохраняются в стеке выражения (float vars остаются в FPU, не выталкиваются в стек):
if (CheckSaveRet(Node) = True) and ((Node^.TypeF = T_Real) or (Node^.TypeF = T_Complex))  then goto endp;

if F_IntermediateLastNode = True then goto endp;  {.310}

//эти комманды не возвращают результат: (T_None)    {.197}
if Node^.TypeF = T_None then   goto endp;
*)


if F_SaveInFPU = False then
begin


 //if I < LFunc-1 then
 if Node^.Pr <> nil  {Node <> BeginTree} {Node^.NNode < LFunc - 1}  then
 begin


   dt:=F_DataType;

   {S:=Interp[I].S;
   NM:=Interp[I].NM;
   NL:=Interp[I].NL;
   N:=Interp[NM].NFunc;
   NF:=Interp[NM].NF; }

   S:=Node^.S;
   NL:=Node^.NL;
   N:=Node^.Pr^.NFunc;
   NF:=Node^.Pr^.NF;

   REA:=GetStackAdr(S,_RE);
   IMA:=GetStackAdr(S,_IM);

   CallT:=Alg.ExFunc[N].Func[NF].CallT;

   //Args. push in stack [ESP]
   if  (CallT = _STACK_VAL)  then    {.304}
   begin
     SaveArgStackVal(Node);
     goto endp;
   end;

   if  (CallT = _STACK_ADDR) or (CallT = _COMPILED) or (CallT = _MEMORY_ESP) or (CallT = _MEMORY_EAX) then      {.309}
   begin
     case Node^.ExtArg of
      D_Real:          dt:=_Double;
      D_Complex:       dt:=_Double;
      E_Real:          dt:=_Extended;
      E_Complex:       dt:=_Extended;
      S_Real:          dt:=_Single;
      S_Complex:       dt:=_Single;
      D_Array_Real:    dt:=_Pointer;
      S_Array_Real:    dt:=_Pointer;
      E_Array_Real:    dt:=_Pointer;
      I_Array_Real:    dt:=_Pointer;
      I_Real:          dt:=_Integer;
      I_Pointer:       dt:=_Pointer;
     end;
   end;

   if (Node^.TypeF = T_Real) and (Node^.COP = _LDINTFORM) then {.309}  //EAX -> MEM
   begin
      MOVREGM(R_EAX,REA);
   end
   else
   if Node^.TypeF = T_Real then
   begin
    FSTPM({GetStackAdr(S,_RE)}REA,{F_DataType}dt);
   end
   else
   if Node^.TypeF = T_Complex then
   begin
           //RE-ST(0); IM-ST(1)
      if  (CallT = _STACK_ADDR) then            {.309}
      begin
         sh:=0;
         if  dt = _Double    then  sh:=sh_D else
         if  dt = _Extended  then  sh:=sh_E;
         FSTPM(REA,dt);
         FSTPM(REA+sh,dt);
      end
      else
      begin
         FSTPM({GetStackAdr(S,_RE)}REA,{F_DataType}dt);
         FSTPM({GetStackAdr(S,_IM)}IMA,{F_DataType}dt);
      end;

   end
   else
   if Node^.TypeF = T_Array then
   begin    {arraycpu}
     //FSTPM({GetStackAdr(S,_RE)}REA,_Pointer);
     //POPF(REA);       {.197}        {.223}

      {.353}   //выгрузка адреса массива из EAX в стек выражения:
      MOVREGM(R_EAX,REA);
   end
   else
   if Node^.TypeF = T_Pointer then
   begin    {arraycpu}

      {.353}   //выгрузка содержимого указателя из EAX в стек выражения:
      MOVREGM(R_EAX,REA);
   end;
 end
 else   //результат последней комманды остаётся в стеке
 begin
  tf:=Node^.TypeF;

  if F_CalcType = T_Complex then
  begin
    case tf of
     T_Real:    begin FLDZ; FXCH1; end;
     //T_Array:  begin FLDZ; FXCH1; end;     {arraycpu}{.223}
    end;
  end
  else
   if F_CalcType = T_Real then
   begin
     if tf = T_Complex then
     begin
      FXCH1;
      FSTP0;
     end;
   end;
 end;


end
else
//////////////////////////////
if F_SaveInFPU = True then
begin

 //if I < LFunc-1 then
 if  Node^.Pr <> nil  {Node <> BeginTree} {Node^.NNode < LFunc - 1}  then
 begin
   {S:=Interp[I].S;
   NM:=Interp[I].NM;
   NL:=Interp[I].NL;
   N:=Interp[NM].NFunc;
   NF:=Interp[NM].NF; }

   S:=Node^.S;
   NL:=Node^.NL;
   N:=Node^.Pr^.NFunc;
   NF:=Node^.Pr^.NF;

   CallT:=Alg.ExFunc[N].Func[NF].CallT;

   //аргументы добавл. ф-ий выталкиваются в память:
  if (Node^.SData = _MEM) or (Node^.ExtArg <> 0) then
  begin

   if  (CallT = _STACK_VAL) {or ((CallT = _COMPILED) and (Interp[I].SData = _MEM))}  {.197} then
   begin
     SaveArgStackVal(Node{i});     {.197}
   end
   else
   if  (CallT = _STACK_ADDR)  then
   begin
     SaveArgStackAdr(Node{i});
   end
   else
   if CallT = _COMPILED then
   begin
      SaveArgPC(Node{i});     {.197}
   end
   else
   if (CallT = _MEMORY_ESP) or (CallT = _MEMORY_EAX)  then
   begin
      SaveArgMemAdr(Node{i})     {.197}
   end
   else
   //остальные 'external functions' (CallT=...) или .SData=_MEM
   begin
     if (Node^.TypeF = T_Real) and (Node^.COP = _LDINTFORM) then {.309}  //EAX -> MEM
     begin
       MOVREGM(R_EAX,GetStackAdr(S,_RE));
     end
     else
     if Node^.TypeF = T_Real then
     begin
       FSTPM(GetStackAdr(S,_RE),F_DataType);
     end
     else
     if Node^.TypeF = T_Complex then
     begin       //RE-ST(0); IM-ST(1)
       FSTPM(GetStackAdr(S,_RE),F_DataType);
       FSTPM(GetStackAdr(S,_IM),F_DataType);
     end
     else {.197}
     if Node^.TypeF = T_Array then    {arraycpu}
     begin
      //FSTPM(GetStackAdr(S,_RE),_Pointer);  {.223}

       {.353}   //выгрузка адреса массива из EAX в стек выражения:
       MOVREGM(R_EAX,GetStackAdr(S,_RE));
     end
     else {.197}
     if Node^.TypeF = T_Pointer then    {arraycpu}
     begin
       {.353}   //выгрузка содержимого указателя из EAX в стек выражения:
       MOVREGM(R_EAX,GetStackAdr(S,_RE));
     end;

   end
  end   //(Node^.SData = _MEM) or (Node^.ExtArg <> 0)


  else  {.353} //для всех остальных: целочисленные аргументы, возращающие результат в EAX сохраняются в стеке выражения всегда!
  begin

     if (Node^.TypeF = T_Real) and (Node^.COP = _LDINTFORM) then {.309}  //EAX -> MEM
     begin
       MOVREGM(R_EAX,GetStackAdr(S,_RE));
     end
     else
     if Node^.TypeF = T_Array then    {arraycpu}
     begin
      //FSTPM(GetStackAdr(S,_RE),_Pointer);  {.223}
      {.353}   //выгрузка адреса массива из EAX в стек выражения:
       MOVREGM(R_EAX,GetStackAdr(S,_RE));
     end
     else {.197}
     if Node^.TypeF = T_Pointer then    {arraycpu}
     begin
       {.353}   //выгрузка содержимого указателя из EAX в стек выражения:
       MOVREGM(R_EAX,GetStackAdr(S,_RE));
     end;

  end;

 end


 else   //результат последней комманды остаётся в стеке
 begin

      tf:=Node^.TypeF;

      if F_CalcType = T_Complex then
      begin
        case tf of
          T_Real:    begin FLDZ; FXCH1; end;
        // T_Array:  begin FLDZ; FXCH1; end;     {arraycpu}{.223}
        end;
      end
      else
      if F_CalcType = T_Real then
      begin
        if tf = T_Complex then
        begin
         FXCH1;
         FSTP0;
        end;
      end;

      //T_Array,T_Pointer,_LDINTFORM - остаются в EAX (если не являются аргументами добавляемых ф-ий)
 end;

end;

endp:
Node^.SData1:=F_SData;
end;



function TForevalH.CheckIfRet(Node: PNode{N: Integer}): Boolean;
begin
 {
  if Interp[Interp[N].NM].NFunc = CM_IF then
     begin
       if (Interp[N].NL = 4) or (Interp[N].NL = 6) then   CheckIfRet:=True
       else
       CheckIfRet:=False;
     end
  else
  CheckIfRet:=False;  }

  if Node^.Pr = nil then
  begin
    CheckIfRet:=False;
  end
  else
  begin
   if Node^.Pr^.NFunc = CM_IF then
     begin
       if (Node^.NL = 4) or (Node^.NL = 6) then   CheckIfRet:=True
       else
       CheckIfRet:=False;
     end
   else
   CheckIfRet:=False;
  end;
end;


function TForevalH.CheckNopRet(Node: PNode{N: Integer}): Boolean;
begin
//является аргументом NOP
//является аргументом PROG  {.316}
 { if Interp[Interp[N].NM].NFunc = CM_NOP then
  begin
    CheckNopRet:=True;
    SetLength(GotoLab,Length(GotoLab)+1);
    GotoLab[High(GotoLab)]:=NFunc;
  end
   else CheckNopRet:=False;   }
  if Node^.Pr = nil then
  begin
    CheckNopRet:=False;
  end
  else
  begin                       {.316}
    if Node^.Pr^.NFunc = {CM_NOP}CM_PROG then
    begin
     CheckNopRet:=True;
     SetLength(GotoLab,Length(GotoLab)+1);
     GotoLab[High(GotoLab)]:=Node;
    end
    else CheckNopRet:=False;
  end;
end;


function TForevalH.CheckSaveRet(Node: PNode{N: Integer}): Boolean;
begin
  {if Interp[Interp[N].NM].NFunc = CM_SAVE then CheckSaveRet:=True
   else CheckSaveRet:=False; }

  if Node^.Pr = nil then
  begin
    CheckSaveRet:=False;
  end
  else
  begin
    if Node^.Pr^.NFunc = CM_SAVE then CheckSaveRet:=True
     else CheckSaveRet:=False;
  end;
end;



function TForevalH.ReadReplFunc(Node: PNode{i: integer}): Boolean;
begin
//полное замещение:
if Node^.RRF = rf_FULL_REPLACE then
  begin
    if Node^.TypeF = T_Real then
    begin
     FLD(TAddress(@Func.RFStack[Node^.MRF]),F_DataType);
    end
    else
    if Node^.TypeF = T_Complex then
    begin
      FLD(TAddress(@Func.RFStack[Node^.MRF]),F_DataType);
      FLD(TAddress(@Func.RFStack[Node^.MRF-1]),F_DataType);
    end;
     ReadReplFunc:=True;
  end
  else
  ReadReplFunc:=False;
end;


procedure TForevalH.WriteReplFunc(Node: PNode{i: integer});
var
L: integer;
Addr: TAddress;
begin
//полное сохранение:
if (Node^.WRF = rf_FULL_REPLACE) then
 begin
  if Node^.TypeF = T_Real then
  begin
    Addr:=TAddress(@Func.RFStack[Node^.MRF]);
    FSTM(Addr,F_DataType);
  end
  else
  if Node^.TypeF = T_Complex then
  begin
   Addr:=TAddress(@Func.RFStack[Node^.MRF-1]);
   FSTM(Addr,F_DataType);
   FXCH1;
   Addr:=TAddress(@Func.RFStack[Node^.MRF]);
   FSTM(Addr,F_DataType);
   FXCH1;
  end
 end;
end;



function TForevalH.GetStackAdr(S,RT: Integer): Cardinal;
var
H: Integer;
begin
GetStackAdr:=0;
if F_Mode = M_Compile then        {.197}
begin
  if RT = _RE then GetStackAdr:=Cardinal(@Func.Stack[S].re)
  else
  if RT = _IM then GetStackAdr:=Cardinal(@Func.Stack[S].im);

    {DB}
    H:=High(Func.Stack);
    if (S < 0) or ( S > H) then
    begin
      Db_WriteStackDataOverFlow:=True;
    end;

end
else
GetStackAdr:=0;
end;





procedure TForevalH.LoadArgSTACK;
var
S,N,NF,j,Adr,Adr1,Adr2,tm,Arg: Cardinal;
sh,i: Integer;
begin
 N:=GNode^.NFunc;//N:=Interp[NFunc].NFunc;
 NF:=GNode^.NF;//NF:=Interp[NFunc].NF;
 S:=GNode^.S;//S:=Interp[NFunc].S;
 Arg:=GNode^.Arg;

 Adr:=GetStackAdr(S,_RE);
 j:=0;
 SetLength(Sadr,0);
 sh:=10;
//перезагрузка аргументов
 for i:=0 to  Arg-1 {Interp[NFunc].Arg-1} do
  begin
   //if Alg.ExFunc[N].Func[NF].TM[i] <> F_DataType then   // если '=', то арг-ты не перегружаются
   begin
    if Alg.ExFunc[N].Func[NF].TV[i]  =  T_Real then
    begin
      tm:=Alg.ExFunc[N].Func[NF].TM[i];
      Adr:=GetStackAdr(S+i,_RE);
       {.309}//off
     { if F_SaveInFPU = False then
      begin
       FLD(Adr,F_DataType);
       FSTPM(Adr,tm);
      end; }
      SetLength(SAdr,Length(SAdr)+1);   SAdr[High(SAdr)]:=Adr;
    end
    else
    if Alg.ExFunc[N].Func[NF].TV[i]  =  T_Complex then
    begin
       tm:=Alg.ExFunc[N].Func[NF].TM[i];
       Adr1:=GetStackAdr(S+i,_RE);  Adr2:=GetStackAdr(S+i,_IM);
        {.309}//off
       {
       if F_SaveInFPU = False then
       begin
        FLD(Adr2,F_DataType);
        FLD(Adr1,F_DataType);
        FSTPM(Adr1,tm);
        sh:=8; if tm = _Extended then sh:=16;
        FSTPM(Adr1+sh,tm);
       end;
       }
        SetLength(SAdr,Length(SAdr)+1);  SAdr[High(SAdr)]:=Adr1;
    end
    else
    if Alg.ExFunc[N].Func[NF].TV[i]  =  T_Array then
    begin
      //tm:=Alg.ExFunc[N].Func[NF].TM[i];
      Adr:=GetStackAdr(S+i,_RE);
       {.309}//off
     { if F_SaveInFPU = False then
      begin
       FILD(Adr);
       FISTP(Adr);
      end;  }
      SetLength(SAdr,Length(SAdr)+1);   SAdr[High(SAdr)]:=Adr;
    end;
   end;
 end;
end;




procedure TForevalH.LoadArgMEM;
var
S,N,NF,j,Adr,vs,Arg: Cardinal;
sh,i: Integer;
begin
if F_SaveInFPU = False then     {.197}
begin

  {
 N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 S:=Interp[NFunc].S;
 }
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 Arg:=GNode^.Arg;


 Adr:=GetStackAdr(S,_RE);
 j:=0;
sh:=sh_E;
//перезагрузка (уплоинение) аргументов   (из стека(32) в стек(16))
 for i:=0 to  Arg-1{Interp[NFunc].Arg-1} do
  begin
    if Alg.ExFunc[N].Func[NF].TV[i]  =  T_Real then
    begin
      vs:=Alg.ExFunc[N].Func[NF].TM[i];
      FLD(GetStackAdr(S+i,_RE),{F_DataType}vs);{.309}
      FSTPM(Adr+j*sh,vs);
      inc(j);
    end
    else
    if Alg.ExFunc[N].Func[NF].TV[i]  =  T_Complex then
    begin
      vs:=Alg.ExFunc[N].Func[NF].TM[i];
      FLD(GetStackAdr(S+i,_IM),{F_DataType}vs); {.309}
      FLD(GetStackAdr(S+i,_RE),{F_DataType}vs);  {.309}
      FSTPM(Adr+j*sh,vs);
      inc(j);
      FSTPM(Adr+j*sh,vs);
      inc(j);
    end
    else
    if Alg.ExFunc[N].Func[NF].TV[i]  =  T_Array then    {.197}
    begin      {arraycpu}
      {FLD(GetStackAdr(S+i,_RE),_Pointer);
      FSTPM(Adr+j*sh,_Pointer); }

      {PUSHF(GetStackAdr(S+i,_RE)) ;
      POPF(Adr+j*sh);}

       MOVMREG(R_EAX,GetStackAdr(S+i,_RE));             {.309}
       MOVREGM(R_EAX,Adr+j*sh);

      inc(j);
    end
 end;

end;
end;



procedure TForevalH.LoadArgPC;
var
S,N,NF,j,Adr,TM,TV,NL,Arg: Cardinal;
sh,k,i: Integer;
AddrM,AddrS: TAddress;
begin

  {
 N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 NL:=Interp[NFunc].NL;
 S:=Interp[NFunc].S;
  }
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 NL:=GNode^.NL;
 Arg:=GNode^.Arg;

 Adr:=GetStackAdr(S,_RE);
 (*
  {.309}
  //перезагрузка аргументов
 for i:=0 to  Arg-1 do
  begin
    TV:=Alg.ExFunc[N].Func[NF].TV[i];
    if  (TV =  T_Real) then
    begin
      TM:=Alg.ExFunc[N].Func[NF].TM[i];
      FLD(GetStackAdr(S+i,_RE),TM);
      FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[i],TM);
    end
    else
    if TV  =  T_Complex then
    begin
      TM:=Alg.ExFunc[N].Func[NF].TM[i];
      FLD(GetStackAdr(S+i,_RE),TM);
      FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[i],TM);
      FLD(GetStackAdr(S+i,_IM),TM);
      if TM = _Double   then FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[i]+SH_D,TM) else
         if TM = _Extended then FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[i]+SH_E,TM)
    end
    else
    if   (TV = T_Array) then
    begin   {arraycpu}
      {FLD(GetStackAdr(S+i,_RE),_Pointer);
      FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[i],_Pointer); }
      PUSHF(GetStackAdr(S+i,_RE));                        {.197}
      POPF(Alg.ExFunc[N].Func[NF].ArgAdr[i]);
    end
 end;
 *)


if F_SaveInFPU = True then
begin

  //т.к. в FPU-стеке запись наоборот:
  for k:={Interp[NFunc].Arg}Arg downto 1 do
  begin

      TV:=Alg.ExFunc[N].Func[NF].TV[k-1];
      TM:=Alg.ExFunc[N].Func[NF].TM[k-1];

      if  (TV =  T_Real)  then
      begin

         if (TM = _Integer) or (TM = _Pointer) then  {.357}
         begin
            MOVMREG(R_EAX,GetStackAdr(S+k-1,_RE));
            MOVREGM(R_EAX,Alg.ExFunc[N].Func[NF].ArgAdr[k-1]);
         end
         else
         begin
            if GNode^.RData[k-1] = _MEM then
               FLD(GetStackAdr(S+k-1,_RE),TM);

            FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[k-1],TM);
         end;

      end
      else
      if   TV = T_Array then      {arraycpu}
      begin
         {FLD(GetStackAdr(S+k-1,_RE),_Pointer);
         FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[k-1],_Pointer); }  {.197}

         {PUSHF(GetStackAdr(S+k-1,_RE));
         POPF(Alg.ExFunc[N].Func[NF].ArgAdr[k-1]);}

         MOVMREG(R_EAX,GetStackAdr(S+k-1,_RE));             {.309}
         MOVREGM(R_EAX,Alg.ExFunc[N].Func[NF].ArgAdr[k-1]);
      end
      else
      if  (TV =  T_Pointer)  then     {.357}
      begin
            MOVMREG(R_EAX,GetStackAdr(S+k-1,_RE));
            MOVREGM(R_EAX,Alg.ExFunc[N].Func[NF].ArgAdr[k-1]);
      end
      else
      if TV  =  T_Complex then
      begin
         if GNode^.RData[k-1] = _MEM then//if Interp[NFunc].RData[k-1] = _MEM then
         begin
            FLD(GetStackAdr(S+k-1,_RE),TM);
            FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[k-1],TM);
            FLD(GetStackAdr(S+k-1,_IM),TM);
            if TM = _Double   then FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[k-1]+SH_D,TM) else
               if TM = _Extended then FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[k-1]+SH_E,TM) else
                   if TM = _Single then FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[k-1]+SH_S,TM)
         end
         else  //in _FPU
         begin
            FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[k-1],TM);
            if TM = _Double   then FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[k-1]+SH_D,TM) else
               if TM = _Extended then FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[k-1]+SH_E,TM) else
                  if TM = _Single then FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[k-1]+SH_S,TM)
         end;
      end;

  end;

end
else
if F_SaveInFPU = False then      {.197}

begin

  {
 N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 NL:=Interp[NFunc].NL;
 S:=Interp[NFunc].S;
 }
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 NL:=GNode^.NL;
 Arg:=GNode^.Arg;

 Adr:=GetStackAdr(S,_RE);

//перезагрузка аргументов
 for i:=0 to  Arg-1{Interp[NFunc].Arg-1} do
  begin
    TV:=Alg.ExFunc[N].Func[NF].TV[i];
    if  (TV =  T_Real) then
    begin

      TM:=Alg.ExFunc[N].Func[NF].TM[i];
      FLD(GetStackAdr(S+i,_RE),TM);
      FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[i],TM);

    end
    else
    if TV  =  T_Complex then
    begin
      TM:=Alg.ExFunc[N].Func[NF].TM[i];
      FLD(GetStackAdr(S+i,_RE),TM);
      FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[i],TM);
      FLD(GetStackAdr(S+i,_IM),TM);
      if TM = _Double   then FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[i]+SH_D,TM) else
         if TM = _Extended then FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[i]+SH_E,TM) else
             if TM = _Single then FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[i]+SH_S,TM)
    end
    else
    if   (TV = T_Array) then
    begin   {arraycpu}
      {FLD(GetStackAdr(S+i,_RE),_Pointer);
      FSTPM(Alg.ExFunc[N].Func[NF].ArgAdr[i],_Pointer); }

      {PUSHF(GetStackAdr(S+i,_RE));
      POPF(Alg.ExFunc[N].Func[NF].ArgAdr[i]); }

       MOVMREG(R_EAX,GetStackAdr(S+i,_RE));             {.309}
       MOVREGM(R_EAX,Alg.ExFunc[N].Func[NF].ArgAdr[i]);
    end
    else
    if  (TV =  T_Pointer)  then     {.357}
    begin
        MOVMREG(R_EAX,GetStackAdr(S+i,_RE));
        MOVREGM(R_EAX,Alg.ExFunc[N].Func[NF].ArgAdr[i]);
    end
 end;

end;


end;


