 {.377}
procedure TForevalH.CRZLOG_C;
var
t1,N,NF,S,tma,tva: Integer;
AdrA: Cardinal;
FD: Extended;
Arg1,Arg2,Res: TComplex;
begin
// LOG(<Const(Real),Const(Complex)>, <Real,Complex> )

 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 t1:=GNode^.TypeA; //Alg.ExFunc[N].Func[NF].TV[0];

 LoadArg1;


  //  Log(Const(Real),Real/Complex)
 if GNode^.AI = 1 then        //  Const(Real)
 begin

   // LOG(ConstReal,Real)=Lg2(Real)*Log(ConstReal,2)     log(a,x)=lg2(x)*log(x,2)
   if t1 = T_Real then          //Const(Real),Real
   begin
     if (GNode^.FD > 0) and (GNode^.FD <> 1.0)  then              // log(a,x)
     begin
        FD:=  fc_LogN(GNode^.FD,2);

        FLD(WriteDataA(FD,_Extended),_Extended);

        MOVAadr(Cardinal(@R_CR_LOG));
        CALLA;

        CheckStack(1);
        CheckStack(-2);
     end
     else
     begin
        FLD(WriteDataA(GNode^.FD,_Extended),_Extended);
        MOVAadr(Cardinal(@R_LOGN));
        CALLA;
        CheckStack(2);
        CheckStack(-3);
     end;
   end
   else

   //  log(a,z1)= 1/ln(a)*(0.5*ln(z1.re^2+z1.im^2)+i*arg(z1))
   if t1 = T_Complex then       //Log(Const(Real),Complex)
   begin
     if (GNode^.FD > 0) and (GNode^.FD <> 1.0)  then              // log(a,z1)
     begin
        FD:=fc_LogN(GNode^.FD,c_exp1);// = 1/fc_Ln(abs(GNode^.FD));

        FLD(WriteDataA(FD,_Extended),_Extended);


        MOVAadr(Cardinal(@Z_CRe_CxLOG));
        CALLA;

        CheckStack(2);
        CheckStack(-3);
     end
     else
     begin
        FLD(WriteDataA(GNode^.FD,_Extended),_Extended);
        MOVAadr(Cardinal(@Z_ReCxLog));
        CALLA;
        CheckStack(3);
        CheckStack(-4);
     end;
   end;
 end
 else
 {.395}                                                          //    log(sin(ai),x)
 if GNode^.AI = 2 then        //  Log(Const(Complex),Real/Complex)
 begin
      if t1 = T_Real then     //  Log(Const(Complex),Real)     log(ai,x)=lg2(x)*log(ai,2)
      begin
            Arg1.re:= GNode^.FDC.re;   Arg1.im:= GNode^.FDC.im;
            Arg2.re:=2;    Arg2.im:=0;
            clogbase_acc(complex(Arg1),complex(Arg2),complex(Res));

            FLD(WriteDataA(Res.im,_Extended),_Extended);
            FLD(WriteDataA(Res.re,_Extended),_Extended);

            MOVAadr(Cardinal(@Z_CR_LOG));
            CALLA;

            CheckStack(1);
            CheckStack(-2);
      end
      else                                                        //      log(sin(ai),z1)
      if t1 = T_Complex then     //  Log(Const(Complex),Complex)     log(ai,z1) = lg2(z1)*log(ai,2)
      begin                      //  log(ai,z1) = 1/ln(ai)*(0.5*ln(z1.re^2+z1.im^2)+i*arg(z1))

            Arg1.re:= GNode^.FDC.re;   Arg1.im:= GNode^.FDC.im;
            cln_acc(complex(Arg1),complex(Res));
            Arg1.re:=1; Arg1.im:=0;
            cdiv_acc(complex(Arg1),complex(Res),complex(Res));

            FLD(WriteDataA(Res.im,_Extended),_Extended);
            FLD(WriteDataA(Res.re,_Extended),_Extended);

            MOVAadr(Cardinal(@Z_CZ_CxLOG));
            CALLA;

            CheckStack(2);
            CheckStack(-4);



      end;

 end;


 SetReg(1); SetReg(2); SetReg(3); SetReg(4);
end;



 {.377}
procedure TForevalH.CR2ZLOG_C;
var
t1,N,NF,S,tma,tva: Integer;
AdrA: Cardinal;
FD: Extended;
Arg1,Arg2,Res: TComplex;
begin
// LOG(<Real,Complex>, <Const(Real),Const(Complex)>)

 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 t1:=GNode^.TypeA; //Alg.ExFunc[N].Func[NF].TV[0];

 LoadArg1;
 // LOG(Real,ConstReal)=Lg2(ConstReal)/Lg2(Real)

 if GNode^.AI = 1 then        //Const(Real)
 begin
   if t1 = T_Real then          // log(Real, Const(Real))
   begin
     if (GNode^.FD > 0) and (GNode^.FD <> 1.0)  then          // log(x,a)
     begin
        FD:=  fc_LogN(2,GNode^.FD);

        FLD(WriteDataA(FD,_Extended),_Extended);

        MOVAadr(Cardinal(@R_CR2_LOG));
        CALLA;

        CheckStack(1);
        CheckStack(-2);
     end
     else
     begin
        FLD(WriteDataA(GNode^.FD,_Extended),_Extended);
        FXCH1;
        MOVAadr(Cardinal(@R_LOGN));
        CALLA;
        CheckStack(2);
        CheckStack(-3);
     end;
   end
   else


   if t1 = T_Complex then       //Log(Complex, Const(Real))
   begin
     if (GNode^.FD > 0) and (GNode^.FD <> 1.0)  then            // log(z1,a)
     begin
        FD:=2*fc_LN(GNode^.FD);

        FLD(WriteDataA(FD,_Extended),_Extended);

        MOVAadr(Cardinal(@Z_CRe2_CxLOG));
        CALLA;

        CheckStack(3);
        CheckStack(-4);
     end
     else
     begin
        FLD(WriteDataA(GNode^.FD,_Extended),_Extended);
        FXCH2; FXCH1;
        MOVAadr(Cardinal(@Z_CxReLog));
        CALLA;
        CheckStack(3);
        CheckStack(-4);
     end;
   end;
 end
 else

  //  Log(<Real,Complex>,Const(Complex))
 {.395}
 if GNode^.AI = 2 then       // Const(Complex)
 begin
                                                             //    log(x,sin(ai))
      if t1 = T_Real then     //  Log(Real,Const(Complex))     log(x,ai)-lg2(ai)/lg2(x)
      begin
            Arg1.re:= GNode^.FDC.re;   Arg1.im:= GNode^.FDC.im;
            Arg2.re:=2;    Arg2.im:=0;
            clogbase_acc(complex(Arg2),complex(Arg1),complex(Res));

            FLD(WriteDataA(Res.im,_Extended),_Extended);
            FLD(WriteDataA(Res.re,_Extended),_Extended);

            MOVAadr(Cardinal(@Z_CZ2_LOG));
            CALLA;

            CheckStack(1);
            CheckStack(-2);
      end
      else                                                   //    log(z1,sin(ai)^2)
      if t1 = T_Complex then     //  Log(Complex,Const(Complex))     log(z1,ai)-lg2(ai)/lg2(z1)
      begin                      //  log(z1,ai) = (0.5*ln(ai.re^2+ai.im^2)+i*arg(ai))/ln(z1)


            Res.re:=0.5*ln(sqr(GNode^.FDC.re)+sqr(GNode^.FDC.im));
            Res.im:=arctan2_acc(GNode^.FDC.im,GNode^.FDC.re);

            FLD(WriteDataA(Res.im,_Extended),_Extended);
            FLD(WriteDataA(Res.re,_Extended),_Extended);

            MOVAadr(Cardinal(@Z_CZ2_CxLOG));
            CALLA;

            CheckStack(2);
            CheckStack(-4);



      end;
 end;




 SetReg(1); SetReg(2); SetReg(3); SetReg(4);
