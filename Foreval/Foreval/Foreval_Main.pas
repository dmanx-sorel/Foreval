procedure TForevalH.IROOT_C;
var
t1,t2,N,NF,S,tv,tm,Num: Integer;
Adr1: TAddress;
begin
{
  При изменении функции также соответственно вносить изменения в блоке вычисления констант !!!
  IROOT_C   используется также в PowerAnalizator
}

 {N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 S:=Interp[NFunc].S; }
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;


  //t2:=Alg.ExFunc[N].Func[NF].TV[1];

if GNode^.AI = 2 then    //Root(Expr,IntForm)
begin

  LoadArg1;
  t1:=Alg.ExFunc[N].Func[NF].TV[0];

  {.395A}
  // root of 2,4,8,16 :              (используется также в PowerAnalizator)
  if (GNode^.TA2 = _IntConst) and
     ((GNode^.IC2 = 2) or (GNode^.IC2 = 4) or (GNode^.IC2 = 8) or (GNode^.IC2 = 16) )
  then
  begin

     if t1 = T_Real  then
     begin

         if GNode^.IC2 = 2 then
         begin
            FSQRT;
         end
         else
         if GNode^.IC2 = 4 then
         begin
            FSQRT; FSQRT;
         end
         else
         if GNode^.IC2 = 8 then
         begin
            FSQRT; FSQRT; FSQRT;
         end
         else
         if GNode^.IC2 = 16 then
         begin
            FSQRT; FSQRT; FSQRT; FSQRT;
         end;

     end
     else
     if t1 = T_Complex  then
     begin

         if GNode^.IC2 = 2 then
         begin
            MOVAadr(Cardinal(@Z_SQRT));   CALLA;
         end
         else
         if GNode^.IC2 = 4 then
         begin
            MOVAadr(Cardinal(@Z_SQRT));   CALLA;
            MOVAadr(Cardinal(@Z_SQRT));   CALLA;
         end
         else
         if GNode^.IC2 = 8 then
         begin
            MOVAadr(Cardinal(@Z_SQRT));   CALLA;
            MOVAadr(Cardinal(@Z_SQRT));   CALLA;
            MOVAadr(Cardinal(@Z_SQRT));   CALLA;
         end
         else
         if GNode^.IC2 = 16 then
         begin
            MOVAadr(Cardinal(@Z_SQRT));   CALLA;
            MOVAadr(Cardinal(@Z_SQRT));   CALLA;
            MOVAadr(Cardinal(@Z_SQRT));   CALLA;
            MOVAadr(Cardinal(@Z_SQRT));   CALLA;
         end;

         CheckStack(1);
         CheckStack(-1);

     end;



  end
  else  // other  root degrees
  begin

     LoadLineFormEAX(_Second);

     if t1 = T_Real  then
     begin
       MOVCadr(Cardinal(@R_IROOT));
       CALLC;
       CheckStack(2);
       CheckStack(-2);
     end
     else
     if t1 = T_Complex  then
     begin
        MOVBadr(Cardinal(@Z_CxIROOT));
        CALLB;
        CheckStack(2);
        CheckStack(-2);
     end;

     SetReg(1);  SetReg(2); SetReg(3);  SetReg(4);
  end;


end
else
if GNode^.AI = 1 then    //Root(RealNum,IntForm)
begin
    LoadLineFormEAX(_Second);
    FLD(WriteData(GNode),F_DataType);
    MOVCadr(Cardinal(@R_IROOT));
    CALLC;
    CheckStack(2);
    CheckStack(-2);

    SetReg(1);  SetReg(2); SetReg(3);  SetReg(4);
end
else    // не работает ->  IROOT3
if GNode^.AI = 3 then    //Root(Expr,IntForm1,IntForm2)
begin

    LoadLineFormEAX(_Second);  //IntForm2
    PUSHR(R_EAX);
    LoadLineFormEAX(_First);  //IntForm1
    POPR(R_EBX);


    LoadArg1;
    MOVCadr(Cardinal(@Z_CxIROOT3Int));
    CALLC;
    CheckStack(3);
    CheckStack(-3);

    SetReg(1);  SetReg(2); SetReg(3);  SetReg(4);
end;



end;




