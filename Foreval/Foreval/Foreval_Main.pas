function TForevalH.DeleteExternalBracketNegPS(PS: PString; var Neg: Integer): Boolean;
label
2,3,endp;
var
b,i,z,a: Integer;
Answ: Boolean;
begin
//SS:=Copy(S,1,Length(S));
z:=1;      Answ:=False;
2:
b:=0; a:=1;

if PS^ = '' then
begin
goto endp;
end;


if PS^[1] = '-' then a:=2;

if  PS^[a] = '(' then
begin

 b:=-1;
 for i:=a+1 to Length(PS^)-1 do
 begin
  if PS^[i] = '(' then b:=b-1;
  if PS^[i] = ')' then b:=b+1;
  if b = 0 then goto 3
 end;


 if PS^[Length(PS^)] = ')' then
 begin
   if a = 2 then
   begin
     Delete(PS^,1,1);
     z:=z*(-1);
   end;

   Answ:=True;
   Delete(PS^,1,1);
   Delete(PS^,Length(PS^),1);
   goto 2;
 end;

end;

3:
if z = -1 then  Neg:=-1 else  Neg:=1;


endp:
DeleteExternalBracketNegPS:=Answ;
end;






