   //загрузка указателя-переменной через команду _LDSA
   if Alg.Obj[ni].TypeF = T_Pointer then
   begin
      ND.COP:=_LDSA;
      ND.TypeF:=T_Pointer;
      ND.TypeM:=_Pointer;
      ND.AI:=tc_PointerVar;
   end;

   goto endp;
