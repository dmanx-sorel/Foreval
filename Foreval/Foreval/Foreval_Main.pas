i: Integer;
nv1,nv2,tv1,tv2,tm1,tm2,Len,code1,code2,code,IC2: Integer;
FD1,FD2: extended;
Str,Str1,Str2,Str3: String;
adr: Cardinal;
BH,BAnsw: Boolean;
Adr1,Adr2: TAddress;
begin
if F_SyntaxErrorCode <> 0 then goto endp;


LV1:=LV;
