begin
if F_SyntaxErrorCode <> 0 then goto endpp;


//LV1:=LV;   {.347}
SetLength(LV1,0);
ND1:=ND;
EOFN:=False;
Len:=Length(LV);
B_PolyU:=False;
{
if Len <> 2 then
begin
 F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
 F_SyntaxErrorString:=F_CurrentString;
 goto endp;
end;
}



{.207}

if Len = 2  then
begin

   SaveSW; {.229} {TryStrToFloat damage SW}

   Str2:=LV[1].Expression;
   Str1:=LV[0].Expression;

   //FindVarA(Str1,nv1,Adr1,tv1,tm1);
   //FindVarA(Str2,nv2,Adr2,tv2,tm2);
   FindVarAPS(@Str1,nv1,Adr1,tv1,tm1);   {.333}
   FindVarAPS(@Str2,nv2,Adr2,tv2,tm2);


   if tv1 = T_Array then
   begin
      ND1.N:=1;
      ND1.COP:=_Func;
      ND1.NFunc:=CM_POLY;
      ND1.NV1:=nv1;
      ND1.AI:=T_Array;
      SetLength(LV1,1);
      LV1[0].Expression:=Copy(Str2,1,Length(Str2));
      LV1[0].NL:=1;
      EOFN:=False;
      goto endp;
   end
   else
   if tv2 = T_Array then
   begin
      ND1.N:=1;
      ND1.COP:=_Func;
      ND1.NFunc:=CM_POLY;
      ND1.NV1:=nv2;
      ND1.AI:=T_Array;
      SetLength(LV1,1);
      LV1[0].Expression:=Copy(Str1,1,Length(Str1));
