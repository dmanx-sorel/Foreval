procedure TForevalH.AddCommand(Node:PNode {I: Integer});
label endp,extf;
var
N,NF,RType,S,R,SDeep,CLS: Integer;
Expr: String;
begin

GNode:=Node;
//Expr:=Interp[i].Expression; //db
{
S:=Interp[I].S;
N:=Interp[NFunc].NFunc;
NF:=Interp[NFunc].NF;
InitMEM(Cardinal(@Interp[NFunc].MEM));
 }
S:=Node^.S;
N:=Node^.NFunc;
NF:=Node^.NF;


if Node^.COP = _LDSC then
begin
 FLD(WriteData(Node),F_DataType);
end
else
if Node^.COP = _LDSCX then
begin
  if Node^.TC = C_Real then
  begin
    FLD(WriteDataA(Node^.FDC.re,F_DataType),F_DataType)
  end
  else
  if Node^.TC = C_Image then
  begin
    FLD(WriteDataA(Node^.FDC.im,F_DataType),F_DataType);
    FLDZ;
  end
  else
  if {Interp[I]}Node^.TC = C_Complex then
  begin
    FLD(WriteDataA(Node^.FDC.im,F_DataType),F_DataType);
    FLD(WriteDataA(Node^.FDC.re,F_DataType),F_DataType);
  end;
end
else
if Node^.COP = _LDSF then
begin
 N:=Node^.NObj;
 LDSF_C(N);
end
else
if Node^.COP = _LDSA then    {.347}
begin
  //загрузка указателя в EAX
  LDSA_C;
end
{else
if Interp[I].COP = _JMP then
begin
 JMP_C(I);
end  }
else
if Node^.COP = _FLD then
begin
 FLD_C(Node);
end
else
if Node^.COP = _LDINTFORM then    {.309}
begin
 LoadLineFormEAX(_First);
 GNode^.ExtArgPlace:=R_EAX;
end
else
if Node^.COP = _FUNC then
