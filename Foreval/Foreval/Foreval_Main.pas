procedure TForevalH.NOT_RM(Reg: Integer; MEM: TAddress);
begin


 if (Reg = R_EAX) and (MEM = 0) then  AddByte2($F7,$D0)  //not eax
 else
 if (Reg = R_EAX) and (MEM = R_EAX) then  AddByte2($F7,$10)  //not [eax]
 else
 if ((Reg = _ABSENT) or (Reg = 0)) and (MEM <> 0) then
 begin
      AddByte2($F7,$15);   //not [MEM]
      AddAddress(MEM);
 end;

 if (Reg <> _ABSENT) or (Reg <> 0) then SetReg(Reg);
end;



