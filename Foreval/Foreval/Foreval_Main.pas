procedure TForevalH.CALL_C;
var
t1,N,NF,S,nv,TM,NM: Integer;
Adr,AdrM,AddrF,Sdeep: Cardinal;
begin
 {N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 S:=Interp[NFunc].S; }

 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 nv:=GNode^.NV1;
 t1:=Alg.ExFunc[N].Func[NF].TV[0];
 //nv:=Interp[NFunc].NV1;
 Adr:=Alg.Obj[nv].Addr;  //адрес переменной
 TM:=Alg.Obj[nv].MType;

 AddrF:=GNode^.Addr1; //адрес функции

 NM:=GNode^.NObj;
 AdrM:=Alg.Obj[NM].Addr;  //адрес массива
 TM:=Alg.Obj[NM].MType;


  //CALL(Pointer)
 if GNode^.AI = 1 then
 begin
      //CALL addr
      AddWord($FF,$15);
      AddAddress(Adr);

 end
 else  //CALL(@Func)
 if GNode^.AI = 4 then
 begin
      //AddWord($FF,$15);
      //AddAddress(AddrF);
      SDeep:=Alg.ExFunc[GNode^.NObj].Func[0].SDeep;
      MOVAadr(AddrF);
      CALLA;
 end
 else
  //вызов сохранённого адреса в стеке. Исп-ся через преобразование типов
       //extf()=sqrt(x)      ptrf:pointer=@extf;  adrI:int=integer(ptrf); callR(pointer(adri))
 if GNode^.AI = 6 then
 begin
    MOVMREG(R_EAX,GetStackAdr(S,_RE));
    CALLA;
 end
 else
 begin
   //Call(Vec[IntConst])
   if GNode^.AI = 5 then
   begin
      //IntConst -> EAX;
      MOVCREG(R_EAX,Trunc(GNode^.FD));
   end
   else
   //CALL(VecInt[IntForm])
   if GNode^.AI = 3 then  //Vec[AIVP]  - vec[IntForm]
   begin
      //AIVP1 -> EAX;
      LineFormN(GNode^.AIVP1,Trunc(GNode^.FD));
   end
   else
   //CALL(VecInt[IntVar])
   if GNode^.AI = 2 then
   begin
     MOVMA(Adr);

   (*
   LoadArg1;
   //trunc
   PUSHCW;    {.227}
   FLDCW(TAddress(@FCW1));
   MEM:=WriteDataA(0,_Integer);
   FISTP(MEM);
   POPCW;    {.227} //FLDCW(TAddress(@FCW2));
   MOVMC(MEM);
   *)
   end
   else
   if GNode^.AI = 0 then     //Vec[Trunc(Stack)]
   begin
     LoadArg1;
     //trunc
     (*
     PUSHCW;    {.227}
     FLDCW(TAddress(@FCW1));
     MEM:=WriteDataA(0,_Integer);
     FISTP(MEM);
     POPCW;    {.227} //FLDCW(TAddress(@FCW2));
     //MOVMC(MEM);
     MOVMA(MEM);
     *)

     //TRUNCR(R_EAX);
     FISTPR(R_EAX); {.387}
 end;


   //  CALL   EAX



   MOVBadr(AdrM);                    //Addr(Vec) -> EBX
    //mov  ebx, [ebx]:
   AddByte($8B); AddByte($1B);      //Addr(Vec[0]) -> EBX
    //mov eax, [ebx+4*eax]
   AddByte($8B); AddByte($04);AddByte($83);    //Vec[indx]->EAX

   CALLA;
 end;

 {.375C}
 if GNode^.AI = 4 then  //явное указание вызываемой ф-ии
 begin
   if N = CM_CALLR then
   begin
    CheckStack(Sdeep);
    if  (SDeep > 1) then CheckStack(-(SDeep-1));
   end
   else
   if N = CM_CALLCX then
   begin
    CheckStack(Sdeep);
    if  (SDeep > 2) then CheckStack(-(SDeep-2));
   end
   else
   if N = CM_CALL then
   begin
    CheckStack(Sdeep);
    CheckStack(-Sdeep);
   end;
 end
 else
 begin

   if N = CM_CALLR then
   begin
    CheckStack(8);
    CheckStack(-7);
   end
   else
   if N = CM_CALLCX then
   begin
    CheckStack(8);
    CheckStack(-6);
   end
   else
   if N = CM_CALL then
   begin
    CheckStack(8);
    CheckStack(-8);
   end;

 end;


end;




