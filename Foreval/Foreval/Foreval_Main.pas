procedure TForevalH.GetSizeInterp;
label endp;
var
E: Exception;
begin
if F_SyntaxErrorCode <> 0 then goto endp;

LInterp:=1;

Tree:=BeginTree; //не обязательно, т.к. чтение дерева - циклически

while Tree^.Ch <> nil do
begin
  Tree:=Tree^.Ch;
end;
//COP=NOP:
inc(LInterp);

while Tree^.Pr <> nil do
begin

 while Tree^.Nb <> nil  do
 begin
   Tree:=Tree^.Nb;
   while Tree^.Ch <> nil do
   begin
    Tree:=Tree^.Ch;
   end;

   //COP=NOP:
   inc(LInterp);
 end;
  //COP<>NOP:
  Tree:=Tree^.Pr;
  inc(LInterp);
end;

endp:

end;


