   ND1.N:=4;
   ND1.NFunc:=CM_POLYDIFFN;
   EOFN:=False;
 end;

 endp:
end;



procedure TForevalH.PolyUReWrite;
var
 Node: PNode;



       procedure   PolyReWriteConst(PolyNode: PNode);
       label endp;
       var
        PrevNode,NextNode,NbNode,PrNode: PNode;
        NCHLD: TArrayPN;
        LenCh,LenChCnst, LenChExpr,NL,S,k,TC,TV,RetType,NP,PosN: Integer;
        ConstNode,ExprNode,CnstPos,ArgTypesExpr: TArrayI;




       begin

        if PolyNode^.NFunc = CM_POLYU then
        begin

          GetAllChilds(PolyNode,NCHLD);
          LenCh:=Length(NCHLD);
          if LenCh = 0 then goto endp;
          ConstNode:=nil; ExprNode:=nil; CnstPos:=nil; ArgTypesExpr:=nil;
          //N:=PolyNode^.NFunc;
          //NF:=PolyNode^.NF;
          TC:=T_Real;
          TV:= PolyNode^.ArgTypes[High(PolyNode^.ArgTypes)];  //тип выражения переменной
          //tv:=Alg.ExFunc[N].Func[NF].TV[0];   //тип выражения переменной

           //проверка на константу
           //-> генерировать команды   _LDSC ,_LDSCX
           //poly(a*b+c*d,x)  poly(ai*b+ci*d,z1) poly(ai*b+c*di,x) poly(a*b+c*d,z1)
          if LenCh = 1 then
          begin

             if NCHLD[0]^.COP = _LDSC then
             begin
                PolyNode^.COP:=_LDSC;
                PolyNode^.N:=0;
                PolyNode^.TC:=T_Real;
                PolyNode^.FD:=NCHLD[0]^.FD;
                PolyNode^.FDC.re:=NCHLD[0]^.FD;
                PolyNode^.FDC.im:=0;
                FreeNode(NCHLD[0]);
                PolyNode^.Ch:=nil;
                F_PolyReWrite := True;
                goto endp;
             end
             else
             if NCHLD[0]^.COP = _LDSCX then
             begin
                PolyNode^.COP:=_LDSCX;
                PolyNode^.N:=0;
                PolyNode^.TC:=T_Complex;
                PolyNode^.FDC.re:=NCHLD[0]^.FDC.re;
                PolyNode^.FDC.im:=NCHLD[0]^.FDC.im;
                FreeNode(NCHLD[0]);
                PolyNode^.Ch:=nil;
                F_PolyReWrite := True;
                goto endp;
             end;

          end;

          PosN:=0;
          //CnstPos - позиции вычисленных конст. аргументов в VPF
          //определение узлов с константами и выражениями
          for k := 0 to LenCh-2 do   //последний эл-т (LenCh-1) - VarExper
          begin

            //просчитывание позиций уже заполненных числами коэфф.:
            if PosN <= High(PolyNode^.VFP)  then    //не обязательно
            begin
               while  PolyNode^.VFP[PosN].indx >= 0 do
               begin
                 inc(PosN);
               end;
            end;

            if (NCHLD[k]^.COP = _LDSC) or (NCHLD[k]^.COP = _LDSCX) then
            begin
              SetLength(ConstNode,Length(ConstNode)+1);
              ConstNode[High(ConstNode)]:=k;
              if NCHLD[k]^.COP = _LDSCX then TC:=T_Complex;

              SetLength(CnstPos,Length(CnstPos)+1);
              CnstPos[High(CnstPos)]:=PosN;
              inc(PosN);
            end
            else
            begin
              SetLength(ExprNode,Length(ExprNode)+1);
              ExprNode[High(ExprNode)]:=k;
              inc(PosN);
              //сохранение типов вытекающих узлов:
              SetLength(ArgTypesExpr,Length(ArgTypesExpr)+1);
              ArgTypesExpr[High(ArgTypesExpr)]:=PolyNode^.ArgTypes[k];
            end;

          end;   //for
          //последний вытекающий узел - VarExpr:
          SetLength(ArgTypesExpr,Length(ArgTypesExpr)+1);
          ArgTypesExpr[High(ArgTypesExpr)]:=PolyNode^.ArgTypes[High(PolyNode^.ArgTypes)];


          LenChExpr:=Length(ExprNode);
          LenChCnst:=Length(ConstNode);

          if  LenChCnst = 0 then goto endp;

          //перезапись выражений с константами
          for k := 0 to LenChCnst-1 do
          begin
              if NCHLD[ConstNode[k]]^.COP = _LDSC then
              begin
                NP:=CnstPos[k];
                PolyNode^.VFP[NP].Re:=NCHLD[ConstNode[k]]^.FD;
                PolyNode^.VFP[NP].indx:=NP;
                PolyNode^.VFP[NP].tc:=T_Real;
               {
                PolyNode^.VFP[ConstNode[k]].Re:=NCHLD[ConstNode[k]]^.FD;
                PolyNode^.VFP[ConstNode[k]].indx:=ConstNode[k];
                PolyNode^.VFP[ConstNode[k]].tc:=T_Real;
                }
              end;

              if NCHLD[ConstNode[k]]^.COP = _LDSCX then
              begin
                NP:=CnstPos[k];
                PolyNode^.VFP[NP].Re:=NCHLD[ConstNode[k]]^.FDC.re;
                PolyNode^.VFP[NP].Im:=NCHLD[ConstNode[k]]^.FDC.im;
                PolyNode^.VFP[NP].indx:=NP;
                PolyNode^.VFP[NP].tc:=T_Complex;
                {
                PolyNode^.VFP[ConstNode[k]].Re:=NCHLD[ConstNode[k]]^.FDC.re;
                PolyNode^.VFP[ConstNode[k]].Re:=NCHLD[ConstNode[k]]^.FDC.im;
                PolyNode^.VFP[ConstNode[k]].indx:=ConstNode[k];
                PolyNode^.VFP[ConstNode[k]].tc:=T_Complex;
                }
              end;

            //удаление
             FreeNode(NCHLD[ConstNode[k]]);
          end;

          //все элементы - константы -> генерировать команду CM_POLY
          if LenChExpr = 0 then
          begin
            PolyNode^.NFunc:=CM_POLY;
            PolyNode^.N:=1;
            PolyNode^.AI:=T_Complex;   //тип полинома по типу аргумента:T_Array ; T_Complex(T_Real or T_Complex)
            if (TV = T_Real) and (TC = T_Real) then RetType:=T_Real else RetType:=T_Complex;
            PolyNode^.TypeF:=RetType;    //возвращаемый тип полинома
            PolyNode^.NF:=FindExeFunc1V(CM_POLY,TV);
            //PolyNode^.Ch:=nil;
            PolyNode^.Ch:=NCHLD[High(NCHLD)]; //указатель  на VarExpr  (только один вытекающий узел)
            F_PolyReWrite:=True;

            goto  endp;
          end;


           //восстановление данных в узлах (для CM_POLYU):
           PolyNode^.N:= PolyNode^.N-LenChCnst;
           S:=PolyNode^.S;
           NL:=1;

           //1-ый
           PolyNode^.Ch:=NCHLD[ExprNode[0]];
           //NCHLD[ExprNode[0]]^.Nb:=NCHLD[High(NCHLD)];  //ссылка первого эл-та на последний с VarExpr(не содержится в ExprNode) Для случая с одним выражением  poly(2,y,2+3*4,x)
           NCHLD[ExprNode[0]]^.S:=S;
           NCHLD[ExprNode[0]]^.NL:=NL;
           inc(S);
           inc(NL);
           //остальные
           for k := 1 to LenChExpr-1 do
           begin
             NCHLD[ExprNode[k]]^.S:=S;
             NCHLD[ExprNode[k]]^.NL:=NL;
             inc(S);
             inc(NL);
             NCHLD[ExprNode[k-1]]^.Nb:=NCHLD[ExprNode[k]];
           end;
           //последний
           NCHLD[ExprNode[High(ExprNode)]]^.Nb:=NCHLD[High(NCHLD)];

           //VarExpr  (в ExprNode не входит VarExpr):
           NCHLD[High(NCHLD)]^.S:=S;
           NCHLD[High(NCHLD)]^.NL:=NL;

           //восстановлеие и перезапись типов оставшихся аргументов (вытекающих узлов)
           SetLength(PolyNode^.ArgTypes,Length(ArgTypesExpr));
           for k := 0 to High(ArgTypesExpr) do
           begin
              PolyNode^.ArgTypes[k]:=ArgTypesExpr[k];
           end;




           F_PolyReWrite:=True;
           //FirstNode:=GetLowLeftNode(BeginTree);  //реинициализация
           //восстановление указателей в линейном списке
           //InitSequentList;
        end;


        endp:
       end;



begin

 F_PolyReWrite:=False;

 Node:=FirstNode;

 while Node <> nil do
 begin
   if Node^.NFunc = CM_POLYU then PolyReWriteConst(Node);
   Node:=Node^.Next;
 end;

 if F_PolyReWrite = True then
 begin
    FirstNode:=GetLowLeftNode(BeginTree);  //реинициализация
    //восстановление указателей в линейном списке
    InitSequentList;
    //восстановление
    //SetExtArg;
 end;
end;





