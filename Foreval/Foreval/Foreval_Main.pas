function TForevalH.CheckOperationOnCompound(NameOP: String; PStr: PString; PosOP: Cardinal): Boolean;
label endp;
var                                       //PNameOP: Имя операции; PStr: Полная строка выражения с операцией; PosOP: позиция этой операции в этой строке
i,nf,Pop1,Pop2,Lop: Integer;
BAnsw: Boolean;
begin
BAnsw:=False;
for i:=0 to High(Alg.Opr) do
begin

 Pop1:=Pos(NameOP,Alg.Opr[i].Name);
 if Pop1 > 0 then
 begin
  Pop2:=Pos(Alg.Opr[i].Name,PStr^);
  if (Pop2 > 0) and (PosOP >= Pop2) and (Length(NameOP)+PosOP <= (Alg.Opr[i].LenOp+Pop2)) then
  begin
    BAnsw:=True;
    goto endp;
  end;

 end;

end;

endp:
CheckOperationOnCompound:=BAnsw;
end;




procedure TForevalH.SetStackSize;
{
 StackSize -
 Вычисление требуемого максимального числа ячеек памяти ( для сохранения промежуточных результатов вычислений)
}
label endp;
begin
if F_SyntaxErrorCode <> 0 then goto endp;
Tree:=BeginTree;   //не обязательно, т.к. чтение дерева - циклически

while Tree^.Ch <> nil do
begin
Tree:=Tree^.Ch;
end;
StackSize:=Tree^.Stack.S;

while Tree^.Pr <> nil do
begin
 while Tree^.Nb <> nil  do
 begin
 Tree:=Tree^.Nb;
  while Tree^.Ch <> nil do
  begin
  Tree:=Tree^.Ch;
  end;
if Tree^.Stack.S > StackSize then StackSize:=Tree^.Stack.S;
 end;
 Tree:=Tree^.Pr;
if Tree^.Stack.S > StackSize then StackSize:=Tree^.Stack.S;
end;


endp:
end;






