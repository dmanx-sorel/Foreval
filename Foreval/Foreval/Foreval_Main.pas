{.383}
procedure TForevalH.AddOperationSymbToList(OpSymb: Char; NArg: Integer; Placement: Integer);
begin

 if (NArg = 2) and (Placement = _Any) then
 begin
    Include(Operation2Arg, AnsiChar(OpSymb));
    Include(BeforeProcDisableSymb, AnsiChar(OpSymb));
    Include(AfterProcDisableSymb, AnsiChar(OpSymb));
    Include(BeforeFuncEnableSymb, AnsiChar(OpSymb));
    Include(AfterFuncEnableSymb, AnsiChar(OpSymb));
    Include(BetweenRoundBracketEnableSymb, AnsiChar(OpSymb));
    Include(BeforeBracketEnableSymb, AnsiChar(OpSymb));
 end
 else
 if (NArg = 2) and (Placement = _Before) then
 begin
   Include(BeforeFuncEnableSymb, AnsiChar(OpSymb));
   Include(BeforeBracketEnableSymb, AnsiChar(OpSymb));
 end
 else
 if (NArg = 1) and (Placement = _Before) then
 begin
   Include(BeforeFuncEnableSymb, AnsiChar(OpSymb));
   Include(BeforeBracketEnableSymb, AnsiChar(OpSymb));
   Include(BeforeProcDisableSymb, AnsiChar(OpSymb));
 end;

end;



{.217}
procedure TForevalH.InitTableRF;
var
 i,j,L: integer;
begin
 SetLength(TableRF,Length(Alg.ExFunc),Length(Alg.ExFunc));

 L:=Length(Alg.ExFunc);
 for i := 0 to L - 1 do
 begin
   for j := 0 to L - 1 do
   begin
        TableRF[i,j].WRF_R:=rf_NO_REPLACE;    //=0
        TableRF[i,j].RRF_R:=rf_NO_REPLACE;    //=0
        TableRF[i,j].WRF_Z:=rf_NO_REPLACE;    //=0
        TableRF[i,j].RRF_Z:=rf_NO_REPLACE;    //=0
        TableRF[i,j].NMEM_R:=0;    //=0
        TableRF[i,j].NMEM_Z:=0;    //=0
        TableRF[i,j].SHFT_R:=0;    //=0
        TableRF[i,j].SHFT_Z:=0;    //=0
        if i=j  then
        begin
          TableRF[i,j].WRF_R:=rf_FULL_REPLACE;
          TableRF[i,j].RRF_R:=rf_FULL_REPLACE;
          TableRF[i,j].NMEM_R:=1;
          TableRF[i,j].WRF_Z:=rf_FULL_REPLACE;
          TableRF[i,j].RRF_Z:=rf_FULL_REPLACE;
          TableRF[i,j].NMEM_Z:=2;
        end;
   end;

   //используется только для функций из TableRF[]
   Alg.ExFunc[i].ReplFuncCFZ:=_YES;
   Alg.ExFunc[i].ReplFuncCFR:=_YES;
 end;

{
  WRF_R -> RRF_R
  WRF_R - ранг сохранения функции: либо полное (=rf_FULL_REPLACE) , либо часть (или несколько частей)
  RRF_R - ранг считывания функции: либо полное (=rf_FULL_REPLACE) , либо часть (или несколько частей)
          NMEM_R, NMEM_Z - число сохраняемых чисел для real/complex функции (для complex - минимум = 2)
          частичное сохранение для функции возможно только одного ранга (независимо от: все ли части будут использованы считывающими функциями или нет)
          напр.: sh->ch сохраняются (WRF_R=rf_EXPR2_REPLACE) "exp", "1/exp" и считываются (ch) оба значения (RRF_R=rf_EXPR2_REPLACE)
                 sh->th сохраняются!! (WRF_R=rf_EXPR2_REPLACE) "exp", "1/exp" , но считывается (th) только "exp" (RRF_R=rf_EXPR1_REPLACE)
 SHFT_R - сдвиг к нужному результату (относительно последнего (всех сохраняемых чисел: NMEM_R/NMEM_Z )) для считывающей функции (если сохраняется чисел больше, чем считывается)
          напр.: sin->cos    сохраняются два (NMEM_R=2)(fsincos: [1]cos,[2]sin); cos считывает одно (первое), сдвиг = 1 (SHFT_R)
          напр.: sinh->tanh    сохраняются четыре (NMEM_Z=4)( [1]RE(exp),[2]IM(exp),[3]RE(1/exp),[4]IM(1/exp))); tanh считывает два первых, сдвиг = 2 (SHFT_Z)
                 (сдвиг указывает на последнее нужное число)
 функция может сохранить результат дважды: полное сохранение  (rf_FULL_REPLACE) и частичное (но только одного ранга)
}
                {  SIN    }
 TableRF[CM_SIN,CM_COS].WRF_R:=rf_COSSINR_REPLACE;
 TableRF[CM_SIN,CM_COS].RRF_R:=rf_FULL_REPLACE;
 TableRF[CM_SIN,CM_COS].NMEM_R:=2;
 TableRF[CM_SIN,CM_COS].SHFT_R:=1;
 TableRF[CM_SIN,CM_COS].WRF_Z:=rf_EXPZ2_REPLACE;
 TableRF[CM_SIN,CM_COS].RRF_Z:=rf_EXPZ2_REPLACE;
 TableRF[CM_SIN,CM_COS].NMEM_Z:=4;

 TableRF[CM_SIN,CM_COSEC].WRF_R:=rf_COSSINR_REPLACE;
 TableRF[CM_SIN,CM_COSEC].RRF_R:=rf_SINR_REPLACE;
 TableRF[CM_SIN,CM_COSEC].NMEM_R:=2;
 TableRF[CM_SIN,CM_COSEC].WRF_Z:=rf_EXPZ2_REPLACE;
 TableRF[CM_SIN,CM_COSEC].RRF_Z:=rf_EXPZ2_REPLACE;
 TableRF[CM_SIN,CM_COSEC].NMEM_Z:=4;

 TableRF[CM_SIN,CM_SEC].WRF_R:=rf_COSSINR_REPLACE;
 TableRF[CM_SIN,CM_SEC].RRF_R:=rf_COSR_REPLACE;
 TableRF[CM_SIN,CM_SEC].NMEM_R:=2;
 TableRF[CM_SIN,CM_SEC].SHFT_R:=1;
 TableRF[CM_SIN,CM_SEC].WRF_Z:=rf_EXPZ2_REPLACE;
 TableRF[CM_SIN,CM_SEC].RRF_Z:=rf_EXPZ2_REPLACE;
 TableRF[CM_SIN,CM_SEC].NMEM_Z:=4;

 TableRF[CM_SIN,CM_TAN].WRF_Z:=rf_EXPZ2_REPLACE;
 TableRF[CM_SIN,CM_TAN].RRF_Z:=rf_EXPZ1_REPLACE;
 TableRF[CM_SIN,CM_TAN].NMEM_Z:=4;
 TableRF[CM_SIN,CM_TAN].SHFT_Z:=2;

 TableRF[CM_SIN,CM_COTAN].WRF_Z:=rf_EXPZ2_REPLACE;
 TableRF[CM_SIN,CM_COTAN].RRF_Z:=rf_EXPZ1_REPLACE;
 TableRF[CM_SIN,CM_COTAN].NMEM_Z:=4;
 TableRF[CM_SIN,CM_COTAN].SHFT_Z:=2;

 {
  COSSIN <-> COS,SIN,SEC,COSEC: исключение, т.к. используются подстановки между функциями с разными выходными типами: Complex vs Real.
  Не предусмотрено в оптимизации Replace...
 }
 {.331}
 TableRF[CM_SIN,CM_COSSIN].WRF_R:=rf_COSSINR_REPLACE;
 TableRF[CM_SIN,CM_COSSIN].RRF_R:=rf_FULL_REPLACE;
 TableRF[CM_SIN,CM_COSSIN].NMEM_R:=2;
