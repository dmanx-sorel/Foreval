       FXCH1;
       FMUL04;    //st(0):RE(exp^-1)
          Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);               //  RE(exp^-1) ->
       FSTM(Addr,F_DataType);
       FXCH3;
       FMUL02;    //st(0):IM(exp)
          Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);               //  IM(exp) ->
       FSTM(Addr,F_DataType);
       FXCH2;
       FMULP4;       //  RE(exp),IM(exp),RE(exp^-1),IM(exp^-1)
       FADDP2;
       FXCH2;       //st(0):IM(exp^-1)
       FCHS;
          Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);                 //  IM(exp^-1) ->
       FSTM(Addr,F_DataType);
       FADDP2;
       FMUL_C05;
       FXCH1;
       FMUL_C05;
       FXCH1;
       ZDIVR_C1;
       {@@L_ZSEC_END:}
            L2:=Length(IComp);
            L2:=L2-L1;

            *)

   end
   else
   if (GNode^.RRF = rf_EXPZ2_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE)   then
   begin
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-2]),F_DataType);    // -> IM(exp)
        FADD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);      // IM(exp)-IM(exp^-1)
        FMUL_C05; // st(0):IM
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-3]),F_DataType);    // -> RE(exp)
        FADD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);      // RE(exp)-RE(exp^-1)
