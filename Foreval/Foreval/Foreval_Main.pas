          //fstp  qword ptr [ebx+8*ecx]:
           AddByte($DD); AddByte($1C);AddByte($CB);
      end;
   end;
end
else
if tm = _Extended then
begin
   if Addr = R_EBX then
   begin
      if REG_indx = R_EAX then
      begin
         //lea   eax,[eax+4*eax]:
         AddByte($8D); AddByte($04);AddByte($80);
         //fstp   tbyte ptr [ebx+2*eax]:
         AddByte($DB); AddByte($3C);AddByte($43);
      end
      else
      if REG_indx = R_ECX then
      begin
          //lea   ecx,[ecx+4*ecx]:
          AddByte($8D); AddByte($0C);AddByte($89);
         //fstp   tbyte ptr [ebx+2*ecx]:
          AddByte($DB); AddByte($3C);AddByte($4B);
      end;
   end;
end;




CheckStack(-1);
end;



procedure TForevalH.SAVE_C;
label err1,endp;
var
N,N1,N2,NF,NV,NM,tf,tv,ts,sh,TM,TM2,TMA,tva,ta1,code2,ArgForm1,ArgForm2,S,IC3,IC2,RegRes,ComCode,PlacementArg: Integer;
AdrM,AdrM2,AdrA,AdrP,Num,AddrA1,AddrA2,AddrObj,AddrI,AddrI1,AddrI2,AddrI3: Cardinal;
IM1,IM2: Integer;
begin
//Аргументы SAVE не выталкиваются в память после вычислений (в SaveResult)( SaveResult: if CheckSaveRet(Node) then goto endp; )
//и в любом режиме остаются в FPU. Иначе - испльзовать LoadArg1, LoadArg2
//Некоторые ошибки , связанные с присвоением разных типов,  отлавливаются только здесь в Save_c



 N:=GNode^.NObj;
 N1:=GNode^.NFunc;
 NF:=GNode^.NF;
 tf:=Alg.ExFunc[N1].Func[NF].TV[0];
 tv:=Alg.Obj[N].TypeF;
 tm:=Alg.Obj[N].MType;
 TS:=GNode^.TS;
 sh:=GetSizeSh(tm);
 //if Alg.Obj[N].MType = _Double then sh:=sh_D else   if Alg.Obj[N].MType = _Extended  then sh:=sh_E;

 S:=GNode^.S;

if GNode^.AI = 3 then    //save(IntVar,IntForm)
begin
       ta1:=GNode^.TA1;

       if (ta1 = _IntForm)  then  //IntForm->IntVar
       begin

           {.357}    //оптимизация для случаев:
          //IntVar1=IntVar1 +- IntConst
          //IntVar1=IntVar1 +- A*IntVar2

          {иначе, общий вариант: LineFormN(GNode^.AIVP1,GNode^.IC1);}


          if SaveSimpleLineForm = True  then goto endp
            else
          LineFormN(GNode^.AIVP1,GNode^.IC1);

       end
       else
       if (ta1 = _IntVar)  then    //IntVar(NV1)->IntVar(NObj)        IntVar1=IntVar2
       begin
          MOVMREG(R_EAX,Alg.Obj[GNode^.NV1].Addr);
       end
       else
       if (ta1 = _IntConst)  then      //IntConst->IntVar          IntVar1=IntConst
       begin
          MOVCREG(R_EAX,GNode^.IC1);
       end;

       MOVREGM(R_EAX,Alg.Obj[N].Addr);  //Result-> IntVar(Alg.Obj[N].Addr)    сохранение результата  ->  IntVar1

end
else
if GNode^.AI = 4 then  //vec[IntForm]=Expr
begin

     if tf =   T_Complex then
     begin
        //vd[k]=z1; x
        F_SyntaxErrorString:='save(real,complex) in:   '+#13#10+GNode^.Expression;
        F_SyntaxErrorCode:=E_NOT_DEFINED_FUNCTION_FOR_TYPE;
        goto endp;
     end;

       ta1:=GNode^.TA1;
       AdrM:=Alg.Obj[N].Addr;  //addr of Array
       TM:=Alg.Obj[N].MType;   //math type of Array
       code2:=GNode^.TA2;

       //оптимизация для случая: VecInteger[IntForm1]=IntForm2    ;  VecPointer[IntForm1]=IntForm2(of Pointers)
       //if (TM = _Integer) and ((code2 = _IntConst) or (code2 = _IntVar) or (code2 = _IntForm)) then
       if ((TM = _Integer) or (TM = _Pointer)) and ((code2 = _IntConst) or (code2 = _IntVar) or (code2 = _IntForm)) then   {.367}
       begin

           if code2 = _IntVar then        //array[IntForm1]=InrVar    //  {.367}
           begin
             AddrI2:=Alg.Obj[GNode^.NV2].Addr;
             LoadLineFormEAX(_First);    //IntForm1
             MOVMREG(R_EBX,AdrM);        //AddrArray->EBX
             MOVMREG(R_ECX,AddrI2);      //AddrIntVar->ECX
           end
           else
           if code2 = _IntConst then        //array[IntForm1]=IntConst   //  {.367}
           begin
             AddrI2:=Alg.Obj[GNode^.NV2].Addr;
             LoadLineFormEAX(_First);    //IntForm1
             MOVMREG(R_EBX,AdrM);        //AddrArray->EBX
             MOVCREG(R_ECX,GNode^.IC2);  //IntConst->ECX
           end
           else
           begin

             LoadLineFormEAX(_Second);  //IntForm2
             PUSHR(R_EAX);
             LoadLineFormEAX(_First);  //IntForm1
             MOVMREG(R_EBX,AdrM);       //Addr->EBX
             POPR(R_ECX);

             {
             LoadLineFormEAX(_Second);  //IntForm2
             MOVREG(R_EAX,R_ESI);
             LoadLineFormEAX(_First);  //IntForm1
             MOVMREG(R_EBX,AdrM);       //Addr->EBX
             MOVREG(R_ESI,R_ECX);
             }
           end;

           // mov [ebx+4*eax],ecx
           AddByte($89); AddByte($0C);AddByte($83);
           
           goto endp;
       end;


       //NCell->EAX
       if (ta1 = _IntForm)  then
       begin
          LineFormN(GNode^.AIVP1,GNode^.IC1);
       end
       else
       if (ta1 = _IntVar)  then
       begin
          MOVMREG(R_EAX,Alg.Obj[GNode^.NV1].Addr);
       end
       else
       if (ta1 = _IntConst)  then
       begin
          MOVCREG(R_EAX,GNode^.IC1);
       end;

       MOVMREG(R_EBX,AdrM);       //Addr->EBX
       SaveArrayCellFPU(R_EBX,R_EAX,TM);

       (*
       if TM = _Double then
       begin
         //fstp  qword ptr [ebx+8*eax]:
         AddByte($DD); AddByte($1C);AddByte($C3);
       end
       else
       if TM = _Extended then
       begin
         //lea   eax,[eax+4*eax]:
         AddByte($8D); AddByte($04);AddByte($80);
         //fstp   tbyte ptr [ebx+2*eax]:
         AddByte($DB); AddByte($3C);AddByte($43);
       end
       else
       if TM = _Integer then
       begin
         //fistp  dword ptr [ebx+4*eax]:
         AddByte($DB); AddByte($1C);AddByte($83);
       end
       else
       if TM = _Single then
       begin
         //fstp  dword ptr [ebx+4*eax]:
         AddByte($D9); AddByte($1C);AddByte($83);
       end;

       CheckStack(-1);
       *)

end
else
{.347}
if GNode^.AI = 5 then  //VecInt[IntForm1]=VecInt[IntForm2]
begin
    AddrA1:=Alg.Obj[GNode^.NObj].Addr;      // vi1[7*j*k+5*k*j*n-3*n-4*k-15]= vi2[7*j*k+5*k*j*n-3*n-4*k-15];  vi1[7*j*k+5*k*j*n-3*n-4*k-15]
    AddrA2:=Alg.Obj[GNode^.NObj2].Addr;     //vi2[5*m+3*k+2*n*k*j*l+2*k-15]=vi1[5*m+3*k+4*n*k*j*l+8*k+10]; vi2[5*m+3*k+2*n*k*j*l+2*k-15]-vi1[5*m+3*k+4*n*k*j*l+8*k+10];
    ArgForm1:=GNode^.TA1;
    ArgForm2:=GNode^.TA2;

    if  ((ArgForm1 = _IntConst) or (ArgForm1 = _IntVar) or (ArgForm1 = _IntForm)) and ((ArgForm2 = _IntConst) or (ArgForm2 = _IntVar) or (ArgForm2 = _IntForm)) then
    begin
           LoadLineFormEAX(_Second);    //ArgForm2
           MOVMREG(R_EBX,AddrA2);  //Addr2->EBX

            // mov edx,[ebx+4*eax]
           //AddByte($8B); AddByte($14);AddByte($83);      // VecInt2[ArgForm2] -> EDX

           // mov esi,[ebx+4*eax]              {.379}
           AddByte3($8B,$34,$83);        // VecInt2[ArgForm2] -> ESI

           LoadLineFormEAX(_First);     //ArgForm1
           MOVMREG(R_EBX,AddrA1);       //Addr1->EBX

           // mov [ebx+4*eax],edx
           //AddByte($89); AddByte($14);AddByte($83);    //EDX -> VecInt1[ArgForm1]

            // mov [ebx+4*eax],esi      {.379}
           AddByte3($89,$34,$83);    //ESI -> VecInt1[ArgForm1]

           //SetReg(R_EDX);
           SetReg(R_ESI);        {.379}
           goto endp;
    end;
   { else
    begin

    end};

end
else
if GNode^.AI = 1 then
begin
 if tf =   T_Real then       //var = real expression
 begin
    if tv =   T_Real then                     //real var =  real expression
    begin
      FSTPM(Alg.Obj[N].Addr,Alg.Obj[N].MType)
    end
    else
    {if (tv =   T_Complex) and (ts = _RE) then
    begin
      FSTPM(Alg.Obj[N].Addr,Alg.Obj[N].MType)
    end
    else
    if (tv =   T_Complex) and (ts = _IM ) then
    begin
      FSTPM(Alg.Obj[N].Addr+sh,Alg.Obj[N].MType)
    end
    else
    if (tv =   T_Complex) and  (ts = 0) then
    begin
      FSTPM(Alg.Obj[N].Addr,Alg.Obj[N].MType)
    end }
     {.203}
     if tv =   T_Complex then                  //complex var =  real expression
     begin
       if  ts = _RE then
         FSTPM(Alg.Obj[N].Addr,Alg.Obj[N].MType)
       else
        if  ts = _IM then
         FSTPM(Alg.Obj[N].AddrIM,Alg.Obj[N].MType)        {.343}
         //FSTPM(Alg.Obj[N].Addr+sh,Alg.Obj[N].MType)
       else
        if ts = 0 then
       begin
         FSTPM(Alg.Obj[N].Addr,Alg.Obj[N].MType);      //expr->re
         FLDZ;
         FSTPM(Alg.Obj[N].AddrIM,Alg.Obj[N].MType);   //0->im      {.343}
         //FSTPM(Alg.Obj[N].Addr+sh,Alg.Obj[N].MType);   //0->im
       end;
     end
     else
     begin           //ptr1=j
        F_SyntaxErrorStringA:='save';
        F_SyntaxErrorString:='save('+NameTypeS[tv]+','+NameTypeS[tf]+')'+ #13#10+'  in:  '  +#13#10+ GNode^.Expression;
        F_SyntaxErrorCode:=E_NOT_DEFINED_FUNCTION_FOR_TYPE;
        goto endp;
     end;

 end
 else
 if tf =   T_Complex then
 begin

    if tv =   T_Real then   // RealVar = ComplexExpr    disable in .395
    begin
      {
      FSTPM(Alg.Obj[N].Addr,Alg.Obj[N].MType);
      FSTP0;
      }
        F_SyntaxErrorStringA:='save';
        F_SyntaxErrorString:='save('+NameTypeS[tv]+','+NameTypeS[tf]+')'+ #13#10+'  in:  '  +#13#10+ GNode^.Expression;
        F_SyntaxErrorCode:=E_NOT_DEFINED_FUNCTION_FOR_TYPE;
        goto endp;
    end
    else
    if (tv =   T_Complex) and (ts = _RE ) then
    begin
      FSTPM(Alg.Obj[N].Addr,Alg.Obj[N].MType);
      FSTP0;
    end
    else
    if (tv =   T_Complex) and (ts = _IM ) then
    begin
      //FSTP0;
      //FSTPM(Alg.Obj[N].Addr+sh,Alg.Obj[N].MType);
      FSTPM(Alg.Obj[N].AddrIM,Alg.Obj[N].MType);  {.343}
      FSTP0;
    end
    else
    if (tv =   T_Complex)  then
    begin
      FSTPM(Alg.Obj[N].Addr,Alg.Obj[N].MType);
      //FSTPM(Alg.Obj[N].Addr+sh,Alg.Obj[N].MType);
      FSTPM(Alg.Obj[N].AddrIM,Alg.Obj[N].MType); {.343}
    end
 end
 else
 if tf = T_Pointer then       // = T_Pointer
 begin
    if tv = T_Pointer then      //PoiterVar=T_Pointer
    begin
        //загрузить T_Pointer из стека выражения в EAX
        MOVMREG(R_EAX,GetStackAdr(S,_RE));
        //-> PointerVar
        MOVREGM(R_EAX,Alg.Obj[N].Addr);
    end
    else
    if (tv = T_Real) and (tm = _Integer) and (F_EnableUseIntegerPointer = True) then     //IntegVar = T_Pointer
    begin
       //загрузить T_Pointer из стека выражения в EAX
        MOVMREG(R_EAX,GetStackAdr(S,_RE));
        //-> PointerVar
        MOVREGM(R_EAX,Alg.Obj[N].Addr);
    end
    else
    goto err1;
 end
 else
 begin
     err1:
                //j=ptr1
     TM:=Alg.Obj[N].MType;
     F_SyntaxErrorStringA:='save';
     F_SyntaxErrorString:='save('+NameMathTypeS[tm]+','+NameTypeS[tf]+')'+ #13#10+'  in:  '  +#13#10+ GNode^.Expression;
     F_SyntaxErrorCode:=E_NOT_DEFINED_FUNCTION_FOR_TYPE;
     goto endp;
 end;
end
else
if GNode^.AI = 2 then   //save(vd,expr,x)      ;vd[y*x]=x+y; vd[y*x]
begin

  if tf =   T_Complex then
  begin
     //vd[x*y]=z1; x
     F_SyntaxErrorString:='save(real,complex) in:   ' +#13#10+ GNode^.Expression;
     F_SyntaxErrorCode:=E_NOT_DEFINED_FUNCTION_FOR_TYPE;
    goto endp;
  end;

  AdrM:=Alg.Obj[N].Addr;
  TM:=Alg.Obj[N].MType;
   {
   FXCH1;
   FLDCW(TAddress(@FCW1));
   MEM:=WriteDataA(0,_Integer);
   FISTP(MEM);
   FLDCW(TAddress(@FCW2));
   MOVMC(MEM);
   }

   //номер элемента массива -> ECX
   if GNode^.CI = 1 then    //Vec[int_var]
   begin
     GetVar1(GNode^.NV1,AdrA,tva,TMA);
     MOVMC(AdrA);
   end
   else
    if GNode^.CI = 2 then    //Vec[int_num]
   begin
     Num:=Trunc(GNode^.FD);
     MOVCadr(NUM);  //Num>=0!!!
   end
   else                            //vec[stack]
   begin
    //FXCH1;              {.359}

    //TRUNCR(R_ECX);
    FISTPR(R_ECX); {.387}

    (*
    PUSHCW;    {.227}
    FLDCW(TAddress(@FCW1));
    MEM:=WriteDataA(0,_Integer);
    FISTP(MEM);
    POPCW;      {.227}   //FLDCW(TAddress(@FCW2));
    MOVMC(MEM);
    *)
   end;



   //адрес массива -> EBX
   {
   MOVBadr(AdrM);
   //mov  ebx, [ebx]:
   AddByte($8B); AddByte($1B);
   }
   MOVMREG(R_EBX,AdrM); //[AddrArray] -> EBX (= @Array[0])  {.369**}

   SaveArrayCellFPU(R_EBX,R_ECX,TM);

   (*
   if TM = _Double then
   begin
    {MOVB1(AdrM);
    MOVA1(Cardinal(@RD_VECS));
    CALLA;}

     MOVBadr(AdrM);
     //mov  ebx, [ebx]:
     AddByte($8B); AddByte($1B);

     //fstp  qword ptr [ebx+8*ecx]:
     AddByte($DD); AddByte($1C);AddByte($CB);
   end
   else
   if TM = _Extended then
   begin
    {MOVB1(AdrM);
    MOVA1(Cardinal(@RE_VECS));
    CALLA;}

      MOVBadr(AdrM);
     //mov  ebx, [ebx]:
     AddByte($8B); AddByte($1B);
     //lea   ecx,[ecx+4*ecx]:
     AddByte($8D); AddByte($0C);AddByte($89);
     //fstp   tbyte ptr [ebx+2*ecx]:
     AddByte($DB); AddByte($3C);AddByte($4B);
   end
   else
   if TM = _Integer then
   begin
    {MOVB1(AdrM);
    MOVA1(Cardinal(@RI_VECS));
    CALLA;}

     MOVBadr(AdrM);
    //mov  ebx, [ebx]:
     AddByte($8B); AddByte($1B);
    //fistp  dword ptr [ebx+4*ecx]:
     AddByte($DB); AddByte($1C);AddByte($8B);
   end
   else
   if TM = _Single then
   begin
     MOVBadr(AdrM);
    //mov  ebx, [ebx]:
     AddByte($8B); AddByte($1B);
    //fstp  dword ptr [ebx+4*ecx]:
     AddByte($D9); AddByte($1C);AddByte($8B);
   end;

   CheckStack(-1);

   *)

 end
else
if GNode^.AI = 10 then    //save(<IntVar,IntArray>,AddrOf<Var,Array,Func>)
begin

   if (GNode^.BI = _IntVar) then     //save(IntVar,AddrOf<Var,Array,Func,Array[indx]>)
   begin

     if (GNode^.CI = tc_AddrVar) or (GNode^.CI = tc_AddrFunc)  then
     begin
        MOVCREG(R_EAX,GNode^.Addr1);
        MOVREGM(R_EAX,Alg.Obj[N].Addr);
     end
     else
     if (GNode^.CI = tc_AddrArray) then
     begin
        MOVCREG(R_EAX,GNode^.Addr1);
        MOVREGM(R_EAX,Alg.Obj[N].Addr);
     end
     else
     if (GNode^.CI = tc_Array) then
     begin
        MOVMREG(R_EAX,GNode^.Addr1);           //вычисление адреса от адреса
        MOVREGM(R_EAX,Alg.Obj[N].Addr);
     end
     else
     if (GNode^.CI = tc_AddrArrayElem) then   //  PtrVar,IntVar=@vec[indx]
     begin
       LoadArrayElem(tc_LoadArrayElemAddr);
       MOVREGM(R_EAX,Alg.Obj[N].Addr); //EAX->PtrVar
     end
     else
     if (GNode^.CI = tc_AnyPointerExpression) then
     begin
        MOVREGM(R_EAX,Alg.Obj[N].Addr);
     end;

   end
   else
   if (GNode^.BI = _IntArray) then     //save(IntArray,AddrOf<Var,Array,Func,Array[indx]>)
   begin

