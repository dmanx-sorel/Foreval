if ((ND.NFunc = CM_MUL) or (ND.NFunc = CM_DIV)) and (F_MulDivOptimization = True) then
begin
 MulDivAnalizator(LV,ND,LV1,ND1,EOFN);
 goto endp;
 {
 if G_NExpr > 2 then
 begin
   Answ:=MulDivAnalizator(LV,ND,LV1,ND1,EOFN);
   if Answ = True then goto endp
   else
   begin
     LV:=LV1;
     ND:=ND1;
   end;
 end
 else
 begin     //(G_NExpr = 2)

          //Sa1:=Copy(PS^,1,NPos-1);
          //Sa2:=Copy(PS^,NPos+1,Length(PS^)-NPos);
          BZ1:=CheckToZeroPS(@LV[0].Expression);
          BZ2:=CheckToZeroPS(@LV[1].Expression);

          if (ND.NFunc = CM_DIV) and (BZ2 = True) then
          begin
            F_InternalError:=E_ZeroDivide ;
            F_SyntaxErrorCode:=E_ERROR_AT_CALCULATION;
            F_SyntaxErrorString:=LV[1].Expression;
            goto endp;
          end
          else
          begin
             //.314
            if (BZ1 = True) and (LV[1].Expression <> S_IM_UNIT)  then
            begin
              ND1.FD:=0;
