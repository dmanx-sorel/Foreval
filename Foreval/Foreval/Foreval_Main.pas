      end ;

   end;

*)

procedure TForevalH.LoadLineFormEAX(place: Integer);
var
ta1,ta2: Integer;
begin
if place = _First  then
begin
       ta1:=GNode^.TA1;

       if (ta1 = _IntForm)  then  //IntForm->IntVar
       begin
          LineFormN(GNode^.AIVP1,GNode^.IC1);
       end
       else
       if (ta1 = _IntVar)  then    //IntVar->IntVar
       begin
          MOVMREG(R_EAX,Alg.Obj[GNode^.NV1].Addr);
       end
       else
       if (ta1 = _IntConst)  then      //IntConst->IntVar
       begin
          MOVCREG(R_EAX,GNode^.IC1);
       end;
end
else
if place = _Second  then
begin
       ta2:=GNode^.TA2;

       if (ta2 = _IntForm)  then  //IntForm->IntVar
       begin
          LineFormN(GNode^.AIVP2,GNode^.IC2);
       end
       else
       if (ta2 = _IntVar)  then    //IntVar->IntVar
       begin
          MOVMREG(R_EAX,Alg.Obj[GNode^.NV2].Addr);
       end
       else
       if (ta2 = _IntConst)  then      //IntConst->IntVar
       begin
          MOVCREG(R_EAX,GNode^.IC2);
       end;
end;

end;





function  TForevalH.SaveSimpleLineForm: Boolean;
var
N,N1,NF,tf,tv,ts,sh,TM,TMA,tva,ta1,code2,ArgForm1,ArgForm2,S,IC1: Integer;
AdrM,AdrA,Num,AddrA1,AddrA2,AddrObj,AddrI,AddrI1,AddrI2: Cardinal;
IM1,IM2: Integer;
Answ: Boolean;
begin
Answ:=False;

  {.357}    //оптимизация для случаев:
          //IntVar1=IntVar1 +- IntConst
          //IntVar1=IntVar1 +- IntVar2

          {иначе, общий вариант: LineFormN(GNode^.AIVP1,GNode^.IC1);}
 N:=GNode^.NObj;

{ N1:=GNode^.NFunc;
 NF:=GNode^.NF;
 tf:=Alg.ExFunc[N1].Func[NF].TV[0];
 tv:=Alg.Obj[N].TypeF;
 tm:=Alg.Obj[N].MType;
 TS:=GNode^.TS;
 if Alg.Obj[N].MType = _Double then sh:=sh_D else   if Alg.Obj[N].MType = _Extended  then sh:=sh_E;
 S:=GNode^.S; }


          if (Length(GNode^.AIVP1) = 1)  then      //IntVar1=IntVar1 +- IntConst
          begin

            if Length(GNode^.AIVP1[0].NV) = 1  then   //  IntVar1=IntVar1 (IntVar1 <> IntVar1*IntVar2*IntVar3*...)
            begin

               GetVar1(GNode^.AIVP1[0].NV[0],AddrI,tva,TMA);

               if (AddrI = Alg.Obj[N].Addr){ and (GNode^.AIVP1[0].A = 1) and  (GNode^.IC1 <> 0)}then      //IntVar1=A*IntVar1; A=1; IntConst <> 0
               begin

                  if GNode^.AIVP1[0].A = 1 then           //IntVar1=IntVar1+-IntConst;
                  begin
                       //IntVar1=IntVar1 + IntConst
                      if (GNode^.IC1 > 0) then
                      begin
                        if GNode^.IC1 = 1 then  //inc(IntVar1)
                        begin
                           INCMEM(AddrI);
                        end
                        else
                        begin
                           AddWord($81,$05);
                           AddAddress(AddrI);
                           AddNum(GNode^.IC1);
                        end;
                        Answ:=True;
                      end
                      else
                       //IntVar1=IntVar1 - IntConst
                      if (GNode^.IC1 < 0) then
                      begin
                        if GNode^.IC1 = -1 then  //dec(IntVar1)
                        begin
                           DECMEM(AddrI);
                        end
                        else
                        begin
                           AddWord($81,$2D);
                           AddAddress(AddrI);
                           AddNum(-GNode^.IC1);
                        end;
                        Answ:=True;
                      end
                      else
                      Answ:=True; {IntVar1=IntVar1}  //without generated command
                  end
                  else   //IntVar1=A*IntVar1+-IntConst; A <> 1
                  begin

                     if (GNode^.AIVP1[0].A = -1)  then    //IntVar1=IntConst-IntVar1 ;
                     begin
                        if  (GNode^.IC1 = 0) then     //IntVar1=-IntVar1 ;
                        begin
                           NEGMEM(AddrI);
                           Answ:=True;
                        end
                        else                     //IntVar1=IntConst-IntVar1 ;
                        begin

                           (*
                            NEGMEM(AddrI);
                            if  (GNode^.IC1 = 1) then  INCMEM(AddrI)
                              else
                            if  (GNode^.IC1 = -1) then DECMEM(AddrI)
                              else                     ADDMEMCONST(AddrI,GNode^.IC1);


                            Answ:=True;
                            *)

                        end;

                     end;

                  end;

               end

            end;
          end
          else
          if (Length(GNode^.AIVP1) = 2) and (GNode^.IC1 = 0) then      //IntVar1=A1*IntVar1 +- A2*IntVar2  ; IntConst = 0
          begin

             if (Length(GNode^.AIVP1[0].NV) = 1) and (Length(GNode^.AIVP1[1].NV) = 1)   then
             //  IntVar1=IntVar1 +- IntVar2 (IntVar1 <> A1*IntVar1*IntVar2*IntVar3*... +- A2*IntVar1*IntVar2*IntVar3*...)
             begin


                IM1:= GNode^.AIVP1[0].A; IM2:=GNode^.AIVP1[1].A;
                GetVar1(GNode^.AIVP1[0].NV[0],AddrI1,tva,TMA);
                GetVar1(GNode^.AIVP1[1].NV[0],AddrI2,tva,TMA);

                if (Alg.Obj[N].Addr = AddrI1) and (IM1 = 1) then    //  IntVar1=A1*IntVar1 +- A2*IntVar2   ; A1 = 1
                begin

                   if IM2 = 1 then      // IntVar1=IntVar1 + IntVar2
                   begin
                     //MOVMREG(R_EAX,AddrI2);
                     MOV_MEM_EAX(AddrI2);
                     AddWord($01,$05);
                     AddAddress(AddrI1);
                     Answ:=True;
                   end
                   else
                   if IM2 = -1 then      // IntVar1=IntVar1 - IntVar2
                   begin
                     //MOVMREG(R_EAX,AddrI2);
                     MOV_MEM_EAX(AddrI2);
                     AddWord($29,$05);
                     AddAddress(AddrI1);
                     Answ:=True;
                   end
                   else       // IntVar1=IntVar1 +- A2*IntVar2
                   begin

                       MOV_MEM_EAX(AddrI2);
                       IMULCREG(R_EAX,abs(IM2));
                       if IM2 > 0 then     // IntVar1=IntVar1 + A2*IntVar2
                       begin
                          AddWord($01,$05);
                          AddAddress(AddrI1);
                          Answ:=True;
                       end
                       else                // IntVar1=IntVar1 - A2*IntVar2
                       begin
                          AddWord($29,$05);
                          AddAddress(AddrI1);
                       end;

                       Answ:=True;

                   end;


                end
                else
                if (Alg.Obj[N].Addr = AddrI2) and (IM2 = 1) then     //  IntVar1=A2*IntVar2 + A1*IntVar1   ; A1 = 1
                begin
                   if IM1 = 1 then      // IntVar1=IntVar2 + IntVar1
                   begin
                     //MOVMREG(R_EAX,AddrI1);
                     MOV_MEM_EAX(AddrI1);
                     AddWord($01,$05);
                     AddAddress(AddrI2);
                     Answ:=True;
                   end
                   else
                   if IM1 = -1 then      // IntVar1=-IntVar2 + IntVar1
                   begin
                      //MOVMREG(R_EAX,AddrI1);
                      MOV_MEM_EAX(AddrI1);
                      AddWord($29,$05);
                      AddAddress(AddrI2);
                      Answ:=True;
                   end
                   else           //  IntVar1=A2*IntVar2 + IntVar1
                   begin

                       MOV_MEM_EAX(AddrI1);
                       IMULCREG(R_EAX,abs(IM1));
                       if IM1 > 0 then     //  IntVar1=A2*IntVar2 + IntVar1
                       begin
                          AddWord($01,$05);
                          AddAddress(AddrI2);
                          Answ:=True;
                       end
                       else                //  IntVar1=-A2*IntVar2 + IntVar1
                       begin
                          AddWord($29,$05);
                          AddAddress(AddrI2);
                       end;

                       Answ:=True;

                   end;
                end
                else
                 // IntVar1=IntVar2+C*IntVar3; C=1,2,4,8     ; lea eax,eax+C*ebx
                if  ((IM1 = 1) and (IM2 = 1))   or      //  IntVar1=IntVar2+IntVar3
                    ((IM1 = 1) and (IM2 = 2))   or      //  IntVar1=IntVar2+2*IntVar3
                    ((IM1 = 1) and (IM2 = 4))   or      //  IntVar1=IntVar2+4*IntVar3
                    ((IM1 = 1) and (IM2 = 8))   or      //  IntVar1=IntVar2+8*IntVar3
                    ((IM1 = 2) and (IM2 = 1))   or      //  IntVar1=2*IntVar2+IntVar3
                    ((IM1 = 4) and (IM2 = 1))   or      //  IntVar1=IntVar2+4*IntVar3
                    ((IM1 = 8) and (IM2 = 1))           //  IntVar1=IntVar2+8*IntVar3
                then
                begin
                //закрыто, менее эффективно
                {
                       AdrM:=Alg.Obj[N].Addr;

                       if (IM1 = 1)  then
                       begin
                          MOV_MEM_EAX(AddrI1);
                          MOV_MEM_EBX(AddrI2);
                          LEA_EAX_EBX(IM2);
                          MOVREGM(R_EAX,AdrM);
                          //MOVBadr(AdrM);
                          //MOV_ADDREBX_EAX;

                          Answ:=True;
                       end
                       else
                      if (IM2 = 1)  then
                      begin
                          MOV_MEM_EAX(AddrI2);
                          MOV_MEM_EBX(AddrI1);
                          LEA_EAX_EBX(IM1);
                          MOVREGM(R_EAX,AdrM);

                          Answ:=True;
                      end;
                }
                end;

             end;

          end
          else

          // IntVar1=IntVar2+C*IntVar3+IC; C=1,2,4,8     ; lea eax,eax+C*ebx+IC;
          if (Length(GNode^.AIVP1) = 2) and (GNode^.IC1 <> 0)  then      //IntVar1=A1*IntVar2 +- A2*IntVar3  ; IntConst <> 0
          begin
              if (Length(GNode^.AIVP1[0].NV) = 1) and (Length(GNode^.AIVP1[1].NV) = 1)   then
               //  IntVar1=IntVar2 +- IntVar3 (IntVar1 <> A1*IntVar1*IntVar2*IntVar3*... +- A2*IntVar1*IntVar2*IntVar3*...)
              begin
                  //(GNode^.IC1 = 0)

                   IM1:= GNode^.AIVP1[0].A; IM2:=GNode^.AIVP1[1].A;
                   //   IntVar1=IM1*IntVar2 + IM2*IntVar3 + IC1;
                   if  ((IM1 = 1) and (IM2 = 1))   or      //  IntVar1=IntVar2+IntVar3
                       ((IM1 = 1) and (IM2 = 2))   or      //  IntVar1=IntVar2+2*IntVar3
                       ((IM1 = 1) and (IM2 = 4))   or      //  IntVar1=IntVar2+4*IntVar3
                       ((IM1 = 1) and (IM2 = 8))   or      //  IntVar1=IntVar2+8*IntVar3
                       ((IM1 = 2) and (IM2 = 1))   or      //  IntVar1=2*IntVar2+IntVar3
                       ((IM1 = 4) and (IM2 = 1))   or      //  IntVar1=IntVar2+4*IntVar3
                       ((IM1 = 8) and (IM2 = 1))           //  IntVar1=IntVar2+8*IntVar3
                   then
                   begin
                   //  закрыто, менее эффективно
                     {
                       AdrM:=Alg.Obj[N].Addr;
                       IC1:=GNode^.IC1;
                       GetVar1(GNode^.AIVP1[0].NV[0],AddrI1,tva,TMA);
                       GetVar1(GNode^.AIVP1[1].NV[0],AddrI2,tva,TMA);

                       if IM1 = 1 then
                       begin
                          MOV_MEM_EAX(AddrI1);
                          MOV_MEM_EBX(AddrI2);
                          LEA_EAX_EBX_CONST(IM2,IC1);
                          MOVREGM(R_EAX,AdrM);

                          Answ:=True;
                       end
                       else
                       if IM2 = 1 then
                       begin
                          MOV_MEM_EAX(AddrI2);
                          MOV_MEM_EBX(AddrI1);
                          LEA_EAX_EBX_CONST(IM1,IC1);
                          MOVREGM(R_EAX,AdrM);

                          Answ:=True;
                       end
                    }

                   end;

              end;

          end;



 SaveSimpleLineForm:=Answ;
end;




function  TForevalH.SaveSimpleLineForm2(AIVP: TArrayIntVarProd; IC: Integer): Boolean;
var
N,N1,NF,tf,tv,ts,sh,TM,TMA,tva,ta1,code2,ArgForm1,ArgForm2,S: Integer;
AdrM,AdrA,Num,AddrA1,AddrA2,AddrObj,AddrI,AddrI1,AddrI2: Cardinal;
IM1,IM2: Integer;
Answ: Boolean;
begin
Answ:=False;

  {.367}    //оптимизация для случая:
          //1*IntVar1 + IntConst2*IntVar2 + IntConst -> EAX



if (Length(AIVP) = 2) {and  (IC = 0)}  then      //A1*IntVar1 +- A2*IntVar2 + IntConst
begin
    if (Length(AIVP[0].NV) = 1) and (Length(AIVP[1].NV) = 1)  then    //  IntVar1 +- IntVar2 (IntVar1 <> A1*IntVar1*IntVar2*IntVar3*... +- A2*IntVar1*IntVar2*IntVar3*...)
    begin
       IM1:= AIVP[0].A; IM2:=AIVP[1].A;
       if (IM1 = 1) and (IM2 <> 1) then       //IntVar1 + IM2*IntVar2
       begin
           GetVar1(AIVP[0].NV[0],AddrI1,tva,TMA);
           GetVar1(AIVP[1].NV[0],AddrI2,tva,TMA);

           MOV_MEM_EAX(AddrI2);
           IMULCREG(R_EAX,IM2);
           ADDMREG(R_EAX,AddrI1);

           Answ:=True;
       end
       else
       if (IM2 = 1) and (IM1 <> 1) then       //IntVar2 + IM1*IntVar1
       begin
           GetVar1(AIVP[0].NV[0],AddrI1,tva,TMA);
           GetVar1(AIVP[1].NV[0],AddrI2,tva,TMA);

           MOV_MEM_EAX(AddrI1);
           IMULCREG(R_EAX,IM1);
           ADDMREG(R_EAX,AddrI2);

           Answ:=True;
       end
       else
       if (IM1 = 1) and (IM2 = 1) then       //IntVar1 + IntVar2
       begin
           GetVar1(AIVP[0].NV[0],AddrI1,tva,TMA);
           GetVar1(AIVP[1].NV[0],AddrI2,tva,TMA);
           MOV_MEM_EAX(AddrI1);
           ADDMREG(R_EAX,AddrI2);

           Answ:=True;
       end
       else
       if (IM1 = 1) and (IM2 = -1) then       //IntVar1 - IntVar2
       begin
           GetVar1(AIVP[0].NV[0],AddrI1,tva,TMA);
           GetVar1(AIVP[1].NV[0],AddrI2,tva,TMA);
           MOV_MEM_EAX(AddrI1);
           SUBMREG(R_EAX,AddrI2);

           Answ:=True;
       end
       else
       if (IM2 = 1) and (IM1 = -1) then       //IntVar2 - IntVar1
       begin
           GetVar1(AIVP[0].NV[0],AddrI1,tva,TMA);
           GetVar1(AIVP[1].NV[0],AddrI2,tva,TMA);
           MOV_MEM_EAX(AddrI2);
           SUBMREG(R_EAX,AddrI1);

           Answ:=True;
       end;

       if (Answ = True) and (IC <> 0) then
       begin
           if IC = 1  then  INCREG(R_EAX)     else
           if IC = -1 then  DECREG(R_EAX)     else
           if IC > 0  then  ADDCREG(R_EAX,IC) else
           if IC < 0  then  SUBCREG(R_EAX,abs(IC));
       end;

    end;
end;



 SaveSimpleLineForm2:=Answ;
end;






