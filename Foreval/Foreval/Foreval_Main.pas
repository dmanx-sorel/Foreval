procedure TForevalH.FindFuncB(NameF: String; NArg,ResType: Integer; var NFunc,NF: Integer);
label endp;
var
i,j,k,LF,NFuncFL,TypeFL,NArgFL: Integer;
Sfn: String;
begin
NF:=_NOT_FOUND;
NFunc:=_NOT_FOUND;


 for i:=0 to High(Alg.ExFunc) do
 begin


       if F_ExtNameFunction = True then LF:=High(Alg.ExFunc[i].NameEx)  else
        begin
          if Length(Alg.ExFunc[i].NameEx) <> 0 then  LF:=0 else LF:=-1;
        end;


       for j := 0 to LF do
       begin

          Sfn:=Alg.ExFunc[i].NameEx[j];


          if (NameF = Sfn) and  (Alg.ExFunc[i].Enable = _YES) then
          begin
            NFunc:=i;
            if (NArg = _ANY) and (ResType = _ANY) then   //только по имени
            begin
              goto endp;
            end;


              NFuncFL:=Length(Alg.ExFunc[i].Func);
              for k := 0 to NFuncFL-1 do
              begin
                NArgFL:=Alg.ExFunc[i].Func[k].NArg;
                TypeFL:=Alg.ExFunc[i].Func[k].TypeF;

                if (NArg = _ANY) and (ResType = TypeFL) then   //по имени и возвращаемого типа
                begin
                    NF:=k; goto endp;
                end
                else
                if (NArgFL = NArg) and (ResType = _ANY) then   //по имени и  по числу аргументов
                begin
                    NF:=k; goto endp;
                end
                else
                if (NArgFL = NArg) and (ResType = TypeFL) then    //по имени , числу аргументов   и возвращаемого типа
                begin
                    NF:=k; goto endp;
                end;


              end;



            goto endp;
          end;

       end;
 end;

endp:
end;




