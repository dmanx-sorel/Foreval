         if BAnsw = True then
         begin
            ND1.AI:=7;             //PType(IntForm of Pointers)
            SetLength(LV1,0);
            ND1.N:=0;
            EOFN:=True;
            BEF:=True;
         end
         else
         if Str1[1] = '@' then     {.369}
         begin
            ND1.AI:=10;             //PType(@Expr); Ptype(@Array[indx]); @Expr -> EAX
            SetLength(LV1,1);
            LV1[0].Expression:=Str1;
            ND1.N:=1;
            EOFN:=False;
            BEF:=True;
         end
         else
         //unknown expr
         begin
              F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT; {.323}
              F_SyntaxErrorString:=Copy(F_CurrentString,1,Length(F_CurrentString));     {.323}
              F_SyntaxErrorName:=Copy(Sv,1,Length(Sv));
              goto endp;
         end;
       end;


    end;




   // WriteFindExtArgInt1PS(@Str3, _Second,  ND1, ND1, BAnsw);




endp:
end;




procedure TForevalH.ArrayAnalizatorPS(PS,PSv,PSa: PString; ni: Integer; LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var BH,EOFN: Boolean);
label endp;
var
ni1,TV: Integer;       //BH - функция найдена да/нет
Sa1,Sv1: String;                     //EOFN - (end of node)-достигнут конец узла: выражение нуждается в дальнейшем разборе да/нет
code,IC,NV: Integer;
FH,FH1: Boolean;
AIVP:  TArrayIntVarProd;

begin


if F_SyntaxErrorCode <> 0 then goto endp;

 LV1:=LV;
 ND1:=ND;
 EOFN:=False;
 BH:=False;


   {F_IntegerOptimization}
       //---------------------------------------------------------

       ND1.NFunc:=CM_LDSVX;
       ND1.NObj:=ni;
       ND1.COP:=_Func;
       BH:=True;

       ND1.ExpressionArg:=PSa^; {.357}   //used in compare at replace func optimization
       ND1.Expression:=PS^; {.357}   //used in compare at replace func optimization


       //поиск элементов векторов: AI = (1)Vec[IntConst], (2)Vec[IntVar], (3)Vec[IntForm], (0)Vec[Trunc(Expr)]
       FindExtArgIntPS(PSa, code, AIVP, NV, IC);
       if code <> _NOT_FOUND then
       begin
          if code = _IntConst then
          begin
            ND1.FD:=IC;
            ND1.AI:=1;
          end
          else
          if code = _IntVar then
          begin
            ND1.NV1:=NV;
            ND1.AI:=2;
          end
          else
          begin
            ND1.AIVP1:=Copy(AIVP,0,Length(AIVP));
            //CopyAIVP(AIVP,ND.AIVP1);
            ND1.AI:=3;
            ND1.FD:=IC;
          end;
          EOFN:=True;
          SetLength(LV1,0);
          ND1.N:=0;
       end
       else
       begin   //Vec[VecInt[indx]],  Vec[expr]
          ND1.AI:=0;
          FH1:=False;

          //Vec[VecInt[indx]]        {.357}
          if F_IntegerOptimization = True then
          FindFuncBrPS(PSa,'[',']',Sv1,Sa1,FH1);

          if FH1 = True then FindVarPS(@Sv1,ni1) else ni1:=-1;
          //VecInt[Sa1]
          if ni1 <> -1 then //ni1 - vector
             if Alg.Obj[ni1].TypeF = T_Array then
                if Alg.Obj[ni1].MType = _Integer then
                begin
                    ND1.NObj2:=ni1;
                    FindExtArgIntPS(@Sa1, code, AIVP, NV, IC);
                    if code <> _NOT_FOUND then
                    begin
                       if code = _IntConst then
                       begin
                         ND1.FD:=IC;
                         ND1.DI:=1;
                       end
                       else
                       if code = _IntVar then
                       begin
                        ND1.NV2:=NV;
                        ND1.DI:=2;
                       end
                       else
                       begin
                        ND1.AIVP1:=Copy(AIVP,0,Length(AIVP));
                       //CopyAIVP(AIVP,ND.AIVP1);
                        ND1.DI:=3;
                        ND1.FD:=IC;
                       end;
                       EOFN:=True;
                       SetLength(LV1,0);
                       ND1.N:=0;
                    end
                    else   // Vec[VecInt[Expr]]
                    begin
                      ND1.DI:=0;
                      SetLength(LV1,1);
                      LV1[0].Expression:=Copy(Sa1,1,Length(Sa1));
                      ND1.N:=1;
                      EOFN:=False;
                    end;

                   ND1.AI:=4;     //Vec[VecInt[indx]]
                   //goto endp;
                end;


          if ND1.AI = 0 then
          begin
             //Vec[expr]
            ND1.AI:=0;
            SetLength(LV1,1);
            LV1[0].Expression:=Copy(PSa^,1,Length(PSa^));
            ND1.N:=1;
            EOFN:=False;
          end;
       end;

       {.353}
       //загрузка элемента массива указателей через команду _LDSA    //vecptr[indx]->eax
       if Alg.Obj[ni].MType = _Pointer then
       begin
           ND1.NObj:=ni;
           ND1.NFunc:=0;
           ND1.COP:=_LDSA;
           ND1.TypeF:=T_Pointer;
           ND1.CI:=ND1.AI;
           ND1.AI:=tc_PointerArray;
       end;

  endp:
end;




   //395x
