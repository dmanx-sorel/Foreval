procedure TForevalH.ReplaceFuncComposite;

//------------------------------------------------------------------------------
      function CompareFunc(Node1,Node2: PNode{N1,N2: Integer}): Boolean;
      label endp;
      var
          NFunc1,NFunc2,NF1,NF2,ResT1,ResT2,NArg1,NArg2,i,NM,TM: Integer;
          Answ: Boolean;
      begin

          NFunc1:=Node1^.NFunc;
          NF1:=Node1^.NF;
          NFunc2:=Node2^.NFunc;
          NF2:=Node2^.NF;
          ResT1:=Node1^.TypeF;
          ResT2:=Node2^.TypeF;

          NArg1:=Length(Alg.ExFunc[NFunc1].Func[NF1].TV);
          NArg2:=Length(Alg.ExFunc[NFunc2].Func[NF2].TV);

          Answ:=True;

          if (F_ReplaceFunctionsCF = True) and (NFunc1 <= High(TableRF)) and (NFunc2 <= High(TableRF)) then      //только составные внутренние
          begin
            //cossin <-> sin,cos,sec,cosec;     {.331}
            if {(ResT1 <> ResT2) or} (NArg1 <> NArg2)  then begin  Answ:=False;  goto endp;  end;

            if ResT2 = T_Real then
               if TableRF[NFunc1,NFunc2].RRF_R = rf_NO_REPLACE then  begin  Answ:=False;  goto endp;  end;

            if ResT2 = T_Complex then
               if TableRF[NFunc1,NFunc2].RRF_Z = rf_NO_REPLACE then  begin  Answ:=False;  goto endp;  end;

             //запрет (composite!) замещения для конкретной ф-ии  соответствующего типа (real/complex):
             if  (ResT1 = T_Complex) and (NFunc1 <> NFunc2) and (Alg.ExFunc[NFunc2].ReplFuncCFZ = _NO) then  begin  Answ:=False;  goto endp;  end;
             if  (ResT1 = T_Real) and (NFunc1 <> NFunc2) and (Alg.ExFunc[NFunc2].ReplFuncCFR = _NO) then  begin  Answ:=False;  goto endp;  end;

             for i := 0 to NArg1 - 1 do
               if Alg.ExFunc[NFunc1].Func[NF1].TV[i] <> Alg.ExFunc[NFunc2].Func[NF2].TV[i] then  begin  Answ:=False;  goto endp;  end;
          end
          else
          begin
              if (NFunc1 <> NFunc2) or (NF1 <> NF2) or (ResT1 <> ResT2)  then Answ:=False;  //только одинаковые функции
          end;

          {.357} //замена массивов vec[expr1] vec[expr2]  ; vd[k+1]+vd[k+1];   vd[k*(n+3)]+vd[k*(n+3)]
          if (NFunc1 = CM_LDSVX) and (NFunc2 = CM_LDSVX) then
          begin
             //Alg.Obj[NObj].MType
             if Node1.NObj <> Node2.NObj then  Answ:=False
             else
             begin  {.375}
               NM:=Node1^.NObj;
               TM:=Alg.Obj[NM].MType;
               if TM = _Integer then  Answ:=False;  //целочисленные массивы не подлежат замене, т.к. могут сохраняться в EAX
             end;
          end;


       endp:
       CompareFunc:=Answ;
      end;

//------------------------------------------------------------------------------

      function CompareIntPower(Node1,Node2: PNode; PS1,PS2: PString): Boolean;
      label 1, endp;
      var
          i,k,br,pt,L,L1,L2,LV1,LV2: Integer;
          Answ: Boolean;
      begin
        Answ:=False;

        L1:=Length(PS1^); L2:=Length(PS2^);
        //if L1 <> L2 then goto endp;      //длина может быть разной x^(-n+5)+x^(5-n)

        if L1 < L2 then L:=L1 else L:=L2;

        //выделение первого аргумента из IntPower = (Arg1,Arg2)
        br:=0; pt:=0;
        for i := 1 to L do
        begin
         if PS1^[i] in OpenBracket then inc(br)
           else
         if PS1^[i] in CloseBracket then dec(br);
         if (br = 0) and (PS1^[i] = ',') then
         begin
            pt:=i;
            goto 1;
         end;
        end;

        1:
        if pt <> 0 then
        begin
          //расположение аргументов для 1 и 2 ой функции д.б. одинаково!
          if  PS2^[pt] = ','  then
          begin
             //размеры первых аргумента д.б. равны
             if  Copy(PS1^,1,pt-1) <> Copy(PS2^,1,pt-1) then goto endp;

             //сравнение IntForm  для 1 и 2 ой функции:
             L1:=Length(Node1^.AIVP2); L2:=Length(Node2^.AIVP2);
             if (L1 = L2) and (Node1^.IC2 = Node2^.IC2) then
             begin
               for i := 0 to L1-1 do
               begin

                 LV1:=Length(Node1^.AIVP2[i].NV); LV2:=Length(Node2^.AIVP2[i].NV);
                 if (LV1 = LV2) and (Node1^.AIVP2[i].A = Node2^.AIVP2[i].A) then
                 begin
                    for k := 0 to LV1-1 do
                    begin
                      if Node1^.AIVP2[i].NV[k] <> Node2^.AIVP2[i].NV[k] then goto endp;
                    end;

                 end
                 else goto endp;

               end;

               Answ:=True;

             end
             else goto endp;

          end;
        end;



        endp:
        CompareIntPower:=Answ;
      end;

//------------------------------------------------------------------------------


label 0,1,2,3,endp;
var
FType1,FType2,Code1,Code2,N1,N2,i,j,k,l,RL,RLB,t1,c1,c2,n,P,ReplF1,ReplF2: Integer;
Sc,Sc1,St1,St2,S,Sf1,Sf2: String;
BH: Boolean;
NFunc1,NFunc2,NF1,NF2,ResT1,ResT2,AlwaysEval1: Integer;
Node,Node1,Node2: PNode;
begin


Node1:=FirstNode;
                                    // if(sin(x) > cos(x), sin(x), cos(x))

                                  //x=sin(x);x=sin(x);x
//цикл по главной комманде:
//legendrep(i,k,x)+legendrep(i,k,x)
//S:= Interp[LFunc-1].Expression;


while Node1 <> nil do
begin
 //i-главная команда
 Sf1:= Node1^.Expression;
 if Node1^.COP <> _FUNC then goto 1;
 if Node1^.RRF = rf_FULL_REPLACE then goto 1;   //если полностью замещена

 NFunc1:=Node1^.NFunc;
 NF1:=Node1^.NF;

 //только для функций:                                                                        {.357}
 if (NFunc1 = CM_DIV) or (NFunc1 = CM_MUL) or (NFunc1 = CM_SUB) or (NFunc1 = CM_ADD) or (NFunc1 = CM_NEG)  then goto 1;


 ResT1:=Node1^.TypeF;

 //ReplF1:=Alg.ExFunc[NFunc1].Func[NF1].ReplFunc;
 ReplF1:=Alg.ExFunc[NFunc1].ReplFunc;

 if (ReplF1 = _No)  then goto 1;
 if (ResT1 = T_None)  then goto 1;           {.216}



  AlwaysEval1:=Node1^.AlwaysEval;           {.395if}
  //if Node1^.AlwaysEval = _NO then goto 1; {.395if}
  if Node1^.EndIf = _YES then   goto 1; {.395if}   // если текущее выражение - последний аргумент в  IF(Arg1 cmp Arg2, Arg3,Arg4)  - Arg4, то прервать замену, т.к. после него нет CM_JMP




 Sc:=Node1^.ExpressionArg;

 //цикл по замещаемой комманде:
 Node2:=Node1^.Next;
 while Node2 <> nil do
 begin
    Sf2:= Node2^.Expression;
    //x=2; y=5; x=sin(x)*cos(y);x=sin(x)*cos(y)-cos(sin(x)); y=cos(y)*sin(x)*cos(y)+sin(x); x=y*sin(y)*cos(x)+cos(x)*sin(y); y=sin(x)/cos(y)+cos(y)/sin(x); x+y
   //для исключения ложной замены при компиляции составных выражений в случаях изменения переменных: x=sin(x);x=sin(x);x
   if (Node2^.NFunc = CM_SAVE) and (F_Enable_All_Replace = False) then goto 1; {.347} // исключение для режима пакетной компиляции:
                                                                                    // f1=r*sin(x)*cos(y); f2=r*sin(x)*sin(y); f3=r*cos(x);
   //if Node2^.NFunc = CM_SAVE then goto 1;      {.193}



   //if (Node2^.NFunc = CM_JMP)  then goto 1;  {.195}     {.395if} // исключение для     sin(x)*if(x>y,1,2)+sin(x) ,   if(sin(x)>cos(y),sin(x),cos(y))
   // если замещающий операнд Node1 вычисляется условно, то он может замещать только в пределах подвыражения: (jmp , end of IF - после него  прерывают его область действия)
   if ( AlwaysEval1 = _NO ) and  (Node2^.NFunc = CM_JMP)  then goto 1; {.395if}  // прервать замену только для невычисляемого аргумента IF
   if ( AlwaysEval1 = _NO ) and (Node2^.EndIf = _YES) then   goto 1; {.395if}            //  sin(x)*if(x>y,1,2)+sin(x) , if(y>x,1,sin(x))+sin(x)



   if (Node2^.NFunc = CM_GOSUB) then goto 1;

   if Node2^.COP <> _FUNC then goto 2;
   if Node2^.RRF = rf_FULL_REPLACE then goto 2;   //если полностью замещена

   //sh(x)+exp(x)+sh(x)+ch(x)    ;;; sh(x)-> exp(x),sh(x)
   //exp(x)+sh(x)+sh(x)
   //sh(x)+ch(x)+exp(x)


   NFunc2:=Node2^.NFunc;
