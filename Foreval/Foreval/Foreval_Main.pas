procedure TForevalH.IPWRC16(P,VType: Integer);
begin
if VType = T_Real then
begin
    case abs(P) of
      0: begin FSTP0; FLD1; end;
      1: ;
      2:  RSQR;
      3:  RIPWR3;
      4:  RIPWR4;
      5:  RIPWR5;
      6:  RIPWR6;
      7:  RIPWR7;
      8:  RIPWR8;
      9:  RIPWR9;
      10: RIPWR10;
      11: RIPWR11;
      12: RIPWR12;
      13: RIPWR13;
      14: RIPWR14;
      15: RIPWR15;
      16: RIPWR16;
    end;

    if P < 0 then
    begin
       FLD1;
       FDIVRP;
    end;

end
else
if VType = T_Complex then
begin
     case abs(P) of
      0: begin FSTP0; FSTP0; FLDZ; FLD1; end;
      1: ;
      2:  ZSQR;
      3:  ZIPWR3;
      4:  ZIPWR4;
      5:  ZIPWR5;
      6:  ZIPWR6;
      7:  ZIPWR7;
      8:  ZIPWR8;
      9:  ZIPWR9;
      10: ZIPWR10;
      11: ZIPWR11;
      12: ZIPWR12;
      13: ZIPWR13;
      14: ZIPWR14;
      15: ZIPWR15;
      16: ZIPWR16;
    end;


    if P < 0 then
    begin
       if F_FAST_DIV = True then
       begin
          MOVAadr(Cardinal(@Z_IPWRN1));
       end
       else
       begin
          FLD1;
          //MOVAadr(Cardinal(@Z_RZDIV_acc));
          MOVAadr(Cardinal(RZDIV_ADDR)); {.345}
       end;
      CALLA;
      CheckStack(2);
      CheckStack(-2);
    end;
end;

end;


