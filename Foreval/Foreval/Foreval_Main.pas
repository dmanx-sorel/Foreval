procedure TForevalH.InsertFuncRF(NodeF,NodeS: PNode{NF,NS: Integer});
label 1,endp,fin;
var
i,s,St: Integer;
L,FN: Integer;
NFuncNF,NFuncNS,RangRRF,NFF,NFS,CRFMem: Cardinal;
RangW,RangR,NMem,MShft:integer;
B_RF:Boolean;
NodeS1: PNode;
Sf,Ss: String;
begin


//NF -> NS
if NodeS^.RRF = rf_FULL_REPLACE  then goto endp;   // (NS) уже полностью замещена



B_RF:=False;
NFuncNF:=NodeF^.NFunc;
NFuncNS:=NodeS^.NFunc;
NFF:=NodeF^.NF;
NFS:=NodeS^.NF;



   GetReplaceData({NF,NS,}NodeF,NodeS,NodeF^.TypeF,RangW,RangR,NMem,MShft);

   if RangW = rf_FULL_REPLACE  then   //сохраняется вся ф-ия (NF)
   begin
     inc(NodeF^.NRF);  //для совместимости (выше^)
     if (NodeF^.WRF = rf_FULL_REPLACE)  then        //уже было сохранение всей ф-ии (NF)
     begin

         if RangR > NodeS^.RRF then        //ранг замещаемой ф-ии выше предыдущего замещения , то выполнить  замещение
         begin
           //если замещается вся ф-ия (NS), то ячейка памяти - MRF
           //если частичное замещение (NS) - то  , то ячейка памяти - MRF_CS
           if RangR = rf_FULL_REPLACE  then
           begin
              NodeS^.MRF:=NodeF^.MRF-MShft;
              NodeS^.RRF:=rf_FULL_REPLACE;
           end
           else
           begin
             NodeS^.MRF_CS:=NodeF^.MRF-MShft;
             NodeS^.RRF:=RangR;
           end;
           B_RF:=True;
         end;
     end
     else                                        //нет-выделить память
     begin
        if RangR > NodeS^.RRF then        //если ранг замещаемой ф-ии выше предыдущего замещения, то выполнить  замещение
       begin
          RFSize:=RFSize+NMem;  //кол-во сохраняемых чисел
          NodeF^.WRF:=rf_FULL_REPLACE;   //если сохраняется вся функция, то ячейка памяти - MRF
          NodeF^.MRF:=RFSize;

           //если замещается вся ф-ия (NS), то ячейка памяти - MRF
           //если частичное замещение (NS) - то  , то ячейка памяти - MRF_CS
           if RangR = rf_FULL_REPLACE  then
           begin
            NodeS^.MRF:=NodeF^.MRF-MShft;
            NodeS^.RRF:=rf_FULL_REPLACE;
           end
           else
           begin
            NodeS^.MRF_CS:=NodeF^.MRF-MShft;
            NodeS^.RRF:=RangR;
           end;

           B_RF:=True;
       end;
     end;

   end
   else    //сохраняется часть ф-ии (NF): ячейка памяти - MWF_CS
   begin
      if NodeF^.WRF_CS = RangW then        //уже было сохранение этой части ф-ии  (NF)
      begin
          if RangR > NodeS^.RRF then        //ранг замещаемой ф-ии выше предыдущего замещения , то выполнить  замещение
          begin
            //если замещается вся ф-ия (NS), то ячейка памяти - MRF
            //если частичное замещение (NS) - то  , то ячейка памяти - MRF_CS
            if RangR = rf_FULL_REPLACE  then
            begin
              NodeS^.MRF:=NodeF^.MWF_CS-MShft;
              NodeS^.RRF:=rf_FULL_REPLACE;
            end
            else
            begin
              NodeS^.MRF_CS:=NodeF^.MWF_CS-MShft;
              NodeS^.RRF:=RangR;
            end;

            B_RF:=True;
          end;
      end
      else             //нет-выделить память
      begin

           if RangR > NodeS^.RRF then        //ранг замещаемой ф-ии выше предыдущего замещения , то выполнить  замещение
          begin
            RFSize:=RFSize+NMem;      //кол-во сохраняемых чисел
            NodeF^.WRF_CS:=RangW;   //часть сохраняемой   функции (NF)
            NodeF^.MWF_CS:=RFSize;

            //если замещается вся ф-ия (NS), то ячейка памяти - MRF
            //если частичное замещение (NS) - то  , то ячейка памяти - MRF_CS
            if RangR = rf_FULL_REPLACE  then
             begin
               NodeS^.MRF:=NodeF^.MWF_CS-MShft;
               NodeS^.RRF:=rf_FULL_REPLACE;
             end
             else
             begin
               NodeS^.MRF_CS:=NodeF^.MWF_CS-MShft;
               NodeS^.RRF:=RangR;
             end;

            B_RF:=True;
          end;
      end;
   end;






fin:
//удалить все вытекающие аргументы замещаемой функции
if B_RF = True  then
begin
  FreeReplacedNodes(NodeS);

(*
  NodeS1:=GetLowLeftNode(NodeS);
  while NodeS1 <> NodeS do
  begin
    NodeS1^.N:=0;
    NodeS1^.NFunc:=CM_NOP;
    NodeS1^.NF:=0;{.197}
    NodeS1^.TypeF:=0;
    NodeS1^.COP:=_NOP;   //только для аргументов замещаемой комманды
    NodeS1^.RRF:=rf_NO_REPLACE;//???????
    //FuncList[Interp[i].Code].FType:=0;
    NodeS1:=NodeS1^.Next;
  end;
*)
   Sf:=NodeF^.Expression;
   Ss:=NodeS^.Expression;
   inc(Db_ReplFuncNum);

end;


{
 if (NFuncNF = CM_DIV) or (NFuncNF = CM_MUL) or (NFuncNF = CM_SUB) or (NFuncNF = CM_ADD) then inc(Db_ReplOpNum)
 else inc(Db_ReplFuncNum);  }


endp:
end;







