procedure TForevalH.FuncInt1(ComCode: Cardinal);
var
  t1,N,NF,S,tv1,tm1: Integer;
  adr1: Cardinal;
begin

  //***** Int1func(IntArg); IntArg -> EAX   ******
N:=GNode^.NFunc;
NF:=GNode^.NF;
if GNode^.AI = 0 then       // IntArg: Stack
begin
 t1:=Alg.ExFunc[N].Func[NF].TV[0];
 LoadArg1;
 if t1 = T_Real then
 begin
  //PUSHCW;    {.227}
  //FLDCW(TAddress(@FCW1));
  MEM:=WriteDataA(0,_Integer);
  FISTP(MEM);
  //POPCW;    {.227} //FLDCW(TAddress(@FCW2));
  MOVMA(MEM);
 end;
end
else
if GNode^.AI = 1 then    // IntArg: IntForm
begin
  LoadLineFormEAX(_First);

  {
  GetVar(GNode^.NV1,adr1,tv1,tm1);
  MOVMA(adr1);
  }

end
else
if GNode^.AI = 2 then      //IntArg: IntArray[indx]
begin
   LoadArrayElem(tc_LoadIntArrayElemEAX);
end;



   // ***** Commands *****//

if ComCode = CM_FACT then
begin
 //mov   ecx, dword ptr [Factorial]
 MOVMREG(R_ECX,Cardinal(@Factorial));
 //lea   ecx, [ecx+eax*8]
 AddByte3($8D,$0C,$C1);
 //lea   eax, [ecx+eax*2]
 AddByte3($8D,$04,$41);
 //fld   tbyte ptr [eax]
 AddByte2($DB,$28);

 CheckStack(1);
 SetReg(R_EAX);
 SetReg(R_ECX);
 {
 MOVBadr(Cardinal(@R_FACT));
 CALLB;
 CheckStack(1);
 }
end
else
if ComCode = CM_FACT2 then
begin

  //mov   ecx, dword ptr [Factorial2F]
 MOVMREG(R_ECX,Cardinal(@Factorial2F));
 //lea   ecx, [ecx+eax*8]
 AddByte3($8D,$0C,$C1);
 //lea   eax, [ecx+eax*2]
 AddByte3($8D,$04,$41);
 //fld   tbyte ptr [eax]
 AddByte2($DB,$28);

 CheckStack(1);
 SetReg(R_EAX);
 SetReg(R_ECX);

{
 MOVBadr(Cardinal(@R_FACT2));
 CALLB;
 CheckStack(1);
 }
end
else
if ComCode = CM_NOT then
begin
  //not eax
  AddByte2($F7,$D0);
  //load FPU from EAX
  MEM:=WriteDataA(0,_Integer);
  MOVAM(MEM);
  FILD(MEM);
end;


end;


