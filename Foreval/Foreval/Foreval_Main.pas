 end;

 {inc(F_IdN);
 ND.IdN:=F_IdN;}
 if {Length(LV) > 0} EOFN = False then
 begin

   for i := 0 to High(LV) do
   begin
     //LV[i].IdL:=F_IdN;
     LV[i].NL:=i+1;
     //if ExtFunc = True then LV[i].ExtFunc:=nf else LV[i].Extfunc:=_NOT_FOUND; {.309}
     if ExtFunc = True then  LV[i].ExtFunc:=ND.NFunc else LV[i].Extfunc:=_NOT_FOUND; {.334}

     (*
     if ND.NFunc <> CM_IF then     {.395if}
     begin
        LV[i].AlwaysEval:=_YES;
        LV[i].EndIf:=_NO;
     end;
    *)

   end;

 end;
end;

   {.395if}
   for i := 0 to High(LV) do
   begin
     if ND.NFunc <> CM_IF then
     begin
        LV[i].AlwaysEval:=_YES;
        LV[i].EndIf:=_NO;
     end;
   end;



endpp:
BFuncArrayFind:= (BFuncFind) or (BArrayFind);
end;





 (*
