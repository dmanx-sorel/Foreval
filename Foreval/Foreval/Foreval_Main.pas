procedure TForevalH._ComplexSUB(Re1,Im1,Re2,Im2: Extended; var Re,Im: Extended);
begin
  Re:=Re1-Re2;
  Im:=Im1-Im2;
end;


procedure TForevalH._ComplexMUL(Re1,Im1,Re2,Im2: Extended; var Re,Im: Extended);
begin
  Re := Re1*Re2-Im1*Im2;
  Im := Re1*Im2+Im1*Re2;
end;



procedure TForevalH._ComplexDIV(Re1,Im1,Re2,Im2: Extended; var Re,Im: Extended);

     procedure _ZZDIV_acc(_Re1,_Im1,_Re2,_Im2: Extended; var _Re,_Im: Extended); assembler;
     //begin
         asm
           pushad
           fld   tbyte ptr _Im2
           fld   tbyte ptr _Re2
           fld   tbyte ptr _Im1
           fld   tbyte ptr _Re1
           call  Z_DIV_ACC
           fstp  tbyte ptr [_Re]
           fstp  tbyte ptr [_Im]
           popad
         end;
     //end;

begin

try
  TryFPUMask;


 { Re := (Re1*Re2+Im1*Im2)/(sqr(Re2)+sqr(Im2));
  Im := (Im1*Re2-Re1*Im2)/(sqr(Re2)+sqr(Im2)); }
   {.361}
  _ZZDIV_acc(Re1,Im1,Re2,Im2, Re, Im);

  TryCatchFPUException;
except
 on E: EZeroDivide      do F_InternalError:=E_ZeroDivide;
 on E: EInvalidOp       do F_InternalError:=E_InvalidOp;
 on E: EOverFlow        do F_InternalError:=E_OverFlow;
 on E: EUnderFlow       do F_InternalError:=E_UnderFlow;
 on E: EIntOverFlow     do F_InternalError:=E_IntOverFlow;
 on E: EAccessViolation do F_InternalError:=E_AccessViolation;
 on E: EOutOfMemory     do F_InternalError:=E_OutOfMemory;
 on E: EStackOverFlow   do F_InternalError:=E_StackOverFlow;
end;

   if F_InternalError <> 0 then
      F_SyntaxErrorCode:=E_INTERNAL_ERROR_AT_CALCULATION;
end;


procedure TForevalH._EvalFunc1Cx(Addr: Pointer;  Arg1: TComplex;  var Res: TComplex);
var
re,im: Extended;
begin

  asm
    pushad
    fld tbyte ptr [Arg1.im]
    fld tbyte ptr [Arg1.re]
    call Addr
    fstp tbyte ptr [Re]
    fstp tbyte ptr [Im]
    popad
  end;


  Res.re:=Re; Res.im:=Im;
end;




procedure TForevalH._EvalFunc1CxInt(Addr: Pointer;  Arg1: TComplex; Arg2: Integer; var Res: TComplex);
var
re,im: Extended;
begin

  asm
    pushad
    fld tbyte ptr [Arg1.im]
    fld tbyte ptr [Arg1.re]
    mov eax,Arg2
    call Addr
    fstp tbyte ptr [Re]
    fstp tbyte ptr [Im]
    popad
  end;

  Res.re:=Re; Res.im:=Im;
end;



procedure TForevalH._EvalFunc1CxInt2(Addr: Pointer;  Arg1: TComplex; Arg2,Arg3: Integer; var Res: TComplex);
var
re,im: Extended;
begin

   asm
    pushad
    fld tbyte ptr [Arg1.im]
    fld tbyte ptr [Arg1.re]
    mov eax,Arg2
    mov ebx,Arg3
    call Addr
    fstp tbyte ptr [Re]
    fstp tbyte ptr [Im]
    popad
  end;

  Res.re:=Re; Res.im:=Im;
end;


procedure TForevalH._EvalFunc1ReInt(Addr: Pointer;  Arg1: Extended; Arg2: Integer; var Res: Extended);
var
re,im: Extended;
begin

  asm
    pushad
    fld tbyte ptr [Arg1]
    mov eax,Arg2
    call Addr
    fstp tbyte ptr [Re]
    popad
  end;


  Res:=Re; //Res.im:=Im;
end;


procedure TForevalH._EvalFunc2Cx(Addr: Pointer;  Arg1,Arg2: TComplex; TV1,TV2: Integer; var Res: TComplex);
var
re,im: Extended;
begin
if (TV1 = T_Complex) and  (TV2 = T_Complex) then
begin
  asm
    pushad
    fld tbyte ptr [Arg2.im]
    fld tbyte ptr [Arg2.re]
    fld tbyte ptr [Arg1.im]
    fld tbyte ptr [Arg1.re]
    call Addr
    fstp tbyte ptr [Re]
    fstp tbyte ptr [Im]
    popad
  end;
end
else
if (TV1 = T_Real) and  (TV2 = T_Complex) then
begin
  asm
    pushad
    fld tbyte ptr [Arg2.im]
    fld tbyte ptr [Arg2.re]
    fld tbyte ptr [Arg1.re]
    call Addr
    fstp tbyte ptr [Re]
    fstp tbyte ptr [Im]
    popad
  end;
end
else
if (TV1 = T_Complex) and  (TV2 = T_Real) then
begin
   asm
    pushad
    fld tbyte ptr [Arg2.re]
    fld tbyte ptr [Arg1.im]
    fld tbyte ptr [Arg1.re]
    call Addr
    fstp tbyte ptr [Re]
    fstp tbyte ptr [Im]
    popad
  end;
end;

Res.re:=Re; Res.im:=Im;

end;


procedure TForevalH._EvalFuncReCx(AddrF: Pointer; Re: TFloat; var Res: TComplex);
begin
 asm
   fld Re
 end;
 _EvalFunc(AddrF,T_Complex,Res);
end;


procedure TForevalH._EvalFunc(AddrF: Pointer; TypeF: Integer; var Res: TComplex);
var
re,im: Extended;
begin
try

re:=0; im:=0;
  if TypeF = T_Real then
  begin
     asm
       pushad
       call AddrF
       fstp tbyte ptr [Re]
       popad
     end;
  end
  else
  if TypeF = T_Complex then
  begin
     asm
       pushad
       call AddrF
       fstp tbyte ptr [Re]
       fstp tbyte ptr [Im]
       popad
     end;
  end;

  Res.re:=Re; Res.im:=Im;

except {.322}
 on E: EZeroDivide      do F_InternalError:=E_ZeroDivide;
 on E: EInvalidOp       do F_InternalError:=E_InvalidOp;
 on E: EOverFlow        do F_InternalError:=E_OverFlow;
 on E: EUnderFlow       do F_InternalError:=E_UnderFlow;
 on E: EIntOverFlow     do F_InternalError:=E_IntOverFlow;
 on E: EAccessViolation do F_InternalError:=E_AccessViolation;
 on E: EOutOfMemory     do F_InternalError:=E_OutOfMemory;
 on E: EStackOverFlow   do F_InternalError:=E_StackOverFlow
end;

if F_InternalError <> 0 then F_SyntaxErrorCode:=E_INTERNAL_ERROR_AT_CALCULATION;    {.326}


end;



procedure TForevalH._EvalFunc1({NFunc,NF: Integer;}PNE: PNode; Arg1: TComplex; var Res: TComplex; var ResType: Integer;  var IsEval: Boolean);
var
 TV1,TypeF,NFunc,NF,IC,IC1,IC2: Integer;
 Addr: Pointer;
 FName: String;
 ArgR: TComplex;
 ArgW,ResW : Foreval_SpecFunc.complex;
 FD: Extended;
 Arg2: TComplex;
 ArgType1,ArgType2: Integer;
begin


  NFunc:=PNE^.NFunc; NF:=PNE^.NF;
  TypeF:=Alg.ExFunc[NFunc].Func[NF].TypeF;
  ResType:=TypeF; {.361} // иcключение для некоторых нестандартных внутренних функций, возвращающих тип результата через Node^.TypeF
  TV1:=Alg.ExFunc[NFunc].Func[NF].TV[0];

  //IsEval:=True;
  IsEval:=False;   {.329}
  Res.re:=0;   Res.im:=0;   FD:=PNE^.FD;
  ArgType1:=0; ArgType2:=0;

  {.335}
  // перекодировка NFunc  _acc функций в NFunc обычных (быстрых) для удобства вычисления конст. функ. в режиме AccFunc
  //(не обязательно. Иначе вычисление через промежуточную компиляцию)
  if F_FAST_STD_FUNC = False then
  begin
    NFunc:=XchNFuncFastAcc(NFunc);
  end;


  if TV1 = T_Real then
  begin
     case NFunc of     //  _Internal     {.357}
       CM_SQR:       begin Res.re:=sqr(Arg1.re);   IsEval:=True; end; {.329}
       CM_SQRT:      begin Res.re:=sqrt(Arg1.re);  IsEval:=True; end; {.329}
       CM_EXP:       begin Res.re:=exp(Arg1.re);   IsEval:=True; end; {.329}
       CM_LN:        begin Res.re:=fc_ln(Arg1.re);    IsEval:=True; end; {.329}
       CM_SIN:       begin Res.re:=sin_acc(Arg1.re);   IsEval:=True; end; {.329}
       CM_COS:       begin Res.re:=cos_acc(Arg1.re);   IsEval:=True; end; {.329}
       CM_TAN:       begin Res.re:=fc_tan(Arg1.re);    IsEval:=True; end; {.329}
       CM_COTAN:     begin Res.re:=cot_acc(Arg1.re);  IsEval:=True; end; {.329}
       CM_SINH:      begin  Res.re:=sinh_acc(Arg1.re);   IsEval:=True; end; {.329}
       CM_COSH:      begin  Res.re:=cosh_acc(Arg1.re);   IsEval:=True; end; {.329}
       CM_TANH:      begin  Res.re:=tanh_acc(Arg1.re);   IsEval:=True; end; {.329}
       CM_COTANH:    begin  Res.re:=coth_acc(Arg1.re);    IsEval:=True; end; {.329}
       CM_ARCSIN:    begin    Res.re:=arcsin_acc(Arg1.re);  IsEval:=True; end; {.329}
       CM_ARCCOS:    begin    Res.re:=arccos_acc(Arg1.re);    IsEval:=True; end; {.329}
       CM_ARCTAN:    begin    Res.re:=arctan(Arg1.re);   IsEval:=True; end; {.329}
       CM_ARCCOTAN:  begin                                    {.335}
                          if F_FAST_STD_FUNC = True then
                             Res.re:=PI_2-arctan(Arg1.re)
                          else
                             Res.re:=arccot_acc(Arg1.re);

                          IsEval:=True;
                     end; {.329}
       CM_ARCSINH:   begin     Res.re:=arcsinh_acc(Arg1.re);   IsEval:=True; end; {.329}
       CM_ARCCOSH:   begin     Res.re:=arccosh_acc(Arg1.re);    IsEval:=True; end; {.329}
       CM_ARCTANH:   begin     Res.re:=arctanh_acc(Arg1.re);    IsEval:=True; end; {.329}
       CM_ARCCOTANH: begin     Res.re:=arccoth_acc(Arg1.re);   IsEval:=True; end; {.329}
       CM_SEC:       begin     Res.re:=sec_acc(Arg1.re);       IsEval:=True; end; {.329}
       CM_COSEC:     begin     Res.re:=csc_acc(Arg1.re);      IsEval:=True; end; {.329}
       CM_SECH:      begin     Res.re:=sech_acc(Arg1.re);      IsEval:=True; end; {.329}
       CM_COSECH:    begin     Res.re:=csch_acc(Arg1.re);      IsEval:=True; end; {.329}
       CM_ARCSEC:    begin     Res.re:=arcsec_acc(Arg1.re);    IsEval:=True; end; {.329}
       CM_ARCCOSEC:  begin     Res.re:=arccsc_acc(Arg1.re);    IsEval:=True; end; {.329}
       CM_ARCSECH:   begin     Res.re:=arcsech_acc(Arg1.re);    IsEval:=True; end; {.329}
       CM_ARCCOSECH: begin     Res.re:=arccsch_acc(Arg1.re);    IsEval:=True; end; {.329}
       CM_LOG2:      begin     Res.re:=fc_log2(Arg1.re);         IsEval:=True; end; {.329}
       CM_LOG10:     begin     Res.re:=fc_log10(Arg1.re);       IsEval:=True; end; {.329}
       CM_FACT2:     begin     Res.re:=factorial2F[{Trunc}Round(Arg1.re)];    IsEval:=True; end; {.329, .385}
       CM_FACT:      begin     Res.re:=factorial[{Trunc}Round(Arg1.re)];   IsEval:=True; end; {.329, .385}
       CM_NOT:       begin     Res.re:=not {Trunc}Round(Arg1.re);   IsEval:=True; end; {.385}
       CM_F2PWR:     begin     Res.re:=power_acc(2,Arg1.re);       IsEval:=True; end; {.329}
       CM_IPWRSGN:   begin
                              if PNE^.AI = 2 then
                              begin
                                 _EvalFuncReCx(@Z_UNeg_ReFPWR,Arg1.re,Res);
                                 ResType:=T_Complex;
                                 IsEval:=True;
                              end
                              else
                              begin
                                Res.re:=power_acc(-1,Arg1.re);
                                ResType:=T_Real;
                                IsEval:=True;
                              end;
                     end;
       CM_IMURZPWR:  begin
                              if PNE^.AI = 1 then
                              begin
                                 _EvalFuncReCx(@Z_ImU_ReFPWR,Arg1.re,Res);
                                 ResType:=T_Complex;
                                 IsEval:=True;
                              end
                              else      //AI=2
                              begin
                                _EvalFuncReCx(@Z_ImUNeg_ReFPWR,Arg1.re,Res);
                                 ResType:=T_Complex;
                                 IsEval:=True;
                              end;
                     end;
       CM_TRUNC:     begin     Res.re:=trunc(Arg1.re);       IsEval:=True; end; {.329}
       CM_ROUND:     begin     Res.re:=round(Arg1.re);       IsEval:=True; end; {.379}
       CM_FRAC:      begin     Res.re:=frac(Arg1.re);      IsEval:=True; end; {.329}
       CM_ABS:       begin     Res.re:=abs(Arg1.re);      IsEval:=True; end; {.329}
       CM_SIGN:      begin if Arg1.re = 0 then Res.re:=0 else if Arg1.re > 0 then Res.re:=1 else Res.re:=-1;  IsEval:=True; end;
       CM_DEG:       begin     Res.re:=Arg1.re*180/3.14159265358979323846264;   IsEval:=True; end;
       CM_RAD:       begin     Res.re:=Arg1.re*3.14159265358979323846264/180;   IsEval:=True; end;


       CM_IPWR:    begin
                       if (PNE^.AI = 2) and (PNE^.TA2 = _IntConst) then //Expr^IntConst
                       begin
                          IC:=PNE^.IC2;
                          Res.re:=fc_IntPower(Arg1.re,IC);
                          IsEval:=True;
                       end
                       else
                       IsEval:=False;
                   end;

       CM_IPWR16:  begin
                          IC:=PNE^.AI;                  //Expr^(+- 1..16)
                          Res.re:=fc_IntPower(Arg1.re,IC);
                          IsEval:=True;
                   end;

       CM_IROOT:   begin
                       if (PNE^.AI = 2) and (PNE^.TA2 = _IntConst) then //root(Expr,IntConst)
                       begin
                          IC:=PNE^.IC2;
                          _EvalFunc1ReInt(@R_IROOT,Arg1.re,IC,Res.re);
                          IsEval:=True;
                       end
                       else
                       IsEval:=False;
                   end;

     CM_CRZIROOT:  begin
                   if (PNE^.AI = 1) and (PNE^.TA2 = _IntConst) then //root(ConstReal,IntConst)
                       begin
                          IC:=PNE^.IC2;
                          _EvalFunc1ReInt(@R_IROOT,Arg1.re,IC,Res.re);
                          ResType:=T_Real;
                          IsEval:=True;
                       end
                       else
                       IsEval:=False;
                   end;



       CM_CZPWR:   begin

                       if PNE^.AI = 1 then   ArgType1:=T_Real else
                       if PNE^.AI = 2 then   ArgType1:=T_Complex;
                       ArgType2:=Alg.ExFunc[PNE^.NFunc].Func[PNE^.NF].TV[0];
                       //или ArgType2:=PNE^.TypeA;

                       if (ArgType1 = T_Real) and (ArgType2 = T_Real) then
                       begin
                         Res.re:=power_acc(PNE^.FD,Arg1.re);
                         IsEval:=True;
                         ResType:=T_Real;
                         //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end
                      (* else

                       if  (ArgType1 = T_Real) and (ArgType2 = T_Complex) then
                       begin
                             Arg2:=Arg1;
                             Arg1.re:=PNE^.FD; Arg1.im:=0;
                            _EvalFunc2Cx(@Z_ReCxFPWR,Arg1,Arg2,ArgType1,ArgType2,Res);
                             IsEval:=True;
                             ResType:=T_Complex;
                            //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end
                       *)
                       else
                       if  (ArgType1 = T_Complex) and (ArgType2 = T_Real) then
                       begin
                              Arg2:=Arg1;
                              Arg2.im:=0;
                              Arg1.re:=PNE^.FDC.re; Arg1.im:=PNE^.FDC.im;
                              cpow_acc(complex(Arg1),complex(Arg2),complex(Res));
                             //_EvalFunc2Cx(@Z_CxReFPWR,Arg1,Arg2,ArgType1,ArgType2,Res);
                              IsEval:=True;
                              ResType:=T_Complex;
                              //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end
                       (*
                       else
                       if  (ArgType1 = T_Complex) and (ArgType2 = T_Complex) then
                       begin
                              Arg2:=Arg1;
                              Arg1.re:=PNE^.FDC.re; Arg1.im:=PNE^.FDC.im;
                             _EvalFunc2Cx(@ZPWR,Arg1,Arg2,ArgType1,ArgType2,Res);
                              IsEval:=True;
                              ResType:=T_Complex;
                             //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end;
                       *)

                   end;

      // !
      CM_CRZLOG:  begin
                       //LOG (ConstReal, ConstReal)
                       if PNE^.AI = 1 then   ArgType1:=T_Real else
                       if PNE^.AI = 2 then   ArgType1:=T_Complex;
                       ArgType2:=Alg.ExFunc[PNE^.NFunc].Func[PNE^.NF].TV[0];
                       //или ArgType2:=PNE^.TypeA;

                       if (ArgType1 = T_Real) and (ArgType2 = T_Real) then
                       begin
                         Res.re:=R_LOG_acc(PNE^.FD,Arg1.re);
                         IsEval:=True;
                         ResType:=T_Real;
                         //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end
                  end;
     //  !
      CM_CR2ZLOG: begin
                       //LOG (ConstReal, ConstReal)
                       if PNE^.AI = 1 then   ArgType1:=T_Real else
                       if PNE^.AI = 2 then   ArgType1:=T_Complex;
                       ArgType2:=Alg.ExFunc[PNE^.NFunc].Func[PNE^.NF].TV[0];
                       //или ArgType2:=PNE^.TypeA;

                       if (ArgType1 = T_Real) and (ArgType2 = T_Real) then
                       begin
                         Res.re:=R_LOG_acc(Arg1.re,PNE^.FD);
                         IsEval:=True;
                         ResType:=T_Real;
                         //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end
                  end


       else
                  begin     //  _External
                      FName:=Alg.ExFunc[NFunc].Name;
                      if FName = 'gamma'    then  begin Res.re:=sfc_gamma(Arg1.re); IsEval:=True; end else
                      if FName = 'lngamma'  then  begin Res.re:=sfc_lngamma(Arg1.re); IsEval:=True; end else  {.334}
                      if FName = 'besselj0' then  begin Res.re:=sfc_j0(Arg1.re); IsEval:=True; end else
                      if FName = 'besselj1' then  begin Res.re:=sfc_j1(Arg1.re); IsEval:=True; end else
                      if FName = 'bessely0' then  begin Res.re:=sfc_y0(Arg1.re); IsEval:=True; end else
                      if FName = 'bessely1' then  begin Res.re:=sfc_y1(Arg1.re); IsEval:=True; end else
                      if FName = 'erf'      then  begin Res.re:=sfc_erf(Arg1.re); IsEval:=True; end else
                      if FName = 'erfc'     then  begin Res.re:=sfc_erfc(Arg1.re); IsEval:=True; end else
                      if FName = 'zeta'     then  begin Res.re:=sfc_zeta(Arg1.re); IsEval:=True; end else
                      if FName = 'psi'      then  begin Res.re:=sfc_psi(Arg1.re); IsEval:=True; end
                      else
                      if (F_CalcConstExtFunc = True) and
                         (Alg.ExFunc[NFunc].Func[NF].IntF = _External) and
                         (Alg.ExFunc[NFunc].Func[NF].Addr <> 0)
                       then EvalFuncN(PNE,Res,IsEval);
                      //IsEval:=False;
                  end;
     end


  end
  else
  if TV1 = T_Complex then
  begin
     case NFunc of
       CM_SQR:     begin  _EvalFunc1Cx(@Z_SQR,Arg1,Res);  IsEval:=True; end; {.329}
       CM_SQRT:    begin  _EvalFunc1Cx(@Z_SQRT,Arg1,Res);  IsEval:=True; end; {.329}
       CM_EXP:     begin  _EvalFunc1Cx(@Z_EXP,Arg1,Res);   IsEval:=True; end; {.329}
       CM_LN:      begin  _EvalFunc1Cx(@Z_LN,Arg1,Res);   IsEval:=True; end; {.329}
       CM_SIN:     begin  _EvalFunc1Cx(@Z_SIN,Arg1,Res);  IsEval:=True; end; {.329}
       CM_COS:     begin  _EvalFunc1Cx(@Z_COS,Arg1,Res);    IsEval:=True; end; {.329}
       CM_TAN:     begin  _EvalFunc1Cx(@Z_TAN,Arg1,Res);    IsEval:=True; end; {.329}
       CM_COTAN:   begin  _EvalFunc1Cx(@Z_COTAN,Arg1,Res);   IsEval:=True; end; {.329}
       CM_SINH:    begin  _EvalFunc1Cx(@Z_SINH,Arg1,Res);   IsEval:=True; end; {.329}
       CM_COSH:    begin  _EvalFunc1Cx(@Z_COSH,Arg1,Res);    IsEval:=True; end; {.329}
       CM_TANH:    begin  _EvalFunc1Cx(@Z_TANH,Arg1,Res);    IsEval:=True; end; {.329}
       CM_COTANH:  begin  _EvalFunc1Cx(@Z_COTANH,Arg1,Res);   IsEval:=True; end; {.329}
       CM_ARCSIN:  begin

                           if F_FAST_STD_FUNC = True then
                               _EvalFunc1Cx(@Z_ARCSIN,Arg1,Res)
                           else
                           begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carcsin_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                           end;

                           IsEval:=True;
                   end; {.329}
       CM_ARCCOS:  begin
                          if F_FAST_STD_FUNC = True then
                               _EvalFunc1Cx(@Z_ARCCOS,Arg1,Res)
                           else
                           begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carccos_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                           end;

                         IsEval:=True;
                   end; {.329}
       CM_ARCTAN:  begin
                           if F_FAST_STD_FUNC = True then
                               _EvalFunc1Cx(@Z_ARCTAN,Arg1,Res)
                           else
                           begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carctan_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                           end;

                           IsEval:=True;
                     end; {.329}
       CM_ARCCOTAN:  begin
                           if F_FAST_STD_FUNC = True then
                                _EvalFunc1Cx(@Z_ARCCOTAN,Arg1,Res)
                           else
                           begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carccot_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                           end;

                           IsEval:=True;
                     end; {.329}
       CM_ARCSINH:   begin    {.335}
                           if F_FAST_STD_FUNC = True then
                                _EvalFunc1Cx(@Z_ARCSINH,Arg1,Res)
                           else
                           begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carcsinh_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                           end;

                             IsEval:=True;
                     end; {.329}
       CM_ARCCOSH:   begin    {.335}

                           if F_FAST_STD_FUNC = True then
                               _EvalFunc1Cx(@Z_ARCCOSH,Arg1,Res)
                           else
                           begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carccosh_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                           end;

                          IsEval:=True;
                     end; {.329}
       CM_ARCTANH:   begin    {.335}
                           if F_FAST_STD_FUNC = True then
                               _EvalFunc1Cx(@Z_ARCTANH,Arg1,Res)
                           else
                           begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carctanh_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                           end;
                           IsEval:=True;
                     end; {.329}
       CM_ARCCOTANH: begin  {.335}
                          if F_FAST_STD_FUNC = True then
                                _EvalFunc1Cx(@Z_ARCCOTANH,Arg1,Res)
                           else
                           begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carccoth_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                           end;

                            IsEval:=True;
                     end; {.329}
       CM_SEC:       begin  _EvalFunc1Cx(@Z_SEC,Arg1,Res);      IsEval:=True; end; {.329}
       CM_COSEC:     begin  _EvalFunc1Cx(@Z_COSEC,Arg1,Res);   IsEval:=True; end; {.329}
       CM_SECH:      begin  _EvalFunc1Cx(@Z_SECH,Arg1,Res);      IsEval:=True; end; {.329}
       CM_COSECH:    begin  _EvalFunc1Cx(@Z_COSECH,Arg1,Res);    IsEval:=True; end; {.329}
       CM_ARCSEC:    begin
                           if F_FAST_STD_FUNC = True then
                              _EvalFunc1Cx(@Z_ARCSEC,Arg1,Res)
                           else
                           begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carcsec_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                           end;

                           IsEval:=True;

                     end; {.329}
       CM_ARCCOSEC:  begin
                         if F_FAST_STD_FUNC = True then
                               _EvalFunc1Cx(@Z_ARCCOSEC,Arg1,Res)
                           else
                           begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carccsc_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                           end;

                          IsEval:=True;
                     end; {.329}
       CM_ARCSECH:   begin   {.335}
                          if F_FAST_STD_FUNC = True then
                                _EvalFunc1Cx(@Z_ARCSECH,Arg1,Res)
                          else
                          begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carcsech_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                          end;

                           IsEval:=True;
                     end; {.329}
       CM_ARCCOSECH:  begin   {.335}
                          if F_FAST_STD_FUNC = True then
                                _EvalFunc1Cx(@Z_ARCCOSECH,Arg1,Res)
                          else
                          begin
                               ArgW.re:=Arg1.re; ArgW.im:=Arg1.im;
                               carccsch_acc(ArgW,ResW);
                               Res.re:=ResW.re; Res.im:=ResW.im;
                          end;

                            IsEval:=True;
                      end; {.329}
       CM_LOG2:       begin ArgR.re:=2;  _EvalFunc2Cx(@Z_ReCxLOG,ArgR,Arg1,T_Real,T_Complex,Res);   IsEval:=True; end;
       CM_LOG10:      begin ArgR.re:=10; _EvalFunc2Cx(@Z_ReCxLOG,ArgR,Arg1,T_Real,T_Complex,Res);   IsEval:=True; end;
       CM_IPWRSGN:    begin _EvalFunc1Cx(@Z_IPWRSGN,Arg1,Res);   IsEval:=True; end;
       CM_ABS:        begin Res.re:=sqrt(sqr(Arg1.re)+sqr(Arg1.im));   IsEval:=True; end;
       CM_SIGN:       begin        {.334}
                            if Arg1.re > 0 then Res.re:=1
                            else
                            if Arg1.re < 0 then Res.re:=-1
                            else
                            if Arg1.im > 0 then Res.re:=1
                            else
                            if Arg1.im < 0 then Res.re:=-1
                            else Res.re:=0;
                            IsEval:=True;
                      end;

       CM_ARG:        begin Res.re:=arctan2_acc(Arg1.im,Arg1.re);   IsEval:=True; end;  {.361}


       CM_IPWR:   begin
                       if (PNE^.AI = 2) and (PNE^.TA2 = _IntConst) then //Expr^IntConst
                       begin
                          IC:=PNE^.IC2;
                          _EvalFunc1CxInt(@Z_IPWR,Arg1,IC,Res);
                            IsEval:=True;
                       end
                       else
                       IsEval:=False;
                   end;

       CM_IPWR16:  begin                       //Expr^(+- 1..16)
                          IC:=PNE^.AI;
                          _EvalFunc1CxInt(@Z_IPWR,Arg1,IC,Res);
                            IsEval:=True;
                   end;

      CM_IROOT:   begin
                       if (PNE^.AI = 2) and (PNE^.TA2 = _IntConst) then //root(Expr,IntConst)
                       begin
                          IC:=PNE^.IC2;
                          _EvalFunc1CxInt(@Z_CxIROOT,Arg1,IC,Res);
                           IsEval:=True;
                       end
                       else   // не работает ->   CM_IROOT3
                       if (PNE^.AI = 3) and (PNE^.TA1 = _IntConst) and (PNE^.TA2 = _IntConst) then //root(Expr,IntConst1,IntConst2)
                       begin
                           IC1:=PNE^.IC1;
                           IC2:=PNE^.IC2;
                          _EvalFunc1CxInt2(@Z_CxIROOT3Int,Arg1,IC1,IC2,Res);
                            IsEval:=True;
                       end
                       else
                       IsEval:=False;
                   end;


     CM_IROOT3:   begin       {.395}
                       if (PNE^.AI = 1) and (PNE^.TA1 = _IntConst) and (PNE^.TA2 = _IntConst) then //root(Expr,IntConst1,IntConst2)
                       begin
                           IC1:=PNE^.IC1;
                           IC2:=PNE^.IC2;
                          _EvalFunc1CxInt2(@Z_CxIROOT3Int,Arg1,IC1,IC2,Res);
                            IsEval:=True;
                       end
                       else
                       IsEval:=False;
                   end;



    CM_CRZIROOT:   begin
                       if (PNE^.AI = 2) and (PNE^.TA2 = _IntConst) then //root(ConstComplex,IntConst)
                       begin
                          IC:=PNE^.IC2;
                          _EvalFunc1CxInt(@Z_CxIROOT,Arg1,IC,Res);
                          IsEval:=True;
                          ResType:=T_Complex;
                       end
                       else
                       IsEval:=False;
                   end;


       CM_CZPWR:   begin

                       if PNE^.AI = 1 then   ArgType1:=T_Real else
                       if PNE^.AI = 2 then   ArgType1:=T_Complex;
                       ArgType2:=Alg.ExFunc[PNE^.NFunc].Func[PNE^.NF].TV[0];
                       //или ArgType2:=PNE^.TypeA;


                       (*if (ArgType1 = T_Real) and (ArgType2 = T_Real) then
                       begin
                         Res.re:=power_acc(PNE^.FD,Arg1.re);
                         IsEval:=True;
                         ResType:=T_Real;
                         //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end
                       else *)
                       if  (ArgType1 = T_Real) and (ArgType2 = T_Complex) then
                       begin
                             Arg2:=Arg1;
                             Arg1.re:=PNE^.FD; Arg1.im:=0;
                            //_EvalFunc2Cx(@Z_ReCxFPWR,Arg1,Arg2,ArgType1,ArgType2,Res);
                            cpow_acc(complex(Arg1),complex(Arg2),complex(Res));
                             IsEval:=True;
                             ResType:=T_Complex;
                            //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end
                       else
                       (*
                       if  (ArgType1 = T_Complex) and (ArgType2 = T_Real) then
                       begin
                              Arg2:=Arg1;
                              Arg2.im:=0;
                              Arg1.re:=PNE^.FDC.re; Arg1.im:=PNE^.FDC.im;
                             _EvalFunc2Cx(@Z_CxReFPWR,Arg1,Arg2,ArgType1,ArgType2,Res);
                              IsEval:=True;
                              ResType:=T_Complex;
                              //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end
                       else *)
                       if  (ArgType1 = T_Complex) and (ArgType2 = T_Complex) then
                       begin
                              Arg2:=Arg1;
                              Arg1.re:=PNE^.FDC.re; Arg1.im:=PNE^.FDC.im;
                             //_EvalFunc2Cx(@ZPWR,Arg1,Arg2,ArgType1,ArgType2,Res);
                             cpow_acc(complex(Arg1),complex(Arg2),complex(Res));
                              IsEval:=True;
                              ResType:=T_Complex;
                             //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end;

                   end;

       // !
     CM_CRZLOG:   begin
                       // LOG(ConstReal, ConstComplex)
                       if PNE^.AI = 1 then   ArgType1:=T_Real else
                       if PNE^.AI = 2 then   ArgType1:=T_Complex;
                       ArgType2:=Alg.ExFunc[PNE^.NFunc].Func[PNE^.NF].TV[0];

                       if  (ArgType1 = T_Real) and (ArgType2 = T_Complex) then
                       begin
                             Arg2:=Arg1;
                             Arg1.re:=PNE^.FD; Arg1.im:=0;
                            //_EvalFunc2Cx(@Z_ReCxLOG,Arg1,Arg2,ArgType1,ArgType2,Res);
                             clogbase_acc(complex(Arg1),complex(Arg2),complex(Res));
                             IsEval:=True;
                             ResType:=T_Complex;
                            //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end
                   end;


    //  !
    CM_CR2ZLOG:   begin
                       // LOG(ConstComplex,ConstReal)
                       if PNE^.AI = 1 then   ArgType1:=T_Real else
                       if PNE^.AI = 2 then   ArgType1:=T_Complex;
                       ArgType2:=Alg.ExFunc[PNE^.NFunc].Func[PNE^.NF].TV[0];

                       if  (ArgType1 = T_Real) and (ArgType2 = T_Complex) then
                       begin
                             //Arg2:=Arg1;
                             Arg2.re:=PNE^.FD; Arg2.im:=0;
                            //_EvalFunc2Cx(@Z_CxReLOG,Arg1,Arg2,ArgType1,ArgType2,Res);
                             clogbase_acc(complex(Arg1),complex(Arg2),complex(Res));
                             IsEval:=True;
                             ResType:=T_Complex;
                            //исключение, т.к. тип рез-та однозначно не определяется заданием ф-ии в Alg.ExFunc[NFunc].Func[NF].TV[0];
                       end
                   end;



     CM_IMURZPWR:  begin
                              if PNE^.AI = 1 then
                              begin
                                 _EvalFunc1Cx(@Z_ImU_CxFPWR,Arg1,Res);
                                 ResType:=T_Complex;
                                 IsEval:=True;
                              end
                              else      //AI=2
                              begin
                                _EvalFunc1Cx(@Z_ImUNeg_CxFPWR,Arg1,Res);
                                 ResType:=T_Complex;
                                 IsEval:=True;
                              end;
                    end;


      else         begin     //  _External
                      FName:=Alg.ExFunc[NFunc].Name;
                       if FName = 'gamma'    then  begin _EvalFunc1Cx(@Z_GAMMA,Arg1,Res) ;   IsEval:=True; end
                       else
                       if FName = 'lngamma'    then  begin _EvalFunc1Cx(@Z_LNGAMMA,Arg1,Res) ;   IsEval:=True; end  {.334}
                       else
                       if FName = 'psi'    then  begin _EvalFunc1Cx(@Z_PSI,Arg1,Res) ;   IsEval:=True; end  {.334}
                       else
                       if FName = 'zeta'    then  begin _EvalFunc1Cx(@Z_ZETA,Arg1,Res) ;   IsEval:=True; end  {.334}
                       else
                       if    (F_CalcConstExtFunc = True) and
                             (Alg.ExFunc[NFunc].Func[NF].IntF = _External) and
                             (Alg.ExFunc[NFunc].Func[NF].Addr <> 0)
                       then  begin EvalFuncN(PNE,Res,IsEval);   IsEval:=True; end
                       else
                       IsEval:=False;
                   end;


     end;


  end ;

end;



procedure TForevalH._EvalFunc2({NFunc,NF: Integer;}PNE: PNode; Arg1,Arg2: TComplex; var Res: TComplex; var IsEval: Boolean);
var
 TV1,TV2,TypeF,NFunc,NF,NA1,NA2: Integer;
 Addr: Pointer;
 FName: String;
begin

  NFunc:=PNE^.NFunc; NF:=PNE^.NF;
  TypeF:=Alg.ExFunc[NFunc].Func[NF].TypeF;
  TV1:=Alg.ExFunc[NFunc].Func[NF].TV[0];
  TV2:=Alg.ExFunc[NFunc].Func[NF].TV[1];

  //IsEval:=True;
  IsEval:=False;   {.329}
  Res.re:=0;   Res.im:=0;

  if (TV1 = T_Real) and (TV2 = T_Real)  then
  begin
     case NFunc of
       CM_POWER:     begin Res.re:=power_acc(Arg1.re,Arg2.re);  IsEval:=True; end; {.329}
       CM_COMPLEX:   begin Res.re:=Arg1.re; Res.im:=Arg2.re;   IsEval:=True; end; {.329}
       CM_ARCTAN2:   begin Res.re:=arctan2_acc(Arg1.re,Arg2.re);   IsEval:=True; end; {.329}
       CM_LOG:       begin Res.re:=fc_logn(Arg1.re,Arg2.re);    IsEval:=True; end; {.329}
       CM_ROOT:      begin _EvalFunc1ReInt(@R_IROOT,Arg1.re,round(Arg2.re),Res.re);     IsEval:=True; end; {.329}
       CM_DECART:    begin Arg1.im:=Arg2.re; _EvalFunc1Cx(@R_Decart,Arg1,Res);   IsEval:=True; end; {.329}
       CM_IDIV:      begin NA1:={Trunc}Round(Arg1.re); NA2:={Trunc}Round(Arg2.re); Res.re:=NA1 div NA2; IsEval:=True;  end; {.379}
       CM_MOD:       begin NA1:={Trunc}Round(Arg1.re); NA2:={Trunc}Round(Arg2.re); Res.re:=NA1 mod NA2; IsEval:=True;  end; {.379}
       CM_AND:       begin NA1:={Trunc}Round(Arg1.re); NA2:={Trunc}Round(Arg2.re); Res.re:=NA1 and NA2; IsEval:=True; end;   {.385}
       CM_OR:        begin NA1:={Trunc}Round(Arg1.re); NA2:={Trunc}Round(Arg2.re); Res.re:=NA1 or NA2; IsEval:=True; end;   {.385}
       CM_XOR:       begin NA1:={Trunc}Round(Arg1.re); NA2:={Trunc}Round(Arg2.re); Res.re:=NA1 xor NA2; IsEval:=True; end;   {.385}
       CM_NAND:      begin NA1:={Trunc}Round(Arg1.re); NA2:={Trunc}Round(Arg2.re); Res.re:=not(NA1 and NA2); IsEval:=True; end;   {.385}
       CM_NOR:       begin NA1:={Trunc}Round(Arg1.re); NA2:={Trunc}Round(Arg2.re); Res.re:=not(NA1 and NA2); IsEval:=True; end;   {.385}
       CM_XNOR:      begin NA1:={Trunc}Round(Arg1.re); NA2:={Trunc}Round(Arg2.re); Res.re:=not(NA1 xor NA2); IsEval:=True; end;   {.385}


       else
       begin
         FName:=Alg.ExFunc[NFunc].Name;
         if FName = 'besseljn' then      begin Res.re:=sfc_jn(round(Arg1.re),Arg2.re);   IsEval:=True; end {.329} else
         if FName = 'besselyn' then      begin Res.re:=sfc_yn(round(Arg1.re),Arg2.re);   IsEval:=True; end else
         if FName = 'sphbesseljn' then   begin Res.re:=sfc_sph_jn(round(Arg1.re),Arg2.re); IsEval:=True; end  else
         if FName = 'legendrep' then     begin Res.re:=sfc_legendre_p(round(Arg1.re),Arg2.re);   IsEval:=True; end else
         if FName = 'chebyshevt' then    begin Res.re:=sfc_chebyshev_t(round(Arg1.re),Arg2.re);   IsEval:=True; end else
         if FName = 'chebyshevu' then    begin Res.re:=sfc_chebyshev_u(round(Arg1.re),Arg2.re);   IsEval:=True; end else
         if FName = 'laguerrep' then     begin Res.re:=sfc_laguerre(round(Arg1.re),Arg2.re);   IsEval:=True; end else
         if FName = 'hermitep' then      begin Res.re:=sfc_hermite_h(round(Arg1.re),Arg2.re);   IsEval:=True; end else

         if   (F_CalcConstExtFunc = True) and
              (Alg.ExFunc[NFunc].Func[NF].IntF = _External) and
              (Alg.ExFunc[NFunc].Func[NF].Addr <> 0) then begin EvalFuncN(PNE,Res,IsEval);   IsEval:=True; end
       end;
       //IsEval:=False;
     end;

  end
  else
  if  (TV1 = T_Complex) and (TV2 = T_Complex)  then
  begin
     case NFunc of
       CM_POWER:   begin  _EvalFunc2Cx(@ZPWR,Arg1,Arg2,TV1,TV2,Res);   IsEval:=True; end; {.329}
       CM_LOG:     begin  _EvalFunc2Cx(@Z_CxCxLOG,Arg1,Arg2,TV1,TV2,Res); IsEval:=True; end; {.329}


       else
       begin
         FName:=Alg.ExFunc[NFunc].Name;

         if    (F_CalcConstExtFunc = True) and
               (Alg.ExFunc[NFunc].Func[NF].IntF = _External) and
               (Alg.ExFunc[NFunc].Func[NF].Addr <> 0) then begin EvalFuncN(PNE,Res,IsEval);  IsEval:=True; end; {.329}
       end;
        //IsEval:=False;
     end;


  end
  else
  if (TV1 = T_Real) and (TV2 = T_Complex)  then
  begin
     case NFunc of
       CM_POWER:    begin _EvalFunc2Cx(@Z_ReCxFPWR,Arg1,Arg2,TV1,TV2,Res);  IsEval:=True; end; {.329}
       CM_LOG:      begin _EvalFunc2Cx(@Z_ReCxLog,Arg1,Arg2,TV1,TV2,Res); IsEval:=True; end; {.329}

       else
       begin
         FName:=Alg.ExFunc[NFunc].Name;

         if    (F_CalcConstExtFunc = True) and
               (Alg.ExFunc[NFunc].Func[NF].IntF = _External) and
               (Alg.ExFunc[NFunc].Func[NF].Addr <> 0) then begin EvalFuncN(PNE,Res,IsEval);  IsEval:=True; end; {.329}
       end;
       //IsEval:=False;
     end;


  end
  else
  if  (TV1 = T_Complex) and (TV2 = T_Real)  then
  begin
    case NFunc of
       CM_POWER:    begin _EvalFunc2Cx(@Z_CxReFPWR,Arg1,Arg2,TV1,TV2,Res);  IsEval:=True; end; {.329}
       CM_LOG:      begin _EvalFunc2Cx(@Z_CxReLog,Arg1,Arg2,TV1,TV2,Res);  IsEval:=True; end; {.329}
       CM_ROOT:     begin _EvalFunc1CxInt(@Z_CxIROOT,Arg1,round(Arg2.re),Res); IsEval:=True; end; {.329}


       else
       begin
         FName:=Alg.ExFunc[NFunc].Name;

         if    (F_CalcConstExtFunc = True) and
               (Alg.ExFunc[NFunc].Func[NF].IntF = _External) and
               (Alg.ExFunc[NFunc].Func[NF].Addr <> 0) then begin  EvalFuncN(PNE,Res,IsEval);  IsEval:=True; end; {.329}
       end;
       //IsEval:=False;
     end;
  end

end;




procedure TForevalH.GetConstArg1(PNE: PNode; var Re1,Im1: Extended; var ResT1: Integer);
var
TC1,COP1: Integer;
PN1: PNode;
begin
    {Если арумент функции func1(arg1) не константа , то ResT1 = NO_Const}

  PN1:=PNE^.Ch;
  //ResT1:=PN1^.TypeF;
  TC1:=PN1^.TC;
  COP1:=PN1^.COP;

  ResT1:=NO_Const;

  if (COP1 = _LDSC) then
  begin
   ResT1:=T_Real;
   Re1:=PN1^.FD; Im1:=0.0;
  end
  else
  if (COP1 = _LDINTFORM)  and (PN1^.TA1 = _IntConst) then
  begin
   ResT1:=T_Real;
   Re1:=PN1^.IC1; Im1:=0.0;
  end
  else
  if (COP1 = _LDSCX) then
  begin
    if TC1 = C_Complex then
    begin
       ResT1:=T_Complex;
       Re1:=PN1^.FDC.re; Im1:=PN1^.FDC.im;
    end
    else
    if TC1 = C_Image then
    begin
       ResT1:=T_Complex;
       Re1:=0.0; Im1:=PN1^.FDC.im;
    end
    else
    if TC1 = C_Real then
    begin
       ResT1:=T_Real;
       Re1:=PN1^.FDC.re; Im1:=0.0;
    end
  end ;

end;




procedure TForevalH.GetConstArg2(PNE: PNode; var Re1,Im1,Re2,Im2: Extended; var ResT1,ResT2: Integer);
var
TC1,TC2,COP1,COP2: Integer;
PN1,PN2: PNode;
begin
  {Если арументы функции func2(arg1,arg2) не константы , то ResT1,ResT2 = NO_Const}

  PN1:=PNE^.Ch; PN2:=PN1^.Nb;
  //ResT1:=PN1^.TypeF;     ResT2:=PN2^.TypeF;
  TC1:=PN1^.TC;   TC2:=PN2^.TC;
  COP1:=PN1^.COP;  COP2:=PN2^.COP;

  ResT1:=NO_Const;  ResT2:=NO_Const;

 if (COP1 = _LDSC) then
 begin
   ResT1:=T_Real;
   Re1:=PN1^.FD; Im1:=0.0;
 end
 else
 if (COP1 = _LDINTFORM)  and (PN1^.TA1 = _IntConst) then
 begin
   ResT1:=T_Real;
   Re1:=PN1^.IC1; Im1:=0.0;
 end
 else
 if (COP1 = _LDSCX) then
 begin
    if TC1 = C_Complex then
    begin
       ResT1:=T_Complex;
       Re1:=PN1^.FDC.re; Im1:=PN1^.FDC.im;
    end
    else
    if TC1 = C_Image then
    begin
       ResT1:=T_Complex;
       Re1:=0.0; Im1:=PN1^.FDC.im;
    end
    else
    if TC1 = C_Real then
    begin
       ResT1:=T_Real;
       Re1:=PN1^.FDC.re; Im1:=0.0;
    end
 end ;


 if (COP2 = _LDSC) then
 begin
   ResT2:=T_Real;
   Re2:=PN2^.FD; Im2:=0.0;
 end
 else
 if (COP2 = _LDINTFORM)  and (PN2^.TA1 = _IntConst) then
 begin
   ResT2:=T_Real;
   Re2:=PN2^.IC1; Im1:=0.0;
 end
 else
 if (COP2 = _LDSCX) then
 begin
    if TC2 = C_Complex then
    begin
       ResT2:=T_Complex;
       Re2:=PN2^.FDC.re; Im2:=PN2^.FDC.im;
    end
    else
    if TC2 = C_Image then
    begin
       ResT2:=T_Complex;
       Re2:=0.0; Im2:=PN2^.FDC.im;
    end
    else
    if TC2 = C_Real then
    begin
       ResT2:=T_Real;
       Re2:=PN2^.FDC.re; Im2:=0.0;
    end
 end ;

end;






function TForevalH.EvalConstFunc0(PNE: PNode): Boolean;
label endp;
var
Re1,Im1,Re2,Im2,ResF: Extended;
ResT1,ResT2,NFunc,NF,NArg,TypeF,TV1: Integer;
Answ,IsEval: Boolean;
Arg1,Res: TComplex;
begin
Answ:=False;
if F_InternalError <> 0  then goto endp;  {.322}

try
TryFPUMask; {.326}


//if True then


      NFunc:=PNE^.NFunc; NF:=PNE^.NF;
      //NArg:=Alg.ExFunc[NFunc].Func[NF].NArg;
      //TypeF:=Alg.ExFunc[NFunc].Func[NF].TypeF;
      //TV1:=Alg.ExFunc[NFunc].Func[NF].TV[0];

      if (NFunc = CM_FACT) and  (PNE^.AI = 1) and (PNE^.TA1 = _IntConst) then
          begin Res.re:=factorial[PNE^.IC1]; Answ:=True; end
      else
      if (NFunc = CM_FACT2) and  (PNE^.AI = 1) and (PNE^.TA1 = _IntConst) then
           begin Res.re:=factorial2F[PNE^.IC1];  Answ:=True; end
      else                {.379}
      if (NFunc = CM_NOT) and  (PNE^.AI = 1) and (PNE^.TA2 = _IntConst) then
           begin Res.re:=not (PNE^.IC1); Answ:=True; end
      else
      if (NFunc = CM_F2PWR) and  (PNE^.AI = 1) and (PNE^.TA2 = _IntConst) then
           begin Res.re:=power_acc(2,PNE^.IC2); Answ:=True; end
      else                   {.361}
      if (NFunc = {CM_IPWRSGN}CM_REUNEGIPWR ) and  (PNE^.AI = 1) and (PNE^.TA2 = _IntConst) then
           begin Res.re:=power_acc(-1,PNE^.IC2); Answ:=True; end;





      if Answ = True then
      begin
              PNE^.FD:=Res.re;
              PNE^.COP := _LDSC;
              PNE^.TypeF:=T_Real;
      end;

EvalConstFunc0:=Answ;

TryCatchFPUException;    {.326}
except {.322}
 on E: EZeroDivide      do F_InternalError:=E_ZeroDivide;
 on E: EInvalidOp       do F_InternalError:=E_InvalidOp;
 on E: EOverFlow        do F_InternalError:=E_OverFlow;
 on E: EUnderFlow       do F_InternalError:=E_UnderFlow;
 on E: EIntOverFlow     do F_InternalError:=E_IntOverFlow;
 on E: EAccessViolation do F_InternalError:=E_AccessViolation;
 on E: EOutOfMemory     do F_InternalError:=E_OutOfMemory;
 on E: EStackOverFlow   do F_InternalError:=E_StackOverFlow
end;


{.385}
if (Answ = True) and (F_InternalError = 0)  then
begin
     if IsNanOrInf(Res.re) = True then   F_InternalError:=E_InvalidOp;
end;

if F_InternalError <> 0 then F_SyntaxErrorCode:=E_INTERNAL_ERROR_AT_CALCULATION;    {.326}

endp:
end;



function TForevalH.EvalConstFunc1(PNE: PNode): Boolean;
label endp;
var
Re1,Im1,Re2,Im2,ResF: Extended;
ResT1,ResT2,NFunc,NF,NArg,TypeF,TV1,ResType: Integer;
Answ,IsEval: Boolean;
Arg1,Res: TComplex;
DataArg: TDataArg;
begin
Answ:=False;
if F_InternalError <> 0  then goto endp;  {.322}

try
TryFPUMask; {.326}



   GetConstArg1(PNE,Re1,Im1,ResT1);  // получить тип аргумента

   if (ResT1 <> NO_Const)  then       //if Arg = const
   begin
      NFunc:=PNE^.NFunc; NF:=PNE^.NF;
      NArg:=Alg.ExFunc[NFunc].Func[NF].NArg;
      TypeF:=Alg.ExFunc[NFunc].Func[NF].TypeF;
      TV1:=Alg.ExFunc[NFunc].Func[NF].TV[0];

      if TV1 = ResT1 then
      begin
         Arg1.re:=Re1; Arg1.im:=Im1;
         _EvalFunc1({NFunc,NF,}PNE,Arg1,Res,ResType,IsEval);

         if IsEval = True then
         begin
               {.361}
           if {TypeF}ResType = T_Real then
           begin
              PNE^.FD:=Res.re;
              PNE^.COP := _LDSC;
              PNE^.TypeF:=T_Real;
           end
           else    {.361}
           if {TypeF}ResType = T_Complex then
           begin
              PNE^.FDC.re:=Res.re;
              PNE^.FDC.im:=Res.im;
              PNE^.COP := _LDSCX;
              PNE^.TypeF:=T_Complex;
           end;

           if PNE^.COP = _LDSCX then PNE^.TC := C_Complex;
           Answ:=True;

         end
         else   // Answ:=False;
         if F_ReduceArgOptimizator = True then        {.395} //для IROOT c 1 аргументом
         begin
            if (ResT1 <> NO_Const)  then   //Arg1 = Const
            begin
                DataArg.Re1:=Re1; DataArg.Im1:=Im1; DataArg.ResT1:=ResT1;
                ReduceArgOptimizator(PNE,DataArg);
            end;
        end
        else  Answ:=False;



      end
      else
      begin {Internal ERROR !!!} end;




   end;



EvalConstFunc1:=Answ;

TryCatchFPUException;    {.326}
except {.322}
 on E: EZeroDivide      do F_InternalError:=E_ZeroDivide;
 on E: EInvalidOp       do F_InternalError:=E_InvalidOp;
 on E: EOverFlow        do F_InternalError:=E_OverFlow;
 on E: EUnderFlow       do F_InternalError:=E_UnderFlow;
 on E: EIntOverFlow     do F_InternalError:=E_IntOverFlow;
 on E: EAccessViolation do F_InternalError:=E_AccessViolation;
 on E: EOutOfMemory     do F_InternalError:=E_OutOfMemory;
 on E: EStackOverFlow   do F_InternalError:=E_StackOverFlow
end;

{.385}
if (Answ = True) and (F_InternalError = 0)  then
begin
  if ResType = T_Real then
  begin
     if IsNanOrInf(Res.re) = True then   F_InternalError:=E_InvalidOp;
  end
  else
  if ResType = T_Complex then
  begin
    if (IsNanOrInf(Res.re) = True) or (IsNanOrInf(Res.im) = True) then   F_InternalError:=E_InvalidOp;
  end;
end;


if F_InternalError <> 0 then F_SyntaxErrorCode:=E_INTERNAL_ERROR_AT_CALCULATION;    {.326}

endp:
end;




function TForevalH.EvalConstFunc2(PNE: PNode): Boolean;
label endp;
var
Re1,Im1,Re2,Im2: Extended;
ResT1,ResT2,NFunc,NF,NArg,TypeF,TV1,TV2: Integer;
Answ,IsEval: Boolean;
Arg1,Arg2,Res: TComplex;
NodeT: PNode;
S: String;
DataArg: TDataArg;
begin
if F_InternalError <> 0  then goto endp;  {.322}

try
TryFPUMask; {.326}

Answ:=False;

   GetConstArg2(PNE,Re1,Im1,Re2,Im2,ResT1,ResT2);

   if (ResT1 <> NO_Const) and (ResT2 <> NO_Const) then      //if Arg1&Arg2 = const
   begin
      NFunc:=PNE^.NFunc; NF:=PNE^.NF;
      NArg:=Alg.ExFunc[NFunc].Func[NF].NArg;
      TypeF:=Alg.ExFunc[NFunc].Func[NF].TypeF;
      TV1:=Alg.ExFunc[NFunc].Func[NF].TV[0];
      TV2:=Alg.ExFunc[NFunc].Func[NF].TV[1];

      if (TV1 = ResT1) and (TV2 = ResT2) then
      begin

           Arg1.re:=Re1; Arg1.im:=Im1;
           Arg2.re:=Re2; Arg2.im:=Im2;
          _EvalFunc2({NFunc,NF,}PNE,Arg1,Arg2,Res,IsEval);

         if IsEval = True then
         begin

           if TypeF = T_Real then
           begin
             PNE^.FD:=Res.re;
             PNE^.COP := _LDSC;
             PNE^.TypeF:=T_Real;
           end
           else
           if TypeF = T_Complex then
           begin
              PNE^.FDC.re:=Res.re;
              PNE^.FDC.im:=Res.im;
              PNE^.COP := _LDSCX;
              PNE^.TypeF:=T_Complex;
           end;

          if PNE^.COP = _LDSCX then PNE^.TC := C_Complex;
          Answ:=True;
         end
         else
         Answ:=False;




      end
      else
      begin {Internal ERROR !!!} end;


   end
   else
   if F_ReduceArgOptimizator = True then
   begin
      if ((ResT1 <> NO_Const) and (ResT2 = NO_Const))      //Arg1 = Const
          or
         ((ResT2 <> NO_Const) and (ResT1 = NO_Const))      //Arg2 = Const   {.395}
      then
      begin
        DataArg.Re1:=Re1; DataArg.Im1:=Im1; DataArg.ResT1:=ResT1;
        DataArg.Re2:=Re2; DataArg.Im2:=Im2; DataArg.ResT2:=ResT2;
        ReduceArgOptimizator(PNE,DataArg);
      end;
   end;




EvalConstFunc2:=Answ;

TryCatchFPUException;    {.326}
except {.322}
 on E: EZeroDivide      do F_InternalError:=E_ZeroDivide;
 on E: EInvalidOp       do F_InternalError:=E_InvalidOp;
 on E: EOverFlow        do F_InternalError:=E_OverFlow;
 on E: EUnderFlow       do F_InternalError:=E_UnderFlow;
 on E: EIntOverFlow     do F_InternalError:=E_IntOverFlow;
 on E: EAccessViolation do F_InternalError:=E_AccessViolation;
 on E: EOutOfMemory     do F_InternalError:=E_OutOfMemory;
 on E: EStackOverFlow   do F_InternalError:=E_StackOverFlow
end;


{.385}
if (Answ = True) and (F_InternalError = 0)  then
begin
  if TypeF = T_Real then
  begin
     if IsNanOrInf(Res.re) = True then   F_InternalError:=E_InvalidOp;
  end
  else
  if TypeF = T_Complex then
  begin
    if (IsNanOrInf(Res.re) = True) or (IsNanOrInf(Res.im) = True) then   F_InternalError:=E_InvalidOp;
  end;
end;


if F_InternalError <> 0 then F_SyntaxErrorCode:=E_INTERNAL_ERROR_AT_CALCULATION;    {.326}

endp:
end;




procedure TForevalH.ReduceArgOptimizator(PNE: PNode; DataArg: TDataArg);
label endp;
var
Re1,Im1,Re2,Im2: Extended;
ResT1,ResT2,NFunc,NF,NArg,TypeF,TV1,TV2: Integer;
Answ,IsEval: Boolean;
Arg1,Arg2,Res: TComplex;
NodeT: PNode;
S: String;
begin
{
 Ограничение:
 1. Выполняет вычисление цепочки одноагргументных  функций
     Func1(Arg1) -> Func1C0()  если Arg1=const

 2. Выполняет вычисление цепочки только для первого!!! аргумента двуаргументных функций
      Func2(Arg1,Arg2) -> Func2C1(Arg2), если Arg1=const

}

NFunc:=PNE^.NFunc;
NArg:=PNE^.N;

if NArg = 1 then
begin

   if NFunc = CM_IROOT  then      {.395}         // 1 аргумент
   begin

      // AI = 3: не работает -> CM_IROOT3
      if PNE^.AI = 3 then     // root(ComplexExpr, IntArg1,IntArg2)
      begin
            FreeChildTree(PNE);                 // root(ai/bi+bi/ai, k+j,n+1)
            PNE^.NFunc:=CM_CZIROOT3;
            PNE^.TypeF:=T_Complex;
            PNE^.FD:=DataArg.Re1;
            PNE^.FDC.re:=DataArg.Re1;
            PNE^.FDC.im:=DataArg.Im1;
            PNE^.N:=0;
            PNE^.NF:=0;
            PNE^.AI:=1;
            PNE^.TypeA:=T_Complex;
            PNE^.TypeF:=T_Complex;
            PNE^.FD:=DataArg.Re1;
            PNE^.FDC.re:=DataArg.Re1;
            PNE^.FDC.im:=DataArg.Im1;

            if M_ParseMode  = M_Compile then inc(Db_NumberReductions);

      end
      else
      begin     // PNE^.AI = 1,2   ;   root(RealExpr, IntArg),   root(ComplexExpr, IntArg)


       NF:=PNE^.NF;
       TV1:=Alg.ExFunc[NFunc].Func[NF].TV[0];
       if (DataArg.ResT1 = T_Real) then        // root(a/b+b/a,n+k)
       begin
         FreeChildTree(PNE);
         PNE^.AI:=1;
         PNE^.NFunc:=CM_CRZIROOT;
         PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV1);    //=0
         PNE^.TypeA:=T_Real;
         PNE^.TypeF:=T_Real;
         PNE^.FD:=DataArg.Re1;
         PNE^.N:=0;

         if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
       end
       else
       if (DataArg.ResT1 = T_Complex) then        // root(ai/bi+bi/ai,n+k)
       begin
         FreeChildTree(PNE);
         PNE^.AI:=2;
         PNE^.NFunc:=CM_CRZIROOT;
         PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV1);      //=1
         PNE^.TypeA:=T_Complex;
         PNE^.TypeF:=T_Complex;
         PNE^.FD:=DataArg.Re1;
         PNE^.FDC.re:=DataArg.Re1;
         PNE^.FDC.im:=DataArg.Im1;
         PNE^.N:=0;

         if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
       end

      end;

   end
   else

   if NFunc = CM_IROOT3  then      {.395}         // 1 аргумент
   begin

      if PNE^.AI = 1 then     // root(ComplexExpr, IntArg1,IntArg2)
      begin
            FreeChildTree(PNE);                 // root(ai/bi+bi/ai, k+j,n+1)
            PNE^.NFunc:=CM_CZIROOT3;
            PNE^.TypeF:=T_Complex;
            PNE^.FD:=DataArg.Re1;
            PNE^.FDC.re:=DataArg.Re1;
            PNE^.FDC.im:=DataArg.Im1;
            PNE^.N:=0;
            PNE^.NF:=0;
            PNE^.AI:=1;
            PNE^.TypeA:=T_Complex;
            PNE^.TypeF:=T_Complex;
            PNE^.FD:=DataArg.Re1;
            PNE^.FDC.re:=DataArg.Re1;
            PNE^.FDC.im:=DataArg.Im1;

            if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
      end

   end

end
else

if NArg = 2 then
begin


  if NFunc = CM_POWER  then
  begin

     NF:=PNE^.NF;
     TV1:=Alg.ExFunc[NFunc].Func[NF].TV[0];
     TV2:=Alg.ExFunc[NFunc].Func[NF].TV[1];

     if (DataArg.ResT1 = T_Real) and (DataArg.ResT2 = NO_Const) then
     begin


      //NArg:=Alg.ExFunc[NFunc].Func[NF].NArg;
      //TypeF:=Alg.ExFunc[NFunc].Func[NF].TypeF;
      //NF:=PNE^.NF;
      //TV1:=Alg.ExFunc[NFunc].Func[NF].TV[0];
      //TV2:=Alg.ExFunc[NFunc].Func[NF].TV[1];

        if (TV1 = T_Real) and (TV2 = T_Real) then
        begin
         //((1+4*(1+2/50))^x)*((1+3*(1+2/3))^((1+3*(1+2/30))^x))
         //(sin(a-b)*cos(b/c))^(x)
         //sin(x)*((1+(1+2/3))^((1+(1+2/30))^x))
         //sin(x)*((1+2/3)^((1+2/30)^x))

         {if TV1 = T_Real then PNE^.AI:=1 else
         if TV1 = T_Complex then PNE^.AI:=2;}


           FreeChldNode(PNE,1);
           PNE^.AI:=1;
           PNE^.NFunc:=CM_CZPWR;
           //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
           PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV2);
           PNE^.TypeA:=T_Real; //Тип аргумента, т.к. в определении CM_CZPWR нет однозначного соответствия (зависит ещё и от типа константы - первый аргумент)
           PNE^.FD:=DataArg.Re1;
           //PNE^.FD1:=fc_Log2(DataArg.Re1);
           PNE^.N:=1;

           if M_ParseMode  = M_Compile then inc(Db_NumberReductions);

        end
        else
        if (TV1 = T_Real) and (TV2 = T_Complex) then
        begin
           FreeChldNode(PNE,1);
           PNE^.AI:=1;
           PNE^.NFunc:=CM_CZPWR;
           //PNE^.NF:=1;   // (=>  T_Complex) !!! используется в LoadArg1
           PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV2);
           PNE^.TypeA:=T_Complex;
           PNE^.FD:=DataArg.Re1;
           //PNE^.FD1:=fc_Log2(DataArg.Re1);
           PNE^.N:=1;

           if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
        end;

     end
     else
     if (DataArg.ResT1 = T_Complex) and (DataArg.ResT2 = NO_Const) then
     begin

        if (TV1 = T_Complex) and (TV2 = T_Real) then
        begin
           FreeChldNode(PNE,1);
           if (DataArg.Re1  = -1) and  (DataArg.Im1  = 0) then
           begin
             PNE^.AI:=2;
             PNE^.NFunc:=CM_IPWRSGN;
             //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
             PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,T_Real);
             PNE^.TypeA:=T_Real;
             PNE^.N:=1;

             if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
           end
           else
           if (DataArg.Re1  = 0) and  (DataArg.Im1  = 1) then
           begin
             PNE^.AI:=1;
             PNE^.NFunc:=CM_IMURZPWR;
             //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
             PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,T_Real);
             PNE^.TypeA:=T_Real;
             PNE^.N:=1;

             if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
           end
           else
           if (DataArg.Re1  = 0) and  (DataArg.Im1  = -1) then
           begin
             PNE^.AI:=2;
             PNE^.NFunc:=CM_IMURZPWR;
             //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
             PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,T_Real);
             PNE^.TypeA:=T_Real;
             PNE^.N:=1;

             if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
           end
           else
           begin
             PNE^.AI:=2;
             PNE^.NFunc:=CM_CZPWR;
             //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
             PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV2);
             PNE^.FDC.re:=DataArg.Re1;
             PNE^.FDC.im:=DataArg.Im1;
             PNE^.TypeA:=T_Real;
             PNE^.N:=1;

             if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
           end;
        end
        else
        if (TV1 = T_Complex) and (TV2 = T_Complex) then
        begin

           FreeChldNode(PNE,1);
           if (DataArg.Re1  = -1) and  (DataArg.Im1  = 0) then
           begin
             PNE^.AI:=0;
             PNE^.NFunc:=CM_IPWRSGN;
             //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
             PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,T_Complex);
             PNE^.TypeA:=T_Complex;
             PNE^.N:=1;

             if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
           end
           else
           if (DataArg.Re1  = 0) and  (DataArg.Im1  = 1) then
           begin
             PNE^.AI:=1;
             PNE^.NFunc:=CM_IMURZPWR;
             //PNE^.NF:=0;     // (=> T_Complex) !!! используется в LoadArg1
             PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,T_Complex);
             PNE^.TypeA:=T_Real;
             PNE^.N:=1;

             if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
           end
           else
           if (DataArg.Re1  = 0) and  (DataArg.Im1  = -1) then
           begin
             PNE^.AI:=2;
             PNE^.NFunc:=CM_IMURZPWR;
             //PNE^.NF:=0;     // (=> T_Complex) !!! используется в LoadArg1
             PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,T_Complex);
             PNE^.TypeA:=T_Real;
             PNE^.N:=1;

             if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
           end
           else
           begin
             PNE^.AI:=2;
             PNE^.NFunc:=CM_CZPWR;
             //PNE^.NF:=1;   // (=>  T_Complex) !!! используется в LoadArg1
             PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV2);
             PNE^.FDC.re:=DataArg.Re1;
             PNE^.FDC.im:=DataArg.Im1;
             PNE^.TypeA:=T_Complex;
             PNE^.N:=1;

             if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
           end;
        end;

     end;


    // InitSequentList;
  end
  else

  if NFunc = CM_LOG then         {.377}
  begin

     NF:=PNE^.NF;
     TV1:=Alg.ExFunc[NFunc].Func[NF].TV[0];
     TV2:=Alg.ExFunc[NFunc].Func[NF].TV[1];

      // Log(Const(Real,Complex),Expr(Real,Complex))
     if (DataArg.ResT2 = NO_Const) and ( (DataArg.ResT1 = T_Real) or  (DataArg.ResT1 = T_Complex) )   then
     begin


        // Log(Const(Real),Expr(Real))
        if (TV1 = T_Real) and (TV2 = T_Real) then     // log(sin(a)^2,x)
        begin

           FreeChldNode(PNE,1);
           PNE^.AI:=1;                   // Log(Const(Real),Expr(Real/Complex))
           PNE^.NFunc:=CM_CRZLOG;
           //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
           PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV2);
           PNE^.TypeA:=T_Real; //Тип аргумента, = TV2
           PNE^.FD:=DataArg.Re1;
           //PNE^.FD1:=fc_Log2(DataArg.Re1);
           PNE^.N:=1;

           if M_ParseMode  = M_Compile then inc(Db_NumberReductions);

        end
        else
        // Log(Const(Real),Expr(Complex))                  // log(sin(a)^2,z1)
        if (TV1 = T_Real) and (TV2 = T_Complex) then
        begin
           FreeChldNode(PNE,1);
           PNE^.AI:=1;                     // Log(Const(Real),Expr(Real/Complex))
           PNE^.NFunc:=CM_CRZLOG;
           //PNE^.NF:=1;   // (=>  T_Complex) !!! используется в LoadArg1
           PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV2);
           PNE^.TypeA:=T_Complex;     // = TV2
           PNE^.FD:=DataArg.Re1;
           //PNE^.FD1:=fc_Log2(DataArg.Re1);
           PNE^.N:=1;

           if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
        end
        else
         // Log(Const(Complex),Expr(Real))      {.395}
        if (TV1 = T_Complex) and (TV2 = T_Real) then     // log(sin(ai)^2,x)
        begin

           FreeChldNode(PNE,1);
           PNE^.AI:=2;                   // Log(Const(Complex),Expr(Real/Complex))
           PNE^.NFunc:=CM_CRZLOG;
           //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
           PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV2);
           PNE^.TypeA:=T_Real; //Тип аргумента = TV2
           PNE^.FD:=DataArg.Re1;
           PNE^.FDC.re:=DataArg.Re1;
           PNE^.FDC.im:=DataArg.Im1;
           PNE^.N:=1;

           if M_ParseMode  = M_Compile then inc(Db_NumberReductions);

        end
       else
         // Log(Const(Complex),Expr(Complex))      {.395}
        if (TV1 = T_Complex) and (TV2 = T_Complex) then     // log(sin(ai)^2,z1)
        begin

           FreeChldNode(PNE,1);
           PNE^.AI:=2;                   // Log(Const(Complex),Expr(Real/Complex))
           PNE^.NFunc:=CM_CRZLOG;
           //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
           PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV2);
           PNE^.TypeA:=T_Complex; //Тип аргумента = TV2
           PNE^.FD:=DataArg.Re1;
           PNE^.FDC.re:=DataArg.Re1;
           PNE^.FDC.im:=DataArg.Im1;
           PNE^.N:=1;

           if M_ParseMode  = M_Compile then inc(Db_NumberReductions);

        end


     end

     else

     // LOG(Expr(Real,Complex), Const(Real,Complex))
     if (DataArg.ResT1 = NO_Const) and ( (DataArg.ResT2 = T_Real) or (DataArg.ResT2 = T_Complex))   then    {.395}
     begin

        //  Log(Expr(Real), Const(Real))
        if (TV1 = T_Real) and (TV2 = T_Real) then             // log(x,sin(a)^2)
        begin
           FreeChldNode(PNE,2);
           PNE^.AI:=1;                   //Log(Expr(Real/Complex),Const(Real))
           PNE^.NFunc:=CM_CR2ZLOG;
           //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
           PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV1);
           PNE^.TypeA:=T_Real;     // = TV1
           PNE^.FD:=DataArg.Re2;
           PNE^.N:=1;

           if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
        end
        else
        //  Log(Expr(Complex), Const(Real))
        if (TV1 = T_Complex ) and (TV2 = T_Real) then             // log(z1,sin(a)^2)
        begin
           FreeChldNode(PNE,2);
           PNE^.AI:=1;                     //Log(Expr(Real/Complex),Const(Real))
           PNE^.NFunc:=CM_CR2ZLOG;
           //PNE^.NF:=1;   // (=>  T_Complex) !!! используется в LoadArg1
           PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV1);
           PNE^.TypeA:=T_Complex;     // = TV1
           PNE^.FD:=DataArg.Re2;
           PNE^.N:=1;

           if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
        end
        else
        //  Log(Expr(Real), Const(Complex))
        if (TV1 = T_Real) and (TV2 = T_Complex) then         // log(x,sin(ai)^2)
        begin
           FreeChldNode(PNE,2);
           PNE^.AI:=2;                   //Log(Expr(Real/Complex),Const(Complex))
           PNE^.NFunc:=CM_CR2ZLOG;
           //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
           PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV1);
           PNE^.TypeA:=T_Real;   // = TV1
           PNE^.FD:=DataArg.Re2;
           PNE^.FDC.re:=DataArg.Re2;
           PNE^.FDC.im:=DataArg.Im2;
           PNE^.N:=1;

           if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
        end
         else
        //  Log(Expr(Complex), Const(Complex))
        if (TV1 = T_Complex) and (TV2 = T_Complex) then           // log(z1,sin(ai)^2)    log(z1,cos(ai)^2)
        begin
           FreeChldNode(PNE,2);
           PNE^.AI:=2;                   //Log(Expr(Real/Complex),Const(Complex))
           PNE^.NFunc:=CM_CR2ZLOG;
           //PNE^.NF:=0;     // (=> T_Real) !!! используется в LoadArg1
           PNE^.NF:=GetIdArgFunc1A(PNE^.NFunc,1,TV1);
           PNE^.TypeA:=T_Complex;   // = TV1
           PNE^.FD:=DataArg.Re2;
           PNE^.FDC.re:=DataArg.Re2;
           PNE^.FDC.im:=DataArg.Im2;
           PNE^.N:=1;

           if M_ParseMode  = M_Compile then inc(Db_NumberReductions);
        end


     end;




  end

end;



end;





procedure TForevalH.GetConstArg1U(PNArg: PNode; place: integer; var Re1,Im1: Extended; var ResT1: Integer);
var
TC1,COP1: Integer;
//PN1: PNode;
begin
    {Если арумент функции func1(arg1) не константа , то ResT1 = NO_Const}

  //PN1:=PNE^.Ch;

  TC1:=PNArg^.TC;
  COP1:=PNArg^.COP;

  ResT1:=NO_Const;

  if (COP1 = _LDSC) then
  begin
   ResT1:=T_Real;
   Re1:=PNArg^.FD; Im1:=0.0;
  end
  else
  if (COP1 = _LDINTFORM)   then
  begin
    if (place = _First) and  (PNArg^.TA1 = _IntConst) then
    begin
      ResT1:=T_Real;
      Re1:=PNArg^.IC1; Im1:=0.0;
    end
    else
     if (place = _Second) and  (PNArg^.TA2 = _IntConst) then
    begin
      ResT1:=T_Real;
      Re1:=PNArg^.IC2; Im1:=0.0;
    end
  end
  else
  if (COP1 = _LDSCX) then
  begin
    if TC1 = C_Complex then
    begin
       ResT1:=T_Complex;
       Re1:=PNArg^.FDC.re; Im1:=PNArg^.FDC.im;
    end
    else
    if TC1 = C_Image then
    begin
       ResT1:=T_Complex;
       Re1:=0.0; Im1:=PNArg^.FDC.im;
    end
    else
    if TC1 = C_Real then
    begin
       ResT1:=T_Real;
       Re1:=PNArg^.FDC.re; Im1:=0.0;
    end
  end ;

end;



