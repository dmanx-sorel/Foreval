procedure TForevalH.FILDBYTE(Reg: Integer);
begin
if Reg = R_EAX then
begin

    AddByte3($66, $31, $DB);    // xor  bx,bx
    AddByte2($8A, $18);          //mov  bl, byte ptr[eax]
    AddByte2($66, $53);          //push bx
    AddByte3($DF, $04, $24);    // fild word ptr [esp]
    AddByte3($83, $C4, $02);    // add esp,2

    SetReg(Reg); SetReg(R_EBX);


     {
     AddByte2($8B, $00);          //mov  eax, [eax]
     AddByte2($66, $50);         // push ax
     AddByte6($66, $81, $24, $24, $FF, $00);   //and  word ptr [esp],$00FF
     AddByte3($DF, $04, $24);    // fild word ptr [esp]
     AddByte3($83, $C4, $02);    // add esp,2

     SetReg(Reg);
     }
end;
end;



procedure TForevalH.FLDREG(Reg,tm: Integer);
//fld type ptr [reg]
begin
if Reg = R_EAX then
begin
   case tm of
     _Double:        AddByte2($DD,$00);       //fld qword ptr  [eax]
     _Extended:      AddByte2($DB,$28);       //fld tbyte ptr  [eax]
     _Single:        AddByte2($D9,$00);       //fld dword ptr  [eax]
     _Integer:       AddByte2($DB,$00);       //fild dword ptr [eax]  {.380}
     _Byte:          FILDBYTE(Reg);           //fild byte ptr  [eax]
     _Word:          AddByte2($DF,$00);       //fild word ptr  [eax]
   end;
end
else
if Reg = R_ESI then
begin
   case tm of
     _Double:        AddByte2($DD,$06);       //fld qword ptr [esi]
     _Extended:      AddByte2($DB,$2E);       //fld tbyte ptr [esi]
     _Single:        AddByte2($D9,$06);       //fld dword ptr [esi]
   end;
end
else
if Reg = R_EDI then
begin
   case tm of
     _Double:        AddByte2($DD,$07);        //fld qword ptr [edi]
     _Extended:      AddByte2($DB,$2F);        //fld tbyte ptr [edi]
     _Single:        AddByte2($D9,$07);        //fld dword ptr [edi]
   end;
end
else
if Reg = R_EBX then
begin
   case tm of
     _Double:        AddByte2($DD,$03);       //fld qword ptr [ebx]
     _Extended:      AddByte2($DB,$2B);       //fld tbyte ptr [ebx]
     _Single:        AddByte2($D9,$03);       //fld dword ptr [ebx]
   end;
end;

CheckStack(1);

end;



procedure TForevalH.FSTPREG(Reg,tm: Integer);
//fstp type ptr [reg]
begin
if Reg = R_ESI then
begin
   case tm of
     _Double:        AddByte2($DD,$1E);        //fstp qword ptr [esi]
     _Extended:      AddByte2($DB,$3E);        //fstp tbyte ptr [esi]
     _Single:        AddByte2($D9,$1E);        //fstp dword ptr [esi]
   end;
end
else
if Reg = R_EDI then
begin
   case tm of
     _Double:        AddByte2($DD,$1F);        //fstp qword ptr [edi]
     _Extended:      AddByte2($DB,$3F);        //fstp tbyte ptr [edi]
     _Single:        AddByte2($D9,$1F);        //fstp dword ptr [edi]
   end;
end
else
if Reg = R_EBX then
begin
   case tm of
     _Double:        AddByte2($DD,$1B);        //fstp qword ptr [ebx]
     _Extended:      AddByte2($DB,$3B);        //fstp tbyte ptr [ebx]
     _Single:        AddByte2($D9,$1B);        //fstp dword ptr [ebx]
   end;
end
else
if Reg = R_EAX then
begin
   case tm of
     _Double:        AddByte2($DD,$18);        //fstp  qword ptr [eax]
     _Extended:      AddByte2($DB,$38);        //fstp  tbyte ptr [eax]
     _Single:        AddByte2($D9,$18);        //fstp  dword ptr [eax]
     _Integer:       AddByte2($DB,$18);        //fistp dword ptr [eax]    {.380}
     _Word:          AddByte2($DF,$18);        //fistp word ptr  [eax]    {.381}
     _Byte:          FISTPBYTE(Reg);           //fistp byte ptr  [eax]
   end;
end;

CheckStack(-1);


end;



procedure TForevalH.FISTPBYTE(Reg: Integer);
begin
if Reg = R_EAX then
begin

    AddByte3($83, $EC, $04);    // sub   esp,4
    AddByte3($DB, $1C, $24);    // fistp dword ptr [esp]
    AddByte3($8A, $1C, $24);    // mov   bl,byte ptr [esp]
    AddByte3($83, $C4, $04);    // add   esp,4
    AddByte2($88, $18);         // mov   byte ptr [eax],bl

    SetReg(Reg); SetReg(R_EBX);
end;


end;



