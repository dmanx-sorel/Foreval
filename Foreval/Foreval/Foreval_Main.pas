procedure TForevalH.InsertInlineCode(BeginAddr: Cardinal; CodeLength: Cardinal);
var
j,k: Integer;
P: ^Byte;
begin
if F_Mode=M_Compile then
begin

 j:=High(ICOMP)+1;
 SetLength(ICOMP,Length(ICOMP)+CodeLength-1); // -1 последняя команда RET !!!
 P:=Pointer(BeginAddr);
 for k := j to j+CodeLength-2 do   // -1 последняя команда RET !!!
 begin
   ICOMP[k]:=P^;
   inc(P);
 end;

end;
end;



