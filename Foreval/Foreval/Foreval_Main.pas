           begin
             ND1.N:=0; ND1.COP:=_Func; ND1.NFunc:=nf;  ND1.NF:=ni;  BEF:=True; EOFN:=True; SetLength(LV1,0);
            //ND.SFunc:=SFunc; {.301}
             goto endp;  {.203}
           end;
           *)

        end

        else
        begin

          F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
          //F_SyntaxErrorName:=Copy(Sf,1,Length(Sf));
          //F_SyntaxErrorString:=Copy(F_CurrentString,1,Length(F_CurrentString));

          //F_SyntaxErrorString:=F_SyntaxErrorName+#13#10+F_SyntaxErrorString;


          //F_SyntaxErrorString:=Copy(Sf,1,Length(Sf));
          //goto endp;

