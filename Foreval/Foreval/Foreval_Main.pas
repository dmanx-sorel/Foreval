procedure TForevalH.COSH_C;
var
t1,N,NF,S,L_ZCOSH_END,L_ZCOSH: Integer;
Addr: TAddress;
L1,L2: integer;
AddrRe1,AddrIm1,AddrRe2,AddrIm2: TAddress;
begin
 {N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 S:=Interp[NFunc].S;
 }
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 t1:=Alg.ExFunc[N].Func[NF].TV[0];

 LoadArg1;
 if t1 = T_Real then
 begin

   if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE) then
   begin
        MOVAadr(Cardinal(@R_COSH));
        CALLA;
        CheckStack(2);
        CheckStack(-2);
   end
   else
   if (GNode^.RRF = rf_EXPR2_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE)   then
    begin
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);    // exp   ->
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);      // 1/exp ->
        FADDP;
        FMUL_C05;    {.217}//FMUL(TAddress(@S_C05),_Double);
    end
    else
    if (GNode^.RRF = rf_EXPR1_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE)   then
    begin
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);       //  exp ->
        FLD0;
        FLD1;
        FDIVRP;
        FADDP;
        FMUL_C05;    {.217}//FMUL(TAddress(@S_C05),_Double);
   end
   else
   if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_EXPR2_REPLACE)    then
   begin
        FEXP;
        Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);
        FSTM(Addr,F_DataType);
        FLD0;
        FLD1;
        FDIVRP;
        Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);
        FSTM(Addr,F_DataType);
        FADDP;
        FMUL_C05;    {.217}//FMUL(TAddress(@S_C05),_Double);
   end
   else
    if (GNode^.RRF = rf_EXPR1_REPLACE) and  (GNode^.WRF_CS = rf_EXPR2_REPLACE)  then
    begin
         FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);       //  exp ->
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);
         FSTM(Addr,F_DataType);
         FLD0;
         FLD1;
         FDIVRP;
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);
         FSTM(Addr,F_DataType);
         FADDP;
         FMUL_C05;    {.217}//FMUL(TAddress(@S_C05),_Double);
    end;

 end
 else
 if t1 = T_Complex then
 begin
  if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE) then
   begin
        MOVAadr(Cardinal(@Z_COSH));
        CALLA;
        CheckStack(2);
        CheckStack(-2);
   end
   else
   begin
   if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_EXPZ2_REPLACE)    then
   begin                         //cosh(z1)+sinh(z1)
        {.377}
        AddrRe1:=TAddress(@Func.RFStack[GNode^.MWF_CS-3]);               //  RE(exp)    ->
        AddrIm1:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);               //  IM(exp)    ->
        AddrRe2:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);               //  RE(exp^-1) ->
        AddrIm2:=TAddress(@Func.RFStack[GNode^.MWF_CS]);                 //  IM(exp^-1) ->

        ZZ_EXPZ_EXPNZ;
        ZZ_SAVE(AddrRe1,AddrIm1,AddrRe2,AddrIm2,F_DataType);

        FADDP2;
        FADDP2;
        FMUL_C05;
        FXCH1;
        FMUL_C05;
        FXCH1;

        (*
         {.335}
        if F_DataType = _Extended then
        begin
          L_ZCOSH:=62;       //size of code
          L_ZCOSH_END:=89;   //size of code
        end
        else
         if F_DataType = _Double then
        begin
          L_ZCOSH:=54;       //size of code
          L_ZCOSH_END:=81;   //size of code
        end;


        //If Z.Im = 0 then: ... else goto @@zcosh
        FLDZ;
        FCOMIP2;
        JMPCI(L_ZCOSH,_JNZ); //jnz @@zcosh
            L1:=Length(IComp);
        //L_ZCOSH - size of:
        FEXP;   //exp(re),im(=0)
           Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-3]);               //  RE(exp) ->
        FSTM(Addr,F_DataType);
        FXCH1;
           Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-2]);               //  IM(exp) ->
        FSTM(Addr,F_DataType);
           Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS]);                 //  IM(exp^-1) ->
        FSTM(Addr,F_DataType);
        FXCH1;
        FLD0;
        FDIVR_C1;      //1/e,0,e
           Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-1]);               //  RE(exp^-1) ->
        FSTM(Addr,F_DataType);
        FADDP;
        FMUL_C05;
        JMP(L_ZCOSH_END);//jmp @@end
            L2:=Length(IComp);
            L2:=L2-L1;

        //full complex z
        //L_ZCOSH_END - size of:

       {@@zcosh:}
            L1:=Length(IComp);
       FEXP;
       FLD0;
       FDIVR_C1;
       FXCH2;
       FSINCOS;
       FLD0;
       FMUL03;   //st(0):RE(exp)
          Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-3]);               //  RE(exp) ->
       FSTM(Addr,F_DataType);
       FXCH1;
       FMUL04;    //st(0):RE(exp^-1)
          Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);               //  RE(exp^-1) ->
       FSTM(Addr,F_DataType);
       FXCH3;
       FMUL02;    //st(0):IM(exp)
          Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);               //  IM(exp) ->
       FSTM(Addr,F_DataType);
       FXCH2;
       FMULP4;       //  RE(exp),IM(exp),RE(exp^-1),IM(exp^-1)
       FADDP2;
       FXCH2;       //st(0):IM(exp^-1)
       FCHS;
          Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);                 //  IM(exp^-1) ->
       FSTM(Addr,F_DataType);
       FADDP2;
       FMUL_C05;
       FXCH1;
       FMUL_C05;
       FXCH1;
       {@@end:}
              L2:=Length(IComp);
              L2:=L2-L1;
        *)

   end
   else
   if (GNode^.RRF = rf_EXPZ2_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE)   then
   begin
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-2]),F_DataType);    // -> IM(exp)
        FADD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);      // IM(exp)-IM(exp^-1)
        FMUL_C05; // st(0):IM
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-3]),F_DataType);    // -> RE(exp)
        FADD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);      // RE(exp)-RE(exp^-1)
        FMUL_C05; // st(0):RE;  st(1):IM
   end
   else
   if (GNode^.RRF = rf_EXPZ1_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE)   then
   begin
       FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);   // -> IM(exp)
       FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);     // -> RE(exp)
       ZPUSH;
       ZDIVR_C1;        // ->  RE(exp^-1),IM(exp^-1),RE(exp),IM(exp)
       FADDP2;  //FSUBP2;
       FXCH2;
       FADDP2;   //FSUBRP2;
       FMUL_C05;
       FXCH1;
       FMUL_C05;
       FXCH1;
   end
   else
   if (GNode^.RRF = rf_EXPZ1_REPLACE) and (GNode^.WRF_CS = rf_EXPZ2_REPLACE)    then
   begin
      FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);     // -> IM(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);
         FSTM(Addr,F_DataType);                                          //  IM(exp) ->
      FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);   // -> RE(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-3]);
         FSTM(Addr,F_DataType);                                          //  RE(exp) ->
      ZPUSH;
      ZDIVR_C1;        // ->  RE(exp^-1),IM(exp^-1),RE(exp),IM(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);
         FSTM(Addr,F_DataType);                                          //  RE(exp^-1) ->
      FADDP2; //FSUBP2;
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);
         FSTM(Addr,F_DataType);                                          //  IM(exp^-1) ->
      FXCH2;
      FADDP2;  //FSUBRP2;
      FMUL_C05;
      FXCH1;
      FMUL_C05;
      FXCH1;
   end;


 end;
 end;

end;




{
  sech(z1)=2/(exp(z1)+exp(-z1))

  1/(exp(z1)+exp(-z1))=

   a:ext=re(exp(z1)); b:ext=im(exp(z1)); Aa:ext=a^2-b^2+1; Bb:ext=2*a*b;
   DE:ext=1/(Aa^2+Bb^2);  ((a*Aa+b*Bb)+i*(b*Aa-a*Bb))*DE


   za:CxExt=exp(z1); a:ext=re(za); b:ext=im(za); Aa:ext=a^2-b^2+1; Bb:ext=2*a*b;
   DE:ext=1/(Aa^2+Bb^2); ((a*Aa+b*Bb)+i*(b*Aa-a*Bb))*DE*2
}
procedure TForevalH.SECH_C;
var
t1,N,NF,S,L_ZSECH_END,L_ZSECH: Integer;
Addr: TAddress;
L1,L2: Integer;
AddrRe1,AddrIm1,AddrRe2,AddrIm2: TAddress;
begin
 {N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 S:=Interp[NFunc].S; }
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;
 t1:=Alg.ExFunc[N].Func[NF].TV[0];

 LoadArg1;
 if t1 = T_Real then
 begin

   if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE) then
   begin
        MOVAadr(Cardinal(@R_COSH));
        CALLA;
        CheckStack(2);
        CheckStack(-2);
        FLD1;
        FDIVRP;
   end
   else
   if (GNode^.RRF = rf_EXPR2_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE)   then
    begin
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);    // exp   ->
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);      // 1/exp ->
        FADDP;
        FMUL_C05;    {.217}//FMUL(TAddress(@S_C05),_Double);
        FLD1;
        FDIVRP;
    end
    else
    if (GNode^.RRF = rf_EXPR1_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE)   then
    begin
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);       //  exp ->
        FLD0;
        FLD1;
        FDIVRP;
        FADDP;
        FMUL_C05;    {.217}//FMUL(TAddress(@S_C05),_Double);
        FLD1;
        FDIVRP;
   end
   else
   if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_EXPR2_REPLACE)    then
   begin
        FEXP;
        Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);
        FSTM(Addr,F_DataType);
        FLD0;
        FLD1;
        FDIVRP;
        Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);
        FSTM(Addr,F_DataType);
        FADDP;
        FMUL_C05;    {.217}//FMUL(TAddress(@S_C05),_Double);
        FLD1;
        FDIVRP;
   end
   else
    if (GNode^.RRF = rf_EXPR1_REPLACE) and  (GNode^.WRF_CS = rf_EXPR2_REPLACE)  then
    begin
         FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);       //  exp ->
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);
         FSTM(Addr,F_DataType);
         FLD0;
         FLD1;
         FDIVRP;
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);
         FSTM(Addr,F_DataType);
         FADDP;
         FMUL_C05;    {.217}//FMUL(TAddress(@S_C05),_Double);
         FLD1;
         FDIVRP;
    end;

 end
 else
 if t1 = T_Complex then
 begin
  if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE) then
   begin
        MOVAadr(Cardinal(@Z_SECH));
        CALLA;
        CheckStack(2);
        CheckStack(-2);
   end
   else
   begin
   if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_EXPZ2_REPLACE)    then
   begin                                           // sech(z1)+cosh(z1)
                                                //(tanh(sech(z1/z2))/(coth(csch(z2/z1))*tanh(z1)))*sinh(z1/z2)
                                                   // z1.im=0; z2.im=0; FastDiv=False ERROR!!!

          {
           a:ext=Re(exp(z1))+Re(exp(-z1)); b:Ext=Im(exp(z1))+Im(exp(-z1));
           DE:Ext=2/(a^2+b^2); a*DE-i*b*DE
          }

        AddrRe1:=TAddress(@Func.RFStack[GNode^.MWF_CS-3]);               //  RE(exp)    ->
        AddrIm1:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);               //  IM(exp)    ->
        AddrRe2:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);               //  RE(exp^-1) ->
        AddrIm2:=TAddress(@Func.RFStack[GNode^.MWF_CS]);                 //  IM(exp^-1) ->

        ZZ_EXPZ_EXPNZ;
        ZZ_SAVE(AddrRe1,AddrIm1,AddrRe2,AddrIm2,F_DataType);
        {
         ST(0) - Re(exp(z1))
         ST(1) - Im(exp(z1))
         ST(2) - Re(exp(-z1))
         ST(3) - Im(exp(-z1))
        }
        FADDP2;
        FADDP2;
        // ST(0) - a; ST(1) - b
        FLD0;
        FMUL0;
        FXCH2;
        FLD0;
        FMUL0;
        FADDP3;
        FXCH2;
        FDIVR_C2;        //FAST_DIV
        // DE,a,b
        FMUL10;
        FCHS;
        FMULP2;


       (*
        {.335}
        if F_DataType = _Extended then
        begin
          L_ZSECH:=62;       //size of code
          L_ZSECH_END:=113;   //size of code
          if F_FAST_DIV = False then  L_ZSECH_END:=98; //Зависит от размера  ZDIVR_C1 !!!
        end
        else
        if F_DataType = _Double then
        begin
          L_ZSECH:=54;       //size of code
          L_ZSECH_END:=105;   //size of code
          if F_FAST_DIV = False then  L_ZSECH_END:=90; //Зависит от размера  ZDIVR_C1 !!!
        end;

            L1:=Length(IComp);
        //If Z.Im = 0 then: ... else goto @@zsech
        FLDZ;
        FCOMIP2;
        JMPCI(L_ZSECH,_JNZ); //jnz @@zsech
            L1:=Length(IComp);
        //L_ZSECH - size of:
        FEXP;   //exp(re),im(=0)
           Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-3]);               //  RE(exp) ->
        FSTM(Addr,F_DataType);
        FXCH1;
           Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-2]);               //  IM(exp) ->
        FSTM(Addr,F_DataType);
           Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS]);                 //  IM(exp^-1) ->
        FSTM(Addr,F_DataType);
        FXCH1;
        FLD0;
        FDIVR_C1;      //1/e,0,e
           Addr:=TAddress(@Func.RFStack[{Interp[NFunc]}GNode^.MWF_CS-1]);               //  RE(exp^-1) ->
        FSTM(Addr,F_DataType);
        FADDP;
        FDIVRC(2.0,_Double);
        JMP(L_ZSECH_END);//jmp @@end
            L2:=Length(IComp);
            L2:=L2-L1;

        //full complex z
        //L_ZSECH_END - size of:

       {@@zsech:}
            L1:=Length(IComp);
       FEXP;
       FLD0;
       FDIVR_C1;
       FXCH2;
       FSINCOS;
       FLD0;
       FMUL03;   //st(0):RE(exp)
          Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-3]);               //  RE(exp) ->
       FSTM(Addr,F_DataType);
       FXCH1;
       FMUL04;    //st(0):RE(exp^-1)
          Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);               //  RE(exp^-1) ->
       FSTM(Addr,F_DataType);
       FXCH3;
       FMUL02;    //st(0):IM(exp)
          Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);               //  IM(exp) ->
       FSTM(Addr,F_DataType);
       FXCH2;
       FMULP4;       //  RE(exp),IM(exp),RE(exp^-1),IM(exp^-1)
       FADDP2;
       FXCH2;       //st(0):IM(exp^-1)
       FCHS;
          Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);                 //  IM(exp^-1) ->
       FSTM(Addr,F_DataType);
       FADDP2;
       FMUL_C05;
       FXCH1;
       FMUL_C05;
       FXCH1;
       ZDIVR_C1;
       {@@end:}
            L2:=Length(IComp);
            L2:=L2-L1;
        *)

   end
   else
   if (GNode^.RRF = rf_EXPZ2_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE)   then
   begin  //read: exp(Z), exp(-Z)

     //ch(z1)+sech(z1)

        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-2]),F_DataType);    // -> IM(exp)
        FADD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);      // IM(exp)-IM(exp^-1)
        FMUL_C05; // st(0):IM
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-3]),F_DataType);    // -> RE(exp)
        FADD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);      // RE(exp)-RE(exp^-1)
        FMUL_C05; // st(0):RE;  st(1):IM
        ZDIVR_C1;

   end
   else
   if (GNode^.RRF = rf_EXPZ1_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE)   then
   begin  //read: exp(Z)

        //exp(z1)+sech(z1)



       FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);   // -> IM(exp)
       FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);     // -> RE(exp)

       (*
       {.377}
       Z__1DIV_EXPIZ_PLUS_EXPNIZ;
       //sech=2*[1/(exp(Z)+exp(-Z)]
       FADD0;
       FXCH1;
       FADD0;
       FXCH1;
       *)

       ZPUSH;
       ZDIVR_C1;        // ->  RE(exp^-1),IM(exp^-1),RE(exp),IM(exp)
       FADDP2;  //FSUBP2;
       FXCH2;
       FADDP2;   //FSUBRP2;
       FMUL_C05;
       FXCH1;
       FMUL_C05;
       FXCH1;
       ZDIVR_C1;

   end
   else
   if (GNode^.RRF = rf_EXPZ1_REPLACE) and (GNode^.WRF_CS = rf_EXPZ2_REPLACE)    then
   begin
      FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);     // -> IM(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-2]);
         FSTM(Addr,F_DataType);                                          //  IM(exp) ->
      FLD(TAddress(@Func.RFStack[GNode^.MRF_CS-1]),F_DataType);   // -> RE(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-3]);
         FSTM(Addr,F_DataType);                                          //  RE(exp) ->
      ZPUSH;
      ZDIVR_C1;        // ->  RE(exp^-1),IM(exp^-1),RE(exp),IM(exp)
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS-1]);
         FSTM(Addr,F_DataType);                                          //  RE(exp^-1) ->
      FADDP2; //FSUBP2;
         Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);
         FSTM(Addr,F_DataType);                                          //  IM(exp^-1) ->
      FXCH2;
      FADDP2;  //FSUBRP2;
      FMUL_C05;
      FXCH1;
      FMUL_C05;
      FXCH1;
      ZDIVR_C1;
   end;


 end;
 end;

end;



procedure TForevalH.TANH_C;
var
t1,N,NF,S,L_ZTANH_END,L_ZTANH: Integer;
Addr: TAddress;
L1,L2: Integer;
AddrRe1,AddrIm1: TAddress;
begin
 {N:=Interp[NFunc].NFunc;
 NF:=Interp[NFunc].NF;
 S:=Interp[NFunc].S; }
 N:=GNode^.NFunc;
 NF:=GNode^.NF;
 S:=GNode^.S;

 t1:=Alg.ExFunc[N].Func[NF].TV[0];

 LoadArg1;
 if t1 = T_Real then
 begin
   if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE) then
   begin
        MOVAadr(Cardinal(@R_TANH));
        CALLA;
        CheckStack(2);
        CheckStack(-2);
   end
   else
   begin

     if GNode^.RRF = rf_EXPR1_REPLACE    then
      begin
        FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);
        FMUL0;
        FLD0;
        FLD1;
        FSUBP;
        FLD1;
        FADDP20;
        FDIVRP;
      end
      else
      if GNode^.RRF = rf_INVERSE_REPLACE    then
      begin
         FLD(TAddress(@Func.RFStack[GNode^.MRF_CS]),F_DataType);
         //FDIVR(TAddress(@S_C1),_Double);
         FLD1; FDIVRP;
      end
      else
      if GNode^.WRF_CS = rf_EXPR1_REPLACE    then
      begin
        FEXP;
        Addr:=TAddress(@Func.RFStack[GNode^.MWF_CS]);
        FSTM(Addr,F_DataType);
        FMUL0;
        FLD0;
        FLD1;
        FSUBP;
        FLD1;
        FADDP20;
        FDIVRP;
      end


    end

 end
 else
 if t1 = T_Complex then
 begin
   if (GNode^.RRF = rf_NO_REPLACE) and (GNode^.WRF_CS = rf_NO_REPLACE) then
   begin
     MOVAadr(Cardinal(@Z_TANH));
     CALLA;
     CheckStack(3);
     CheckStack(-3);
   end
   else
   begin
      if GNode^.RRF = rf_EXPZ1_REPLACE    then
      begin
