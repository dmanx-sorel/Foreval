 }
end
else
begin
  LV1:=LV;
  ND1:=ND;
end;


 //F_IdN не изменилась = ND1.F_IdN!!! (StringAnalizator)

{
NumberAnalizatorA(LV[0].Expression,nv1,FD1,VC1);     //VC = _Const(FD); = _Var(nf); = _None(Stack);
NumberAnalizatorA(LV[1].Expression,nv2,FD2,VC2);                                //op = +  -  *  /
}

// поиск только действительных констант  (комплексные в MulDivAnalizator)
{.305}
FindVarConstPS(@LV[0].Expression,nv1,FD1,VC1);
FindVarConstPS(@LV[1].Expression,nv2,FD2,VC2);

if (VC1 = _ComplexVar) or (VC1 =  _FloatVar) or (VC1 =  _IntVar) then VC1:=_Var
else
if (VC1 = _NOT_FOUND) then VC1:=_None;

if (VC2 = _ComplexVar) or (VC2 =  _FloatVar) or (VC2 =  _IntVar) then VC2:=_Var
else
if (VC2 = _NOT_FOUND) then VC2:=_None;


if (VC1 = _Var)   and (VC2 = _None)   then ND1.NV1:=nv1                         //S op v
else
if (VC1 = _Const) and (VC2 = _None)   then ND1.FD:=FD1                          //S op c
else
if (VC1 = _None)  and (VC2 = _Var)    then ND1.nv1:=nv2                         //S op v
else
if (VC1 = _None)  and (VC2 = _Const)  then ND1.FD:=FD2                          //S op c
else
if (VC1 = _Var)   and (VC2 = _Var)    then begin ND1.nv1:=nv1; ND1.nv2:=nv2; end//v1 op v2
else
if (VC1 = _Var)   and (VC2 = _Const)  then begin ND1.nv1:=nv1; ND1.FD:=FD2; end //v op  c
else
if (VC1 = _Const) and (VC2 = _Var)    then begin ND1.FD:=FD1; ND1.nv1:=nv2; end;//c op v

ND1.TC:=C_Real;




if (VC1 = _None) and (VC2 = _None) then
begin
 EOFN:=False;
 ND1.N:=2;
 goto endp;
end
else
if (VC1 = _None) and (VC2 <> _None) then
begin
  EOFN:=False;
  ND1.N:=1;
  Str:=Copy(LV[0].Expression,1,Length(LV[0].Expression));
  SetLength(LV1,1);
  LV1[0].Expression:=Copy(Str,1,Length(Str));
  LV1[0].NL:=1;
  //LV1[0].IdL:=F_IdN;
end
else
if (VC1 <> _None) and (VC2 = _None) then
begin
  EOFN:=False;
  ND1.N:=1;
  Str:=Copy(LV[1].Expression,1,Length(LV[1].Expression));
  SetLength(LV1,1);
  LV1[0].Expression:=Copy(Str,1,Length(Str));
  LV1[0].NL:=1;
  //LV1[0].IdL:=F_IdN;
end
else
if (VC1 <> _None) and (VC2 <> _None) then
begin
 EOFN:=True;
 ND1.N:=0;
 SetLength(LV1,0);
end;





if ND1.NFunc = CM_ADD then
begin
 if (VC1 = _Const) and (VC2 = _Const) then
 begin
  ND1.FD:=FD1+FD2;
  ND1.COP:=_LDSC;
  ND1.NFunc:=0;
 end
end
else
if ND1.NFunc = CM_SUB then
begin
 if (VC1 = _Const) and (VC2 = _Const) then
 begin
  ND1.FD:=FD1-FD2;
  ND1.COP:=_LDSC;
  ND1.NFunc:=0;
 end
 else
 if (VC1 = _Var) and (VC2 = _None)  then   ND1.Inv:=1  //v-S
 else
 if (VC1 = _Const) and (VC2 = _None) then  ND1.Inv:=1   //c-S
 else
 if (VC1 = _Const) and (VC2 = _Var)  then  ND1.Inv:=1   //c-v
 else
 if (VC1 = _Var) and (VC2 = _Var)  then                 //i-i
 begin
   GetVar1(nv1,adr,tv1,tm);
   GetVar1(nv2,adr,tv2,tm);
   if (tv1 = IM_UNIT) and (tv2 = IM_UNIT) then
   begin
     ND1.FD:=0;
     ND1.COP:=_LDSC;
     ND1.NFunc:=0;
   end;
 end;
end
else
if ND1.NFunc = CM_MUL then
begin
  if (VC1 = _Const) and (VC2 = _Const) then
  begin
   ND1.FD:=FD1*FD2;
   ND1.COP:=_LDSC;
   ND1.NFunc:=0;
  end
  else
 if (VC1 = _Var) and (VC2 = _Var)  then                 //i*i
 begin
   GetVar1(nv1,adr,tv1,tm);
   GetVar1(nv2,adr,tv2,tm);
   if (tv1 = IM_UNIT) and (tv2 = IM_UNIT) then   {.395}
   begin
     ND1.FDC.re:=-1;
     ND1.FDC.im:=0;
     ND1.FD:=-1;
     ND1.COP:=_LDSCX;
     ND1.NFunc:=0;
     EOFN:=True;
     ND1.N:=0;
     SetLength(LV1,0);
     ND1.TC:=C_Complex;

   end;
 end
end
else
if ND1.NFunc = CM_DIV then
begin
  if (VC1 = _Const) and (VC2 = _Const) then
  begin
   ND1.FD:=FD1/FD2;
   ND1.COP:=_LDSC;
   ND1.NFunc:=0;
  end
  else
 if (VC1 = _Var) and (VC2 = _None)  then   ND1.Inv:=1  //v/S
 else
 if (VC1 = _Const) and (VC2 = _None) then  ND1.Inv:=1   //c/S
 else
 if (VC1 = _Const) and (VC2 = _Var)  then  ND1.Inv:=1   //c/v
 else
 if (VC1 = _Var) and (VC2 = _Var)  then                 //i/i
 begin
   GetVar1(nv1,adr,tv1,tm);
   GetVar1(nv2,adr,tv2,tm);
   if (tv1 = IM_UNIT) and (tv2 = IM_UNIT) then    {.395}
   begin
     ND1.FDC.re:=1;
     ND1.FDC.im:=0;
     ND1.FD:=1;
     ND1.COP:=_LDSCX;
     ND1.NFunc:=0;
     EOFN:=True;
     ND1.N:=0;
     SetLength(LV1,0);
     ND1.TC:=C_Complex;
   end;
 end;
end;


endp:
TryCatchFPUException;    {.229}
end;




//procedure TForevalH.FactAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);
procedure TForevalH.INT1FUNC_Analizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);
label endp;
var
C,Im: TFloat;
VC1,VC2: Integer;
S,NA,TV: Integer;
i: Integer;
nv1,nv2,ni,tv1,tv2,tm,P,RP,Len,code2: Integer;
FD1,FD2: extended;
Str1,Sindx: String;
Addr: Cardinal;
BH,BAnsw,SB: Boolean;
NDA: TDataNode;
TypeV, TypeIndx: Integer;
begin
if F_SyntaxErrorCode <> 0 then goto endp;

TryFPUMask; {.229}

Len:=Length(LV);
if (Len <> 1) then
begin
   {.333}
 {F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
 F_SyntaxErrorString:=F_CurrentString;}
 goto endp;
end;

LV1:=LV;
ND1:=ND;
EOFN:=False;
BH:=False;

Str1:=LV[0].Expression;
 WriteFindExtArgInt1PS(@Str1, _First, ND1, IntegerVarForm,  ND1, BAnsw);
 if Bansw = True then
 begin
    if ND1.TA1 = _IntConst then
    begin
      ND1.COP:=_LDSC;
      ND1.NFunc:=0;
      if ND.NFunc = CM_FACT then
         ND1.FD:=Factorial[ND1.IC1]
      else
      if ND.NFunc = CM_FACT2  then
         ND1.FD:=Factorial2F[ND1.IC1]
      else
      if (ND.NFunc = CM_NOT)  then
         ND1.FD:=not (ND1.IC1);

      EOFN:=True;
      LV1:=nil;
      ND1.N:=0;

    end
    else
    begin
     //IntForm!
     ND1.AI:=1;
     EOFN:=True;
     ND1.N:=0;
     SetLength(LV1,0);
    end;
 end
 else
 begin

       //IntArray[IntForm]!,IntArray[IntForm]!!     {.369}

        if FindArray(@Str1, NDA, ni, TypeV, TypeIndx, Addr, Sindx) = True then
           if (TypeV = _Integer) and ((TypeIndx = _IntVar) or (TypeIndx =_IntConst) or (TypeIndx = _IntForm) ) then
           begin
             ND1.AI:=2;
             ND1.N:=0;
             ND1.NObj2:=ni;
             ND1.DI:=NDA.AI; //тип аргумента массива в DI !!
             ND1.AIVP1:=Copy(NDA.AIVP1,0,Length(NDA.AIVP1));
             ND1.FD:=NDA.FD; //константа аргумента массива @vec[IntConst]
             ND1.NV2:=NDA.NV1; //переменная аргумента массива @vec[Intconst]

             SetLength(LV1,0);
             EOFN:=True;
             goto endp;
           end;


 end;



endp:
TryCatchFPUException;    {.229}
end;





procedure TForevalH.AddrAnalizator(LV:PLevel; ND: TDataNode; var LV1:PLevel; var ND1: TDataNode; var EOFN: Boolean);
label endp;
var
C,Im: TFloat;
VC1,VC2: Integer;
S,NA,TV: Integer;
i: Integer;
nv1,nv2,tv1,tv2,tm,P,RP,Len,code2,ni, TypeV, TypeIndx, TypeObj: Integer;
FD1,FD2: extended;
Str,Str1,Str2,Str3,Sindx: String;
adr,Addr: Cardinal;
BH,BAnsw,SB: Boolean;
NDA: TDataNode;
begin
if F_SyntaxErrorCode <> 0 then goto endp;



LV1:=LV;
ND1:=ND;
EOFN:=False;



Len:=Length(LV);
if (Len <> 1)  then
begin
   {.333}
 {F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
 F_SyntaxErrorString:=F_CurrentString;}
 goto endp;
end;


{
Загрузка адреса: @Func; @var; @array
}    {.347}
if F_EnableUsePointer = True then
begin

   {.378}
   TypeObj:=tobj_Any;

   if ND.NFunc = CM_ADDR_ARRAY      then      TypeObj:=tobj_Array
    else
   if ND.NFunc = CM_ADDR_FUNC       then      TypeObj:=tobj_Func
    else
   if ND.NFunc = CM_ADDR_VAR        then      TypeObj:=tobj_Var
    else
   if ND.NFunc = CM_ADDR            then      TypeObj:=tobj_Any;



   BH:=FindAddrObj(@LV[0].Expression, TypeObj, ND1,ND1);     //только адреса func,var,array:     @x, @k, @z1.re,@z1.im, @z1, @vd, @sp2
   if BH = True then
   begin
      ND1.COP:=_LDSA;
      ND1.TypeF:={T_Real;}T_Pointer;//T_Real;//T_Integer//T_Pointer;
      EOFN:=True;
      ND1.NFunc:=0;
      ND1.N:=0;
      //ND1.IsReplExpr= // прописывается в  FindAddrObj
      SetLength(LV1,0);
      goto endp;
   end
   else
   begin    //поиск  vec[indx] :        @vd[2*k+3]
      //if FindArray(PS,  ND,  ND1,  Sindx) = True then
      //FindArray(PS: PString; var NDA: TDataNode;  var ni, TypeV, TypeIndx: Integer; var Addr: Cardinal;   var Sindx: String): Boolean;
     if FindArray(@LV[0].Expression, NDA, ni, TypeV, TypeIndx, Addr, Sindx) = True then
     begin

         ND1.NObj2:=ni;
         //ND1.Addr1:=Addr;//Alg.Obj[ni].Addr;
         ND1.AI:=tc_AddrArrayElem;
         ND1.COP:=_LDSA;
         ND1.TypeF:={T_Real;}T_Pointer;//T_Real;//T_Integer//T_Pointer;
         EOFN:=True;
         ND1.NFunc:=0;
         ND1.N:=0;
         SetLength(LV1,0);
         ND1.DI:=NDA.AI; //тип аргумента массива в DI !!
         ND1.AIVP1:=Copy(NDA.AIVP1,0,Length(NDA.AIVP1));
         ND1.FD:=NDA.FD; //константа аргумента массива @vec[IntConst]
         ND1.NV2:=NDA.NV1; //переменная аргумента массива @vec[Intconst]

         if TypeIndx = _Stack then
         begin
           EOFN:=False;
           ND1.N:=1;
           SetLength(LV1,1);
           LV1[0].Expression:=Sindx;
           ND1.DI:=0;
         end;



      end
      else
      begin
          F_SyntaxErrorCode:=E_WRONG_EXPRESSION;
          //F_SyntaxErrorString:=F_CurrentString;
      end;
   end;


end;


endp:
//TryCatchFPUException;    {.229}
end;




