Tree:=BeginTree;
Tree^.Ch^.SData:={_FPU}_MEM;
Tree^.Ch^.Nb^.SData:=_FPU{_MEM};
Tree^.RData[0]:=Tree^.Ch^.SData;
Tree^.RData[1]:=Tree^.Ch^.Nb^.SData;
