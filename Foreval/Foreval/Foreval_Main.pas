procedure TForevalH.POLYDIFFAnalizator(LV: PLevel; ND: TDataNode;  var LV1: PLevel; var ND1: TDataNode; var EOFN: boolean);
label endp;
var
ni,tv1,tv2,tm1,L,P,nv1: Integer;
Adr1: Cardinal;
begin
 //LV1:=LV;
 ND1:=ND;
 L:=Length(LV);

if   (L <> 3)  then
begin
   F_SyntaxErrorCode:=E_INCOINCIDENCE_NUMBER_OF_ARGUMENTS;
   F_SyntaxErrorString:=F_CurrentString;
  goto endp;
end;



//FindVarA(LV[0].Expression,nv1,Adr1,tv1,tm1);
FindVarAPS(@LV[0].Expression,nv1,Adr1,tv1,tm1);    {.333}

 if TV1 <> T_Array  then
 begin
   F_SyntaxErrorCode:=E_INCORRECT_ARGUMENT;
   F_SyntaxErrorString:=F_CurrentString;
   goto endp;
 end;



 {.203}
 if TryStrToInt(LV1[2].Expression,P) = false then
 begin
  P:=-1;
 end;

 if (P = 1) or (P = 2) or (P = 3) then
 begin
   ND1.NFunc:=CM_POLYDIFF;
   ND1.COP:=_Func;
   //ND1.NV1:=nv1;
   ND1.AI:=tm1;
   ND1.CI:=P;
   ND1.N:=1;
   ND1.NObj:=nv1;
   SetLength(LV1,1);
   LV1[0].Expression:=Copy(LV[1].Expression,1,Length(LV[1].Expression));
   LV1[0].NL:=1;
   EOFN:=False;
 end
 else
 begin
   //SetLength(LV1,3);
   LV1:=LV;
   SetLength(LV1,4);
