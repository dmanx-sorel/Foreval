begin

    LoadLineFormEAX(_Second);
    FLDPI;
    SUBESP(4);
    // mov   [esp],eax
    AddByte($89);AddByte($04);AddByte($24);
    // fidiv dword ptr [esp]
    AddByte($DA);AddByte($34);AddByte($24);
    ADDESP(4);
    FSINCOS;
   {

  LoadLineFormEAX(_Second);

  //fld1
  AddWord($D9,$E8);
  //and eax,1
  AddByte($83);AddByte($E0);AddByte($01);
  //jz +$2
  AddWord($74,$02);
  //fchs
  AddWord($D9,$E0);


  CheckStack(1);
  }
end
