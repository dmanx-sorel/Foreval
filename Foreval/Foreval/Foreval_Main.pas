 else
 //PType(ArrayPrt[indx])
 begin
   //PType(VecPtr[IntConst])
   if GNode^.AI = 5 then
   begin
      //IntConst -> EAX;
      MOVCREG(R_EAX,Trunc(GNode^.FD));
