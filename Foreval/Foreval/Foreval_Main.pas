procedure TForevalH.ReplaceOptimizator;
label endp;
var
i,j,FType,CODE,t1: Integer;
BH: Boolean;
begin
if F_InternalError <> 0 then goto endp; {.322}

if  F_SyntaxErrorCode  = 0 then
begin
  RFSize:=-1;

  {
  if (F_ReplaceFunctionsCF = True) and (F_ReplaceFunctions = True) then ReplaceFuncComposite
    else
     if F_ReplaceFunctions = True then ReplaceFunc;
  }

    SetReplExprData;   {.375B}
    if F_IF = True then
    begin
      SetReplIFArg; {.395if}
    end;

  {.347}
    if F_ReplaceFunctions = True then  ReplaceFuncComposite;
    if F_ReplaceOperations = True then ReplaceOperations;
    SetLength(Func.RFStack,RFSize+1);
    if RFSize >= 1 then
    begin
      if F_ReplaceFunctionsCF = True  then DelVoidSaveCF else  DelVoidSave; {.195} {.217}
    end;


end;

endp:
end;





procedure TForevalH.SetReplExprData;
label endp;
var
NodeTree,Childs: PNode;
S: String;
NFunc: Integer;
IsRepl: Integer;
begin
{
  инициализирует поле: IsReplExprInArg = _No,_Yes

  NodeTree^.IsReplExprInArg = _No -
    в вытекающих узлах (потомки текущего узла NodeTree -> NodeTree^.Ch) содержатся выражения с запретом замены оптимизации Replace
    как следствие, родительский узел - NodeTree не может оптимизироваться заменой Replace
  NodeTree^.IsReplExprInArg = _Yes -
    все вытекающие выражения-потомки могут оптимизироваться заменой Replace (и соответственно, родительский узел - NodeTree - тоже)


  NodeTree^.IsReplExpr = _No,_Yes   инициализированы при разборе выражения.
}

    //sin(sin(x)+cos(cos(y)+pcRFN1())+tan(x))+sin(sin(x)+cos(cos(y)+pcRFN1())+tan(x))
    //sin(x+cos(t+tan(y))+y)+sin(x+cos(t+tan(y))+y)
    //sin(cos(tan(cotan(x)+cotan(y))+tan(y))+cos(t))+sin(cos(tan(cotan(x)+cotan(y))+tan(y))+cos(t))
    //sin(cos(tan(cotan(x)+rand(x,y))+tan(y))+cos(t))+sin(cos(tan(cotan(x)+rand(x,y))+tan(y))+cos(t))
   //spCallExt(@x,@pcRFN1,y)
   //sin(cos(tan(spCallExt(@x,@pcRFN1,y))))+sin(cos(tan(spCallExt(@x,@pcRFN1,y))))
   //sin(cos(tan(pcRFN1())))+sin(cos(tan(pcRFN1())))

NodeTree:=GetLowLeftNode(Tree);

while NodeTree <> Tree do
begin

   //S:=NodeTree^.Expression;
   if NodeTree^.Ch = nil then  NodeTree^.IsReplExprInArg:=NodeTree^.IsReplExpr
   else
   begin
     Childs:=NodeTree^.Ch;    IsRepl:=_Yes;
     while Childs <> nil do
     begin
       if (Childs^.IsReplExpr = _No) or (Childs^.IsReplExprInArg = _No) then IsRepl:=_No;
       Childs:=Childs^.Nb;
     end;
     NodeTree^.IsReplExprInArg:=IsRepl;
   end;

   NodeTree:=NodeTree^.Next;

end;

//для главного (NodeTree = Tree):
 //S:=NodeTree^.Expression;
 if NodeTree^.Ch = nil then  NodeTree^.IsReplExprInArg:=NodeTree^.IsReplExpr
 else
 begin
     Childs:=NodeTree^.Ch;    IsRepl:=_Yes;
     while Childs <> nil do
     begin
       if (Childs^.IsReplExpr = _No) or (Childs^.IsReplExprInArg = _No) then IsRepl:=_No;
       Childs:=Childs^.Nb;
     end;
     NodeTree^.IsReplExprInArg:=IsRepl;
 end;


endp:
end;




