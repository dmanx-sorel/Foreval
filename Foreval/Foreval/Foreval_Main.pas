procedure TForevalH.StringAnalizatorMEPS(PS:PString; var N: Integer; var COP,COPinv: Integer; var HS:PLevel{; varNeg: Integer});
label endp;
var
S2,SMOP,SMOP1: String;                                //ME- multi expression (not binary)
//BH,IH,IH1: PLevel;
i,p,b,br,bs,bc,L: Integer;
Neg1,MOP,MOP1,SB,NCop1,NCop2: Integer;
NPOS: Cardinal;
C: extended;

begin
if F_SyntaxErrorCode <> 0 then goto endp;
(*
FindExternalBracket(S,SS,Neg1);
if SS = '' then
begin
 F_ErrorCode:=E_MISSING_EXPRESSION;
 F_SyntaxErrorString:=S;
 goto endp;
end;

//для чисел с экспонентой 1.233454565E+1233
SaveSW; {.249} {TryStrToFloat damage SW}
if TryStrToFloat(SS,C,G_FMT) = true then  MOP:=_NOP else FindMainOperation(SS,MOP);
*)

//FindMainOperationP(PS,MOP,NPOS);
SMOP:=''; SMOP1:='';
FindMainOperationPS(PS,MOP,NPOS,NCop1,NCop2); {.315}


//k=-j*k
//k=-2*k
//k=-j*k*2*n
//k=-2*j*k*5



{$IFNDEF NEWPARSE}
{.357}
 if (MOP = _NOT_FOUND) and (NCop2 = COP_MUL) and (NCop1 = COP_NEG) and (NPOS > 0) then MOP:=COP_MUL;
{$ENDIF}
{
 Для случая, если перед выражением с главной операцией MUL идёт минус (NEG)  -j*k ; -2*k; -2*j*k*n; -k*2*j;
 В этих случаях FindMainOperationPS возвращает  _NOT_FOUND , т.к. главная операция  NEG - одноаргументна
 NCop2 - двуаргументная операция (если есть) NPOS - её позиция; NCop1 - однаргументная операция в начале выражения
 Иначе выражение не распознаётся, как IntForm
}

{$IFDEF NEWPARSE}
{.383}
 if (MOP = COP_NEG) and (NCop1 = COP_NEG) and  (NCop2 = COP_MUL)     then MOP:=COP_MUL    // -j*k ; -2*j*k
 else
 if (MOP = COP_NEG) and (NCop1 = COP_NEG) and  (NCop2 = _NOT_FOUND)  then MOP:=_NOT_FOUND; // -2; -a
{$ENDIF}


if MOP = COP_ADD then  MOP:=_ADD else
if MOP = COP_SUB then  MOP:=_SUB else
if MOP = COP_MUL then  MOP:=_MUL else
if MOP = COP_DIV then  MOP:=_DIV else
if MOP = _NOT_FOUND then MOP:=_NOP;

COPinv:=_NOP;


if MOP = _ADD then begin MOP1:=_SUB; SMOP:='+'; SMOP1:='-'; end
else
if MOP = _SUB then begin MOP:=_ADD;  MOP1:=_SUB; SMOP:='+'; SMOP1:='-'; end
else
if MOP = _MUL then begin MOP1:=_DIV; SMOP:='*'; SMOP1:='/'; end
else
if MOP = _DIV then begin MOP := _MUL;  MOP1:=_DIV; SMOP:='*'; SMOP1:='/'; end;

//Neg:=Neg1;
N:=0;

if MOP <> _NOP then
 begin
 p:=1; b:=0;  br:=0; bs:=0; bc:=0;


(*
if PS^[1] = '(' then br:=-1; else
  if SS[1] = '[' then bs:=-1 else
    if SS[1] = '{' then bc:=-1;
*)

if PS^[1] = '(' then b:=-1;

L:=Length(PS^);

 for i:=2 to L do
  begin

   if PS^[i] in OpenBracket then  dec(b)
   else
   if PS^[i] in CloseBracket then inc(b);
   (*
   if PS^[i] = '(' then br:=br-1   else
   if PS^[i] = ')' then br:=br+1   else
   if PS^[i] = '[' then bs:=bs-1 else
   if PS^[i] = ']' then bs:=bs+1;
   if SS[i] = '{' then bc:=bc-1;
   if SS[i] = '}' then bc:=bc+1;
   *)

   if (b = 0) {(br = 0) and (bs = 0) and (bc = 0)} and ((PS^[i] = SMOP) or (PS^[i] = SMOP1)) then
    begin

      if Copy(PS^,p,i-p) = '' then
      begin
       F_SyntaxErrorCode:=E_MISSING_EXPRESSION;
       F_SyntaxErrorString:=Copy(PS^,1,Length(PS^));
       //raise ESyntaxError.Create('');
       goto endp;
      end;

     N:=N+1;
     SetLength(HS,N);
     HS[N-1].Expression:=Copy(PS^,p,i-p);
     HS[N-1].COP:=_NOP;
     //HS[N-1].ExtArg:=_None;
     if (N-1) > 0 then
     begin
      if PS^[p-1] = '-' then  begin HS[N-1].COP:=_SUB; COPinv:=_SUB; end   else
      if PS^[p-1] = '/' then  begin HS[N-1].COP:=_DIV; COPinv:=_DIV; end   else
      if PS^[p-1] = '*' then  HS[N-1].COP:=_MUL   else
      if PS^[p-1] = '+' then  HS[N-1].COP:=_ADD;
     end;
     p:=i+1;
    end;
  end;

 N:=N+1;
 SetLength(HS,N);
 HS[N-1].Expression:=Copy(PS^,p,L-p+1);
 HS[N-1].COP:=_NOP;

 if PS^[p-1] = '-' then  begin HS[N-1].COP:=_SUB; COPinv:=_SUB; end   else
 if PS^[p-1] = '/' then  begin HS[N-1].COP:=_DIV; COPinv:=_DIV; end   else
 if PS^[p-1] = '*' then  HS[N-1].COP:=_MUL   else
 if PS^[p-1] = '+' then  HS[N-1].COP:=_ADD;
 end
else
begin   {  узел без операции - число, переменная, функция}
 L:=Length(PS^);
 N:=1;
 SetLength(HS,N);
 HS[0].Expression:=Copy(PS^,1,L);
 //HS[0].ExtArg:=_None;
 //N:=0; {.221} //N=0 -end of node !!
end;

COP:=MOP;

endp:
end;



procedure TForevalH.FindExtArgIntPS(PS: PString; var code: Integer; {var FIN: TFin;} var AIVP: TArrayIntVarProd; var NV,IC: Integer);
label endp,endpp;
{

 code = _IntConst   = IC
 code = _IntVar     = NV
 code = _IntForm    = a1*I1*...Ik+a2*I1*...*In+...+am*I1*...*Im+CI;  AIVP[]=ArrayOf(IVP); IVP.NV=ArrayOf(nv); IVP.A = ai;
 code = _NOT_FOUND;
}
var
  LV:PLevel;
  COP,COPinv,N,i,im: Integer;
  IVP: TIntVarProd;
  BDelBr: Boolean;
begin
if F_SyntaxErrorCode <> 0 then goto endpp;
                                    {.367} //арифм указателей не откл-ся
if (F_IntegerOptimization = False) and (F_EnablePointerMath = False) then
begin
 code:=_NOT_FOUND;
 goto endpp;
end;

BDelBr:=DeleteExternalBracketPS(PS);
if PS^ = '' then
begin
 F_SyntaxErrorCode:=5;
 goto endp;
end;

SetLength(AIVP,0);
code := _NOT_FOUND;
IC:=0;
SetLength(IVP.NV,0);

StringAnalizatorMEPS(PS,N,COP,COPinv,LV{,Neg});

if (COP = _MUL) and (COPinv = _DIV) then
begin
 code := _NOT_FOUND;
 goto endp;
end
else
if (COP = _MUL)  then
begin
  SetLength(IVP.NV,0);
  FindIntVarProdL(LV,COP,COPinv,code,IVP);
  if code = _NOT_FOUND then  goto endp;
  if code = _IntConst then    {.335} //func(2*3)
  begin
      code:=_IntConst;
      ic:=IVP.A;
      goto endp;
  end;
  SetLength(AIVP,1);
  AIVP[0]:=IVP;
  code:=_IntForm;
  //goto endp;
end
else
if COP = _ADD then
begin

   for i:=0 to High(LV) do
   begin
     SetLength(IVP.NV,0);

     FindIntVarProdSPS(@LV[i].Expression,code,IVP);

     if code = _NOT_FOUND then  goto endp;

     if LV[i].COP = _SUB then    IVP.A:=-IVP.A;

     if code = _IntConst then    IC:=IC+IVP.A
     else
     begin
       SetLength(AIVP,Length(AIVP)+1);
       AIVP[High(AIVP)]:=IVP;
     end;

   end;

   if Length(AIVP) = 0 then code:=_IntConst else code:=_IntForm;
end
else
if COP = _NOP then
begin
    FindIntVarConstP(PS,nv,im,code);
    if code = _NOT_FOUND then
    begin
      //code:=_NOT_FOUND;
      //goto endp;
    end
    else
    if code = _IntConst then
    begin
      code:=_IntConst;
      ic:=im;
       //убрать:
      //code := _IntForm;
    end
    else
    if code = _IntVar then
    begin
      if im = 1 then
      begin
        code:=_IntVar;
        //убрать:
        {SetLength(IVP.NV,Length(IVP.NV)+1);
        IVP.NV[High(IVP.NV)]:=nv;
        IVP.A:=im;
        SetLength(AIVP,Length(AIVP)+1);
        AIVP[High(AIVP)]:=IVP;
        code := _IntForm; }
      end
      else     //-n
      begin
        SetLength(IVP.NV,Length(IVP.NV)+1);
        IVP.NV[High(IVP.NV)]:=nv;
        IVP.A:=im;
        SetLength(AIVP,Length(AIVP)+1);
        AIVP[High(AIVP)]:=IVP;
        code := _IntForm;
      end
    end
end;


// else  code:=_IntForm;


endp:
if BDelBr = True  then   PS^:='('+PS^+')';

endpp:
end;




procedure TForevalH.FindIntVarProdSPS(PS: PString; var code: Integer;{ var FIN: TFin;} var IVP: TIntVarProd);
{
{
 code = _IntProd     = a*i1*i2*...*in        ; a,b - int. coeff;         i1,...,in - int.var;  a=>PN.A, i1,...,in=>PN.NV,
 code = _IntVar      = a*i                   ; a,b - int. coeff;                i  - int.var;  i=>FIN.NV, a=>FIN.A,
 code = _IntNum      = a                     ; a - int.num.                                    a=>FIN.A
 code = _NOT_FOUND
}

label endp;
var
LV: PLevel;
i,MC,N,COP,COPinv: Integer;
begin
if F_SyntaxErrorCode <> 0 then goto endp;

if PS^ = '' then
begin
 F_SyntaxErrorCode:=5;
 goto endp;
end;

StringAnalizatorMEPS(PS,N,COP,COPinv,LV{Neg});

FindIntVarProdL(LV,COP,COPinv,code,IVP);


endp:
end;



procedure TForevalH.FindIntVarProdL(LV: PLevel; COP,COPinv: Integer; var code: Integer;{ var FIN: TFin;} var IVP: TIntVarProd);
{
{
 code = _IntProd       = a*i1*i2*...*in        ; a,b - int. coeff;         i1,...,in - int.var;  a=>PN.A, i1,...,in=>PN.NV,
 code = _IntVar        = a*i                   ; a,b - int. coeff;                i  - int.var;  i=>FIN.NV, a=>FIN.A,
 code = _IntConst      = a                     ; a - int.num.                                    a=>FIN.A
 code = _NOT_FOUND
}

label endp;
var
i,MC,H,nv,ic,typeVC: Integer;
begin
if F_SyntaxErrorCode <> 0 then goto endp;

IVP.A:=0;
SetLength(IVP.NV,0);
//StringAnalizatorME(PS,N,COP,COPinv,LV{Neg});

if (COP = _MUL) and (COPinv = _DIV) then
begin
 code := _NOT_FOUND;
 goto endp;
end
else
if (COP <> _MUL) and (COP <> _NOP) then   // ^,!,!!
begin
 code := _NOT_FOUND;
 goto endp;
end;

{
FIN.A:=0;
FIN.B:=0;
FIN.NV:=-1;  }

MC:=1;

if (COP = _MUL)  then
begin

  H:=High(LV);
  for i:=0 to High(LV) do
  begin

    FindIntVarConstP(@LV[i].Expression,nv,ic,typeVC);
    if typeVC = _NOT_FOUND then
    begin
      code:=_NOT_FOUND;
      goto endp;
    end
    else
    if typeVC = _IntConst then
    begin
      MC:=MC*ic;
      //code:=_IntConst;
    end
    else
    if typeVC = _IntVar then
    begin
      SetLength(IVP.NV,Length(IVP.NV)+1);
      IVP.NV[High(IVP.NV)]:=nv;
      //code = _IntProd;
      MC:=MC*ic;  //-n
    end
    else
