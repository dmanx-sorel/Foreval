procedure TForevalH.FindTheFuncInExprPS(PS: PString; NF: Integer; var Sa: String; var FH: Boolean);
//проверяет строку PS = 'func(Sarg)' на содержание функции c кодом NF ,если да, возвращает её аргумент - Sa и FH=True
var
Sf: String;
begin
   FindFuncBrPS(PS,'(',')',Sf,Sa,FH);
   if FH = True then
   begin
      FH:=FindTheFuncPS(@Sf, NF);
   end;
end;



procedure TForevalH.FindFuncBrInExprPS(PS: PString; var NF: Integer; var Sf,Sa: String; var FH: Boolean);
//  проверяет строку PS = 'func(Sarg)' на содержание функции
// ,если да, то:  FH=True, возвращает её код - NF, имя - Sf, аргумент - Sa
// NF - общий код фукции (без идентефикации числа и типов аргументов)
{var
Sf: String;}
begin
   FindFuncBrPS(PS,'(',')',Sf,Sa,FH);
   if FH = True then
   begin
      FindFuncPS(@Sf, NF);
      if NF = _NOT_FOUND then
      begin
        FH:=False;
        F_SyntaxErrorCode:=E_UNKNOWN_FUNCTION;
      end
      else FH:=True;
   end;
end;







